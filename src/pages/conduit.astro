  <!-- ── STATS STRIP ── -->
  <div class="stats-strip">
    <div class="stat">
      <span class="stat-value c" data-count="1024">1 024</span>
      <span class="stat-label">default known-packs limit</span>
      <span class="stat-note">← 64 in vanilla Velocity</span>
    </div>
    <div class="stat">
      <span class="stat-value g" data-count="0">0</span>
