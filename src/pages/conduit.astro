            <span class="t-gap"></span>
            <span class="t-line t-section">[modded]</span>
            <span class="t-line-del"><span class="t-key">max-known-packs</span>     = <span class="t-val">64</span></span>
            <span class="t-line-add"><span class="t-key">max-known-packs</span>         = <span class="t-val">1024</span><span class="t-ann">← configurable</span></span>
            <span class="t-line"><span class="t-key">handshake-cache</span>         = <span class="t-val">true</span></span>
            <span class="t-line"><span class="t-key">handshake-cache-ttl</span>     = <span class="t-val">300</span></span>
