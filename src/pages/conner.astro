---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Conner — Modern Merch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: #0f1117;
      color: white;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at top left, rgba(122,92,255,0.35), transparent 30%),
        radial-gradient(circle at bottom right, rgba(0,183,255,0.25), transparent 35%),
        #0f1117;
      z-index: -1;
    }

    /* ── NAV ── */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 22px 7%;
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 200;
      background: rgba(15,17,23,0.75);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .logo {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -1px;
      background: linear-gradient(90deg, #8b5cf6, #38bdf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .nav-links { display:flex; gap:28px; align-items:center; }
    .nav-links a { color:rgba(255,255,255,0.8); text-decoration:none; font-weight:500; transition:0.25s; }
    .nav-links a:hover { color:white; }
    .cart-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      color: white;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      transition: 0.2s;
      font-family: 'Inter', sans-serif;
    }
    .cart-btn:hover { background: rgba(255,255,255,0.1); }
    .cart-count {
      background: linear-gradient(90deg,#8b5cf6,#38bdf8);
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      border-radius: 999px;
      padding: 2px 7px;
      min-width: 20px;
      text-align: center;
      display: none;
    }
    .cart-count.has-items { display: inline-block; }

    /* ── HERO ── */
    .hero {
      min-height: 88vh;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 7%;
      gap: 60px;
      flex-wrap: wrap;
    }
    .hero-text { flex:1; min-width:300px; }
    .hero-text h1 {
      font-size: clamp(3rem,7vw,6rem);
      line-height: 0.95;
      margin-bottom: 24px;
      font-weight: 800;
    }
    .hero-text h1 span {
      background: linear-gradient(90deg,#8b5cf6,#38bdf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero-text p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.7);
      line-height: 1.7;
      max-width: 620px;
      margin-bottom: 34px;
    }
    .hero-buttons { display:flex; gap:18px; flex-wrap:wrap; }
    .btn { padding:14px 26px; border-radius:16px; text-decoration:none; font-weight:700; transition:0.25s; cursor:pointer; font-family:'Inter',sans-serif; border:none; }
    .btn-primary { background:linear-gradient(90deg,#8b5cf6,#38bdf8); color:white; box-shadow:0 12px 30px rgba(56,189,248,0.2); }
    .btn-primary:hover { transform:translateY(-3px); }
    .btn-secondary { border:1px solid rgba(255,255,255,0.15); color:white; background:rgba(255,255,255,0.05); }
    .btn-secondary:hover { background:rgba(255,255,255,0.1); }

    .hero-card { flex:1; min-width:300px; display:flex; justify-content:center; }
    .floating-card {
      width:100%; max-width:450px;
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.1);
      backdrop-filter:blur(18px);
      border-radius:32px;
      padding:28px;
      box-shadow:0 25px 60px rgba(0,0,0,0.4);
      animation:float 5s ease-in-out infinite;
    }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    .floating-card img { width:100%; border-radius:24px; margin-bottom:20px; }
    .floating-card h3 { font-size:1.5rem; margin-bottom:10px; }
    .floating-card p { color:rgba(255,255,255,0.7); margin-bottom:20px; line-height:1.6; }
    .price-row { display:flex; justify-content:space-between; align-items:center; }
    .price { font-size:1.7rem; font-weight:800; }

    /* ── SHOP ── */
    .shop { padding:90px 7%; }
    .section-title { font-size:2.5rem; margin-bottom:50px; font-weight:800; }
    .product-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:28px; }
    .product-card {
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:28px;
      overflow:hidden;
      transition:0.3s;
      backdrop-filter:blur(12px);
    }
    .product-card:hover { transform:translateY(-8px); border-color:rgba(139,92,246,0.45); }
    .product-card img { width:100%; height:240px; object-fit:cover; }
    .product-content { padding:24px; }
    .product-content h3 { margin-bottom:10px; font-size:1.3rem; }
    .product-content p { color:rgba(255,255,255,0.7); line-height:1.6; margin-bottom:20px; }
    .product-footer { display:flex; justify-content:space-between; align-items:center; }

    .buy-btn {
      border:none; padding:12px 18px; border-radius:14px;
      background:linear-gradient(90deg,#8b5cf6,#38bdf8);
      color:white; font-weight:700; cursor:pointer; transition:0.2s;
      font-family:'Inter',sans-serif; font-size:0.875rem;
    }
    .buy-btn:hover { transform:scale(1.05); }
    .buy-btn.added { background:rgba(255,255,255,0.12); cursor:default; transform:none !important; }

    /* ── NEWSLETTER ── */
    .newsletter {
      margin:90px 7%; padding:60px; border-radius:32px;
      background:linear-gradient(135deg,rgba(139,92,246,0.22),rgba(56,189,248,0.16));
      border:1px solid rgba(255,255,255,0.08); text-align:center;
    }
    .newsletter h2 { font-size:2.5rem; margin-bottom:18px; }
    .newsletter p { color:rgba(255,255,255,0.75); margin-bottom:28px; }
    .newsletter-form { display:flex; justify-content:center; gap:14px; flex-wrap:wrap; }
    .newsletter-form input {
      padding:14px 18px; width:320px; border-radius:14px;
      border:none; outline:none; background:rgba(255,255,255,0.1);
      color:white; font-family:'Inter',sans-serif;
    }
    .newsletter-form input::placeholder { color:rgba(255,255,255,0.35); }

    footer {
      padding:40px 7%; text-align:center;
      color:rgba(255,255,255,0.55);
      border-top:1px solid rgba(255,255,255,0.08);
    }

    /* ── CART DRAWER ── */
    .cart-overlay {
      position:fixed; inset:0; z-index:400;
      background:rgba(0,0,0,0.5);
      backdrop-filter:blur(4px);
      opacity:0; pointer-events:none;
      transition:opacity 0.3s;
    }
    .cart-overlay.open { opacity:1; pointer-events:auto; }

    .cart-drawer {
      position:fixed; top:0; right:0; bottom:0; z-index:500;
      width:min(420px,100vw);
      background:#13151f;
      border-left:1px solid rgba(255,255,255,0.08);
      display:flex; flex-direction:column;
      transform:translateX(100%);
      transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
      box-shadow:-20px 0 60px rgba(0,0,0,0.5);
    }
    .cart-drawer.open { transform:translateX(0); }

    .drawer-header {
      display:flex; align-items:center; justify-content:space-between;
      padding:22px 24px;
      border-bottom:1px solid rgba(255,255,255,0.07);
    }
    .drawer-title { font-size:1.1rem; font-weight:700; }
    .drawer-close {
      width:32px; height:32px; border-radius:8px;
      border:1px solid rgba(255,255,255,0.1);
      background:rgba(255,255,255,0.05);
      color:rgba(255,255,255,0.6); font-size:1.1rem;
      cursor:pointer; display:flex; align-items:center; justify-content:center;
      transition:0.2s;
    }
    .drawer-close:hover { background:rgba(255,255,255,0.1); color:white; }

    .cart-items { flex:1; overflow-y:auto; padding:16px 24px; }
    .cart-empty {
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      height:100%; gap:12px; color:rgba(255,255,255,0.3);
      font-size:0.9rem; text-align:center; padding:40px;
    }
    .cart-empty-icon { font-size:2.5rem; opacity:0.4; }

    .cart-item {
      display:flex; gap:14px; align-items:center;
      padding:14px 0; border-bottom:1px solid rgba(255,255,255,0.06);
    }
    .cart-item:last-child { border-bottom:none; }
    .cart-item-img {
      width:64px; height:64px; border-radius:12px;
      object-fit:cover; flex-shrink:0;
    }
    .cart-item-info { flex:1; min-width:0; }
    .cart-item-name { font-size:0.875rem; font-weight:600; margin-bottom:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .cart-item-price { font-size:0.875rem; color:rgba(255,255,255,0.5); }
    .cart-item-remove {
      width:28px; height:28px; border-radius:7px; flex-shrink:0;
      border:1px solid rgba(255,255,255,0.08); background:transparent;
      color:rgba(255,255,255,0.35); font-size:0.9rem;
      cursor:pointer; transition:0.2s; display:flex; align-items:center; justify-content:center;
    }
    .cart-item-remove:hover { background:rgba(255,80,80,0.12); border-color:rgba(255,80,80,0.3); color:#ff5050; }

    .cart-item-qty {
      display:flex; align-items:center; gap:8px; margin-top:6px;
    }
    .qty-btn {
      width:24px; height:24px; border-radius:6px;
      border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05);
      color:white; font-size:0.8rem; cursor:pointer; transition:0.15s;
      display:flex; align-items:center; justify-content:center;
    }
    .qty-btn:hover { background:rgba(255,255,255,0.12); }
    .qty-num { font-size:0.8rem; font-weight:600; min-width:16px; text-align:center; }

    .drawer-footer {
      padding:20px 24px;
      border-top:1px solid rgba(255,255,255,0.07);
    }
    .cart-subtotal {
      display:flex; justify-content:space-between; align-items:center;
      margin-bottom:16px;
    }
    .cart-subtotal-label { font-size:0.875rem; color:rgba(255,255,255,0.5); }
    .cart-subtotal-value { font-size:1.2rem; font-weight:800; }
    .checkout-btn {
      width:100%; padding:16px; border-radius:16px; border:none;
      background:linear-gradient(90deg,#8b5cf6,#38bdf8);
      color:white; font-weight:700; font-size:1rem;
      cursor:pointer; transition:0.2s; font-family:'Inter',sans-serif;
      box-shadow:0 8px 24px rgba(139,92,246,0.3);
    }
    .checkout-btn:hover { transform:translateY(-2px); box-shadow:0 12px 30px rgba(139,92,246,0.4); }
    .checkout-btn:disabled { opacity:0.5; cursor:not-allowed; transform:none; }

    /* ── CHECKOUT MODAL ── */
    .checkout-overlay {
      position:fixed; inset:0; z-index:600;
      background:rgba(0,0,0,0.6); backdrop-filter:blur(8px);
      display:flex; align-items:center; justify-content:center;
      padding:20px;
      opacity:0; pointer-events:none; transition:opacity 0.3s;
    }
    .checkout-overlay.open { opacity:1; pointer-events:auto; }

    .checkout-modal {
      background:#13151f;
      border:1px solid rgba(255,255,255,0.1);
      border-radius:24px;
      width:100%; max-width:480px;
      max-height:90vh; overflow-y:auto;
      box-shadow:0 40px 80px rgba(0,0,0,0.7);
      animation:pop 0.35s cubic-bezier(0.16,1,0.3,1);
    }
    @keyframes pop { from{transform:scale(0.93);opacity:0} to{transform:scale(1);opacity:1} }

    .modal-header {
      display:flex; align-items:center; justify-content:space-between;
      padding:22px 24px 18px;
      border-bottom:1px solid rgba(255,255,255,0.07);
    }
    .modal-title { font-size:1.1rem; font-weight:700; }
    .modal-close {
      width:32px; height:32px; border-radius:8px;
      border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05);
      color:rgba(255,255,255,0.6); font-size:1.1rem;
      cursor:pointer; display:flex; align-items:center; justify-content:center; transition:0.2s;
    }
    .modal-close:hover { background:rgba(255,255,255,0.1); color:white; }

    .modal-body { padding:24px; }

    /* order summary inside modal */
    .order-summary {
      background:rgba(255,255,255,0.04);
      border:1px solid rgba(255,255,255,0.07);
      border-radius:14px;
      padding:16px;
      margin-bottom:24px;
    }
    .order-summary-title { font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:12px; }
    .order-line { display:flex; justify-content:space-between; font-size:0.875rem; margin-bottom:8px; color:rgba(255,255,255,0.7); }
    .order-line:last-child { margin-bottom:0; }
    .order-total { display:flex; justify-content:space-between; padding-top:12px; margin-top:4px; border-top:1px solid rgba(255,255,255,0.07); font-weight:700; font-size:1rem; }

    /* express pay buttons */
    .express-title { font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:12px; }
    .express-btns { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:20px; }
    .express-pay-btn {
      padding:13px; border-radius:13px; border:1.5px solid rgba(255,255,255,0.12);
      background:rgba(255,255,255,0.05); cursor:pointer; transition:0.2s;
      display:flex; align-items:center; justify-content:center; gap:8px;
      font-family:'Inter',sans-serif; font-weight:700; font-size:0.875rem; color:white;
    }
    .express-pay-btn:hover { background:rgba(255,255,255,0.1); border-color:rgba(255,255,255,0.25); transform:translateY(-1px); }
    .apple-btn { background:black; border-color:rgba(255,255,255,0.2); }
    .apple-btn:hover { background:#1a1a1a; }
    .google-btn { background:white; color:#1f1f1f; border-color:white; }
    .google-btn:hover { background:#f0f0f0; }

    .divider {
      display:flex; align-items:center; gap:12px;
      margin-bottom:20px;
      font-size:0.75rem; color:rgba(255,255,255,0.25);
    }
    .divider::before, .divider::after {
      content:''; flex:1; height:1px; background:rgba(255,255,255,0.08);
    }

    /* card form */
    .field { margin-bottom:14px; }
    .field label { display:block; font-size:0.72rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:6px; }
    .field input {
      width:100%; padding:13px 14px; border-radius:11px;
      border:1.5px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05);
      color:white; font-family:'Inter',sans-serif; font-size:0.9rem; outline:none;
      transition:border-color 0.2s, box-shadow 0.2s;
    }
    .field input:focus { border-color:rgba(139,92,246,0.6); box-shadow:0 0 0 3px rgba(139,92,246,0.12); }
    .field input::placeholder { color:rgba(255,255,255,0.2); }
    .field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

    .pay-now-btn {
      width:100%; padding:16px; border-radius:16px; border:none;
      background:linear-gradient(90deg,#8b5cf6,#38bdf8);
      color:white; font-weight:700; font-size:1rem;
      cursor:pointer; transition:0.2s; font-family:'Inter',sans-serif;
      margin-top:8px;
      box-shadow:0 8px 24px rgba(139,92,246,0.3);
    }
    .pay-now-btn:hover { transform:translateY(-2px); }
    .pay-now-btn:disabled { opacity:0.6; cursor:not-allowed; transform:none; }

    .secure-note {
      display:flex; align-items:center; justify-content:center; gap:6px;
      margin-top:14px; font-size:0.72rem; color:rgba(255,255,255,0.25);
    }

    /* processing + success screens */
    .processing-screen, .success-screen {
      display:none; flex-direction:column; align-items:center;
      justify-content:center; padding:48px 24px; text-align:center; gap:16px;
    }
    .processing-screen.show, .success-screen.show { display:flex; }

    .spinner-ring {
      width:52px; height:52px; border-radius:50%;
      border:3px solid rgba(139,92,246,0.2);
      border-top-color:#8b5cf6;
      animation:spin 0.8s linear infinite;
    }
    @keyframes spin { to{transform:rotate(360deg)} }

    .success-icon {
      width:60px; height:60px; border-radius:50%;
      background:linear-gradient(135deg,#22c55e,#16a34a);
      display:flex; align-items:center; justify-content:center;
      animation:pop 0.5s cubic-bezier(0.16,1,0.3,1);
    }
    .processing-title, .success-title { font-size:1.2rem; font-weight:800; }
    .processing-sub, .success-sub { font-size:0.875rem; color:rgba(255,255,255,0.45); line-height:1.6; }
    .success-amount { font-size:2rem; font-weight:800; background:linear-gradient(90deg,#8b5cf6,#38bdf8); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .success-method { font-size:0.8rem; color:rgba(255,255,255,0.35); }
    .done-btn {
      padding:13px 32px; border-radius:14px; border:1px solid rgba(255,255,255,0.12);
      background:rgba(255,255,255,0.06); color:white; font-weight:600;
      cursor:pointer; transition:0.2s; font-family:'Inter',sans-serif; margin-top:8px;
    }
    .done-btn:hover { background:rgba(255,255,255,0.1); }

    @media (max-width: 900px) {
      .hero { padding-top:60px; padding-bottom:60px; }
      .nav-links { display:none; }
      .newsletter { padding:40px 20px; }
    }
  </style>
</head>
<body>

  <!-- ── CART OVERLAY + DRAWER ── -->
  <div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>
  <div class="cart-drawer" id="cart-drawer">
    <div class="drawer-header">
      <span class="drawer-title">Your Cart</span>
      <button class="drawer-close" onclick="closeCart()">✕</button>
    </div>
    <div class="cart-items" id="cart-items">
      <div class="cart-empty">
        <div class="cart-empty-icon">🛍️</div>
        <div>Your cart is empty.<br>Add something to get started.</div>
      </div>
    </div>
    <div class="drawer-footer">
      <div class="cart-subtotal">
        <span class="cart-subtotal-label">Subtotal</span>
        <span class="cart-subtotal-value" id="cart-subtotal">$0.00</span>
      </div>
      <button class="checkout-btn" id="checkout-btn" onclick="openCheckout()" disabled>Checkout</button>
    </div>
  </div>

  <!-- ── CHECKOUT MODAL ── -->
  <div class="checkout-overlay" id="checkout-overlay">
    <div class="checkout-modal" id="checkout-modal">
      <div id="payment-screen">
        <div class="modal-header">
          <span class="modal-title">Checkout</span>
          <button class="modal-close" onclick="closeCheckout()">✕</button>
        </div>
        <div class="modal-body">

          <!-- order summary -->
          <div class="order-summary">
            <div class="order-summary-title">Order Summary</div>
            <div id="order-lines"></div>
            <div class="order-total">
              <span>Total</span>
              <span id="order-total">$0.00</span>
            </div>
          </div>

          <!-- express pay -->
          <div class="express-title">Express checkout</div>
          <div class="express-btns">
            <button class="express-pay-btn apple-btn" onclick="expressCheckout('Apple Pay')">
              <svg width="16" height="16" viewBox="0 0 814 1000" fill="white"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105.8-57.2-155.5-127.4C46 405.8 0 303.8 0 206.7c0-123.2 80.4-188.7 158.8-188.7 85.5 0 138.3 56.7 195.2 56.7 54.1 0 115.2-59.9 203.6-59.9 32.4 0 132.1 2.9 198.3 106.9zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
              Apple Pay
            </button>
            <button class="express-pay-btn google-btn" onclick="expressCheckout('Google Pay')">
              <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
              Google Pay
            </button>
          </div>

          <div class="divider">or pay by card</div>

          <!-- card form -->
          <div class="field">
            <label>Card Number</label>
            <input id="card-num" type="text" placeholder="1234 5678 9012 3456" maxlength="19" autocomplete="cc-number"/>
          </div>
          <div class="field field-row">
            <div>
              <label>Expiry</label>
              <input id="card-exp" type="text" placeholder="MM / YY" maxlength="7" autocomplete="cc-exp"/>
            </div>
            <div>
              <label>CVC</label>
              <input id="card-cvc" type="text" placeholder="123" maxlength="4" autocomplete="cc-csc"/>
            </div>
          </div>
          <div class="field">
            <label>Name on card</label>
            <input id="card-name" type="text" placeholder="Your name" autocomplete="cc-name"/>
          </div>

          <button class="pay-now-btn" id="pay-now-btn" onclick="cardCheckout()">Pay <span id="pay-amount"></span></button>

          <div class="secure-note">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Secured by SSL encryption
          </div>
        </div>
      </div>

      <!-- processing -->
      <div class="processing-screen" id="processing-screen">
        <div class="spinner-ring"></div>
        <div class="processing-title">Processing payment…</div>
        <div class="processing-sub" id="processing-method">Contacting your bank</div>
      </div>

      <!-- success -->
      <div class="success-screen" id="success-screen">
        <div class="success-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="success-title">Order confirmed! 🎉</div>
        <div class="success-amount" id="success-amount"></div>
        <div class="success-method" id="success-method"></div>
        <div class="success-sub">A confirmation has been sent to your email.<br>Estimated delivery: 3–5 business days.</div>
        <button class="done-btn" onclick="finishCheckout()">Done</button>
      </div>
    </div>
  </div>

  <!-- ── NAV ── -->
  <nav>
    <div class="logo">CONNER</div>
    <div class="nav-links">
      <a href="#shop">Shop</a>
      <a href="#featured">Featured</a>
      <a href="#newsletter">Updates</a>
    </div>
    <button class="cart-btn" onclick="openCart()">
      🛍️ Cart <span class="cart-count" id="cart-count">0</span>
    </button>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-text">
      <h1>Modern merch for the <span>next generation.</span></h1>
      <p>Conner delivers bold creator merch alongside premium diaper-care cosmetics and comfort essentials with a sleek modern storefront experience.</p>
      <div class="hero-buttons">
        <a href="#shop" class="btn btn-primary">Shop Collection</a>
        <a href="#featured" class="btn btn-secondary">Featured Drop</a>
      </div>
    </div>
    <div class="hero-card">
      <div class="floating-card">
        <img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?q=80&w=1200&auto=format&fit=crop" alt="Featured product">
        <h3>Conner DiaperCare Bundle</h3>
        <p>A premium diaper-care cosmetic bundle featuring skin cream, wipes, powder, and comfort essentials.</p>
        <div class="price-row">
          <div class="price">$39.99</div>
          <button class="buy-btn" onclick="addToCart(this, 'Conner DiaperCare Bundle', 39.99, 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?q=80&w=200&auto=format&fit=crop')">Add to Cart</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SHOP ── -->
  <section class="shop" id="shop">
    <h2 class="section-title">Trending Products</h2>
    <div class="product-grid">

      <div class="product-card" id="featured">
        <img src="https://images.unsplash.com/photo-1556228578-dd6c2d8f4b8d?q=80&w=1200&auto=format&fit=crop" alt="Product">
        <div class="product-content">
          <h3>SoftCare Diaper Cosmetic Kit</h3>
          <p>Includes premium diaper-care wipes, lotion, powder, and comfort accessories with minimalist packaging.</p>
          <div class="product-footer">
            <strong>$24.99</strong>
            <button class="buy-btn" onclick="addToCart(this, 'SoftCare Diaper Cosmetic Kit', 24.99, 'https://images.unsplash.com/photo-1556228578-dd6c2d8f4b8d?q=80&w=200&auto=format&fit=crop')">Buy Now</button>
          </div>
        </div>
      </div>

      <div class="product-card">
        <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?q=80&w=1200&auto=format&fit=crop" alt="Product">
        <div class="product-content">
          <h3>BabyFresh Cosmetic Bundle</h3>
          <p>Modern diaper-care cosmetic collection featuring skincare creams, wipes, and aesthetic storage containers.</p>
          <div class="product-footer">
            <strong>$49.99</strong>
            <button class="buy-btn" onclick="addToCart(this, 'BabyFresh Cosmetic Bundle', 49.99, 'https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?q=80&w=200&auto=format&fit=crop')">Buy Now</button>
          </div>
        </div>
      </div>

      <div class="product-card">
        <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=1200&auto=format&fit=crop" alt="Product">
        <div class="product-content">
          <h3>Conner Ultimate Care Pack</h3>
          <p>A luxury diaper-care themed merch package with cosmetic accessories, branded apparel, and exclusive items.</p>
          <div class="product-footer">
            <strong>$69.99</strong>
            <button class="buy-btn" onclick="addToCart(this, 'Conner Ultimate Care Pack', 69.99, 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=200&auto=format&fit=crop')">Buy Now</button>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── NEWSLETTER ── -->
  <section class="newsletter" id="newsletter">
    <h2>Stay Updated</h2>
    <p>Join the Conner mailing list for new drops, exclusive deals, and limited collections.</p>
    <form class="newsletter-form" id="newsletter-form">
      <input type="email" placeholder="Enter your email" required>
      <button type="submit" class="btn btn-primary">Subscribe</button>
    </form>
  </section>

  <footer>
    © 2026 Conner. All rights reserved.
  </footer>

  <script>
    // ── Cart state ──
    let cart = []; // { id, name, price, img, qty }
    let nextId = 1;

    function fmt(n) { return '$' + n.toFixed(2); }

    function cartTotal() {
      return cart.reduce((s, i) => s + i.price * i.qty, 0);
    }

    function updateCartUI() {
      const total = cartTotal();
      const count = cart.reduce((s, i) => s + i.qty, 0);

      // nav badge
      const badge = document.getElementById('cart-count');
      badge.textContent = count;
      badge.classList.toggle('has-items', count > 0);

      // subtotal
      document.getElementById('cart-subtotal').textContent = fmt(total);

      // checkout btn
      document.getElementById('checkout-btn').disabled = cart.length === 0;

      // render items
      const el = document.getElementById('cart-items');
      if (!cart.length) {
        el.innerHTML = '<div class="cart-empty"><div class="cart-empty-icon">🛍️</div><div>Your cart is empty.<br>Add something to get started.</div></div>';
        return;
      }
      el.innerHTML = '';
      cart.forEach(item => {
        const div = document.createElement('div');
        div.className = 'cart-item';
        div.innerHTML = `
          <img class="cart-item-img" src="${item.img}" alt="${item.name}">
          <div class="cart-item-info">
            <div class="cart-item-name">${item.name}</div>
            <div class="cart-item-price">${fmt(item.price)}</div>
            <div class="cart-item-qty">
              <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
              <span class="qty-num">${item.qty}</span>
              <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
            </div>
          </div>
          <button class="cart-item-remove" onclick="removeItem(${item.id})">✕</button>
        `;
        el.appendChild(div);
      });
    }

    function addToCart(btn, name, price, img) {
      const existing = cart.find(i => i.name === name);
      if (existing) {
        existing.qty++;
      } else {
        cart.push({ id: nextId++, name, price, img, qty: 1 });
      }
      btn.textContent = 'Added ✓';
      btn.classList.add('added');
      setTimeout(() => { btn.textContent = btn.textContent.includes('Add') ? 'Add to Cart' : 'Buy Now'; btn.classList.remove('added'); }, 1800);
      updateCartUI();
      openCart();
    }

    function removeItem(id) {
      cart = cart.filter(i => i.id !== id);
      updateCartUI();
    }

    function changeQty(id, delta) {
      const item = cart.find(i => i.id === id);
      if (!item) return;
      item.qty = Math.max(1, item.qty + delta);
      updateCartUI();
    }

    // ── Cart drawer ──
    function openCart() {
      document.getElementById('cart-overlay').classList.add('open');
      document.getElementById('cart-drawer').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeCart() {
      document.getElementById('cart-overlay').classList.remove('open');
      document.getElementById('cart-drawer').classList.remove('open');
      document.body.style.overflow = '';
    }

    // ── Checkout modal ──
    function openCheckout() {
      closeCart();
      // populate order summary
      const lines = document.getElementById('order-lines');
      lines.innerHTML = cart.map(i =>
        `<div class="order-line"><span>${i.name} × ${i.qty}</span><span>${fmt(i.price * i.qty)}</span></div>`
      ).join('');
      document.getElementById('order-total').textContent = fmt(cartTotal());
      document.getElementById('pay-amount').textContent = fmt(cartTotal());

      showScreen('payment-screen');
      document.getElementById('checkout-overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeCheckout() {
      document.getElementById('checkout-overlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    function showScreen(id) {
      ['payment-screen','processing-screen','success-screen'].forEach(s => {
        const el = document.getElementById(s);
        if (el.classList.contains('processing-screen') || el.classList.contains('success-screen')) {
          el.classList.remove('show');
        } else {
          el.style.display = s === id ? 'block' : 'none';
        }
      });
      if (id !== 'payment-screen') document.getElementById(id).classList.add('show');
    }

    function processPayment(method) {
      document.getElementById('payment-screen').style.display = 'none';
      document.getElementById('processing-method').textContent = `Processing via ${method}…`;
      document.getElementById('processing-screen').classList.add('show');

      setTimeout(() => {
        document.getElementById('processing-screen').classList.remove('show');
        document.getElementById('success-amount').textContent = fmt(cartTotal());
        document.getElementById('success-method').textContent = `Paid with ${method}`;
        document.getElementById('success-screen').classList.add('show');
      }, 2200);
    }

    function expressCheckout(method) {
      processPayment(method);
    }

    function cardCheckout() {
      processPayment('Credit / Debit Card');
    }

    function finishCheckout() {
      closeCheckout();
      cart = [];
      // reset all buy buttons
      document.querySelectorAll('.buy-btn').forEach(btn => {
        btn.textContent = btn.closest('.floating-card') ? 'Add to Cart' : 'Buy Now';
        btn.classList.remove('added');
      });
      updateCartUI();
    }

    // ── Card formatting ──
    document.getElementById('card-num').addEventListener('input', e => {
      let v = e.target.value.replace(/\D/g,'').slice(0,16);
      e.target.value = v.match(/.{1,4}/g)?.join(' ') ?? v;
    });
    document.getElementById('card-exp').addEventListener('input', e => {
      let v = e.target.value.replace(/\D/g,'').slice(0,4);
      if (v.length >= 3) v = v.slice(0,2) + ' / ' + v.slice(2);
      e.target.value = v;
    });
    document.getElementById('card-cvc').addEventListener('input', e => {
      e.target.value = e.target.value.replace(/\D/g,'').slice(0,4);
    });

    // ── Newsletter ──
    document.getElementById('newsletter-form').addEventListener('submit', e => {
      e.preventDefault();
      alert('Thanks for subscribing to Conner updates.');
    });
  </script>

</body>
</html>
