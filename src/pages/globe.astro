    .map(link => `<a class="selected-link" href="${escapeAttr(link.url)}" target="_blank" rel="noopener">${escapeHtml(link.label)} ↗</a>`)
    .join('');
  const detailButton = `<button class="selected-link" type="button" data-detail-id="${escapeAttr(event.id)}">${escapeHtml(eventTypeLabel(event.kind))} details</button>`;
