<style is:global>
@view-transition { navigation: auto; }
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #020810;
  --bg2: #070f1f;
  --panel: rgba(5, 8, 18, 0.82);
  --panel-strong: rgba(6, 10, 22, 0.94);
  --line: rgba(255, 255, 255, 0.08);
  --line-strong: rgba(64, 200, 255, 0.24);
  --text: #c8f0ff;
  --muted: rgba(200, 240, 255, 0.56);
  --dim: rgba(200, 240, 255, 0.28);
  --cyan: #40c8ff;
  --teal: #00ffcc;
  --red: #ff5d73;
  --orange: #ff9d4d;
  --yellow: #ffd75e;
  --mono: "JetBrains Mono", monospace;
  --sans: "Inter", system-ui, sans-serif;
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
html, body {
  width: 100%;
  min-height: 100%;
  background:
    radial-gradient(circle at 20% 20%, rgba(0, 120, 200, 0.22), transparent 28%),
    radial-gradient(circle at 80% 12%, rgba(0, 255, 204, 0.12), transparent 22%),
    radial-gradient(circle at 50% 80%, rgba(255, 93, 115, 0.08), transparent 26%),
    linear-gradient(180deg, #030812 0%, #020810 45%, #050a15 100%);
  color: var(--text);
  font-family: var(--sans);
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
}
body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 26px 26px;
  mask-image: radial-gradient(circle at center, rgba(0,0,0,0.9), transparent 92%);
}
a { color: inherit; text-decoration: none; }
button, input { font: inherit; }
button {
  border: 0;
  background: none;
  color: inherit;
}

#app {
  position: fixed;
  inset: 0;
}

#globe-canvas {
  position: absolute;
  inset: 0;
}

.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: calc(var(--safe-top) + 16px) 20px 0;
  pointer-events: none;
}

.brand,
.toolbar,
.hud,
.panel,
.footer-links,
.status-toast {
  pointer-events: auto;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  border: 1px solid var(--line);
  background: rgba(4, 8, 18, 0.76);
  border-radius: 16px;
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.34);
}

.brand-mark {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at 30% 30%, rgba(64, 200, 255, 0.9), rgba(64, 200, 255, 0.08) 60%, transparent 62%),
    radial-gradient(circle at 70% 70%, rgba(0, 255, 204, 0.48), transparent 48%);
  box-shadow: 0 0 26px rgba(64, 200, 255, 0.3);
}

.brand-mark svg { width: 20px; height: 20px; }
.brand-copy { display: flex; flex-direction: column; gap: 4px; }
.brand-kicker {
  font-family: var(--mono);
  font-size: 0.54rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--dim);
}
.brand-title {
  font-size: 0.86rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.beta-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 18px;
  padding: 0 8px;
  border-radius: 999px;
  border: 1px solid rgba(255, 214, 94, 0.22);
  background: rgba(255, 214, 94, 0.12);
  color: #ffd75e;
  font-family: var(--mono);
  font-size: 0.46rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 10px;
}

.tool-btn,
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 14px;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: rgba(4, 8, 18, 0.74);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color 0.18s, background 0.18s, color 0.18s, transform 0.18s;
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
}

.tool-btn:hover,
.chip:hover {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.18);
  transform: translateY(-1px);
}

.tool-btn svg {
  width: 13px;
  height: 13px;
  fill: currentColor;
}

.chip-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 0 12px currentColor;
}

.chip.active {
  color: var(--text);
  border-color: rgba(64, 200, 255, 0.38);
  background: rgba(0, 120, 200, 0.18);
}

.chip[data-filter="quakes"].active { color: var(--cyan); }
.chip[data-filter="storms"].active { color: var(--red); }
.chip[data-filter="wildfires"].active { color: var(--orange); }
.chip[data-filter="volcanoes"].active { color: var(--yellow); }

.hud {
  position: fixed;
  left: 20px;
  bottom: calc(var(--safe-bottom) + 22px);
  z-index: 15;
  display: grid;
  gap: 10px;
  width: min(360px, calc(100vw - 40px));
}

.hud-card,
.panel,
.footer-links,
.status-toast {
  border: 1px solid var(--line);
  background: var(--panel);
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
  box-shadow: 0 16px 50px rgba(0, 0, 0, 0.32);
}

.hud-card {
  border-radius: 18px;
  padding: 16px 18px;
}

.hud-kicker,
.panel-kicker,
.list-kicker,
.stat-label {
  font-family: var(--mono);
  font-size: 0.54rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--dim);
}

.hud-title {
  margin-top: 8px;
  font-size: clamp(1.35rem, 2vw, 1.8rem);
  line-height: 1.08;
  letter-spacing: -0.02em;
  max-width: 12ch;
}

.hud-sub {
  margin-top: 12px;
  font-size: 0.82rem;
  line-height: 1.7;
  color: var(--muted);
  max-width: 34ch;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.stat {
  min-width: 0;
  padding: 12px 12px 10px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.02);
}

.stat-value {
  margin-top: 8px;
  font-size: 1.32rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.03em;
}

.stat-meta {
  margin-top: 4px;
  font-size: 0.66rem;
  color: var(--muted);
}

.panel {
  position: fixed;
  top: calc(var(--safe-top) + 90px);
  right: 20px;
  bottom: calc(var(--safe-bottom) + 20px);
  z-index: 15;
  width: min(420px, calc(100vw - 40px));
  border-radius: 22px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-head {
  padding: 18px 18px 14px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent);
}

.panel-title-row {
  margin-top: 10px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.panel-title {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.panel-updated {
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}

.filter-row {
  margin-top: 14px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.search-wrap {
  margin-top: 12px;
  position: relative;
}

.search-input {
  width: 100%;
  min-height: 40px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  color: var(--text);
  padding: 0 14px 0 38px;
  font-family: var(--mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
}

.search-input::placeholder {
  color: var(--dim);
}

.search-icon {
  position: absolute;
  left: 13px;
  top: 50%;
  transform: translateY(-50%);
  width: 14px;
  height: 14px;
  fill: var(--dim);
  pointer-events: none;
}

.feed {
  min-height: 0;
  overflow-y: auto;
  padding: 8px 10px 14px;
}

.feed::-webkit-scrollbar { width: 6px; }
.feed::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 999px;
}

.selected {
  margin: 0 8px 10px;
  padding: 16px;
  border-radius: 18px;
  border: 1px solid rgba(64, 200, 255, 0.18);
  background: rgba(0, 120, 200, 0.08);
}

.selected.empty {
  border-style: dashed;
  background: rgba(255, 255, 255, 0.02);
}

.selected-type {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.selected-title {
  margin-top: 10px;
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.35;
}

.selected-meta {
  margin-top: 10px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.meta-pill {
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
}

.selected-copy {
  margin-top: 12px;
  font-size: 0.78rem;
  line-height: 1.7;
  color: var(--muted);
}

.selected-link {
  margin-top: 14px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text);
}

.list-head {
  padding: 6px 8px 10px;
}

.event-list {
  display: grid;
  gap: 8px;
}

.event-btn {
  width: 100%;
  text-align: left;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.02);
  padding: 13px 14px;
  cursor: pointer;
  transition: border-color 0.16s, background 0.16s, transform 0.16s;
}

.event-btn:hover,
.event-btn:focus-visible {
  outline: none;
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.16);
  transform: translateY(-1px);
}

.event-btn.active {
  border-color: rgba(64, 200, 255, 0.28);
  background: rgba(0, 120, 200, 0.12);
}

.event-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.event-type {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.event-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 14px currentColor;
}

.event-label {
  font-family: var(--mono);
  font-size: 0.55rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

.event-time {
  font-family: var(--mono);
  font-size: 0.52rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--dim);
  white-space: nowrap;
}

.event-title {
  margin-top: 10px;
  font-size: 0.84rem;
  line-height: 1.45;
  color: var(--text);
}

.event-sub {
  margin-top: 7px;
  font-size: 0.68rem;
  line-height: 1.55;
  color: var(--muted);
}

.footer-links {
  position: fixed;
  right: 20px;
  bottom: calc(var(--safe-bottom) + 20px);
  z-index: 15;
  display: inline-flex;
  align-items: center;
  gap: 18px;
  padding: 12px 16px;
  border-radius: 999px;
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}

.footer-links a:hover { color: var(--text); }

.status-toast {
  position: fixed;
  top: calc(var(--safe-top) + 82px);
  left: 50%;
  transform: translateX(-50%);
  z-index: 25;
  padding: 10px 14px;
  border-radius: 999px;
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
}

.status-toast.show { opacity: 1; }

.beta-overlay {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: grid;
  place-items: center;
  padding: 20px;
  background: rgba(2, 8, 16, 0.78);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.beta-overlay.hidden {
  display: none;
}

.detail-overlay {
  position: fixed;
  inset: 0;
  z-index: 42;
  display: grid;
  place-items: center;
  padding: 20px;
  background: rgba(2, 8, 16, 0.74);
  -webkit-backdrop-filter: blur(14px);
  backdrop-filter: blur(14px);
}

.detail-overlay.hidden {
  display: none;
}

.detail-modal {
  width: min(720px, 100%);
  max-height: min(78svh, 760px);
  overflow: auto;
  border-radius: 24px;
  border: 1px solid rgba(64, 200, 255, 0.18);
  background: rgba(8, 12, 24, 0.97);
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
}

.detail-modal::-webkit-scrollbar { width: 6px; }
.detail-modal::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.14);
  border-radius: 999px;
}

.detail-head {
  position: sticky;
  top: 0;
  z-index: 1;
  padding: 18px 20px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  background: rgba(8, 12, 24, 0.94);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
}

.detail-title {
  margin-top: 10px;
  font-size: 1.08rem;
  line-height: 1.35;
  font-weight: 700;
}

.detail-close {
  min-width: 40px;
  min-height: 40px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  font-family: var(--mono);
  font-size: 0.9rem;
  color: var(--muted);
  cursor: pointer;
}

.detail-body {
  padding: 18px 20px 22px;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.detail-stat {
  padding: 12px 12px 10px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.02);
}

.detail-stat-value {
  margin-top: 8px;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text);
}

.detail-text-block {
  margin-top: 16px;
  padding: 14px 16px;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.02);
}

.detail-text-block p + p {
  margin-top: 10px;
}

.detail-copy {
  font-size: 0.8rem;
  line-height: 1.75;
  color: var(--muted);
}

.detail-actions {
  margin-top: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.selected-actions {
  margin-top: 14px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.beta-modal {
  width: min(480px, 100%);
  border-radius: 22px;
  border: 1px solid rgba(64, 200, 255, 0.2);
  background: rgba(7, 12, 24, 0.96);
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
  padding: 24px 22px 20px;
}

.beta-title {
  margin-top: 12px;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.beta-copy {
  margin-top: 12px;
  font-size: 0.8rem;
  line-height: 1.75;
  color: var(--muted);
}

.beta-list {
  margin-top: 14px;
  display: grid;
  gap: 8px;
  font-size: 0.74rem;
  line-height: 1.6;
  color: var(--muted);
}

.beta-list div::before {
  content: "•";
  color: var(--cyan);
  margin-right: 8px;
}

.beta-actions {
  margin-top: 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.beta-dismiss {
  min-height: 40px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid rgba(64, 200, 255, 0.28);
  background: rgba(0, 120, 200, 0.16);
  color: var(--text);
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
}

.beta-dismiss:hover {
  background: rgba(0, 120, 200, 0.24);
}

.beta-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.66rem;
  color: var(--muted);
}

.beta-toggle input {
  width: 14px;
  height: 14px;
  accent-color: var(--cyan);
}

.loading-cover {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: grid;
  place-items: center;
  background: linear-gradient(180deg, rgba(2,8,16,0.94), rgba(2,8,16,0.82));
  transition: opacity 0.35s, visibility 0.35s;
}

.loading-cover.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.loading-box {
  display: grid;
  gap: 14px;
  justify-items: center;
}

.loading-ring {
  width: 78px;
  height: 78px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.08);
  position: relative;
}

.loading-ring::before,
.loading-ring::after {
  content: "";
  position: absolute;
  inset: 10px;
  border-radius: 50%;
