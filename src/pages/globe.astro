    <div class="selected-meta">
      <span class="meta-pill">${escapeHtml(categorySummary(event))}</span>
      <span class="meta-pill">${escapeHtml(formatAgo(event.time))}</span>
      <span class="meta-pill">${escapeHtml(event.source)}</span>
    </div>
    <div class="selected-copy">${escapeHtml(event.place || event.description || 'Open event')}</div>
    ${detailRows}
    <div class="selected-actions">${detailButton}${sourceLinks}</div>
  `;

  selectedCard.querySelector('[data-detail-id]')?.addEventListener('click', () => openEventDetail(event.id));
}

function renderEventList() {
  const visibleEvents = events
    .filter(event => activeFilters.has(event.kind))
    .filter(event => {
      if (!eventSearchTerm) return true;
      const haystack = [event.title, event.place, event.source, categorySummary(event)].join(' ').toLowerCase();
      return haystack.includes(eventSearchTerm);
    })
    .sort((a, b) => scoreEvent(b) - scoreEvent(a))
    .slice(0, 14);

  eventList.innerHTML = '';
  visibleEvents.forEach(event => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = `event-btn${event.id === selectedId ? ' active' : ''}`;
    btn.dataset.eventId = event.id;
    btn.innerHTML = `
      <div class="event-top">
        <div class="event-type">
          <span class="event-dot" style="color:${eventColor(event.kind)};background:${eventColor(event.kind)}"></span>
          <span class="event-label">${escapeHtml(eventTypeLabel(event.kind))}</span>
        </div>
        <span class="event-time">${escapeHtml(formatAgo(event.time))}</span>
      </div>
      <div class="event-title">${escapeHtml(event.title)}</div>
      <div class="event-sub">${escapeHtml(categorySummary(event))} · ${escapeHtml(event.place || 'Live event')}</div>
      <div class="event-sub">${escapeHtml(event.source)}</div>
    `;
    btn.addEventListener('click', () => focusEvent(event.id, { openDetail: true }));
    eventList.appendChild(btn);
  });

  if (!visibleEvents.length) {
    const emptyMessage = eventSearchTerm
      ? 'No events match that search right now.'
      : activeFilters.has('storms')
        ? 'No active severe storms are being published in the current NASA EONET open-event feed.'
        : 'All visible layers are off. Re-enable a feed to populate the globe.';
    eventList.innerHTML = `<div class="event-sub" style="padding:8px 8px 20px;color:rgba(200,240,255,0.42)">${emptyMessage}</div>`;
  }
}

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(value) {
  return escapeHtml(value);
}

