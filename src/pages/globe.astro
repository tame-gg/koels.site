      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="rgba(200,240,255,0.9)" stroke-width="1.5">
          <circle cx="12" cy="12" r="7.5"></circle>
          <path d="M4.5 12h15M12 4.5c2.2 2.3 3.3 4.8 3.3 7.5S14.2 17.2 12 19.5M12 4.5c-2.2 2.3-3.3 4.8-3.3 7.5S9.8 17.2 12 19.5"></path>
        </svg>
      </span>
      <span class="brand-copy">
        <span class="brand-kicker">koels.site / live globe</span>
