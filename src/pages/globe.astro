      <div class="filter-row" id="filter-row">
        <button class="chip active" data-filter="quakes" type="button"><span class="chip-dot"></span>Quakes</button>
        <button class="chip active" data-filter="storms" type="button"><span class="chip-dot"></span>Storms</button>
        <button class="chip active" data-filter="wildfires" type="button"><span class="chip-dot"></span>Wildfires</button>
        <button class="chip active" data-filter="volcanoes" type="button"><span class="chip-dot"></span>Volcanoes</button>
      </div>
      <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        <input class="search-input" id="event-search" type="text" placeholder="Search place, event, source..." />
      </div>
