---
// Spectre Extension Store
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Extensions — Spectre Browser</title>
  <meta name="description" content="A curated store of open-source Chromium extensions, vetted and ready to install in Spectre Browser." />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://koels.site/extension" />
  <meta property="og:title"       content="Extensions — Spectre Browser" />
  <meta property="og:description" content="Open-source extensions, curated for privacy. Download and install in Spectre with one click." />
  <meta property="og:image"       content="https://koels.site/og.png" />
  <meta property="og:site_name"   content="Spectre Browser" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #05050f;
      --bg2:      #08081a;
      --bg3:      #0b0b1f;
      --surface:  rgba(255,255,255,0.035);
      --surface2: rgba(255,255,255,0.065);
      --border:   rgba(255,255,255,0.07);
      --border2:  rgba(255,255,255,0.13);
      --text:     #eeeeff;
      --muted:    rgba(238,238,255,0.52);
      --dim:      rgba(238,238,255,0.28);
      --cyan:     #00ccff;
      --cyan2:    #66deff;
      --violet:   #7b5fff;
      --green:    #00e87a;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255,255,255,0.028) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
      z-index: 0;
    }

    nav, main, footer { position: relative; z-index: 1; }

    /* ─── NAV ─── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 56px;
      background: rgba(5,5,15,0.82);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
    }

    .logo {
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .logo-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--cyan);
      box-shadow: 0 0 8px var(--cyan), 0 0 16px rgba(0,204,255,0.4);
    }

    .nav-right { display: flex; align-items: center; gap: 2rem; }

    .nav-links { display: flex; gap: 1.75rem; list-style: none; }

    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.15s;
    }

    .nav-links a:hover { color: var(--text); }

    .nav-gh {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.38rem 0.9rem;
      border-radius: 6px;
      border: 1px solid var(--border2);
      background: var(--surface);
      color: var(--muted);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      transition: border-color 0.2s, color 0.2s;
    }

    .nav-gh:hover { border-color: var(--cyan); color: var(--text); }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      text-align: center;
      padding: 7rem 1.5rem 5rem;
      overflow: hidden;
    }

    .hero-glow {
      position: absolute;
      top: -80px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 500px;
      background: radial-gradient(ellipse at 50% 35%,
        rgba(0,204,255,0.09) 0%,
        rgba(123,95,255,0.06) 40%,
        transparent 70%);
      pointer-events: none;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.28rem 0.9rem;
      border-radius: 99px;
      border: 1px solid rgba(0,204,255,0.22);
      background: rgba(0,204,255,0.06);
      color: var(--cyan2);
      font-size: 0.76rem;
      font-weight: 500;
      font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.04em;
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin-bottom: 1.25rem;
    }

    .hero h1 .accent {
      background: linear-gradient(100deg, var(--cyan), var(--cyan2) 60%, #aaf0ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 1.05rem;
      color: var(--muted);
      max-width: 480px;
      margin: 0 auto 2.5rem;
      line-height: 1.75;
    }

    /* ─── FILTERS ─── */
    .filters {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 3.5rem;
    }

    .filter-btn {
      padding: 0.38rem 1rem;
      border-radius: 99px;
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

    .filter-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

    .filter-btn.active {
      background: rgba(0,204,255,0.1);
      border-color: rgba(0,204,255,0.35);
      color: var(--cyan);
    }

    /* ─── GRID ─── */
    .store {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 1.5rem 6rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1rem;
    }

    .ext-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: border-color 0.2s, background 0.2s, transform 0.15s;
      position: relative;
      overflow: hidden;
    }

    .ext-card::after {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 120px; height: 120px;
      background: radial-gradient(circle at top right, rgba(0,204,255,0.04), transparent 65%);
      pointer-events: none;
    }

    .ext-card:hover {
      border-color: rgba(0,204,255,0.2);
      background: var(--surface2);
      transform: translateY(-2px);
    }

    .ext-card[data-category="Privacy"]:hover    { border-color: rgba(0,204,255,0.25); }
    .ext-card[data-category="Security"]:hover   { border-color: rgba(0,232,122,0.25); }
    .ext-card[data-category="Productivity"]:hover { border-color: rgba(123,95,255,0.25); }
    .ext-card[data-category="Appearance"]:hover { border-color: rgba(255,165,0,0.25); }

    .ext-header { display: flex; align-items: center; gap: 0.9rem; }

    .ext-icon {
      width: 52px;
      height: 52px;
      border-radius: 12px;
      overflow: hidden;
      flex-shrink: 0;
      background: var(--bg3);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ext-icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 6px;
    }

    .ext-meta { min-width: 0; flex: 1; }

    .ext-name {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      margin-bottom: 0.25rem;
    }

    .ext-tag {
      display: inline-block;
      padding: 0.15rem 0.55rem;
      border-radius: 4px;
      font-size: 0.68rem;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .tag-Privacy     { background: rgba(0,204,255,0.1);   color: var(--cyan);   border: 1px solid rgba(0,204,255,0.2); }
    .tag-Security    { background: rgba(0,232,122,0.1);   color: #00e87a;       border: 1px solid rgba(0,232,122,0.2); }
    .tag-Productivity{ background: rgba(123,95,255,0.1);  color: #a084ff;       border: 1px solid rgba(123,95,255,0.2); }
    .tag-Appearance  { background: rgba(255,165,0,0.1);   color: #ffa500;       border: 1px solid rgba(255,165,0,0.2); }

    .ext-desc {
      font-size: 0.855rem;
      color: var(--muted);
      line-height: 1.65;
      flex: 1;
    }

    .ext-actions { display: flex; gap: 0.6rem; margin-top: auto; }

    .btn-install {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      background: rgba(0,204,255,0.12);
      border: 1px solid rgba(0,204,255,0.28);
      color: var(--cyan);
      font-size: 0.82rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }

    .btn-install:hover:not(:disabled) { background: rgba(0,204,255,0.2); border-color: rgba(0,204,255,0.45); }

    .btn-install.loading {
      opacity: 0.6;
      cursor: wait;
    }

    .btn-install.installed {
      background: rgba(0,232,122,0.12);
      border-color: rgba(0,232,122,0.3);
      color: #00e87a;
      cursor: default;
    }

    .btn-install.error {
      background: rgba(255,69,96,0.1);
      border-color: rgba(255,69,96,0.3);
      color: #ff4560;
    }

    .btn-source {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.6rem 0.85rem;
      border-radius: 8px;
      background: transparent;
      border: 1px solid var(--border2);
      color: var(--dim);
      font-size: 0.82rem;
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s;
    }

    .btn-source:hover { border-color: rgba(255,255,255,0.25); color: var(--muted); }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { display: inline-block; animation: spin 0.8s linear infinite; }

    /* ─── HOW TO INSTALL ─── */
    .install-section {
      background: var(--bg2);
      border-top: 1px solid var(--border);
      padding: 5rem 1.5rem;
    }

    .install-inner {
      max-width: 680px;
      margin: 0 auto;
    }

    .section-tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--cyan);
      font-family: 'JetBrains Mono', monospace;
      margin-bottom: 0.6rem;
    }

    .install-inner h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 2.5rem;
    }

    .steps { display: flex; flex-direction: column; gap: 1rem; }

    .step {
      display: flex;
      gap: 1.1rem;
      align-items: flex-start;
      padding: 1.1rem 1.25rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
    }

    .step-num {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: rgba(0,204,255,0.1);
      border: 1px solid rgba(0,204,255,0.2);
      color: var(--cyan);
      font-size: 0.8rem;
      font-weight: 700;
      font-family: 'JetBrains Mono', monospace;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .step-body { font-size: 0.9rem; color: var(--muted); line-height: 1.65; padding-top: 0.15rem; }
    .step-body strong { color: var(--text); }
    .step-body code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.82em;
      color: var(--cyan2);
      background: rgba(0,204,255,0.07);
      border-radius: 3px;
      padding: 0.1em 0.35em;
    }

    /* ─── FOOTER ─── */
    .footer-outer { border-top: 1px solid var(--border); }

    footer {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 2.5rem 1.5rem;
      text-align: center;
    }

    .footer-logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
    }

    .footer-logo .logo-dot { width: 6px; height: 6px; box-shadow: 0 0 5px var(--cyan); }
    .footer-links { display: flex; gap: 1.75rem; }
    .footer-links a { font-size: 0.8rem; color: var(--dim); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text); }
    .footer-copy { font-size: 0.75rem; color: var(--dim); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 700px) {
      nav { padding: 0 1.25rem; }
      .nav-links { display: none; }
      .hero { padding: 5rem 1.25rem 4rem; }
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/spectre" class="logo">
      <span class="logo-dot"></span>
      Spectre
    </a>
    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="/spectre#features">Features</a></li>
        <li><a href="/spectre#download">Download</a></li>
        <li><a href="/spectre#privacy-policy">Privacy</a></li>
      </ul>
      <a href="https://github.com/koelss/Spectre" target="_blank" rel="noopener" class="nav-gh">
        ↗ GitHub
      </a>
    </div>
  </nav>

  <main>

    <section class="hero">
      <div class="hero-glow"></div>
      <div class="badge">open source only</div>
      <h1>The <span class="accent">Extension</span> Store</h1>
      <p class="hero-sub">
        Every extension here is open source, vetted, and downloaded directly
        from the developer — no Google, no middlemen, no telemetry.
      </p>

      <div class="filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="Privacy">Privacy</button>
        <button class="filter-btn" data-filter="Security">Security</button>
        <button class="filter-btn" data-filter="Productivity">Productivity</button>
        <button class="filter-btn" data-filter="Appearance">Appearance</button>
      </div>
    </section>

    <div class="store">
      <div class="grid" id="grid">

        <div class="ext-card" data-category="Privacy" data-repo="gorhill/uBlock" data-asset="chromium.zip">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/ublock-origin.svg" alt="uBlock Origin" /></div>
            <div class="ext-meta">
              <div class="ext-name">uBlock Origin</div>
              <span class="ext-tag tag-Privacy">Privacy</span>
            </div>
          </div>
          <p class="ext-desc">The most effective ad and tracker blocker available. Lightweight, wide-spectrum, and completely open. Already bundled with Spectre.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/gorhill/uBlock/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/gorhill/uBlock" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Privacy" data-repo="ClearURLs/Addon" data-asset=".zip">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/clearurls.svg" alt="ClearURLs" /></div>
            <div class="ext-meta">
              <div class="ext-name">ClearURLs</div>
              <span class="ext-tag tag-Privacy">Privacy</span>
            </div>
          </div>
          <p class="ext-desc">Automatically strips tracking parameters from URLs — UTM tags, fbclid, gclid, and hundreds more — before they ever reach the server.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/ClearURLs/Addon/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/ClearURLs/Addon" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Privacy" data-repo="EFForg/privacybadger" data-asset=".zip">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/privacy-badger.png" alt="Privacy Badger" /></div>
            <div class="ext-meta">
              <div class="ext-name">Privacy Badger</div>
              <span class="ext-tag tag-Privacy">Privacy</span>
            </div>
          </div>
          <p class="ext-desc">Learns to block invisible trackers automatically by watching for cross-site tracking behaviour. Made by the EFF, not a filter list.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/EFForg/privacybadger/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/EFForg/privacybadger" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Privacy" data-repo="Cookie-AutoDelete/Cookie-AutoDelete" data-asset=".zip">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/cookie-autodelete.png" alt="Cookie AutoDelete" /></div>
            <div class="ext-meta">
              <div class="ext-name">Cookie AutoDelete</div>
              <span class="ext-tag tag-Privacy">Privacy</span>
            </div>
          </div>
          <p class="ext-desc">Automatically deletes cookies from closed tabs. Keep cookies only for sites you whitelist — everything else gets wiped instantly.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/Cookie-AutoDelete/Cookie-AutoDelete/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/Cookie-AutoDelete/Cookie-AutoDelete" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Security" data-repo="bitwarden/clients" data-asset="dist-chrome">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/bitwarden.png" alt="Bitwarden" /></div>
            <div class="ext-meta">
              <div class="ext-name">Bitwarden</div>
              <span class="ext-tag tag-Security">Security</span>
            </div>
          </div>
          <p class="ext-desc">Open-source password manager. Stores your credentials end-to-end encrypted in your own vault. Fills logins, generates strong passwords.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/bitwarden/clients/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/bitwarden/clients" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Security" data-repo="keepassxreboot/keepassxc-browser" data-asset="keepassxc-browser">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/keepassxc.svg" alt="KeePassXC-Browser" /></div>
            <div class="ext-meta">
              <div class="ext-name">KeePassXC-Browser</div>
              <span class="ext-tag tag-Security">Security</span>
            </div>
          </div>
          <p class="ext-desc">Connects Spectre to your local KeePassXC database. Credentials never leave your machine — everything stays offline and encrypted.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/keepassxreboot/keepassxc-browser/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/keepassxreboot/keepassxc-browser" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Productivity" data-repo="violentmonkey/violentmonkey" data-asset="chromium">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/violentmonkey.png" alt="Violentmonkey" /></div>
            <div class="ext-meta">
              <div class="ext-name">Violentmonkey</div>
              <span class="ext-tag tag-Productivity">Productivity</span>
            </div>
          </div>
          <p class="ext-desc">Open-source userscript manager. Run custom JavaScript on any website to modify, automate, or enhance pages however you want.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/violentmonkey/violentmonkey/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/violentmonkey/violentmonkey" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Productivity" data-repo="ajayyy/SponsorBlock" data-asset="ChromeExtension">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/sponsorblock.png" alt="SponsorBlock" /></div>
            <div class="ext-meta">
              <div class="ext-name">SponsorBlock</div>
              <span class="ext-tag tag-Productivity">Productivity</span>
            </div>
          </div>
          <p class="ext-desc">Automatically skips sponsor segments, intros, outros, and self-promotion in YouTube videos using a community-driven database.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/ajayyy/SponsorBlock/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/ajayyy/SponsorBlock" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Productivity" data-repo="gildas-lormeau/SingleFile" data-asset="chromium">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/singlefile.png" alt="SingleFile" /></div>
            <div class="ext-meta">
              <div class="ext-name">SingleFile</div>
              <span class="ext-tag tag-Productivity">Productivity</span>
            </div>
          </div>
          <p class="ext-desc">Save a complete web page — including images, CSS, and fonts — into a single self-contained HTML file. Works offline, no account needed.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/gildas-lormeau/SingleFile/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/gildas-lormeau/SingleFile" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Productivity" data-repo="Anarios/return-youtube-dislike" data-asset=".zip">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/return-yt-dislike.png" alt="Return YouTube Dislike" /></div>
            <div class="ext-meta">
              <div class="ext-name">Return YouTube Dislike</div>
              <span class="ext-tag tag-Productivity">Productivity</span>
            </div>
          </div>
          <p class="ext-desc">Brings back the YouTube dislike count using a crowdsourced database. See how many people actually disliked a video before you watch it.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/Anarios/return-youtube-dislike/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/Anarios/return-youtube-dislike" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Appearance" data-repo="darkreader/darkreader" data-asset="chromium.zip">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/dark-reader.png" alt="Dark Reader" /></div>
            <div class="ext-meta">
              <div class="ext-name">Dark Reader</div>
              <span class="ext-tag tag-Appearance">Appearance</span>
            </div>
          </div>
          <p class="ext-desc">Enables dark mode on every website. Fully customisable brightness, contrast, and sepia filters — no eyestrain, no white flash.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/darkreader/darkreader/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/darkreader/darkreader" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

        <div class="ext-card" data-category="Appearance" data-repo="openstyles/stylus" data-asset="chromium">
          <div class="ext-header">
            <div class="ext-icon"><img src="/extensions/stylus.png" alt="Stylus" /></div>
            <div class="ext-meta">
              <div class="ext-name">Stylus</div>
              <span class="ext-tag tag-Appearance">Appearance</span>
            </div>
          </div>
          <p class="ext-desc">Install custom CSS themes for any website. Thousands of user styles on userstyles.world — restyle Reddit, Twitter, GitHub, or anything.</p>
          <div class="ext-actions">
            <button class="btn-install" data-fallback="https://github.com/openstyles/stylus/releases/latest">↓ Download</button>
            <a class="btn-source" href="https://github.com/openstyles/stylus" target="_blank" rel="noopener">Source</a>
          </div>
        </div>

      </div>
    </div>

    <!-- ─── HOW TO INSTALL ─── -->
    <section class="install-section">
      <div class="install-inner">
        <span class="section-tag">How to install</span>
        <h2>Installing an extension in Spectre</h2>

        <div class="steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-body">
              <strong>Download the extension</strong> — click <code>↓ Download</code> on any card above. On the GitHub releases page, grab the file ending in <code>.zip</code> or <code>.crx</code> (look for "chromium" in the filename).
            </div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-body">
              <strong>Extract the zip</strong> — unzip it into a permanent folder somewhere on your computer. Don't delete the folder after installing — Spectre needs it to stay there.
            </div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-body">
              <strong>Open Extensions in Spectre</strong> — click the <code>⋮</code> menu in the top right, then <code>Extensions</code>.
            </div>
          </div>
          <div class="step">
            <div class="step-num">4</div>
            <div class="step-body">
              <strong>Install unpacked</strong> — click <code>Install unpacked</code> and select the folder you extracted in step 2. The extension will load immediately and persist across restarts.
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <div class="footer-outer">
    <footer>
      <a href="/spectre" class="footer-logo">
        <span class="logo-dot"></span>
        Spectre
      </a>
      <div class="footer-links">
        <a href="https://github.com/koelss/Spectre" target="_blank" rel="noopener">GitHub</a>
        <a href="/spectre#privacy-policy">Privacy Policy</a>
        <a href="/spectre#download">Download</a>
      </div>
      <span class="footer-copy">Open source only. No Chrome Web Store required.</span>
    </footer>
  </div>

  <script>
    // ── Filters ──
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'))
        btn.classList.add('active')
        const filter = btn.dataset.filter
        document.querySelectorAll('.ext-card').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none'
        })
      })
    })

    // ── One-click install (only active when running inside Spectre) ──
    const inSpectre = typeof window.spectreStore !== 'undefined' && window.spectreStore.isSpectre

    async function initCards() {
      let installed = {}
      if (inSpectre && window.spectreSettings?.installedExtRepos) {
        try { installed = await window.spectreSettings.installedExtRepos() } catch {}
      }

      document.querySelectorAll('.ext-card').forEach(card => {
        const btn = card.querySelector('.btn-install')
        const repo = card.dataset.repo
        const asset = card.dataset.asset
        const fallback = btn.dataset.fallback

        if (inSpectre && repo && asset) {
          if (installed[repo]) {
            btn.classList.add('installed')
            btn.textContent = '✓ Installed'
          } else {
            btn.textContent = '⚡ Add to Spectre'
          }

          btn.addEventListener('click', async () => {
            if (btn.classList.contains('installed') || btn.classList.contains('loading')) return
            btn.classList.add('loading')
            btn.innerHTML = '<span class="spinner">↻</span> Installing…'
            try {
              const result = await window.spectreStore.installExtension(repo, asset)
              if (result.success) {
                btn.classList.remove('loading')
                btn.classList.add('installed')
                btn.textContent = '✓ Installed'
              } else {
                throw new Error(result.error)
              }
            } catch (err) {
              btn.classList.remove('loading')
              btn.classList.add('error')
              btn.textContent = '✕ Failed — click to retry'
              btn.addEventListener('click', () => {
                btn.classList.remove('error')
                btn.textContent = '⚡ Add to Spectre'
              }, { once: true })
              console.error('Install failed:', err.message)
            }
          })
        } else {
          btn.addEventListener('click', () => window.open(fallback, '_blank'))
        }
      })
    }

    initCards()
  </script>

</body>
</html>
