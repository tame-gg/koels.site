// Init
const grid = document.getElementById('modGrid');
const searchInput = document.getElementById('searchInput');
const pills = document.querySelectorAll('.pill');
const visCountEl = document.getElementById('visCount');
const totalCountEl = document.getElementById('totalCount');
const emptyState = document.getElementById('emptyState');
const statTotal = document.getElementById('statTotal');

let activeFilter = 'all';

const CAT_LABEL = {
  performance:'Perf', world:'World', content:'Content',
  visual:'Visual', qol:'QoL', library:'Library'
};

function buildCards() {
  MODS.forEach((mod, i) => {
    const row = document.createElement('div');
    row.className = 'mod-card';
    row.dataset.cat = mod.cat;
    row.dataset.name = mod.name.toLowerCase();
    row.dataset.author = mod.author.toLowerCase();
    row.dataset.desc = mod.desc.toLowerCase();
    row.style.animationDelay = (i * 8) + 'ms';
    row.innerHTML = `
      <div class="row-index">${String(i + 1).padStart(2, '0')}</div>
      <div class="row-main">
        <div class="row-top">
          <span class="mod-name">${mod.name}</span>
          <span class="cat-badge">${CAT_LABEL[mod.cat] || mod.cat}</span>
          <span class="mod-author">by <span>${mod.author}</span></span>
        </div>
        <div class="mod-desc">${mod.desc}</div>
      </div>
      <div class="row-right">
        <a class="cf-link" href="${mod.url}" target="_blank" rel="noopener">CurseForge</a>
      </div>
    `;
    grid.appendChild(row);
  });
}

function filterCards() {
  const q = searchInput.value.toLowerCase().trim();
  const cards = grid.querySelectorAll('.mod-card');
  let visible = 0;
  let rowNum = 0;
  cards.forEach(card => {
    const matchCat = activeFilter === 'all' || card.dataset.cat === activeFilter;
    const matchSearch = !q || card.dataset.name.includes(q) || card.dataset.author.includes(q) || card.dataset.desc.includes(q);
    const show = matchCat && matchSearch;
    card.classList.toggle('hidden', !show);
    if (show) {
      rowNum++;
      const idx = card.querySelector('.row-index');
      if (idx) idx.textContent = String(rowNum).padStart(2, '0');
      visible++;
    }
  });
  visCountEl.textContent = visible;
  emptyState.classList.toggle('show', visible === 0);
}

function updateStats() {
  statTotal.textContent = MODS.length;
  totalCountEl.textContent = MODS.length;
  visCountEl.textContent = MODS.length;
}

pills.forEach(pill => {
  pill.addEventListener('click', () => {
    pills.forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    activeFilter = pill.dataset.cat;
    filterCards();
  });
});

searchInput.addEventListener('input', filterCards);

buildCards();
updateStats();
</script>
