// Init
const grid = document.getElementById('modGrid');
const searchInput = document.getElementById('searchInput');
const pills = document.querySelectorAll('.pill');
const visCountEl = document.getElementById('visCount');
const totalCountEl = document.getElementById('totalCount');
const emptyState = document.getElementById('emptyState');
const statTotal = document.getElementById('statTotal');

let activeFilter = 'all';

const CAT_LABEL = {
  performance:'Perf', world:'World', content:'Content',
  visual:'Visual', qol:'QoL', library:'Library'
};

function buildCards() {
  MODS.forEach((mod, i) => {
    const card = document.createElement('div');
    card.className = 'mod-card';
    card.dataset.cat = mod.cat;
    card.dataset.name = mod.name.toLowerCase();
    card.dataset.author = mod.author.toLowerCase();
    card.dataset.desc = mod.desc.toLowerCase();
    card.style.animationDelay = (i * 15) + 'ms';
    card.innerHTML = `
      <div class="card-top-bar"></div>
      <div class="card-body">
        <div class="card-head">
          <div class="mod-name">${mod.name}</div>
          <div class="cat-badge">${CAT_LABEL[mod.cat] || mod.cat}</div>
        </div>
        <div class="mod-author">by <span>${mod.author}</span></div>
        <div class="mod-desc">${mod.desc}</div>
        <div class="card-footer">
          <a class="cf-link" href="${mod.url}" target="_blank" rel="noopener">CurseForge</a>
        </div>
      </div>
    `;
    grid.appendChild(card);
  });
}

function filterCards() {
  const q = searchInput.value.toLowerCase().trim();
  const cards = grid.querySelectorAll('.mod-card');
  let visible = 0;
  cards.forEach(card => {
    const matchCat = activeFilter === 'all' || card.dataset.cat === activeFilter;
    const matchSearch = !q || card.dataset.name.includes(q) || card.dataset.author.includes(q) || card.dataset.desc.includes(q);
    const show = matchCat && matchSearch;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  visCountEl.textContent = visible;
  emptyState.classList.toggle('show', visible === 0);
}

function updateStats() {
  statTotal.textContent = MODS.length;
  totalCountEl.textContent = MODS.length;
  visCountEl.textContent = MODS.length;
}

pills.forEach(pill => {
  pill.addEventListener('click', () => {
    pills.forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    activeFilter = pill.dataset.cat;
    filterCards();
  });
});

searchInput.addEventListener('input', filterCards);

buildCards();
updateStats();
</script>
</body>
</html>
