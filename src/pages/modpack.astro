---
// src/pages/modpack.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>koels.site — Modpack</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2303030a'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23a29bfe'/%3E%3Cstop offset='100%25' stop-color='%236c5ce7'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:       #03030a;
  --bg2:      #08080f;
  --surface:  #0f0f1a;
  --surface2: #141420;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text:     #f0eeff;
  --muted:    rgba(240,238,255,0.68);
  --dim:      rgba(240,238,255,0.4);
  --accent:   #6c5ce7;
  --accent2:  #a29bfe;
  --lime:     #00ff88;
  --red:      #ff4757;
  --amber:    #ffa502;
  --cyan:     #00d2d3;
  --white:    #ffffff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:16px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

/* ── NOISE ── */
body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:58px; display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid rgba(0,120,200,0.14);
  background:rgba(2,8,16,0.72);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:#e8f8ff;
  display:flex; align-items:center; gap:10px;
}
.logo a { color:inherit }
.logo-pulse {
  width:6px; height:6px; border-radius:50%;
  background:#00ffcc; box-shadow:0 0 10px #00ffcc;
  animation:lg-pulse 2s ease infinite;
}
@keyframes lg-pulse { 0%,100%{box-shadow:0 0 6px #00ffcc} 50%{box-shadow:0 0 20px #00ffcc,0 0 40px rgba(0,255,204,0.2)} }

.nav { display:flex; align-items:center; gap:28px }
.nav a {
  font-family:var(--mono); font-size:0.7rem; letter-spacing:0.14em;
  color:rgba(200,240,255,0.5); text-transform:uppercase; transition:color 0.2s;
}
.nav a:hover { color:#e8f8ff }
.nav a.active { color:#40c8ff }

/* ── HERO ── */
.hero {
  padding: 120px 40px 60px;
  max-width: 1100px;
  margin: 0 auto;
  position: relative;
}
.hero::before {
  content:''; position:absolute; top:0; left:0; right:0; height:340px;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 80% 100% at 50% 0%, black 0%, transparent 80%);
  -webkit-mask-image:radial-gradient(ellipse 80% 100% at 50% 0%, black 0%, transparent 80%);
  opacity:0.45; pointer-events:none;
}
.hero-glow {
  position:absolute; top:-60px; left:50%;
  transform:translateX(-50%);
  width:600px; height:400px;
  background:radial-gradient(ellipse, rgba(108,92,231,0.1) 0%, transparent 70%);
  pointer-events:none;
}
.hero-inner { position:relative; z-index:1; animation:fade-up 0.8s var(--ease) both }
@keyframes fade-up { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }

.eyebrow {
  display:inline-flex; align-items:center; gap:10px; margin-bottom:20px;
  font-family:var(--mono); font-size:0.68rem; font-weight:500;
  letter-spacing:0.22em; text-transform:uppercase; color:var(--accent2);
}
.eyebrow-line { width:24px; height:1px; background:var(--accent) }

h1 {
  font-size:clamp(2.4rem,5vw,4.2rem);
  font-weight:900; line-height:0.92; letter-spacing:-0.04em;
  color:var(--white); margin-bottom:20px;
}
h1 .grad {
  background:linear-gradient(135deg, var(--accent2) 0%, #c084fc 50%, var(--accent2) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 4s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }

.hero-sub {
  font-family:var(--mono); font-size:0.8rem; color:var(--muted);
  letter-spacing:0.05em; margin-bottom:36px;
  max-width:520px; line-height:1.6;
}

/* Stats bar */
.stats-bar {
  display:flex; gap:28px; flex-wrap:wrap;
  padding:18px 0; border-top:1px solid var(--border); border-bottom:1px solid var(--border);
  margin-bottom:40px;
}
.stat { display:flex; flex-direction:column; gap:3px }
.stat-val {
  font-family:var(--mono); font-size:1.35rem; font-weight:700;
  color:var(--white); letter-spacing:-0.02em;
}
.stat-val .unit { font-size:0.65rem; font-weight:400; color:var(--accent2); margin-left:2px }
.stat-label {
  font-family:var(--mono); font-size:0.58rem; letter-spacing:0.18em;
  text-transform:uppercase; color:var(--dim);
}

/* ── SEARCH + FILTER ── */
.controls {
  max-width:1100px; margin:0 auto 32px;
  padding:0 40px;
  display:flex; gap:12px; align-items:center; flex-wrap:wrap;
}
.search-wrap {
  flex:1; min-width:220px;
  display:flex; align-items:center;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:8px; overflow:hidden;
  transition:border-color 0.2s, box-shadow 0.2s;
}
.search-wrap:focus-within {
  border-color:var(--accent);
  box-shadow:0 0 0 3px rgba(108,92,231,0.15);
}
.search-icon {
  padding:0 12px; color:var(--dim);
  font-family:var(--mono); font-size:0.75rem;
  user-select:none;
}
.search-wrap input {
  flex:1; padding:10px 12px 10px 0; border:none; outline:none;
  background:transparent; color:var(--text);
  font-family:var(--mono); font-size:0.8rem;
}
.search-wrap input::placeholder { color:var(--dim) }

.filter-pills { display:flex; gap:8px; flex-wrap:wrap }
.pill {
  padding:7px 14px; border-radius:6px;
  border:1px solid var(--border2);
  background:var(--surface);
  font-family:var(--mono); font-size:0.62rem; font-weight:600;
  letter-spacing:0.12em; text-transform:uppercase;
  cursor:pointer; transition:all 0.18s;
  color:var(--muted);
}
.pill:hover { border-color:var(--accent2); color:var(--accent2) }
.pill.active {
  background:rgba(108,92,231,0.15);
  border-color:var(--accent);
  color:var(--accent2);
}
.pill[data-cat="performance"].active { background:rgba(0,255,136,0.1); border-color:var(--lime); color:var(--lime) }
.pill[data-cat="world"].active { background:rgba(0,210,211,0.1); border-color:var(--cyan); color:var(--cyan) }
.pill[data-cat="content"].active { background:rgba(255,165,2,0.1); border-color:var(--amber); color:var(--amber) }
.pill[data-cat="visual"].active { background:rgba(162,155,254,0.12); border-color:var(--accent2); color:var(--accent2) }
.pill[data-cat="library"].active { background:rgba(240,238,255,0.06); border-color:rgba(240,238,255,0.3); color:var(--muted) }
.pill[data-cat="qol"].active { background:rgba(255,71,87,0.1); border-color:var(--red); color:var(--red) }



/* ── LIST ── */
.grid-wrap { max-width:860px; margin:0 auto; padding:0 40px 80px; position:relative; }
.mod-count {
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--dim); margin-bottom:20px;
}
.mod-count span { color:var(--accent2) }

.mod-grid { display:flex; flex-direction:column; gap:0; }

/* MOD ROW */
.mod-card {
  display:flex; align-items:baseline; gap:16px;
  padding:13px 0;
  border-bottom:1px solid var(--border);
  animation:row-in 0.3s var(--ease) both;
  transition:background 0.15s;
  position:relative;
}
.mod-card:first-child { border-top:1px solid var(--border) }
@keyframes row-in { from{opacity:0;transform:translateX(-6px)} to{opacity:1;transform:translateX(0)} }
.mod-card.hidden { display:none }

/* left accent bar */
.mod-card::before {
  content:''; position:absolute; left:0; top:50%; transform:translateY(-50%);
  width:2px; height:0; border-radius:2px;
  transition:height 0.2s var(--ease), opacity 0.2s;
  opacity:0;
}
.mod-card:hover::before { height:60%; opacity:1 }
.mod-card[data-cat="performance"]::before { background:var(--lime) }
.mod-card[data-cat="world"]::before       { background:var(--cyan) }
.mod-card[data-cat="content"]::before     { background:var(--amber) }
.mod-card[data-cat="visual"]::before      { background:var(--accent2) }
.mod-card[data-cat="library"]::before     { background:rgba(255,255,255,0.25) }
.mod-card[data-cat="qol"]::before         { background:var(--red) }

.row-index {
  font-family:var(--mono); font-size:0.6rem; color:var(--dim);
  width:28px; flex-shrink:0; text-align:right; line-height:1;
  padding-top:2px;
}

.row-main { flex:1; min-width:0; }

.row-top { display:flex; align-items:center; gap:10px; margin-bottom:3px; flex-wrap:wrap; }

.mod-name {
  font-size:0.88rem; font-weight:700; color:var(--white);
}

.cat-badge {
  font-family:var(--mono); font-size:0.5rem; font-weight:700;
  letter-spacing:0.14em; text-transform:uppercase;
  padding:2px 6px; border-radius:3px; white-space:nowrap; flex-shrink:0;
}
[data-cat="performance"] .cat-badge { background:rgba(0,255,136,0.12); color:var(--lime); border:1px solid rgba(0,255,136,0.2) }
[data-cat="world"]       .cat-badge { background:rgba(0,210,211,0.12); color:var(--cyan); border:1px solid rgba(0,210,211,0.2) }
[data-cat="content"]     .cat-badge { background:rgba(255,165,2,0.12); color:var(--amber); border:1px solid rgba(255,165,2,0.2) }
[data-cat="visual"]      .cat-badge { background:rgba(162,155,254,0.12); color:var(--accent2); border:1px solid rgba(162,155,254,0.2) }
[data-cat="library"]     .cat-badge { background:rgba(255,255,255,0.07); color:var(--muted); border:1px solid var(--border2) }
[data-cat="qol"]         .cat-badge { background:rgba(255,71,87,0.12); color:var(--red); border:1px solid rgba(255,71,87,0.2) }

.mod-author {
  font-family:var(--mono); font-size:0.6rem; color:var(--dim); letter-spacing:0.06em;
}
.mod-author span { color:var(--accent2) }

.mod-desc {
  font-size:0.78rem; color:var(--muted); line-height:1.5; margin-top:4px;
}

.row-right {
  flex-shrink:0; display:flex; align-items:center;
}
.cf-link {
  font-family:var(--mono); font-size:0.55rem; font-weight:600;
  letter-spacing:0.12em; text-transform:uppercase;
  color:var(--dim); transition:color 0.2s;
  display:flex; align-items:center; gap:4px;
  white-space:nowrap;
}
.cf-link:hover { color:var(--accent2) }
.cf-link::after { content:'↗'; font-size:0.6rem }

/* ── EMPTY STATE ── */
.empty-state {
  display:none; text-align:center; padding:64px 24px;
}
.empty-state.show { display:block }
.empty-icon { font-size:2.2rem; margin-bottom:14px; opacity:0.5 }
.empty-msg { font-family:var(--mono); font-size:0.75rem; color:var(--dim); letter-spacing:0.06em }

/* ── FOOTER ── */
footer {
  border-top:1px solid var(--border);
  padding:24px 40px;
  display:flex; justify-content:space-between; align-items:center; gap:20px; flex-wrap:wrap;
}
.footer-left { font-family:var(--mono); font-size:0.6rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--dim) }
.footer-right { display:flex; gap:20px; align-items:center }
.footer-right a { font-family:var(--mono); font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim); transition:color 0.2s }
.footer-right a:hover { color:var(--muted) }

@media (max-width:600px) {
  header { padding:0 20px }
  .hero, .controls, .grid-wrap { padding-left:20px; padding-right:20px }
  .stats-bar { gap:18px }
  .row-index { display:none }
  .row-right { display:none }
}
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-pulse"></div>
    <a href="/">koels.site</a>
  </div>
  <nav class="nav">
    <a href="/modpack" class="active">Modpack</a>
    <a href="/links">Links</a>
  </nav>
</header>

<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div class="eyebrow">
      <span class="eyebrow-line"></span>
      <span>NeoForge · 1.21.x</span>
    </div>
    <h1>My <span class="grad">Modpack</span></h1>
    <p class="hero-sub">A curated collection of mods for exploration, performance, and vibes.<br>All on NeoForge.</p>
    <a href="https://discord.gg/7VdjWMMtSc" target="_blank" rel="noopener" style="
      display:inline-flex;align-items:center;gap:10px;
      margin-bottom:32px;
      padding:11px 22px;border-radius:8px;
      background:rgba(88,101,242,0.12);border:1px solid rgba(88,101,242,0.35);
      font-family:var(--mono);font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
      color:#8ea1f7;text-decoration:none;
      transition:background 0.2s,border-color 0.2s,transform 0.15s;
    " onmouseover="this.style.background='rgba(88,101,242,0.22)';this.style.borderColor='rgba(88,101,242,0.6)';this.style.transform='translateY(-2px)'"
       onmouseout="this.style.background='rgba(88,101,242,0.12)';this.style.borderColor='rgba(88,101,242,0.35)';this.style.transform='translateY(0)'">
      <svg width="18" height="14" viewBox="0 0 71 55" fill="#8ea1f7" xmlns="http://www.w3.org/2000/svg"><path d="M60.1 4.9A58.6 58.6 0 0 0 45.7.9a.2.2 0 0 0-.2.1 40.8 40.8 0 0 0-1.8 3.7 54.1 54.1 0 0 0-16.2 0A37.7 37.7 0 0 0 25.6 1a.2.2 0 0 0-.2-.1A58.4 58.4 0 0 0 11 4.9a.2.2 0 0 0-.1.1C1.6 18.7-1 32.2.3 45.5a.2.2 0 0 0 .1.2 58.9 58.9 0 0 0 17.7 8.9.2.2 0 0 0 .2-.1 42 42 0 0 0 3.6-5.9.2.2 0 0 0-.1-.3 38.7 38.7 0 0 1-5.5-2.6.2.2 0 0 1 0-.4c.4-.3.7-.6 1.1-.8a.2.2 0 0 1 .2 0c11.5 5.3 24 5.3 35.4 0a.2.2 0 0 1 .2 0l1.1.9a.2.2 0 0 1 0 .3 36 36 0 0 1-5.5 2.6.2.2 0 0 0-.1.3c1 2 2.3 4 3.6 5.9a.2.2 0 0 0 .2.1 58.7 58.7 0 0 0 17.8-8.9.2.2 0 0 0 .1-.2c1.5-15.5-2.5-29-10.6-40.5a.2.2 0 0 0-.1-.1ZM23.7 37.5c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2c3.6 0 6.5 3.3 6.4 7.2 0 4-2.8 7.2-6.4 7.2Zm23.6 0c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2c3.6 0 6.5 3.3 6.4 7.2 0 4-2.8 7.2-6.4 7.2Z"/></svg>
      Join the Discord
    </a>
    <div class="stats-bar">
      <div class="stat">
        <div class="stat-val" id="statTotal">—</div>
        <div class="stat-label">Total Mods</div>
      </div>
      <div class="stat">
        <div class="stat-val"><span class="unit" style="font-size:1rem;margin:0"></span>6<span class="unit">perf</span></div>
        <div class="stat-label">Performance</div>
      </div>
      <div class="stat">
        <div class="stat-val">4<span class="unit">shaders</span></div>
        <div class="stat-label">Shader Packs</div>
      </div>
      <div class="stat">
        <div class="stat-val"><span style="color:var(--amber)">●</span></div>
        <div class="stat-label">NeoForge</div>
      </div>
    </div>
  </div>
</section>

<div class="controls">
  <div class="search-wrap">
    <span class="search-icon">/</span>
    <input type="text" id="searchInput" placeholder="search mods..." autocomplete="off" />
  </div>
  <div class="filter-pills">
    <button class="pill active" data-cat="all">All</button>
    <button class="pill" data-cat="performance">Perf</button>
    <button class="pill" data-cat="world">World</button>
    <button class="pill" data-cat="content">Content</button>
    <button class="pill" data-cat="visual">Visual</button>
    <button class="pill" data-cat="qol">QoL</button>
    <button class="pill" data-cat="library">Library</button>
  </div>
</div>

<div class="grid-wrap">
  <div class="mod-count">Showing <span id="visCount">—</span> of <span id="totalCount">—</span> mods</div>
  <div class="mod-grid" id="modGrid">
    <div class="empty-state" id="emptyState">
      <div class="empty-icon">◌</div>
      <div class="empty-msg">No mods match your search</div>
    </div>
  </div>
</div>

<footer>
  <div class="footer-left">koels.site · modpack</div>
  <div class="footer-right">
    <a href="https://modrinth.com" target="_blank" rel="noopener">Modrinth</a>
    <a href="https://curseforge.com" target="_blank" rel="noopener">CurseForge</a>
    <a href="https://neoforged.net" target="_blank" rel="noopener">NeoForge</a>
  </div>
</footer>


<script>
const MODS = [
  // ── PERFORMANCE ──
  { name:"Sodium", author:"JellySquid", cat:"performance", desc:"The gold standard rendering engine replacement. Massively boosts FPS by optimizing chunk rendering and reducing GPU/CPU overhead.", url:"https://www.curseforge.com/minecraft/mc-mods/sodium" },
  { name:"Lithium", author:"JellySquid", cat:"performance", desc:"Server-side and single-player optimizations for game logic — ticking, AI, physics, and chunk management — with no gameplay changes.", url:"https://www.curseforge.com/minecraft/mc-mods/lithium" },
  { name:"FerriteCore", author:"malte0811", cat:"performance", desc:"Dramatically reduces RAM usage by deduplicating blockstate memory. Essential for large modpacks to avoid out-of-memory crashes.", url:"https://www.curseforge.com/minecraft/mc-mods/ferritecore" },
  { name:"ModernFix", author:"embeddedt", cat:"performance", desc:"An all-in-one mod that reduces startup time, memory usage, and lag spikes through dozens of micro-optimizations.", url:"https://www.curseforge.com/minecraft/mc-mods/modernfix" },
  { name:"FastBoot", author:"dnlayu", cat:"performance", desc:"Parallelizes resource loading during game startup so you get to the main menu faster.", url:"https://www.curseforge.com/minecraft/mc-mods/fastboot" },
  { name:"Dynamic FPS", author:"juliand665", cat:"performance", desc:"Drops render speed to 1fps when the game window is unfocused, saving CPU/GPU power while you alt-tab.", url:"https://www.curseforge.com/minecraft/mc-mods/dynamic-fps" },
  { name:"BadOptimizations", author:"thosea", cat:"performance", desc:"A collection of small client-side tweaks that individually seem minor but together give a noticeable FPS boost.", url:"https://www.curseforge.com/minecraft/mc-mods/badoptimizations" },
  { name:"ImmediatelyFast", author:"RaphiMC", cat:"performance", desc:"Optimizes immediate mode rendering (HUD, GUI, entities) that Sodium doesn't touch, giving extra FPS in complex scenes.", url:"https://www.curseforge.com/minecraft/mc-mods/immediatelyfast" },
  { name:"AI Improvements", author:"QueenOfMissiles", cat:"performance", desc:"Overhauls mob AI scheduling so entities further from players tick less aggressively, reducing server load.", url:"https://www.curseforge.com/minecraft/mc-mods/ai-improvements" },
  { name:"Chloride (Embeddium++)", author:"SrRapero720", cat:"performance", desc:"Extra Sodium/Embeddium graphical options and performance tweaks not present in the base mod.", url:"https://www.curseforge.com/minecraft/mc-mods/chloride" },
