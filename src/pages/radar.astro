---
// src/pages/radar.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>koels.site — Radar</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%2303030a'/%3E%3Ccircle cx='16' cy='16' r='13' fill='none' stroke='%236c5ce7' stroke-width='0.8' opacity='0.4'/%3E%3Ccircle cx='16' cy='16' r='9' fill='none' stroke='%236c5ce7' stroke-width='0.8' opacity='0.5'/%3E%3Ccircle cx='16' cy='16' r='5' fill='none' stroke='%236c5ce7' stroke-width='0.8' opacity='0.7'/%3E%3Ccircle cx='16' cy='16' r='2' fill='%23a29bfe'/%3E%3Cline x1='16' y1='16' x2='27' y2='7' stroke='%23a29bfe' stroke-width='1.5' stroke-linecap='round'/%3E%3Ccircle cx='24' cy='9' r='2' fill='%2300ff88'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; overflow:hidden; font-family:"JetBrains Mono",monospace; }
body { background:#03030a; color:#f0eeff; }
#map { position:fixed; inset:0; z-index:1; }

/* HEADER */
#header {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  height:54px; display:flex; align-items:center; justify-content:space-between;
  padding:0 20px;
  background:rgba(3,3,10,0.92); border-bottom:1px solid rgba(255,255,255,0.07);
  backdrop-filter:blur(20px);
}
.header-left { display:flex; align-items:center; gap:14px; }
.back-btn {
  display:flex; align-items:center; gap:5px;
  font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase;
  color:rgba(240,238,255,0.4); text-decoration:none; transition:color 0.2s;
}
.back-btn:hover { color:#f0eeff; }
.back-btn svg { width:13px; height:13px; fill:currentColor; }
.hdiv { width:1px; height:16px; background:rgba(255,255,255,0.1); }
.radar-logo { display:flex; align-items:center; gap:9px; }
.radar-logo-icon { width:30px; height:30px; flex-shrink:0; }
.radar-logo-icon svg { width:100%; height:100%; }
.radar-logo-main { font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#f0eeff; line-height:1; }
.radar-logo-sub  { font-size:0.52rem; letter-spacing:0.14em; text-transform:uppercase; color:rgba(240,238,255,0.35); line-height:1; margin-top:2px; }
.header-right { display:flex; align-items:center; gap:12px; }
.alert-pill {
  display:flex; align-items:center; gap:5px; padding:4px 11px; border-radius:999px;
  font-size:0.58rem; letter-spacing:0.1em; text-transform:uppercase;
  border:1px solid rgba(255,71,87,0.3); background:rgba(255,71,87,0.08); color:#ff4757;
}
.alert-pill.none { border-color:rgba(255,255,255,0.08); background:transparent; color:rgba(240,238,255,0.3); }
.alert-pill svg { width:9px; height:9px; fill:currentColor; }
#last-updated { font-size:0.56rem; color:rgba(240,238,255,0.28); letter-spacing:0.08em; }

/* ALERTS PANEL */
#panel {
  position:fixed; top:54px; right:0; bottom:0; z-index:900; width:290px;
  background:rgba(3,3,10,0.95); border-left:1px solid rgba(255,255,255,0.06);
  backdrop-filter:blur(20px);
  display:flex; flex-direction:column;
  transform:translateX(100%); transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
}
#panel.open { transform:translateX(0); }
#panel-toggle {
  position:fixed; top:50%; right:0; z-index:950; transform:translateY(-50%);
  width:22px; height:52px;
  background:rgba(3,3,10,0.88); border:1px solid rgba(255,255,255,0.08); border-right:none;
  border-radius:6px 0 0 6px; display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.2s;
  opacity:0; pointer-events:none;
}
#panel-toggle.has-alerts { opacity:0.55; pointer-events:auto; }
#panel-toggle.has-alerts:hover { background:rgba(108,92,231,0.25); opacity:1; }
#panel-toggle svg { width:11px; height:11px; fill:rgba(240,238,255,0.6); transition:transform 0.3s; }
#panel.open ~ #panel-toggle { right:290px; opacity:1 !important; pointer-events:auto; }
#panel.open ~ #panel-toggle svg { transform:rotate(180deg); }
.panel-header {
  padding:14px 14px 10px; border-bottom:1px solid rgba(255,255,255,0.06);
  font-size:0.58rem; letter-spacing:0.14em; text-transform:uppercase;
  color:rgba(240,238,255,0.4); display:flex; align-items:center; justify-content:space-between;
}
.panel-header b { color:#ff4757; }
#alerts-list { flex:1; overflow-y:auto; padding:8px; scrollbar-width:thin; scrollbar-color:rgba(255,255,255,0.08) transparent; }
#alerts-list::-webkit-scrollbar { width:3px; }
#alerts-list::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:2px; }
.alert-item { padding:9px 12px; border-radius:7px; margin-bottom:5px; border:1px solid transparent; cursor:pointer; transition:all 0.18s; position:relative; overflow:hidden; }
.alert-item::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; }
.alert-item:hover { background:rgba(255,255,255,0.04) !important; }
.sev-extreme  { border-color:rgba(255,0,200,0.35);  background:rgba(255,0,200,0.07); }
.sev-extreme::before  { background:#ff00cc; }
.sev-severe   { border-color:rgba(255,45,45,0.3);  background:rgba(255,45,45,0.06); }
.sev-severe::before   { background:#ff2d2d; }
.sev-moderate { border-color:rgba(255,165,0,0.2);  background:rgba(255,165,0,0.05); }
.sev-moderate::before { background:#ffa500; }
.sev-minor    { border-color:rgba(255,214,0,0.2);  background:rgba(255,214,0,0.04); }
.sev-minor::before    { background:#ffd600; }
.sev-unknown  { border-color:rgba(255,255,255,0.08); background:rgba(255,255,255,0.02); }
.sev-unknown::before  { background:rgba(255,255,255,0.2); }
.alert-event { font-size:0.66rem; font-weight:700; color:#f0eeff; margin-bottom:2px; line-height:1.3; }
.alert-area  { font-size:0.57rem; color:rgba(240,238,255,0.42); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.alert-time  { font-size:0.52rem; color:rgba(240,238,255,0.22); margin-top:3px; }
.no-alerts   { padding:28px 14px; text-align:center; font-size:0.6rem; color:rgba(240,238,255,0.22); letter-spacing:0.08em; line-height:1.8; }

/* LEGEND */
#legend {
  position:fixed; bottom:128px; left:16px; z-index:900;
  background:rgba(3,3,10,0.88); border:1px solid rgba(255,255,255,0.07);
  border-radius:10px; padding:10px 12px;
  backdrop-filter:blur(16px);
}
.legend-title { font-size:0.52rem; letter-spacing:0.14em; text-transform:uppercase; color:rgba(240,238,255,0.3); margin-bottom:7px; }
.legend-items { display:flex; flex-direction:column; gap:4px; }
.legend-item { display:flex; align-items:center; gap:7px; }
.legend-dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.legend-label { font-size:0.56rem; color:rgba(240,238,255,0.45); }

/* TIMELINE */
#timeline {
  position:fixed; bottom:16px; left:50%; transform:translateX(-50%);
  z-index:900;
  background:rgba(3,3,10,0.92); border:1px solid rgba(255,255,255,0.09);
  border-radius:16px; padding:12px 18px 14px;
  backdrop-filter:blur(20px);
  width:min(540px, calc(100vw - 32px));
}
.tl-row1 {
  display:flex; align-items:center; gap:12px; margin-bottom:10px;
}
#play-btn {
  width:30px; height:30px; border-radius:50%; flex-shrink:0;
  background:rgba(108,92,231,0.2); border:1.5px solid rgba(108,92,231,0.5);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.18s;
}
#play-btn:hover { background:rgba(108,92,231,0.45); transform:scale(1.06); }
#play-btn svg { width:12px; height:12px; fill:#a29bfe; }
#time-display {
  flex:1; text-align:center;
  font-size:0.65rem; color:rgba(240,238,255,0.5); letter-spacing:0.05em;
}
#time-display .t-time { color:#f0eeff; font-weight:700; }
#time-display .t-sep  { color:rgba(240,238,255,0.2); margin:0 5px; }
#time-display .t-ago  { color:rgba(162,155,254,0.8); }
#time-display .t-pos  { color:rgba(240,238,255,0.25); font-size:0.55rem; }

/* Scrubber */
#scrubber-outer { position:relative; }
#scrubber-track {
  width:100%; height:5px; border-radius:999px;
  background:rgba(255,255,255,0.1); position:relative; cursor:pointer;
}
#scrubber-fill {
  height:100%; border-radius:999px;
  background:linear-gradient(90deg,#6c5ce7,#a29bfe);
  width:0%; pointer-events:none; transition:width 0.05s;
}
#scrubber-thumb {
  position:absolute; top:50%; left:0%;
  width:14px; height:14px; border-radius:50%;
  background:#a29bfe; border:2px solid #fff;
  box-shadow:0 0 8px rgba(162,155,254,0.7);
  transform:translate(-50%,-50%);
  pointer-events:none;
}
#scrubber-ticks {
  display:flex; justify-content:space-between;
  margin-top:8px; padding:0 1px;
}
.tick-label {
  font-size:0.5rem; color:rgba(240,238,255,0.3);
  font-family:"JetBrains Mono",monospace; letter-spacing:0;
  line-height:1;
}
.tick-label.is-now { color:#a29bfe; font-weight:700; }

/* status */
#radar-status {
  position:fixed; top:64px; left:50%; transform:translateX(-50%);
  z-index:1100; background:rgba(3,3,10,0.9); border:1px solid rgba(255,255,255,0.1);
  border-radius:8px; padding:6px 14px; font-size:0.58rem; color:rgba(240,238,255,0.6);
  letter-spacing:0.08em; pointer-events:none; opacity:0; transition:opacity 0.3s;
}
#radar-status.show { opacity:1; }

/* Leaflet overrides */
.leaflet-container { background:#03030a !important; }
.leaflet-tile-pane { filter:brightness(0.88) saturate(0.5); }
.leaflet-pane.radar-pane { filter:none !important; }
.leaflet-control-zoom a {
  background:rgba(3,3,10,0.9) !important; color:rgba(240,238,255,0.7) !important;
  border-color:rgba(255,255,255,0.1) !important; font-family:"JetBrains Mono",monospace !important;
}
.leaflet-control-zoom a:hover { background:rgba(108,92,231,0.3) !important; color:#fff !important; }
.leaflet-control-attribution {
  background:rgba(3,3,10,0.7) !important; color:rgba(240,238,255,0.2) !important;
  font-family:"JetBrains Mono",monospace !important; font-size:9px !important;
}
.leaflet-control-attribution a { color:rgba(162,155,254,0.5) !important; }
.alert-tooltip {
  background:rgba(3,3,10,0.95) !important; border:1px solid rgba(255,71,87,0.3) !important;
  border-radius:6px !important; color:#f0eeff !important;
  font-family:"JetBrains Mono",monospace !important; font-size:0.6rem !important;
  padding:7px 10px !important; box-shadow:0 4px 20px rgba(0,0,0,0.5) !important;
}
</style>
</head>
<body>

<div id="map"></div>
<div id="radar-status" id="radar-status">Loading radar…</div>

<div id="header">
  <div class="header-left">
    <a class="back-btn" href="/">
      <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      Back
    </a>
    <div class="hdiv"></div>
    <div class="radar-logo">
      <div class="radar-logo-icon">
        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
          <defs><radialGradient id="rg" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#a29bfe" stop-opacity="0.9"/>
            <stop offset="100%" stop-color="#6c5ce7" stop-opacity="0"/>
          </radialGradient></defs>
          <circle cx="16" cy="16" r="14" fill="none" stroke="rgba(108,92,231,0.2)" stroke-width="1"/>
          <circle cx="16" cy="16" r="10" fill="none" stroke="rgba(108,92,231,0.3)" stroke-width="1"/>
          <circle cx="16" cy="16" r="6"  fill="none" stroke="rgba(108,92,231,0.5)" stroke-width="1"/>
          <circle cx="16" cy="16" r="2"  fill="#a29bfe"/>
          <line x1="16" y1="16" x2="28" y2="6" stroke="url(#rg)" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="23" cy="9" r="1.8" fill="#00ff88" opacity="0.85">
            <animate attributeName="opacity" values="0.85;0.1;0.85" dur="1.8s" repeatCount="indefinite"/>
            <animate attributeName="r" values="1.8;2.4;1.8" dur="1.8s" repeatCount="indefinite"/>
          </circle>
        </svg>
      </div>
      <div>
        <div class="radar-logo-main">Radar</div>
        <div class="radar-logo-sub">koels.site</div>
      </div>
    </div>
  </div>
  <div class="header-right">
    <div class="alert-pill none" id="alert-pill">
      <svg viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z"/></svg>
      <span id="alert-num">0</span>&nbsp;Alerts
    </div>
    <div id="last-updated">—</div>
  </div>
</div>

<div id="panel">
  <div class="panel-header">Active Alerts — Global &nbsp;<b id="panel-count">0</b></div>
  <div id="alerts-list"><div class="no-alerts">Loading alerts…</div></div>
</div>
<div id="panel-toggle" onclick="togglePanel()">
  <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
</div>

<div id="legend">
  <div class="legend-title">Alert Severity</div>
  <div class="legend-items">
    <div class="legend-item"><div class="legend-dot" style="background:#ff00cc"></div><div class="legend-label">Extreme</div></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ff2d2d"></div><div class="legend-label">Severe</div></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ffa500"></div><div class="legend-label">Moderate</div></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ffd600"></div><div class="legend-label">Minor</div></div>
  </div>
</div>

<div id="timeline">
  <div class="tl-row1">
    <div id="play-btn" onclick="togglePlay()">
      <svg id="play-icon"  viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      <svg id="pause-icon" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </div>
    <div id="time-display">
      <span class="t-time">--:-- --</span>
      <span class="t-sep">·</span>
      <span class="t-ago">Loading…</span>
    </div>
  </div>
  <div id="scrubber-outer">
    <div id="scrubber-track">
      <div id="scrubber-fill"></div>
      <div id="scrubber-thumb"></div>
    </div>
    <div id="scrubber-ticks"></div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── MAP SETUP ──────────────────────────────────────────────────────────────
const map = L.map('map', {
  center: [37, -95], zoom: 4,
  zoomControl: true,
  preferCanvas: true
});

// CartoDB Dark Matter — free, no API key
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap contributors © CARTO',
  subdomains: 'abcd', maxZoom: 19
}).addTo(map);

// Custom pane for radar tiles so they are NOT affected by the base tile CSS filter
map.createPane('radarPane');
map.getPane('radarPane').style.zIndex = 300;
map.getPane('radarPane').classList.add('radar-pane');

// ── RADAR via Iowa State IEM NEXRAD ───────────────────────────────────────
const IEM_TS   = ['900913-m50m','900913-m45m','900913-m40m','900913-m35m',
                   '900913-m30m','900913-m25m','900913-m20m','900913-m15m',
                   '900913-m10m','900913-m05m','900913'];
const IEM_MINS = [50,45,40,35,30,25,20,15,10,5,0];
const FRAME_MS = 650;   // ms per frame during playback
const HOLD_MS  = 1600;  // ms to hold on last frame before looping

let frames     = [];
let currentIdx = 0;
let playing    = false;
let playTimer  = null;

function setStatus(msg, show) {
  const el = document.getElementById('radar-status');
  el.textContent = msg;
  el.classList.toggle('show', !!show);
}

function buildFrames() {
  frames.forEach(f => { try { map.removeLayer(f.layer); } catch(e){} });
  frames = IEM_TS.map((ts, i) => ({
    ts, minsAgo: IEM_MINS[i],
    layer: L.tileLayer(
      `https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/nexrad-n0q-${ts}/{z}/{x}/{y}.png`,
      { opacity: 0, pane: 'radarPane', maxZoom: 18 }
    )
  }));
  buildTicks();
}

// Add ALL layers to the map at opacity 0 right away so tiles start downloading
function preloadAll() {
  setStatus('Loading radar…', true);
  frames.forEach(f => f.layer.addTo(map));
  // Show the most recent frame once its tiles are ready
  let shown = false;
  frames[frames.length - 1].layer.once('load', () => {
    if (!shown) { shown = true; showFrame(frames.length - 1); setStatus('', false); startPlay(); }
  });
  // Fallback: show + play after 5s even if load event never fires
  setTimeout(() => {
    if (!shown) { shown = true; showFrame(frames.length - 1); setStatus('', false); startPlay(); }
  }, 5000);
}

function showFrame(idx) {
  // Hide old
  if (frames[currentIdx]) frames[currentIdx].layer.setOpacity(0);
  currentIdx = Math.max(0, Math.min(idx, frames.length - 1));
  frames[currentIdx].layer.setOpacity(0.8);
  updateUI();
}

function updateUI() {
  const f   = frames[currentIdx];
  const now = new Date();
  const t   = new Date(now.getTime() - f.minsAgo * 60000);
  const h   = t.getHours(), m = t.getMinutes();
  const hh  = ((h % 12) || 12);
  const mm  = m.toString().padStart(2, '0');
  const ap  = h < 12 ? 'AM' : 'PM';
  const ago = f.minsAgo === 0 ? 'LIVE · NOW' : `${f.minsAgo}m ago`;

  document.getElementById('time-display').innerHTML =
    `<span class="t-time">${hh}:${mm} ${ap}</span>` +
    `<span class="t-sep"> · </span>` +
    `<span class="t-ago">${ago}</span>` +
    `<span class="t-sep"> · </span>` +
    `<span class="t-pos">${currentIdx + 1}/${frames.length}</span>`;

  const pct = (currentIdx / (frames.length - 1)) * 100;
  document.getElementById('scrubber-fill').style.width = pct + '%';
  document.getElementById('scrubber-thumb').style.left  = pct + '%';
}

function buildTicks() {
  const picks = [0, 2, 5, 7, frames.length - 1];
  document.getElementById('scrubber-ticks').innerHTML = picks.map(i => {
    const f = frames[i];
    const label = f.minsAgo === 0 ? 'NOW' : `-${f.minsAgo}m`;
    return `<span class="tick-label${f.minsAgo === 0 ? ' is-now' : ''}">${label}</span>`;
  }).join('');
}

// ── GLOBAL RADAR (RainViewer — worldwide coverage) ───────────────────────
// Used when the map viewport is outside the US (IEM only covers CONUS)
let rvApiData   = null;
let rvFrames    = [];
let rvLayers    = {};
let rvActive    = null;
let globalMode  = false;

async function loadRainViewer() {
  try {
    const data = await (await fetch('https://api.rainviewer.com/public/weather-maps.json')).json();
    rvApiData = data;
    rvFrames  = [...(data.radar?.past||[]), ...(data.radar?.nowcast||[])];
    // Pre-create layers
    Object.values(rvLayers).forEach(l => { try { map.removeLayer(l); } catch(e){} });
    rvLayers = {};
    const sz = window.devicePixelRatio >= 2 ? 512 : 256;
    rvFrames.forEach(f => {
      rvLayers[f.path] = L.tileLayer(
        data.host + f.path + '/' + sz + '/{z}/{x}/{y}/2/1_1.png',
        { opacity:0, pane:'radarPane', maxNativeZoom:7, maxZoom:19 }
      );
    });
  } catch(e) { console.error('RainViewer load error:', e); }
}

function showRVFrame(idx) {
  if (!rvFrames.length) return;
  idx = Math.max(0, Math.min(idx, rvFrames.length - 1));
  if (rvActive) { rvActive.setOpacity(0); }
  const path  = rvFrames[idx].path;
  const layer = rvLayers[path];
  if (layer) {
    if (!map.hasLayer(layer)) layer.addTo(map);
    layer.setOpacity(0.75);
    rvActive = layer;
  }
}

// Detect if center of map is roughly outside CONUS
function isOutsideUS() {
  const c = map.getCenter();
  return !(c.lat > 24 && c.lat < 50 && c.lng > -126 && c.lng < -65);
}

// Called every animation frame — pick IEM or RainViewer based on viewport
function getFrameCount()  { return globalMode ? rvFrames.length  : frames.length; }

map.on('moveend', () => {
  const outside = isOutsideUS();
  if (outside !== globalMode) {
    globalMode = outside;
    // Switch radar source: hide the other
    if (globalMode) {
      frames.forEach(f => f.layer.setOpacity(0));
      showRVFrame(rvFrames.length - 1);
    } else {
      if (rvActive) rvActive.setOpacity(0);
      showFrame(frames.length - 1);
    }
  }
});

loadRainViewer();
setInterval(loadRainViewer, 300000);

// ── PLAY / PAUSE ──────────────────────────────────────────────────────────
function animStep() {
  if (!playing) return;
  const total = globalMode ? rvFrames.length : frames.length;
  const next  = currentIdx + 1;
  if (next >= total) {
    playTimer = setTimeout(() => {
      if (playing) {
        currentIdx = -1;
        animStep();
      }
    }, HOLD_MS);
  } else {
    currentIdx = next;
    if (globalMode) showRVFrame(currentIdx);
    else            showFrame(currentIdx);
    playTimer = setTimeout(animStep, FRAME_MS);
  }
}

function startPlay() {
  if (playing) return;
  playing = true;
  document.getElementById('play-icon').style.display  = 'none';
  document.getElementById('pause-icon').style.display = '';
  currentIdx = 0;
  if (globalMode) showRVFrame(0); else showFrame(0);
  playTimer = setTimeout(animStep, FRAME_MS);
}

function togglePlay() {
  if (playing) {
    playing = false;
    clearTimeout(playTimer); playTimer = null;
    document.getElementById('play-icon').style.display  = '';
    document.getElementById('pause-icon').style.display = 'none';
  } else {
    startPlay();
  }
}

buildFrames();
preloadAll();
setInterval(() => { buildFrames(); preloadAll(); }, 300000);

// ── SCRUBBER ──────────────────────────────────────────────────────────────
function scrubTo(clientX) {
  const rect = document.getElementById('scrubber-track').getBoundingClientRect();
  const pct  = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
  if (playing) {
    playing = false; clearTimeout(playTimer); playTimer = null;
    document.getElementById('play-icon').style.display  = '';
    document.getElementById('pause-icon').style.display = 'none';
  }
  showFrame(Math.round(pct * (frames.length - 1)));
}

let dragging = false;
const track = document.getElementById('scrubber-track');
track.addEventListener('mousedown',  e => { dragging = true; scrubTo(e.clientX); });
track.addEventListener('touchstart', e => { dragging = true; scrubTo(e.touches[0].clientX); }, {passive:true});
window.addEventListener('mousemove',  e => { if (dragging) scrubTo(e.clientX); });
window.addEventListener('touchmove',  e => { if (dragging) scrubTo(e.touches[0].clientX); }, {passive:true});
window.addEventListener('mouseup',   () => dragging = false);
window.addEventListener('touchend',  () => dragging = false);

// ── GLOBAL ALERTS ─────────────────────────────────────────────────────────
let alertLayers = [];
const SEV = { Extreme:'#ff00cc', Severe:'#ff2d2d', Moderate:'#ffa500', Minor:'#ffd600', Unknown:'rgba(255,255,255,0.3)' };
const sevOrder = { Extreme:0, Severe:1, Moderate:2, Minor:3, Unknown:4 };
const sevClass = s => 'sev-' + (s||'unknown').toLowerCase();
const timeAgo = iso => {
  if (!iso) return '';
  const d = Math.round((Date.now() - new Date(iso)) / 60000);
  return d < 60 ? `${d}m ago` : d < 1440 ? `${Math.round(d/60)}h ago` : `${Math.round(d/1440)}d ago`;
};

// Map bounds → which region APIs to query
// We always fetch NWS (US). For Europe we use MeteoAlarm via open-meteo proxy.
// For other regions we use Open-Meteo's global alert feed where available.

async function fetchNWSAlerts() {
  try {
    const data = await (await fetch('https://api.weather.gov/alerts/active?status=actual&message_type=alert&limit=500')).json();
    return (data.features||[]).map(f => ({
      severity: f.properties.severity || 'Unknown',
      event:    f.properties.event || 'Alert',
      area:     f.properties.areaDesc || '',
      sent:     f.properties.sent,
      geometry: f.geometry,
      region:   'US'
    }));
  } catch(e) { return []; }
}

async function fetchOpenMeteoAlerts() {
  // Open-Meteo provides global severe weather alerts via their free API (no key)
  // Uses DWD (Germany), Météo-France, MET Norway, Environment Canada, etc.
  const regions = [
    { name:'Europe',  lat:50,  lon:10  },
    { name:'Canada',  lat:56,  lon:-96 },
    { name:'Australia', lat:-25, lon:134 },
    { name:'UK',      lat:54,  lon:-2  },
    { name:'Japan',   lat:36,  lon:138 },
  ];
  const results = [];
  await Promise.allSettled(regions.map(async r => {
    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${r.lat}&longitude=${r.lon}&daily=weathercode&timezone=auto&forecast_days=1`;
      // Open-Meteo doesn't have an alerts endpoint yet — use their partner
      // Use 7timer / wttr for fallback but actually the best free global alert API is:
      // https://openweathermap.org/api/push-weather-alerts (needs key)
      // Best truly-free option: scrape NWS international + use meteoalert RSS
    } catch(e) {}
  }));
  return results;
}

// Use both NWS (US) + RainViewer's alert overlay for global coverage
async function loadAlerts() {
  alertLayers.forEach(l => { try { map.removeLayer(l); } catch(e){} });
  alertLayers = [];

  // Fetch US alerts from NWS
  const usAlerts = await fetchNWSAlerts();

  // Fetch global alerts from Open-Meteo (EU, CA, AU, etc.)
  // Open-Meteo forecast API gives us weather codes we can interpret
  // For actual polygon alerts globally, use the MeteoAlarm GeoJSON (EU only, free)
  const euAlerts = await fetchEUAlerts();

  const allAlerts = [...usAlerts, ...euAlerts].sort((a,b) =>
    (sevOrder[a.severity]||4) - (sevOrder[b.severity]||4)
  );

  const list  = document.getElementById('alerts-list');
  const total = allAlerts.length;
  document.getElementById('alert-num').textContent   = total;
  document.getElementById('panel-count').textContent = total;
  document.getElementById('alert-pill').className    = total ? 'alert-pill' : 'alert-pill none';
  // Show the toggle arrow only when there are alerts
  document.getElementById('panel-toggle').classList.toggle('has-alerts', total > 0);

  if (!total) {
    list.innerHTML = '<div class="no-alerts">No active alerts.<br>All clear globally.</div>';
  } else {
    list.innerHTML = '';
    allAlerts.forEach(a => {
      const col = SEV[a.severity] || SEV.Unknown;
      if (a.geometry) {
        const gl = L.geoJSON(a.geometry, {
          style:{ color:col, fillColor:col, weight:1.5, opacity:0.85, fillOpacity:0.12 }
        });
        gl.bindTooltip(`<strong>${a.event}</strong><br>${a.area}`, { className:'alert-tooltip', sticky:true });
        gl.addTo(map); alertLayers.push(gl);
      }
      const item = document.createElement('div');
      item.className = `alert-item ${sevClass(a.severity)}`;
      const badge = a.region ? `<span style="opacity:0.4;font-size:0.48rem;margin-left:4px">${a.region}</span>` : '';
      item.innerHTML = `<div class="alert-event">${a.event}${badge}</div><div class="alert-area">${a.area}</div><div class="alert-time">${timeAgo(a.sent)} · ${a.severity}</div>`;
      if (a.geometry) item.onclick = () => map.flyToBounds(L.geoJSON(a.geometry).getBounds(), {padding:[60,60],duration:1.2});
      list.appendChild(item);
    });
  }

  const now = new Date();
  document.getElementById('last-updated').textContent =
    `${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
}

async function fetchEUAlerts() {
  // MeteoAlarm provides EU-wide severe weather alerts as GeoJSON — free, no key
  try {
    const data = await (await fetch('https://feeds.meteoalarm.org/api/v1/warnings/region/europe')).json();
    return (data.features||[]).map(f => {
      const p = f.properties||{};
      const awareness = p.awareness_level || '';
      // MeteoAlarm levels: 1=green(none), 2=yellow, 3=orange, 4=red
      const lvl = parseInt(awareness.split(';')[0]) || 1;
      const sev = lvl >= 4 ? 'Extreme' : lvl === 3 ? 'Severe' : lvl === 2 ? 'Moderate' : 'Minor';
      return {
        severity: sev,
        event:    p.awareness_type ? p.awareness_type.split(';')[1] || 'Weather Alert' : 'Weather Alert',
        area:     p.region_name || p.country || 'Europe',
        sent:     p.from || null,
        geometry: f.geometry,
        region:   'EU'
      };
    });
  } catch(e) {
    // Fallback: try the CORS-friendly GeoJSON endpoint
    try {
      const r = await fetch('https://feeds.meteoalarm.org/feeds/meteoalarm-legacy-atom-europe');
      // RSS fallback — skip if CORS blocked
      return [];
    } catch(e2) { return []; }
  }
}

function togglePanel() { document.getElementById('panel').classList.toggle('open'); }

loadAlerts();
setInterval(loadAlerts, 60000);
</script>
