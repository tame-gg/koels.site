---
// src/pages/radar.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="description" content="Real-time weather radar with live severe weather alerts for the US, Europe, Canada, Australia, New Zealand, Japan, and more."/>
<meta name="theme-color" content="#020810"/>
<meta property="og:title" content="koels.site — Radar"/>
<meta property="og:description" content="Real-time weather radar with live alerts worldwide."/>
<meta property="og:type" content="website"/>
<title>koels.site — Radar</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%23020810'/%3E%3Ccircle cx='16' cy='16' r='13' fill='none' stroke='%230078c8' stroke-width='0.8' opacity='0.4'/%3E%3Ccircle cx='16' cy='16' r='9' fill='none' stroke='%230078c8' stroke-width='0.8' opacity='0.5'/%3E%3Ccircle cx='16' cy='16' r='5' fill='none' stroke='%2340c8ff' stroke-width='0.8' opacity='0.7'/%3E%3Ccircle cx='16' cy='16' r='2' fill='%2340c8ff'/%3E%3Cline x1='16' y1='16' x2='27' y2='7' stroke='%2340c8ff' stroke-width='1.5' stroke-linecap='round'/%3E%3Ccircle cx='24' cy='9' r='2' fill='%2300ffcc'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://unpkg.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="anonymous"/>
<style is:global>
@view-transition { navigation: auto; }
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; overflow:hidden; font-family:'Inter',system-ui,sans-serif; -webkit-font-smoothing:antialiased; }
body { background:#020810; color:#c8f0ff; }
#map { position:fixed; inset:0; z-index:1; }

/* CSS custom properties — header height + iOS safe-area insets */
:root {
  --hdr: 54px;
  --sat: env(safe-area-inset-top, 0px);
  --sab: env(safe-area-inset-bottom, 0px);
  --sal: env(safe-area-inset-left, 0px);
  --sar: env(safe-area-inset-right, 0px);
}

/* HEADER */
#header {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  height:calc(var(--hdr) + var(--sat));
  display:flex; align-items:center; justify-content:space-between;
  padding:var(--sat) 20px 0;
  background:rgba(3,3,10,0.92); border-bottom:1px solid rgba(255,255,255,0.07);
  -webkit-backdrop-filter:blur(20px);
  backdrop-filter:blur(20px);
}
.header-left { display:flex; align-items:center; gap:14px; }
.radar-logo { display:flex; align-items:center; gap:9px; }
.radar-logo-icon { width:30px; height:30px; flex-shrink:0; }
.radar-logo-icon svg { width:100%; height:100%; }
.radar-logo-main { font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#c8f0ff; line-height:1; }
.radar-logo-sub  { font-size:0.52rem; letter-spacing:0.14em; text-transform:uppercase; color:rgba(200,240,255,0.35); line-height:1; margin-top:2px; }
.header-right { display:flex; align-items:center; gap:12px; }
.alert-pill {
  display:flex; align-items:center; gap:5px; padding:4px 11px; border-radius:999px;
  font-size:0.58rem; letter-spacing:0.1em; text-transform:uppercase;
  border:1px solid rgba(255,71,87,0.3); background:rgba(255,71,87,0.08); color:#ff4757;
  -webkit-tap-highlight-color:transparent;
}
.alert-pill.none { border-color:rgba(255,255,255,0.08); background:transparent; color:rgba(200,240,255,0.3); }
.alert-pill svg { width:9px; height:9px; fill:currentColor; }
#last-updated { font-size:0.56rem; color:rgba(200,240,255,0.28); letter-spacing:0.08em; }
.beta-badge {
  font-size:0.48rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase;
  color:#020810; background:linear-gradient(135deg,#40c8ff,#00ffcc); border-radius:4px;
  padding:2px 7px; align-self:center;
}
/* BETA DISCLAIMER MODAL */
#beta-overlay {
  position:fixed; inset:0; z-index:9999;
  background:rgba(3,3,10,0.85);
  -webkit-backdrop-filter:blur(12px);
  backdrop-filter:blur(12px);
  display:flex; align-items:center; justify-content:center;
  padding:20px;
}
#beta-overlay.hidden { display:none; }
#beta-modal {
  background:rgba(14,13,28,0.98); border:1px solid rgba(0,120,200,0.35);
  border-radius:16px; padding:32px 28px; max-width:420px; width:100%;
  box-shadow:0 24px 60px rgba(0,0,0,0.6);
}
.beta-modal-icon { font-size:2rem; margin-bottom:14px; }
.beta-modal-title {
  font-size:1rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase;
  color:#c8f0ff; margin-bottom:8px;
}
.beta-modal-sub {
  font-size:0.62rem; letter-spacing:0.06em; color:rgba(200,240,255,0.5);
  text-transform:uppercase; margin-bottom:16px;
}
.beta-modal-body {
  font-size:0.66rem; color:rgba(200,240,255,0.55); line-height:1.8;
  margin-bottom:24px;
}
.beta-modal-body b { color:rgba(200,240,255,0.8); }
.beta-modal-footer { display:flex; align-items:center; justify-content:space-between; gap:12px; }
.beta-dismiss-btn {
  flex:1; padding:10px; border-radius:8px; cursor:pointer; font-family:"JetBrains Mono",monospace;
  font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:700;
  background:rgba(0,120,200,0.25); border:1.5px solid rgba(0,120,200,0.5); color:#40c8ff;
  transition:all 0.18s;
}
.beta-dismiss-btn:hover { background:rgba(0,120,200,0.45); }
.beta-dont-show {
  display:flex; align-items:center; gap:7px; cursor:pointer;
  font-size:0.56rem; color:rgba(200,240,255,0.3); letter-spacing:0.06em;
  white-space:nowrap; user-select:none;
}
.beta-dont-show input { accent-color:#0078c8; width:13px; height:13px; cursor:pointer; }
.beta-dont-show:hover { color:rgba(200,240,255,0.55); }

/* ALERTS PANEL */
#panel {
  position:fixed; top:calc(var(--hdr) + var(--sat)); right:0; bottom:0; z-index:900; width:360px;
  background:rgba(5,4,18,0.99); border-left:1px solid rgba(0,120,200,0.12);
  backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
  display:flex; flex-direction:column;
  transform:translateX(100%); transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
  box-shadow:-8px 0 40px rgba(0,0,0,0.4);
  will-change:transform;
}
#panel.open { transform:translateX(0); }
#panel-toggle {
  position:fixed; top:50%; right:0; z-index:950; transform:translateY(-50%);
  width:22px; height:56px;
  background:rgba(5,4,18,0.95); border:1px solid rgba(0,120,200,0.2); border-right:none;
  border-radius:6px 0 0 6px; display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.2s; opacity:0; pointer-events:none;
  touch-action:manipulation; -webkit-tap-highlight-color:transparent;
}
#panel-toggle:focus-visible { outline:2px solid #40c8ff; outline-offset:-2px; }
#panel-toggle.has-alerts { opacity:0.6; pointer-events:auto; }
#panel-toggle.has-alerts:hover { background:rgba(0,120,200,0.25); opacity:1; }
#panel-toggle svg { width:11px; height:11px; fill:rgba(162,155,254,0.7); transition:transform 0.3s; }
#panel.open ~ #panel-toggle { right:360px; opacity:1 !important; pointer-events:auto; }
#panel.open ~ #panel-toggle svg { transform:rotate(180deg); }

/* Panel header */
.panel-header {
  padding:16px 18px 14px; border-bottom:1px solid rgba(255,255,255,0.06);
  display:flex; align-items:center; justify-content:space-between; flex-shrink:0;
  background:rgba(0,120,200,0.04);
}
.panel-header-title {
  font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(200,240,255,0.4);
  display:flex; align-items:center; gap:8px;
}
.panel-header-title::before {
  content:''; display:inline-block; width:7px; height:7px; border-radius:50%;
  background:#ff4757; box-shadow:0 0 6px rgba(255,71,87,0.8);
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.panel-header-count {
  font-size:0.72rem; font-weight:700; color:#ff4757;
  background:rgba(255,71,87,0.12); border:1px solid rgba(255,71,87,0.3);
  border-radius:6px; padding:3px 10px; min-width:32px; text-align:center;
  letter-spacing:0.04em;
}

/* Region tabs */
#region-tabs {
  display:flex; gap:4px; padding:10px 12px 9px;
  border-bottom:1px solid rgba(255,255,255,0.05);
  overflow-x:auto; scrollbar-width:none; flex-shrink:0;
}
#region-tabs::-webkit-scrollbar { display:none; }
.rtab {
  flex-shrink:0; font-size:0.5rem; letter-spacing:0.1em; text-transform:uppercase;
  padding:4px 11px; border-radius:5px; cursor:pointer; transition:all 0.15s;
  border:1px solid rgba(255,255,255,0.08); color:rgba(200,240,255,0.32);
  background:transparent; font-family:"JetBrains Mono",monospace;
}
.rtab:hover { color:rgba(200,240,255,0.65); border-color:rgba(255,255,255,0.18); background:rgba(255,255,255,0.04); }
.rtab.active { background:rgba(0,120,200,0.18); border-color:rgba(0,120,200,0.5); color:#40c8ff; }

/* Alert list scroll area */
#alerts-list {
  flex:1; overflow-y:auto; padding:8px 10px 16px;
  scrollbar-width:thin; scrollbar-color:rgba(0,120,200,0.15) transparent;
}
#alerts-list::-webkit-scrollbar { width:3px; }
#alerts-list::-webkit-scrollbar-thumb { background:rgba(0,120,200,0.2); border-radius:3px; }

/* Severity group dividers */
.alert-group-header {
  display:flex; align-items:center; gap:10px; padding:14px 4px 6px; margin-top:2px;
}
.alert-group-label {
  font-size:0.48rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(200,240,255,0.25); flex-shrink:0;
}
.alert-group-line { flex:1; height:1px; background:rgba(255,255,255,0.05); }
.alert-group-n {
  font-size:0.48rem; color:rgba(200,240,255,0.2); flex-shrink:0;
  background:rgba(255,255,255,0.05); border-radius:3px; padding:1px 6px;
}

/* Alert cards */
.alert-item {
  display:flex; flex-direction:column;
  border-radius:8px; margin-bottom:6px;
  border:1px solid rgba(255,255,255,0.08);
  overflow:hidden; transition:border-color 0.15s, box-shadow 0.15s;
  background:rgba(14,12,32,0.8);
}
.alert-item:hover { box-shadow:0 4px 20px rgba(0,0,0,0.4); }

/* Top accent bar */
.alert-bar { height:3px; width:100%; display:block; }
.sev-extreme .alert-bar  { background:linear-gradient(90deg,#ff55dd,#ff00cc); }
.sev-severe  .alert-bar  { background:linear-gradient(90deg,#ff6b6b,#ff3737); }
.sev-moderate .alert-bar { background:linear-gradient(90deg,#ffb84d,#ff9500); }
.sev-minor   .alert-bar  { background:linear-gradient(90deg,#ffe566,#ffd60a); }
.sev-unknown .alert-bar  { background:rgba(255,255,255,0.12); }

/* Severity border tints */
.sev-extreme  { border-color:rgba(255,0,200,0.2); }
.sev-severe   { border-color:rgba(255,55,55,0.2); }
.sev-moderate { border-color:rgba(255,149,0,0.18); }
.sev-minor    { border-color:rgba(255,214,10,0.14); }

/* Card body */
.alert-body { padding:10px 12px 10px; display:flex; flex-direction:column; gap:5px; }

/* Top row: severity + time */
.alert-top-row {
  display:flex; align-items:center; justify-content:space-between;
}
.alert-sev-badge { display:flex; align-items:center; gap:5px; }
.alert-sev-dot {
  width:7px; height:7px; border-radius:50%; flex-shrink:0; display:inline-block;
}
.alert-sev-text {
  font-size:10px; letter-spacing:0.12em; text-transform:uppercase; font-weight:700;
}
.alert-time-chip {
  font-size:10px; color:rgba(200,240,255,0.3); white-space:nowrap;
}

/* Event title */
.alert-event {
  font-size:12px; font-weight:600; color:rgba(200,240,255,0.92);
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.4;
}

/* Alert tag (e.g. TORNADO, SEVERE TSTM, FLOOD) */
.alert-tag-row {
  display:flex; align-items:center; gap:4px; flex-wrap:wrap;
  margin-bottom:2px;
}
.alert-tag-chip {
  font-size:8.5px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
  padding:2px 6px; border-radius:3px;
  border:1px solid;
  background:rgba(255,255,255,0.05);
  white-space:nowrap;
  font-family:"JetBrains Mono",monospace;
}

/* Area */
.alert-area {
  font-size:11px; color:rgba(200,240,255,0.4); line-height:1.5;
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}

/* Footer: source + link */
.alert-footer {
  display:flex; align-items:center; justify-content:space-between;
  padding-top:8px; margin-top:2px;
  border-top:1px solid rgba(255,255,255,0.06);
}
.alert-source-chip {
  font-size:10px; letter-spacing:0.08em; text-transform:uppercase;
  padding:3px 8px; border-radius:4px;
  border:1px solid rgba(0,120,200,0.3); color:rgba(162,155,254,0.6);
  background:rgba(0,120,200,0.08);
}
.alert-gov-link,
.alert-gov-link:link,
.alert-gov-link:visited {
  font-size:10px; letter-spacing:0.06em; text-transform:uppercase;
  color:rgba(200,240,255,0.45); text-decoration:none;
  padding:3px 8px; border-radius:4px;
  border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04);
  transition:color 0.14s, border-color 0.14s, background 0.14s;
}
.alert-gov-link:hover {
  color:#c8f0ff; border-color:rgba(255,255,255,0.25); background:rgba(255,255,255,0.08);
}

.no-alerts {
  padding:48px 20px; text-align:center; font-size:11px;
  color:rgba(200,240,255,0.2); letter-spacing:0.08em; line-height:2.4;
}

/* LEGEND — bottom left corner, horizontal pill */
#legend {
  position:fixed; bottom:20px; left:20px; z-index:900;
  background:rgba(5,4,18,0.94); border:1px solid rgba(0,120,200,0.2);
  border-radius:12px; padding:11px 20px;
  backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
  display:flex; align-items:center; gap:16px;
  box-shadow:0 4px 24px rgba(0,0,0,0.35);
}
.legend-title {
  font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase;
  color:rgba(200,240,255,0.35); white-space:nowrap; margin-right:2px;
}
.legend-items { display:flex; align-items:center; gap:14px; }
.legend-item { display:flex; align-items:center; gap:7px; }
.legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.legend-label { font-size:0.68rem; color:rgba(200,240,255,0.55); white-space:nowrap; font-weight:500; }

/* TIMELINE */
#timeline {
  position:fixed; bottom:16px; left:50%; transform:translateX(-50%);
  z-index:900;
  background:rgba(3,3,10,0.92); border:1px solid rgba(255,255,255,0.09);
  border-radius:16px; padding:12px 18px 14px;
  -webkit-backdrop-filter:blur(20px);
  backdrop-filter:blur(20px);
  width:min(540px, calc(100vw - 32px));
}
.tl-row1 {
  display:flex; align-items:center; gap:12px; margin-bottom:10px;
}
#play-btn {
  width:30px; height:30px; border-radius:50%; flex-shrink:0;
  background:rgba(0,120,200,0.2); border:1.5px solid rgba(0,120,200,0.5);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.18s;
  touch-action:manipulation; -webkit-tap-highlight-color:transparent;
}
#play-btn:hover { background:rgba(0,120,200,0.45); transform:scale(1.06); }
#play-btn:focus-visible { outline:2px solid #40c8ff; outline-offset:2px; }
#play-btn svg { width:12px; height:12px; fill:#40c8ff; }
#time-display {
  flex:1; text-align:center;
  font-size:0.65rem; color:rgba(200,240,255,0.5); letter-spacing:0.05em;
}
#time-display .t-time { color:#c8f0ff; font-weight:700; }
#time-display .t-sep  { color:rgba(200,240,255,0.2); margin:0 5px; }
#time-display .t-ago  { color:rgba(162,155,254,0.8); }
#time-display .t-pos  { color:rgba(200,240,255,0.25); font-size:0.55rem; }

/* Scrubber */
#scrubber-outer { position:relative; }
#scrubber-track {
  width:100%; height:5px; border-radius:999px;
  background:rgba(255,255,255,0.1); position:relative; cursor:pointer;
  touch-action:none;
}
/* Expanded invisible touch target via pseudo-element — doesn't affect visuals */
#scrubber-track::before {
  content:''; position:absolute;
  inset:-10px 0;
}
#scrubber-fill {
  height:100%; border-radius:999px;
  background:linear-gradient(90deg,#0078c8,#40c8ff,#00ffcc);
  width:0%; pointer-events:none; transition:width 0.05s;
}
#scrubber-thumb {
  position:absolute; top:50%; left:0%;
  width:14px; height:14px; border-radius:50%;
  background:#40c8ff; border:2px solid #fff;
  box-shadow:0 0 8px rgba(162,155,254,0.7);
  transform:translate(-50%,-50%);
  pointer-events:none;
  will-change:left;
}
#scrubber-ticks {
  display:flex; justify-content:space-between;
  margin-top:8px; padding:0 1px;
}
.tick-label {
  font-size:0.5rem; color:rgba(200,240,255,0.3);
  font-family:"JetBrains Mono",monospace; letter-spacing:0;
  line-height:1;
}
.tick-label.is-now { color:#40c8ff; font-weight:700; }

/* status */
#radar-status {
  position:fixed; top:calc(var(--hdr) + 10px + var(--sat)); left:50%; transform:translateX(-50%);
  z-index:1100; background:rgba(3,3,10,0.9); border:1px solid rgba(255,255,255,0.1);
  border-radius:8px; padding:6px 14px; font-size:0.58rem; color:rgba(200,240,255,0.6);
  letter-spacing:0.08em; pointer-events:none; opacity:0; transition:opacity 0.3s;
}
#radar-status.show { opacity:1; }

/* Leaflet overrides */
.leaflet-container { background:#020810 !important; }
.leaflet-tile-pane { filter:brightness(0.88) saturate(0.5); }
.leaflet-pane.radar-pane { filter:none !important; }

/* LOCATE ME BUTTON */
#locate-btn {
  position:fixed; top:calc(var(--hdr) + 10px + var(--sat)); right:calc(12px + var(--sar)); z-index:1000;
  width:36px; height:36px; border-radius:8px; cursor:pointer;
  background:rgba(3,3,10,0.92); border:1px solid rgba(0,120,200,0.3);
  display:flex; align-items:center; justify-content:center;
  transition:all 0.2s; -webkit-backdrop-filter:blur(16px); backdrop-filter:blur(16px);
  box-shadow:0 4px 16px rgba(0,0,0,0.4);
  touch-action:manipulation; -webkit-tap-highlight-color:transparent;
}
#locate-btn:hover { background:rgba(0,120,200,0.3); border-color:rgba(0,120,200,0.6); transform:scale(1.05); }
#locate-btn:focus-visible { outline:2px solid #40c8ff; outline-offset:2px; }
#locate-btn svg { width:18px; height:18px; }
#locate-btn.locating svg circle { animation: pulse-ring-stroke 1s ease-out infinite; }
@keyframes pulse-ring-stroke {
  0% { stroke:rgba(162,155,254,0.85); }
  50% { stroke:#40c8ff; filter:drop-shadow(0 0 4px #40c8ff); }
  100% { stroke:rgba(162,155,254,0.85); }
}

/* SEARCH BAR */
#search-container {
  position:fixed; top:calc(var(--hdr) + 10px + var(--sat)); left:50%; transform:translateX(-50%);
  z-index:1000; width:min(400px, calc(100vw - 116px));
}
#search-input {
  width:100%; padding:9px 14px 9px 36px; border-radius:10px;
  background:rgba(3,3,10,0.92); border:1px solid rgba(0,120,200,0.25);
  color:#c8f0ff; font-family:"JetBrains Mono",monospace; font-size:0.68rem;
  letter-spacing:0.04em; outline:none;
  -webkit-backdrop-filter:blur(16px); backdrop-filter:blur(16px);
  box-shadow:0 4px 20px rgba(0,0,0,0.4);
  transition:border-color 0.2s, box-shadow 0.2s;
}
#search-input::placeholder { color:rgba(200,240,255,0.25); }
#search-input:focus { border-color:rgba(0,120,200,0.6); box-shadow:0 4px 24px rgba(0,120,200,0.15); }
#search-icon {
  position:absolute; left:11px; top:50%; transform:translateY(-50%);
  width:16px; height:16px; fill:rgba(162,155,254,0.5); pointer-events:none;
}
#search-results {
  position:absolute; top:calc(100% + 4px); left:0; right:0;
  background:rgba(5,4,18,0.98); border:1px solid rgba(0,120,200,0.2);
  border-radius:10px; max-height:240px; overflow-y:auto;
  box-shadow:0 8px 32px rgba(0,0,0,0.5);
