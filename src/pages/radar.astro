---
// src/pages/radar.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>koels.site — Radar</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%2303030a'/%3E%3Ccircle cx='16' cy='16' r='13' fill='none' stroke='%236c5ce7' stroke-width='0.8' opacity='0.4'/%3E%3Ccircle cx='16' cy='16' r='9' fill='none' stroke='%236c5ce7' stroke-width='0.8' opacity='0.5'/%3E%3Ccircle cx='16' cy='16' r='5' fill='none' stroke='%236c5ce7' stroke-width='0.8' opacity='0.7'/%3E%3Ccircle cx='16' cy='16' r='2' fill='%23a29bfe'/%3E%3Cline x1='16' y1='16' x2='27' y2='7' stroke='%23a29bfe' stroke-width='1.5' stroke-linecap='round'/%3E%3Ccircle cx='24' cy='9' r='2' fill='%2300ff88'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; overflow:hidden; font-family:"JetBrains Mono",monospace; }
body { background:#03030a; color:#f0eeff; }
#map { position:fixed; inset:0; z-index:1; }

/* HEADER */
#header {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  height:54px; display:flex; align-items:center; justify-content:space-between;
  padding:0 20px;
  background:rgba(3,3,10,0.92); border-bottom:1px solid rgba(255,255,255,0.07);
  backdrop-filter:blur(20px);
}
.header-left { display:flex; align-items:center; gap:14px; }
.back-btn {
  display:flex; align-items:center; gap:5px;
  font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase;
  color:rgba(240,238,255,0.4); text-decoration:none; transition:color 0.2s;
}
.back-btn:hover { color:#f0eeff; }
.back-btn svg { width:13px; height:13px; fill:currentColor; }
.hdiv { width:1px; height:16px; background:rgba(255,255,255,0.1); }
.radar-logo { display:flex; align-items:center; gap:9px; }
.radar-logo-icon { width:30px; height:30px; flex-shrink:0; }
.radar-logo-icon svg { width:100%; height:100%; }
.radar-logo-main { font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#f0eeff; line-height:1; }
.radar-logo-sub  { font-size:0.52rem; letter-spacing:0.14em; text-transform:uppercase; color:rgba(240,238,255,0.35); line-height:1; margin-top:2px; }
.header-right { display:flex; align-items:center; gap:12px; }
.alert-pill {
  display:flex; align-items:center; gap:5px; padding:4px 11px; border-radius:999px;
  font-size:0.58rem; letter-spacing:0.1em; text-transform:uppercase;
  border:1px solid rgba(255,71,87,0.3); background:rgba(255,71,87,0.08); color:#ff4757;
}
.alert-pill.none { border-color:rgba(255,255,255,0.08); background:transparent; color:rgba(240,238,255,0.3); }
.alert-pill svg { width:9px; height:9px; fill:currentColor; }
#last-updated { font-size:0.56rem; color:rgba(240,238,255,0.28); letter-spacing:0.08em; }
.beta-badge {
  font-size:0.48rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase;
  color:#03030a; background:#a29bfe; border-radius:4px;
  padding:2px 7px; align-self:center;
}
/* BETA DISCLAIMER MODAL */
#beta-overlay {
  position:fixed; inset:0; z-index:9999;
  background:rgba(3,3,10,0.85); backdrop-filter:blur(12px);
  display:flex; align-items:center; justify-content:center;
  padding:20px;
}
#beta-overlay.hidden { display:none; }
#beta-modal {
  background:rgba(14,13,28,0.98); border:1px solid rgba(108,92,231,0.35);
  border-radius:16px; padding:32px 28px; max-width:420px; width:100%;
  box-shadow:0 24px 60px rgba(0,0,0,0.6);
}
.beta-modal-icon { font-size:2rem; margin-bottom:14px; }
.beta-modal-title {
  font-size:1rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase;
  color:#f0eeff; margin-bottom:8px;
}
.beta-modal-sub {
  font-size:0.62rem; letter-spacing:0.06em; color:rgba(240,238,255,0.5);
  text-transform:uppercase; margin-bottom:16px;
}
.beta-modal-body {
  font-size:0.66rem; color:rgba(240,238,255,0.55); line-height:1.8;
  margin-bottom:24px;
}
.beta-modal-body b { color:rgba(240,238,255,0.8); }
.beta-modal-footer { display:flex; align-items:center; justify-content:space-between; gap:12px; }
.beta-dismiss-btn {
  flex:1; padding:10px; border-radius:8px; cursor:pointer; font-family:"JetBrains Mono",monospace;
  font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:700;
  background:rgba(108,92,231,0.25); border:1.5px solid rgba(108,92,231,0.5); color:#a29bfe;
  transition:all 0.18s;
}
.beta-dismiss-btn:hover { background:rgba(108,92,231,0.45); }
.beta-dont-show {
  display:flex; align-items:center; gap:7px; cursor:pointer;
  font-size:0.56rem; color:rgba(240,238,255,0.3); letter-spacing:0.06em;
  white-space:nowrap; user-select:none;
}
.beta-dont-show input { accent-color:#6c5ce7; width:13px; height:13px; cursor:pointer; }
.beta-dont-show:hover { color:rgba(240,238,255,0.55); }

/* ALERTS PANEL */
#panel {
  position:fixed; top:54px; right:0; bottom:0; z-index:900; width:360px;
  background:rgba(5,4,18,0.99); border-left:1px solid rgba(108,92,231,0.12);
  backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
  display:flex; flex-direction:column;
  transform:translateX(100%); transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
  box-shadow:-8px 0 40px rgba(0,0,0,0.4);
}
#panel.open { transform:translateX(0); }
#panel-toggle {
  position:fixed; top:50%; right:0; z-index:950; transform:translateY(-50%);
  width:22px; height:56px;
  background:rgba(5,4,18,0.95); border:1px solid rgba(108,92,231,0.2); border-right:none;
  border-radius:6px 0 0 6px; display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.2s; opacity:0; pointer-events:none;
}
#panel-toggle.has-alerts { opacity:0.6; pointer-events:auto; }
#panel-toggle.has-alerts:hover { background:rgba(108,92,231,0.25); opacity:1; }
#panel-toggle svg { width:11px; height:11px; fill:rgba(162,155,254,0.7); transition:transform 0.3s; }
#panel.open ~ #panel-toggle { right:360px; opacity:1 !important; pointer-events:auto; }
#panel.open ~ #panel-toggle svg { transform:rotate(180deg); }

/* Panel header */
.panel-header {
  padding:16px 18px 14px; border-bottom:1px solid rgba(255,255,255,0.06);
  display:flex; align-items:center; justify-content:space-between; flex-shrink:0;
  background:rgba(108,92,231,0.04);
}
.panel-header-title {
  font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(240,238,255,0.4);
  display:flex; align-items:center; gap:8px;
}
.panel-header-title::before {
  content:''; display:inline-block; width:7px; height:7px; border-radius:50%;
  background:#ff4757; box-shadow:0 0 6px rgba(255,71,87,0.8);
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.panel-header-count {
  font-size:0.72rem; font-weight:700; color:#ff4757;
  background:rgba(255,71,87,0.12); border:1px solid rgba(255,71,87,0.3);
  border-radius:6px; padding:3px 10px; min-width:32px; text-align:center;
  letter-spacing:0.04em;
}

/* Region tabs */
#region-tabs {
  display:flex; gap:4px; padding:10px 12px 9px;
  border-bottom:1px solid rgba(255,255,255,0.05);
  overflow-x:auto; scrollbar-width:none; flex-shrink:0;
}
#region-tabs::-webkit-scrollbar { display:none; }
.rtab {
  flex-shrink:0; font-size:0.5rem; letter-spacing:0.1em; text-transform:uppercase;
  padding:4px 11px; border-radius:5px; cursor:pointer; transition:all 0.15s;
  border:1px solid rgba(255,255,255,0.08); color:rgba(240,238,255,0.32);
  background:transparent; font-family:"JetBrains Mono",monospace;
}
.rtab:hover { color:rgba(240,238,255,0.65); border-color:rgba(255,255,255,0.18); background:rgba(255,255,255,0.04); }
.rtab.active { background:rgba(108,92,231,0.18); border-color:rgba(108,92,231,0.5); color:#a29bfe; }

/* Alert list scroll area */
#alerts-list {
  flex:1; overflow-y:auto; padding:8px 10px 16px;
  scrollbar-width:thin; scrollbar-color:rgba(108,92,231,0.15) transparent;
}
#alerts-list::-webkit-scrollbar { width:3px; }
#alerts-list::-webkit-scrollbar-thumb { background:rgba(108,92,231,0.2); border-radius:3px; }

/* Severity group dividers */
.alert-group-header {
  display:flex; align-items:center; gap:10px; padding:14px 4px 6px; margin-top:2px;
}
.alert-group-label {
  font-size:0.48rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(240,238,255,0.25); flex-shrink:0;
}
.alert-group-line { flex:1; height:1px; background:rgba(255,255,255,0.05); }
.alert-group-n {
  font-size:0.48rem; color:rgba(240,238,255,0.2); flex-shrink:0;
  background:rgba(255,255,255,0.05); border-radius:3px; padding:1px 6px;
}

/* Alert cards */
.alert-item {
  display:flex; flex-direction:column;
  border-radius:10px; margin-bottom:7px;
  border:1px solid rgba(255,255,255,0.07);
  overflow:hidden; transition:all 0.16s;
  min-width:0; position:relative;
  background:rgba(255,255,255,0.02);
}
.alert-item:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(0,0,0,0.35); }

/* Top accent bar */
.alert-bar { height:3px; width:100%; flex-shrink:0; }

/* Card body */
.alert-body { padding:10px 12px 9px; display:flex; flex-direction:column; gap:4px; }

/* Severity bar colors */
.sev-extreme  { border-color:rgba(255,0,200,0.22); }
.sev-extreme:hover  { border-color:rgba(255,0,200,0.4); background:rgba(255,0,200,0.05) !important; }
.sev-extreme .alert-bar  { background:linear-gradient(90deg,#ff55dd,#ff00cc); }
.sev-severe   { border-color:rgba(255,55,55,0.22); }
.sev-severe:hover   { border-color:rgba(255,55,55,0.4); background:rgba(255,55,55,0.05) !important; }
.sev-severe .alert-bar   { background:linear-gradient(90deg,#ff5555,#ff3737); }
.sev-moderate { border-color:rgba(255,149,0,0.2); }
.sev-moderate:hover { border-color:rgba(255,149,0,0.38); background:rgba(255,149,0,0.04) !important; }
.sev-moderate .alert-bar { background:linear-gradient(90deg,#ffad33,#ff9500); }
.sev-minor    { border-color:rgba(255,214,10,0.15); }
.sev-minor:hover    { border-color:rgba(255,214,10,0.3); background:rgba(255,214,10,0.03) !important; }
.sev-minor .alert-bar    { background:linear-gradient(90deg,#ffe033,#ffd60a); }
.sev-unknown  { border-color:rgba(255,255,255,0.07); }
.sev-unknown:hover  { background:rgba(255,255,255,0.04) !important; }
.sev-unknown .alert-bar  { background:rgba(255,255,255,0.15); }

/* Severity badge row */
.alert-top-row {
  display:flex; align-items:center; justify-content:space-between; gap:6px;
}
.alert-sev-badge {
  display:inline-flex; align-items:center; gap:5px;
}
.alert-sev-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.alert-sev-text {
  font-size:0.48rem; letter-spacing:0.14em; text-transform:uppercase;
  font-weight:700;
}
.alert-time-chip {
  font-size:0.43rem; color:rgba(240,238,255,0.22); letter-spacing:0.05em;
  white-space:nowrap; flex-shrink:0;
}

/* Card text */
.alert-event {
  font-size:0.66rem; font-weight:600; color:rgba(240,238,255,0.93);
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.3;
}
.alert-area {
  font-size:0.52rem; color:rgba(240,238,255,0.38); line-height:1.5;
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}

/* Bottom row: source chip + gov link */
.alert-footer {
  display:flex; align-items:center; justify-content:space-between;
  margin-top:3px; padding-top:7px;
  border-top:1px solid rgba(255,255,255,0.05);
}
.alert-source-chip {
  font-size:0.43rem; letter-spacing:0.08em; text-transform:uppercase;
  padding:2px 7px; border-radius:4px; white-space:nowrap;
  border:1px solid rgba(108,92,231,0.25); color:rgba(162,155,254,0.55);
  background:rgba(108,92,231,0.07);
}
.alert-gov-link {
  font-size:0.43rem; letter-spacing:0.06em; text-transform:uppercase;
  color:rgba(162,155,254,0.5); text-decoration:none;
  display:inline-flex; align-items:center; gap:4px;
  padding:2px 7px; border-radius:4px;
  border:1px solid rgba(108,92,231,0.18); background:rgba(108,92,231,0.05);
  transition:all 0.14s;
}
.alert-gov-link:hover {
  color:#a29bfe; border-color:rgba(108,92,231,0.45); background:rgba(108,92,231,0.15);
}


.no-alerts {
  padding:48px 20px; text-align:center; font-size:0.62rem;
  color:rgba(240,238,255,0.2); letter-spacing:0.08em; line-height:2.4;
}

/* LEGEND — bottom left corner, horizontal pill */
#legend {
  position:fixed; bottom:20px; left:20px; z-index:900;
  background:rgba(5,4,18,0.94); border:1px solid rgba(108,92,231,0.2);
  border-radius:12px; padding:11px 20px;
  backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
  display:flex; align-items:center; gap:16px;
  box-shadow:0 4px 24px rgba(0,0,0,0.35);
}
.legend-title {
  font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase;
  color:rgba(240,238,255,0.35); white-space:nowrap; margin-right:2px;
}
.legend-items { display:flex; align-items:center; gap:14px; }
.legend-item { display:flex; align-items:center; gap:7px; }
.legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.legend-label { font-size:0.68rem; color:rgba(240,238,255,0.55); white-space:nowrap; font-weight:500; }

/* TIMELINE */
#timeline {
  position:fixed; bottom:16px; left:50%; transform:translateX(-50%);
  z-index:900;
  background:rgba(3,3,10,0.92); border:1px solid rgba(255,255,255,0.09);
  border-radius:16px; padding:12px 18px 14px;
  backdrop-filter:blur(20px);
  width:min(540px, calc(100vw - 32px));
}
.tl-row1 {
  display:flex; align-items:center; gap:12px; margin-bottom:10px;
}
#play-btn {
  width:30px; height:30px; border-radius:50%; flex-shrink:0;
  background:rgba(108,92,231,0.2); border:1.5px solid rgba(108,92,231,0.5);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.18s;
}
#play-btn:hover { background:rgba(108,92,231,0.45); transform:scale(1.06); }
#play-btn svg { width:12px; height:12px; fill:#a29bfe; }
#time-display {
  flex:1; text-align:center;
  font-size:0.65rem; color:rgba(240,238,255,0.5); letter-spacing:0.05em;
}
#time-display .t-time { color:#f0eeff; font-weight:700; }
#time-display .t-sep  { color:rgba(240,238,255,0.2); margin:0 5px; }
#time-display .t-ago  { color:rgba(162,155,254,0.8); }
#time-display .t-pos  { color:rgba(240,238,255,0.25); font-size:0.55rem; }

/* Scrubber */
#scrubber-outer { position:relative; }
#scrubber-track {
  width:100%; height:5px; border-radius:999px;
  background:rgba(255,255,255,0.1); position:relative; cursor:pointer;
}
#scrubber-fill {
  height:100%; border-radius:999px;
  background:linear-gradient(90deg,#6c5ce7,#a29bfe);
  width:0%; pointer-events:none; transition:width 0.05s;
}
#scrubber-thumb {
  position:absolute; top:50%; left:0%;
  width:14px; height:14px; border-radius:50%;
  background:#a29bfe; border:2px solid #fff;
  box-shadow:0 0 8px rgba(162,155,254,0.7);
  transform:translate(-50%,-50%);
  pointer-events:none;
}
#scrubber-ticks {
  display:flex; justify-content:space-between;
  margin-top:8px; padding:0 1px;
}
.tick-label {
  font-size:0.5rem; color:rgba(240,238,255,0.3);
  font-family:"JetBrains Mono",monospace; letter-spacing:0;
  line-height:1;
}
.tick-label.is-now { color:#a29bfe; font-weight:700; }

/* status */
#radar-status {
  position:fixed; top:64px; left:50%; transform:translateX(-50%);
  z-index:1100; background:rgba(3,3,10,0.9); border:1px solid rgba(255,255,255,0.1);
  border-radius:8px; padding:6px 14px; font-size:0.58rem; color:rgba(240,238,255,0.6);
  letter-spacing:0.08em; pointer-events:none; opacity:0; transition:opacity 0.3s;
}
#radar-status.show { opacity:1; }

/* Leaflet overrides */
.leaflet-container { background:#03030a !important; }
.leaflet-tile-pane { filter:brightness(0.88) saturate(0.5); }
.leaflet-pane.radar-pane { filter:none !important; }
.leaflet-control-zoom a {
  background:rgba(3,3,10,0.9) !important; color:rgba(240,238,255,0.7) !important;
  border-color:rgba(255,255,255,0.1) !important; font-family:"JetBrains Mono",monospace !important;
}
.leaflet-control-zoom a:hover { background:rgba(108,92,231,0.3) !important; color:#fff !important; }
.leaflet-control-attribution {
  background:rgba(3,3,10,0.7) !important; color:rgba(240,238,255,0.2) !important;
  font-family:"JetBrains Mono",monospace !important; font-size:9px !important;
}
.leaflet-control-attribution a { color:rgba(162,155,254,0.5) !important; }
.alert-tooltip {
  background:rgba(3,3,10,0.95) !important; border:1px solid rgba(255,71,87,0.3) !important;
  border-radius:6px !important; color:#f0eeff !important;
  font-family:"JetBrains Mono",monospace !important; font-size:0.6rem !important;
  padding:7px 10px !important; box-shadow:0 4px 20px rgba(0,0,0,0.5) !important;
}
</style>
</head>
<body>

<div id="beta-overlay">
  <div id="beta-modal">
    <div class="beta-modal-icon">🚧</div>
    <div class="beta-modal-title">This site is in Beta</div>
    <div class="beta-modal-sub">koels.site — Radar</div>
    <div class="beta-modal-body">
      Some features on this page are <b>not fully functional</b> yet.<br><br>
      Radar playback, scrubbing, and global coverage are still being worked on.
      You may encounter bugs or incomplete behavior.
    </div>
    <div class="beta-modal-footer">
      <button class="beta-dismiss-btn" onclick="
        if(document.getElementById('beta-no-show').checked){
          try{localStorage.setItem('beta_dismissed','1')}catch(e){}
        }
        document.getElementById('beta-overlay').style.display='none';
      ">Got it</button>
      <label class="beta-dont-show">
        <input type="checkbox" id="beta-no-show"> Don’t show again
      </label>
    </div>
  </div>
</div>
<script>
  try{if(localStorage.getItem('beta_dismissed')==='1')document.getElementById('beta-overlay').style.display='none';}catch(e){}
</script>
<div id="map"></div>
<div id="radar-status" id="radar-status">Loading radar…</div>

<div id="header">
  <div class="header-left">
    <a class="back-btn" href="/">
      <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      Back
    </a>
    <div class="hdiv"></div>
    <div class="radar-logo">
      <div class="radar-logo-icon">
        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
          <defs><radialGradient id="rg" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#a29bfe" stop-opacity="0.9"/>
            <stop offset="100%" stop-color="#6c5ce7" stop-opacity="0"/>
          </radialGradient></defs>
          <circle cx="16" cy="16" r="14" fill="none" stroke="rgba(108,92,231,0.2)" stroke-width="1"/>
          <circle cx="16" cy="16" r="10" fill="none" stroke="rgba(108,92,231,0.3)" stroke-width="1"/>
          <circle cx="16" cy="16" r="6"  fill="none" stroke="rgba(108,92,231,0.5)" stroke-width="1"/>
          <circle cx="16" cy="16" r="2"  fill="#a29bfe"/>
          <line x1="16" y1="16" x2="28" y2="6" stroke="url(#rg)" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="23" cy="9" r="1.8" fill="#00ff88" opacity="0.85">
            <animate attributeName="opacity" values="0.85;0.1;0.85" dur="1.8s" repeatCount="indefinite"/>
            <animate attributeName="r" values="1.8;2.4;1.8" dur="1.8s" repeatCount="indefinite"/>
          </circle>
        </svg>
      </div>
      <div>
        <div style="display:flex;align-items:center;gap:7px;">
          <div class="radar-logo-main">Radar</div>
          <span class="beta-badge">BETA</span>
        </div>
        <div class="radar-logo-sub">koels.site</div>
      </div>
    </div>
  </div>
  <div class="header-right">
    <div class="alert-pill none" id="alert-pill">
      <svg viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z"/></svg>
      <span id="alert-num">0</span>&nbsp;Alerts
    </div>
    <div id="last-updated">—</div>
  </div>
</div>

<div id="panel">
  <div class="panel-header">
    <span class="panel-header-title">Active Alerts</span>
    <span class="panel-header-count" id="panel-count">0</span>
  </div>
  <div id="region-tabs">
    <button class="rtab active" data-region="ALL" onclick="filterRegion(this)">All</button>
    <button class="rtab" data-region="US"  onclick="filterRegion(this)">US</button>
    <button class="rtab" data-region="EU"  onclick="filterRegion(this)">EU</button>
    <button class="rtab" data-region="CA"  onclick="filterRegion(this)">CA</button>
    <button class="rtab" data-region="AU"  onclick="filterRegion(this)">AU</button>
    <button class="rtab" data-region="NZ"  onclick="filterRegion(this)">NZ</button>
  </div>
  <div id="alerts-list"><div class="no-alerts">Loading alerts…</div></div>
</div>
<div id="panel-toggle" onclick="togglePanel()">
  <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
</div>

<div id="legend">
  <div class="legend-title">Severity</div>
  <div class="legend-items">
    <div class="legend-item"><div class="legend-dot" style="background:#ff00cc"></div><div class="legend-label">Extreme</div></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ff3737"></div><div class="legend-label">Severe</div></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ff9500"></div><div class="legend-label">Moderate</div></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ffd60a"></div><div class="legend-label">Minor</div></div>
  </div>
</div>

<div id="timeline">
  <div class="tl-row1">
    <div id="play-btn" onclick="togglePlay()">
      <svg id="play-icon"  viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      <svg id="pause-icon" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </div>
    <div id="time-display">
      <span class="t-time">--:-- --</span>
      <span class="t-sep">·</span>
      <span class="t-ago">Loading…</span>
    </div>
  </div>
  <div id="scrubber-outer">
    <div id="scrubber-track">
      <div id="scrubber-fill"></div>
      <div id="scrubber-thumb"></div>
    </div>
    <div id="scrubber-ticks"></div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
window.addEventListener('DOMContentLoaded', function() {

// ── MAP SETUP ──────────────────────────────────────────────────────────────
const map = L.map('map', {
  center: [37, -95], zoom: 4,
  zoomControl: true,
  preferCanvas: true
});

// CartoDB Dark Matter — free, no API key
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap contributors © CARTO',
  subdomains: 'abcd', maxZoom: 19
}).addTo(map);

// Custom pane for radar tiles so they are NOT affected by the base tile CSS filter
map.createPane('radarPane');
map.getPane('radarPane').style.zIndex = 300;
map.getPane('radarPane').classList.add('radar-pane');

// ── RADAR SOURCES ────────────────────────────────────────────────────────
//
// 1. RainViewer  — GLOBAL base, animated XYZ tiles, ~180 countries, zoom 8
// 2. IEM NEXRAD  — US/CONUS overlay, animated XYZ, zoom 10, high detail
// 3. MSC GeoMet  — Canada WMS overlay, free, no key
// 4. DWD         — Germany/Europe WMS overlay, free, no key
//
// RainViewer drives the master frame count (~12 past frames, 10-min steps).
// IEM/MSC/DWD are synced to the same timestamps.
// All layers coexist — each covers its region and returns transparent elsewhere.

const FRAME_MS = 600;
const HOLD_MS  = 1800;

// IEM time slots matching approx 10-min intervals to align with RainViewer
const IEM_SLOTS = [
  { ts:'900913-m50m', minsAgo:50 }, { ts:'900913-m45m', minsAgo:45 },
  { ts:'900913-m40m', minsAgo:40 }, { ts:'900913-m35m', minsAgo:35 },
  { ts:'900913-m30m', minsAgo:30 }, { ts:'900913-m25m', minsAgo:25 },
  { ts:'900913-m20m', minsAgo:20 }, { ts:'900913-m15m', minsAgo:15 },
  { ts:'900913-m10m', minsAgo:10 }, { ts:'900913-m05m', minsAgo: 5 },
  { ts:'900913',      minsAgo: 0 },
];

// frames[i] = { minsAgo, time, rvLayer, iemLayer }
let frames     = [];
let currentIdx = 0;
let playing    = false;
let playTimer  = null;
let seqId      = 0;
let activeRV   = null;
let activeIEM  = null;

// WMS overlays (static, update TIME param each frame)
let wmsCanada = null;
let wmsDWD    = null;

function setStatus(msg, show) {
  const el = document.getElementById('radar-status');
  el.textContent = msg;
  el.classList.toggle('show', !!show);
}

function isoUTC(d) {
  return d.toISOString().replace(/\.\d{3}Z$/, 'Z');
}

function floorMins(d, n) {
  return new Date(Math.floor(d.getTime() / (n * 60000)) * (n * 60000));
}

function buildWMSOverlays() {
  if (wmsCanada) { try { map.removeLayer(wmsCanada); } catch(e){} }
  if (wmsDWD)    { try { map.removeLayer(wmsDWD);    } catch(e){} }

  // Canada — MSC GeoMet 1km radar, free, no key
  wmsCanada = L.tileLayer.wms('https://geo.weather.gc.ca/geomet?', {
    layers: 'RADAR_1KM_RRAI', version: '1.3.0',
    format: 'image/png', transparent: true,
    opacity: 0.85, pane: 'radarPane', maxZoom: 19,
    attribution: 'MSC/ECCC'
  }).addTo(map);

  // Germany + Europe — DWD 1km radar, free, no key
  wmsDWD = L.tileLayer.wms('https://maps.dwd.de/geoserver/dwd/wms?', {
    layers: 'dwd:RX-Produkt', version: '1.3.0',
    format: 'image/png', transparent: true,
    opacity: 0.85, pane: 'radarPane', maxZoom: 19,
    attribution: 'DWD'
  }).addTo(map);
}

function updateWMSTime(minsAgo) {
  const t = floorMins(new Date(Date.now() - minsAgo * 60000), 5);
  const ts = isoUTC(t);
  if (wmsCanada) wmsCanada.setParams({ TIME: ts }, false);
  if (wmsDWD)    wmsDWD.setParams({ TIME: ts }, false);
}

async function loadRadar() {
  try {
    setStatus('Loading radar\u2026', true);

    // Fetch RainViewer manifest for global coverage
    const rv   = await (await fetch('https://api.rainviewer.com/public/weather-maps.json')).json();
    const rvPast = rv.radar?.past || [];
    if (!rvPast.length) { setStatus('No radar data', true); return; }

    stopPlay();  // stop before touching layers

    // Tear down old layers
    frames.forEach(f => {
      try { map.removeLayer(f.rvLayer);  } catch(e){}
      try { map.removeLayer(f.iemLayer); } catch(e){}
    });
    activeRV = null; activeIEM = null;

    const nowSec = Math.floor(Date.now() / 1000);
    const sz = 256;

    // Use IEM_SLOTS as master timeline; find closest RainViewer frame per slot
    frames = IEM_SLOTS.map((slot, i) => {
      const frameTime = nowSec - slot.minsAgo * 60;
      const closest   = rvPast.reduce((b, r) =>
        Math.abs(r.time - frameTime) < Math.abs(b.time - frameTime) ? r : b
      );
      return {
        minsAgo:  slot.minsAgo,
        time:     frameTime,
        // RainViewer — global base (entire world)
        rvLayer:  L.tileLayer(
          rv.host + closest.path + '/' + sz + '/{z}/{x}/{y}/2/1_1.png',
          { opacity: 0, pane: 'radarPane', maxNativeZoom: 8, maxZoom: 19 }
        ),
        // IEM NEXRAD — US high-res overlay (transparent outside CONUS)
        iemLayer: L.tileLayer(
          `https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/nexrad-n0q-${slot.ts}/{z}/{x}/{y}.png`,
          { opacity: 0, pane: 'radarPane', maxNativeZoom: 10, maxZoom: 19 }
        )
      };
    });

    // Preload all at opacity 0
    frames.forEach(f => {
      f.rvLayer.addTo(map);
      f.iemLayer.addTo(map);
      // Hide IEM error tiles returned outside CONUS
      f.iemLayer.on('tileerror', evt => { evt.tile.style.display = 'none'; });
    });

    // Build/update WMS overlays
    buildWMSOverlays();
    buildTicks();

    // Show latest frame then autoplay
    // Use a simple shown flag — no seqId check here so the fallback always fires
    let shown = false;
    const go = () => {
      if (shown) return;
      shown = true;
      showFrame(frames.length - 1);
      setStatus('', false);
      startPlay();
    };
    // Try to trigger on tile load, but always fall back after 3s
    frames[frames.length - 1].rvLayer.once('load', go);
    setTimeout(go, 3000);

  } catch(e) {
    console.error('Radar load error:', e);
    setStatus('Radar unavailable', true);
  }
}

function showFrame(idx) {
  if (!frames.length) return;
  if (activeRV)  activeRV.setOpacity(0);
  if (activeIEM) activeIEM.setOpacity(0);
  currentIdx = Math.max(0, Math.min(idx, frames.length - 1));
  activeRV  = frames[currentIdx].rvLayer;  activeRV.setOpacity(0.75);
  activeIEM = frames[currentIdx].iemLayer; activeIEM.setOpacity(0.9);
  updateWMSTime(frames[currentIdx].minsAgo);
  updateUI();
}

function updateUI() {
  if (!frames.length) return;
  const f   = frames[currentIdx];
  const ago = f.minsAgo === 0 ? 'LIVE \u00b7 NOW' : `${f.minsAgo}m ago`;
  document.getElementById('time-display').innerHTML =
    `<span class="t-time">${fmtTime(f.time)}</span>` +
    `<span class="t-sep"> \u00b7 </span><span class="t-ago">${ago}</span>` +
    `<span class="t-sep"> \u00b7 </span><span class="t-pos">${currentIdx+1}/${frames.length}</span>`;
  const pct = frames.length > 1 ? (currentIdx / (frames.length - 1)) * 100 : 100;
  document.getElementById('scrubber-fill').style.width = pct + '%';
  document.getElementById('scrubber-thumb').style.left  = pct + '%';
}

function fmtTime(unixSec) {
  const t = new Date(unixSec * 1000);
  const h = t.getHours(), m = t.getMinutes();
  return `${((h % 12) || 12)}:${m.toString().padStart(2, '0')} ${h < 12 ? 'AM' : 'PM'}`;
}

function buildTicks() {
  if (!frames.length) return;
  const n = frames.length;
  const picks = [0, Math.floor(n * .25), Math.floor(n * .5), Math.floor(n * .75), n - 1];
  document.getElementById('scrubber-ticks').innerHTML =
    [...new Set(picks)].map(i => {
      const f = frames[i], isNow = f.minsAgo === 0;
      return `<span class="tick-label${isNow ? ' is-now' : ''}">${isNow ? 'NOW' : '-' + f.minsAgo + 'm'}</span>`;
    }).join('');
}

// ── PLAY / PAUSE ──────────────────────────────────────────────────────────
// seqId is incremented on every start/stop. Each scheduled timeout captures
// the seqId at the time it was scheduled — if seqId changed before it fires,
// it's stale and bails immediately. Guarantees zero ghost callbacks.

function setPlayIcon(on) {
  document.getElementById('play-icon').style.display  = on ? 'none' : '';
  document.getElementById('pause-icon').style.display = on ? ''     : 'none';
}

function _next(id, idx, delay) {
  clearTimeout(playTimer);
  playTimer = setTimeout(() => {
    if (id !== seqId) return;
    if (idx >= frames.length) {
      // Hold on last frame then loop
      showFrame(frames.length - 1);
      _next(id, 0, HOLD_MS);
    } else {
      showFrame(idx);
      _next(id, idx + 1, FRAME_MS);
    }
  }, delay);
}

function startPlay() {
  if (playing || !frames.length) return;
  playing = true;
  seqId++;
  setPlayIcon(true);
  const next = currentIdx >= frames.length - 1 ? 0 : currentIdx + 1;
  if (next === 0) showFrame(0);
  _next(seqId, next, FRAME_MS);
}

function stopPlay() {
  playing = false;
  seqId++;
  clearTimeout(playTimer);
  playTimer = null;
  setPlayIcon(false);
}

function togglePlay() {
  if (playing) stopPlay();
  else         startPlay();
}
// Expose to global scope so the inline onclick="togglePlay()" can reach it
window.togglePlay = togglePlay;

loadRadar();
setInterval(loadRadar, 300000);
// ── SCRUBBER ──────────────────────────────────────────────────────────────
function scrubTo(clientX) {
  const rect = document.getElementById('scrubber-track').getBoundingClientRect();
  const pct  = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
  if (playing) stopPlay();
  if (frames.length) showFrame(Math.round(pct * (frames.length - 1)));
}

let dragging = false;
const track = document.getElementById('scrubber-track');
track.addEventListener('mousedown',  e => { dragging = true; scrubTo(e.clientX); });
track.addEventListener('touchstart', e => { dragging = true; scrubTo(e.touches[0].clientX); }, {passive:true});
window.addEventListener('mousemove',  e => { if (dragging) scrubTo(e.clientX); });
window.addEventListener('touchmove',  e => { if (dragging) scrubTo(e.touches[0].clientX); }, {passive:true});
window.addEventListener('mouseup',   () => dragging = false);
window.addEventListener('touchend',  () => dragging = false);

// ── GLOBAL ALERTS ─────────────────────────────────────────────────────────
let alertLayers = [];
let cachedAlerts = [];
const SEV = { Extreme:'#ff00cc', Severe:'#ff2d2d', Moderate:'#ffa500', Minor:'#ffd600', Unknown:'rgba(255,255,255,0.3)' };
const sevOrder = { Extreme:0, Severe:1, Moderate:2, Minor:3, Unknown:4 };
const sevClass = s => 'sev-' + (s||'unknown').toLowerCase();
const timeAgo = iso => {
  if (!iso) return '';
  const d = Math.round((Date.now() - new Date(iso)) / 60000);
  return d < 60 ? `${d}m ago` : d < 1440 ? `${Math.round(d/60)}h ago` : `${Math.round(d/1440)}d ago`;
};

// Map bounds → which region APIs to query
// We always fetch NWS (US). For Europe we use MeteoAlarm via open-meteo proxy.
// For other regions we use Open-Meteo's global alert feed where available.

async function fetchNWSAlerts() {
  try {
    const data = await (await fetch('https://api.weather.gov/alerts/active?status=actual&message_type=alert&limit=500')).json();
    return (data.features||[]).map(f => ({
      severity: f.properties.severity || 'Unknown',
      event:    f.properties.event || 'Alert',
      area:     f.properties.areaDesc || '',
      sent:     f.properties.sent,
      geometry: f.geometry,
      region:   'US',
      source:   'NWS',
      url:      f.id || f.properties['@id'] || 'https://www.weather.gov/alerts'
    }));
  } catch(e) { return []; }
}

// ── CANADA — MSC GeoMet OGC API (free, no key, CORS-friendly) ─────────────
async function fetchCanadaAlerts() {
  try {
    const url = 'https://api.weather.gc.ca/collections/warnings/items?f=json&limit=500&lang=en';
    const data = await (await fetch(url)).json();
    return (data.features || []).map(f => {
      const p = f.properties || {};
      let sev = 'Minor';
      if (/warning/i.test(p.alert_name||''))    sev = 'Severe';
      if (/watch/i.test(p.alert_name||''))      sev = 'Moderate';
      if (/advisory/i.test(p.alert_name||''))   sev = 'Minor';
      if (/tornado|extreme/i.test(p.alert_name||'')) sev = 'Extreme';
      return {
        severity: sev,
        event:    p.alert_name || p.type || 'Weather Alert',
        area:     p.zone || p.location || 'Canada',
        sent:     p.effective || null,
        geometry: f.geometry,
        region:   'CA',
        source:   'ECCC',
        url:      p.url || 'https://weather.gc.ca/warnings/index_e.html'
      };
    });
  } catch(e) { return []; }
}

// ── AUSTRALIA — BOM public app API (no key required) ──────────────────────
// Source: api.weather.bom.gov.au — official Bureau of Meteorology backend
async function fetchAustraliaAlerts() {
  try {
    const data = await (await fetch(
      'https://api.weather.bom.gov.au/v1/warnings',
      { headers: { 'Accept': 'application/json' } }
    )).json();
    return (data.data || []).map(w => {
      // BOM warning_group_type: "flood_warning", "severe_thunderstorm_warning",
      // "tropical_cyclone_warning", "fire_weather_warning", "coastal_hazard_warning", etc.
      const wtype = (w.warning_group_type || '').toLowerCase();
      let sev = 'Minor';
      if (/tropical_cyclone|extreme/i.test(wtype))           sev = 'Extreme';
      else if (/severe_thunderstorm|major_flood|fire_weather/i.test(wtype)) sev = 'Severe';
      else if (/moderate_flood|coastal_hazard|strong_wind/i.test(wtype))    sev = 'Moderate';

      // Build a clean area string: prefer the full title location over bare state code
      // BOM title is e.g. "Flood Warning for the Daly River" — strip the warning type prefix
      const rawTitle = w.title || w.short_title || 'Weather Warning';
      // area: pull the "for..." part of the title if present, else fall back to state
      const forMatch = rawTitle.match(/for(.+)/i);
      const area = forMatch
        ? forMatch[1].trim()
        : (w.state ? w.state.toUpperCase() : 'Australia');

      // Event label: strip trailing location noise to keep it concise
      const event = rawTitle
        .replace(/\s+for\s+.+/i, '')   // "Flood Warning" not "Flood Warning for the Daly River"
        .trim();

      return {
        severity: sev,
        event,
        area,
        sent:     w.issue_time || null,
        geometry: null,
        region:   'AU',
        source:   'BOM',
        url:      w.id ? 'https://www.bom.gov.au/products/' + w.id + '.shtml' : 'https://www.bom.gov.au/warnings/'
      };
    }).filter(a => a.event && !/cancel|terminated/i.test(a.event));
  } catch(e) { return []; }
}

// ── NEW ZEALAND — MetService public CAP Atom feed (no key) ─────────────────
async function fetchNZAlerts() {
  try {
    const r = await fetch('https://alerts.metservice.com/cap/rss');
    if (!r.ok) return [];
    const txt = await r.text();
    const doc = new DOMParser().parseFromString(txt, 'text/xml');
    return [...doc.querySelectorAll('item')].map(item => {
      const title = item.querySelector('title')?.textContent || 'Weather Alert';
      let sev = 'Minor';
      if (/severe|heavy|gale|extreme/i.test(title))   sev = 'Severe';
      if (/thunderstorm|tornado|cyclone/i.test(title)) sev = 'Extreme';
      const area = item.querySelector('description')?.textContent?.split(':')[0] || 'New Zealand';
      const nzLink = item.querySelector('link')?.textContent || 'https://www.metservice.com/warnings/home';
      return { severity:sev, event:title, area, sent:null, geometry:null, region:'NZ', source:'MetService', url:nzLink };
    });
  } catch(e) { return []; }
}

// US (NWS) + EU (MeteoAlarm) + Canada (MSC GeoMet) + Australia (BOM) + NZ (MetService)
async function loadAlerts() {
  alertLayers.forEach(l => { try { map.removeLayer(l); } catch(e){} });
  alertLayers = [];

  // Fetch all regions in parallel
  const [usAlerts, euAlerts, caAlerts, auAlerts, nzAlerts] = await Promise.all([
    fetchNWSAlerts(),
    fetchEUAlerts(),
    fetchCanadaAlerts(),
    fetchAustraliaAlerts(),
    fetchNZAlerts(),
  ]);

  const allAlerts = [...usAlerts, ...euAlerts, ...caAlerts, ...auAlerts, ...nzAlerts].sort((a,b) =>
    (sevOrder[a.severity]||4) - (sevOrder[b.severity]||4)
  );

  const total = allAlerts.length;
  document.getElementById('alert-num').textContent   = total;
  document.getElementById('panel-count').textContent = total;
  document.getElementById('alert-pill').className    = total ? 'alert-pill' : 'alert-pill none';
  document.getElementById('panel-toggle').classList.toggle('has-alerts', total > 0);

  // Update timestamp
  const now = new Date();
  document.getElementById('last-updated').textContent =
    `${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;

  // Store and render
  cachedAlerts = allAlerts;
  activeRegionFilter = 'ALL';
  // Reset tab highlight to ALL
  document.querySelectorAll('.rtab').forEach(t => t.classList.toggle('active', t.dataset.region === 'ALL'));
  renderAlertList();
  renderAlertLayers();
}

// ── ALERT LIST RENDERING ───────────────────────────────────────────────────
let activeRegionFilter = 'ALL';

function filterRegion(tab) {
  activeRegionFilter = tab.dataset.region;
  document.querySelectorAll('.rtab').forEach(t => t.classList.toggle('active', t === tab));
  renderAlertList();
}
window.filterRegion = filterRegion;

function makeAlertCard(a) {
  const item = document.createElement('div');
  item.className = `alert-item ${sevClass(a.severity)}`;

  const timeStr = timeAgo(a.sent);
  const sevColors = { Extreme:'#ff00cc', Severe:'#ff3737', Moderate:'#ff9500', Minor:'#ffd60a', Unknown:'rgba(255,255,255,0.25)' };
  const sevColor = sevColors[a.severity] || sevColors.Unknown;

  const govLinkHtml = a.url
    ? `<a class="alert-gov-link" href="${a.url}" target="_blank" rel="noopener" onclick="event.stopPropagation()">&#8599; View alert</a>`
    : '';

  item.innerHTML =
    `<div class="alert-bar"></div>` +
    `<div class="alert-body">` +
      `<div class="alert-top-row">` +
        `<div class="alert-sev-badge">` +
          `<span class="alert-sev-dot" style="background:${sevColor};box-shadow:0 0 5px ${sevColor}77"></span>` +
          `<span class="alert-sev-text" style="color:${sevColor}">${a.severity || 'Unknown'}</span>` +
        `</div>` +
        (timeStr ? `<span class="alert-time-chip">${timeStr}</span>` : '') +
      `</div>` +
      `<div class="alert-event" title="${a.event}">${a.event}</div>` +
      `<div class="alert-area" title="${a.area}">${a.area}</div>` +
      `<div class="alert-footer">` +
        (a.source ? `<span class="alert-source-chip">${a.source}</span>` : '<span></span>') +
        govLinkHtml +
      `</div>` +
    `</div>`;

  if (a.geometry) {
    item.addEventListener('click', (e) => {
      if (e.target.closest('.alert-gov-link')) return;
      map.flyToBounds(L.geoJSON(a.geometry).getBounds(), {padding:[60,60], duration:1.2});
    });
  }
  return item;
}

function renderAlertList() {
  const list = document.getElementById('alerts-list');
  const filtered = activeRegionFilter === 'ALL'
    ? cachedAlerts
    : cachedAlerts.filter(a => a.region === activeRegionFilter);

  if (!filtered.length) {
    list.innerHTML = cachedAlerts.length
      ? `<div class="no-alerts">No alerts for ${activeRegionFilter}.</div>`
      : `<div class="no-alerts">No active alerts.<br>All clear globally.</div>`;
    return;
  }

  list.innerHTML = '';

  // Group by severity
  const groups = [
    { key:'Extreme',  label:'Extreme' },
    { key:'Severe',   label:'Severe' },
    { key:'Moderate', label:'Moderate' },
    { key:'Minor',    label:'Minor' },
    { key:'Unknown',  label:'Other' },
  ];

  groups.forEach(g => {
    const items = filtered.filter(a => a.severity === g.key);
    if (!items.length) return;

    const hdr = document.createElement('div');
    hdr.className = 'alert-group-header';
    hdr.innerHTML =
      `<span class="alert-group-label">${g.label}</span>` +
      `<span class="alert-group-line"></span>` +
      `<span class="alert-group-n">${items.length}</span>`;
    list.appendChild(hdr);

    items.forEach(a => list.appendChild(makeAlertCard(a)));
  });
}

// Severity → minimum zoom level before showing on map
const SEV_MIN_ZOOM = { Extreme:2, Severe:3, Moderate:5, Minor:6, Unknown:7 };

function renderAlertLayers() {
  // Tear down existing layers safely
  alertLayers.forEach(l => { try { map.removeLayer(l); } catch(e){} });
  alertLayers = [];

  const zoom = map.getZoom();
  let drawn = 0;
  const MAX_LAYERS = 300; // hard cap to prevent frame-rate collapse

  cachedAlerts.forEach(a => {
    if (!a.geometry) return;
    if (drawn >= MAX_LAYERS) return;
    // Only render if zoom meets severity threshold
    const minZ = SEV_MIN_ZOOM[a.severity] ?? 6;
    if (zoom < minZ) return;

    const col = SEV[a.severity] || SEV.Unknown;
    // Thinner strokes and less fill at lower zooms for readability
    const weight = zoom < 5 ? 1 : 1.5;
    const fillOp = zoom < 5 ? 0.08 : 0.12;
    const gl = L.geoJSON(a.geometry, {
      style:{ color:col, fillColor:col, weight, opacity:0.85, fillOpacity:fillOp }
    });
    gl.bindTooltip(`<strong>${a.event}</strong><br>${a.area}`, { className:'alert-tooltip', sticky:true });
    gl.addTo(map);
    alertLayers.push(gl);
    drawn++;
  });
}

// Re-render alert polygons whenever the user zooms (throttled)
let _zoomTimer = null;
map.on('zoomend', () => {
  clearTimeout(_zoomTimer);
  _zoomTimer = setTimeout(renderAlertLayers, 150);
});

async function fetchEUAlerts() {
  // MeteoAlarm provides EU-wide severe weather alerts as GeoJSON — free, no key
  try {
    const data = await (await fetch('https://feeds.meteoalarm.org/api/v1/warnings/region/europe')).json();
    return (data.features||[]).map(f => {
      const p = f.properties||{};
      const awareness = p.awareness_level || '';
      // MeteoAlarm levels: 1=green(none), 2=yellow, 3=orange, 4=red
      const lvl = parseInt(awareness.split(';')[0]) || 1;
      const sev = lvl >= 4 ? 'Extreme' : lvl === 3 ? 'Severe' : lvl === 2 ? 'Moderate' : 'Minor';
      const EU_AGENCY = {
        AT:'ZAMG',BE:'RMI',BG:'NIMH',HR:'DHMZ',CY:'CMS',CZ:'CHMI',
        DK:'DMI',EE:'EMI',FI:'FMI',FR:'Météo-France',DE:'DWD',
        GR:'EMY',HU:'OMSZ',IS:'IMO',IE:'Met Éireann',IT:'ARPA',
        LV:'LVGMC',LT:'LHMT',LU:'MeteoLux',MT:'MMS',NL:'KNMI',
        NO:'MET Norway',PL:'IMGW',PT:'IPMA',RO:'ANM',RS:'RHMSS',
        SK:'SHMU',SI:'ARSO',ES:'AEMET',SE:'SMHI',CH:'MeteoSwiss',
        GB:'Met Office',UA:'UHC',TR:'MGM',ME:'IHMS',MK:'UHMR',
        AL:'IGJEO',BA:'FHMZBIH',MD:'SHS'
      };
      const cc = (p.country||'').toUpperCase();
      const agency = EU_AGENCY[cc] || (cc||'MeteoAlarm');
      return {
        severity: sev,
        event:    p.awareness_type ? p.awareness_type.split(';')[1] || 'Weather Alert' : 'Weather Alert',
        area:     p.region_name || p.country || 'Europe',
        sent:     p.from || null,
        geometry: f.geometry,
        region:   'EU',
        source:   agency,
        url:      'https://www.meteoalarm.org/en/live/'
      };
    });
  } catch(e) {
    // Fallback: try the CORS-friendly GeoJSON endpoint
    try {
      const r = await fetch('https://feeds.meteoalarm.org/feeds/meteoalarm-legacy-atom-europe');
      // RSS fallback — skip if CORS blocked
      return [];
    } catch(e2) { return []; }
  }
}

function togglePanel() { document.getElementById('panel').classList.toggle('open'); }
window.togglePanel = togglePanel;

loadAlerts();
setInterval(loadAlerts, 60000);

// ── BETA DISCLAIMER handled inline on the modal button ───────────────────

});
