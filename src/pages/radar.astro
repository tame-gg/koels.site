// ── US SPC — Storm Prediction Center watches (tornado/severe tstm) ────────
async function fetchSPCWatches() {
  try {
    // SPC provides active watches as GeoJSON
    const data = await (await fetch('https://www.spc.noaa.gov/products/watch/active-watches.geojson')).json();
    return (data.features || []).map(f => {
      const p = f.properties || {};
      const evt = (p.type || p.event || '').toLowerCase();
      // SPC watches are always either tornado or severe thunderstorm
      const isTornado = /tornado/.test(evt);
      const sev = isTornado ? 'Extreme' : 'Severe';
      const tag = isTornado ? 'TORNADO WATCH' : 'SEVERE TSTM WATCH';

      return {
        severity: sev,
        event:    p.type || p.event || 'SPC Watch',
        tag,
        area:     p.countyname || p.state || '',
        sent:     p.date || null,
        geometry: f.geometry,
        region:   'US',
        source:   'SPC',
        url:      'https://www.spc.noaa.gov/products/watch/',
        instruction: null,
        headline: p.description || null
      };
    });
  } catch(e) { return []; }
}

// ── US NHC — National Hurricane Center tropical alerts ─────────────────────
async function fetchNHCAlerts() {
  try {
    // NHC provides active tropical cyclone advisories as GeoJSON
    const data = await (await fetch('https://www.nhc.noaa.gov/gis/atcf/active.json')).json();
    return (data.features || []).map(f => {
      const p = f.properties || {};
      const name = p.name || 'Tropical Cyclone';
      const type = (p.type || '').toLowerCase();
      let sev = 'Moderate';
      let tag = 'TROPICAL';
      if (/hurricane|major hurricane/.test(type)) { sev = 'Extreme'; tag = 'HURRICANE'; }
      else if (/tropical storm/.test(type)) { sev = 'Severe'; tag = 'TROPICAL STORM'; }
      else if (/tropical depression/.test(type)) { sev = 'Moderate'; tag = 'TROPICAL DEPRESSION'; }
      else if (/invest/.test(type)) { sev = 'Minor'; tag = 'INVEST'; }

      return {
        severity: sev,
        event:    `${name} — ${p.type || 'Tropical Cyclone'}`,
        tag,
        area:     p.basin || 'Atlantic/Pacific',
        sent:     p.advisoryDate || null,
        geometry: f.geometry,
        region:   'US',
        source:   'NHC',
        url:      'https://www.nhc.noaa.gov/',
        instruction: null,
        headline: `${name}: ${p.type}`
      };
    });
  } catch(e) { return []; }
}

// US (NWS) + EU (MeteoAlarm) + Canada (MSC GeoMet) + Australia (BOM) + NZ (MetService)
// + South America (GDACS) + Japan (JMA/GDACS) + India (IMD/GDACS)
// + US SPC (Storm Prediction Center watches) + US NHC (National Hurricane Center)
async function loadAlerts() {
  _gdacsPromise = null; // Reset cache so each load cycle fetches fresh data
  alertLayers.forEach(l => { try { map.removeLayer(l); } catch(e){} });
  alertLayers = [];

  // Fetch all regions and supplemental sources in one parallel batch
  const [usAlerts, euAlerts, caAlerts, auAlerts, nzAlerts, saAlerts, jpAlerts, inAlerts, spcWatches, nhcAlerts] = await Promise.all([
    fetchNWSAlerts(),
    fetchEUAlerts(),
    fetchCanadaAlerts(),
    fetchAustraliaAlerts(),
    fetchNZAlerts(),
    fetchSouthAmericaAlerts(),
    fetchJapanAlerts(),
    fetchIndiaAlerts(),
    fetchSPCWatches(),
    fetchNHCAlerts(),
  ]);

  const allAlerts = [...usAlerts, ...euAlerts, ...caAlerts, ...auAlerts, ...nzAlerts, ...saAlerts, ...jpAlerts, ...inAlerts, ...spcWatches, ...nhcAlerts].sort((a,b) =>
    (sevOrder[a.severity]||4) - (sevOrder[b.severity]||4)
  );

  const total = allAlerts.length;
  document.getElementById('alert-num').textContent   = total;
  document.getElementById('panel-count').textContent = total;
  document.getElementById('alert-pill').classList.toggle('none', !total);
  document.getElementById('panel-toggle').classList.toggle('has-alerts', total > 0);

  // Update timestamp
  const now = new Date();
  document.getElementById('last-updated').textContent =
    `${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;

  // Store and render
  cachedAlerts = allAlerts;
  activeRegionFilter = 'ALL';
  // Reset tab highlight to ALL
  document.querySelectorAll('.rtab').forEach(t => t.classList.toggle('active', t.dataset.region === 'ALL'));
  renderAlertList();
  renderAlertLayers();
}

// ── ALERT LIST RENDERING ───────────────────────────────────────────────────
let activeRegionFilter = 'ALL';

function filterRegion(tab) {
  activeRegionFilter = tab.dataset.region;
  document.querySelectorAll('.rtab').forEach(t => t.classList.toggle('active', t === tab));
  renderAlertList();
}
window.filterRegion = filterRegion;

function escHtml(s) {
  return String(s || '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}
function safeUrl(u) {
  if (!u) return '';
  try {
    const p = new URL(u);
    return (p.protocol === 'http:' || p.protocol === 'https:') ? u : '';
  } catch(e) { return ''; }
}

function makeAlertCard(a) {
  const item = document.createElement('div');
  item.className = `alert-item ${sevClass(a.severity)}`;

  const timeStr = timeAgo(a.sent);
  const sevColors = { Extreme:'#ff00cc', Severe:'#ff3737', Moderate:'#ff9500', Minor:'#ffd60a', Unknown:'rgba(255,255,255,0.25)' };
  const sevColor = sevColors[a.severity] || sevColors.Unknown;

  // Tag pill (e.g. TORNADO, SEVERE TSTM, FLOOD, etc.)
  const tagHtml = a.tag
    ? `<span class="alert-tag-chip" style="border-color:${sevColor}44;color:${sevColor};background:${sevColor}11">${escHtml(a.tag)}</span>`
    : '';

  const cleanUrl = safeUrl(a.url);
  const govLinkHtml = cleanUrl
    ? `<a class="alert-gov-link" href="${escHtml(cleanUrl)}" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">&#8599; View alert</a>`
    : '';

  const eSev   = escHtml(a.severity || 'Unknown');
  const eEvent = escHtml(a.event);
  const eArea  = escHtml(a.area);
  const eSrc   = escHtml(a.source);
  const eTime  = escHtml(timeStr);

  item.innerHTML =
    `<div class="alert-bar"></div>` +
    `<div class="alert-body">` +
      `<div class="alert-top-row">` +
        `<div class="alert-sev-badge">` +
          `<span class="alert-sev-dot" style="background:${sevColor};box-shadow:0 0 5px ${sevColor}77"></span>` +
          `<span class="alert-sev-text" style="color:${sevColor}">${eSev}</span>` +
        `</div>` +
        (eTime ? `<span class="alert-time-chip">${eTime}</span>` : '') +
      `</div>` +
      (tagHtml ? `<div class="alert-tag-row">${tagHtml}</div>` : '') +
      `<div class="alert-event" title="${eEvent}">${eEvent}</div>` +
      `<div class="alert-area" title="${eArea}">${eArea}</div>` +
      `<div class="alert-footer">` +
        (eSrc ? `<span class="alert-source-chip">${eSrc}</span>` : '<span></span>') +
        govLinkHtml +
      `</div>` +
    `</div>`;

  if (a.geometry) {
    item.dataset.clickable = 'true';
    item.style.cursor = 'pointer';
    item.addEventListener('click', (e) => {
      if (e.target.closest('.alert-gov-link')) return;
      map.flyToBounds(L.geoJSON(a.geometry).getBounds(), {padding:[60,60], duration:1.2});
    });
  }
  return item;
}

function renderAlertList() {
  const list = document.getElementById('alerts-list');
  const filtered = activeRegionFilter === 'ALL'
    ? cachedAlerts
    : cachedAlerts.filter(a => a.region === activeRegionFilter);

  if (!filtered.length) {
    list.innerHTML = cachedAlerts.length
      ? `<div class="no-alerts">No alerts for ${activeRegionFilter}.</div>`
      : `<div class="no-alerts">No active alerts.<br>All clear globally.</div>`;
    return;
  }

  list.innerHTML = '';

  // Group by severity
  const groups = [
    { key:'Extreme',  label:'Extreme' },
    { key:'Severe',   label:'Severe' },
    { key:'Moderate', label:'Moderate' },
    { key:'Minor',    label:'Minor' },
    { key:'Unknown',  label:'Other' },
  ];

  groups.forEach(g => {
    const items = filtered.filter(a => a.severity === g.key);
    if (!items.length) return;

    const hdr = document.createElement('div');
    hdr.className = 'alert-group-header';
    hdr.innerHTML =
      `<span class="alert-group-label">${g.label}</span>` +
      `<span class="alert-group-line"></span>` +
      `<span class="alert-group-n">${items.length}</span>`;
    list.appendChild(hdr);

    items.forEach(a => list.appendChild(makeAlertCard(a)));
  });
}

// Severity → minimum zoom level before showing on map
const SEV_MIN_ZOOM = { Extreme:2, Severe:3, Moderate:5, Minor:6, Unknown:7 };

function renderAlertLayers() {
  // Tear down existing layers safely
  alertLayers.forEach(l => { try { map.removeLayer(l); } catch(e){} });
  alertLayers = [];

  const zoom = map.getZoom();
  let drawn = 0;
  const MAX_LAYERS = 300; // hard cap to prevent frame-rate collapse

  cachedAlerts.forEach(a => {
    if (!a.geometry) return;
    if (drawn >= MAX_LAYERS) return;
    // Only render if zoom meets severity threshold
    const minZ = SEV_MIN_ZOOM[a.severity] ?? 6;
    if (zoom < minZ) return;

    const col = SEV[a.severity] || SEV.Unknown;
    // Thinner strokes and less fill at lower zooms for readability
    const weight = zoom < 5 ? 1 : 1.5;
    const fillOp = zoom < 5 ? 0.08 : 0.12;
    const gl = L.geoJSON(a.geometry, {
      style:{ color:col, fillColor:col, weight, opacity:0.85, fillOpacity:fillOp }
    });
    gl.bindTooltip(`<strong>${a.event}</strong><br>${a.area}`, { className:'alert-tooltip', sticky:true });
    gl.addTo(map);
    alertLayers.push(gl);
    drawn++;
  });
}

// Re-render alert polygons AND refresh regional overlays when the user zooms or pans (throttled)
let _zoomTimer = null;
let _lastRegionCheck = '';
map.on('zoomend moveend', () => {
  clearTimeout(_zoomTimer);
  _zoomTimer = setTimeout(() => {
    renderAlertLayers();
    // Check if we moved to a new region (debounced)
    const c = map.getCenter();
    const key = detectRegion(c.lat, c.lng);
    if (key !== _lastRegionCheck) {
      _lastRegionCheck = key;
      refreshRadarForRegion();
    }
    // Force tiles to redraw at new zoom
    if (activeRV && map.hasLayer(activeRV)) activeRV.redraw();
    if (activeIEM && map.hasLayer(activeIEM)) activeIEM.redraw();
  }, 200);
});

async function fetchEUAlerts() {
  // MeteoAlarm provides EU-wide severe weather alerts as GeoJSON — free, no key
  try {
    const data = await (await fetch('https://feeds.meteoalarm.org/api/v1/warnings/region/europe')).json();
    return (data.features||[]).map(f => {
      const p = f.properties||{};
      const awareness = p.awareness_level || '';
      const awarenessType = (p.awareness_type || '').toLowerCase();
      // MeteoAlarm levels: 1=green(none), 2=yellow, 3=orange, 4=red
      const lvl = parseInt(awareness.split(';')[0]) || 1;
      const sev = lvl >= 4 ? 'Extreme' : lvl === 3 ? 'Severe' : lvl === 2 ? 'Moderate' : 'Minor';
      const EU_AGENCY = {
        AT:'ZAMG',BE:'RMI',BG:'NIMH',HR:'DHMZ',CY:'CMS',CZ:'CHMI',
        DK:'DMI',EE:'EMI',FI:'FMI',FR:'Météo-France',DE:'DWD',
        GR:'EMY',HU:'OMSZ',IS:'IMO',IE:'Met Éireann',IT:'ARPA',
        LV:'LVGMC',LT:'LHMT',LU:'MeteoLux',MT:'MMS',NL:'KNMI',
        NO:'MET Norway',PL:'IMGW',PT:'IPMA',RO:'ANM',RS:'RHMSS',
        SK:'SHMU',SI:'ARSO',ES:'AEMET',SE:'SMHI',CH:'MeteoSwiss',
        GB:'Met Office',UA:'UHC',TR:'MGM',ME:'IHMS',MK:'UHMR',
        AL:'IGJEO',BA:'FHMZBIH',MD:'SHS'
      };
      const cc = (p.country||'').toUpperCase();
      const agency = EU_AGENCY[cc] || (cc||'MeteoAlarm');

      // Determine tag based on awareness type
      let tag = '';
      if (/thunderstorm/.test(awarenessType)) tag = 'SEVERE TSTM';
      else if (/tornado/.test(awarenessType)) tag = 'TORNADO';
      else if (/rain|flood/.test(awarenessType)) tag = 'FLOOD';
      else if (/wind/.test(awarenessType)) tag = 'HIGH WIND';
      else if (/snow|ice/.test(awarenessType)) tag = 'WINTER STORM';
      else if (/heat|temperature/.test(awarenessType)) tag = 'HEAT';
      else if (/cold|frost/.test(awarenessType)) tag = 'EXTREME COLD';
      else if (/fog/.test(awarenessType)) tag = 'FOG';
      else if (/coastal/.test(awarenessType)) tag = 'COASTAL HAZARD';
      else if (/forest.?fire|wildfire/.test(awarenessType)) tag = 'FIRE DANGER';
      else if (/avalanche/.test(awarenessType)) tag = 'AVALANCHE';
      else if (/rainbow|rain/.test(awarenessType)) tag = 'HEAVY RAIN';

      return {
        severity: sev,
        event:    p.awareness_type ? p.awareness_type.split(';')[1] || 'Weather Alert' : 'Weather Alert',
        tag,
        area:     p.region_name || p.country || 'Europe',
        sent:     p.from || null,
        geometry: f.geometry,
        region:   'EU',
        source:   agency,
        url:      'https://www.meteoalarm.org/en/live/',
        instruction: p.description || null,
        headline: p.awareness_type || null
      };
    });
  } catch(e) {
    try {
      const r = await fetch('https://feeds.meteoalarm.org/feeds/meteoalarm-legacy-atom-europe');
      if (!r.ok) return [];
      const txt = await r.text();
      const doc = new DOMParser().parseFromString(txt, 'text/xml');
      return [...doc.querySelectorAll('entry')].map(entry => {
        const title   = entry.querySelector('title')?.textContent   || 'Weather Alert';
        const id      = entry.querySelector('id')?.textContent       || '';
        const updated = entry.querySelector('updated')?.textContent  || null;
        const summary = entry.querySelector('summary')?.textContent  || '';
        const ccMatch = id.match(/\/([A-Z]{2})\//);
        const cc = ccMatch ? ccMatch[1] : '';
        const t = title.toLowerCase();
        let sev = 'Minor';
        if (/extreme|red/.test(t))         sev = 'Extreme';
        else if (/severe|orange/.test(t))  sev = 'Severe';
        else if (/moderate|yellow/.test(t)) sev = 'Moderate';
        let tag = '';
        if (/thunderstorm/.test(t))        tag = 'SEVERE TSTM';
        else if (/tornado/.test(t))        tag = 'TORNADO';
        else if (/wind/.test(t))           tag = 'HIGH WIND';
        else if (/rain|flood/.test(t))     tag = 'FLOOD';
        else if (/snow|ice/.test(t))       tag = 'WINTER STORM';
        else if (/heat/.test(t))           tag = 'HEAT';
        else if (/fog/.test(t))            tag = 'FOG';
        return { severity: sev, event: title, tag, area: cc || 'Europe', sent: updated, geometry: null, region: 'EU', source: 'MeteoAlarm', url: 'https://www.meteoalarm.org/en/live/', instruction: null, headline: summary };
      });
    } catch(e2) { return []; }
  }
}

function togglePanel() {
  const panel   = document.getElementById('panel');
  const toggle  = document.getElementById('panel-toggle');
  const pill    = document.getElementById('alert-pill');
  const isOpen  = panel.classList.toggle('open');
  toggle.setAttribute('aria-expanded', isOpen);
  pill.setAttribute('aria-expanded',   isOpen);
  // On mobile the panel overlaps the weather widget — hide it while panel is open
  if (window.matchMedia('(max-width: 640px)').matches) {
    document.getElementById('weather-widget').classList.toggle('panel-hidden', isOpen);
  }
}
window.togglePanel = togglePanel;

// Swipe down to close panel on mobile
(function() {
  const panel = document.getElementById('panel');
  let startY = 0, startTime = 0;
  panel.addEventListener('touchstart', e => {
    startY = e.touches[0].clientY;
    startTime = Date.now();
  }, { passive:true });
  panel.addEventListener('touchend', e => {
    const dy = e.changedTouches[0].clientY - startY;
    const dt = Date.now() - startTime;
    if (dy > 60 && dt < 400) togglePanel(); // swipe down fast
  }, { passive:true });
})();

// ── LOCATE ME ─────────────────────────────────────────────────────────────
window.locateMe = function() {
  if (!navigator.geolocation) {
    setStatus('Geolocation is not supported by your browser.', true);
    setTimeout(() => setStatus('', false), 4000);
    return;
  }
  const btn = document.getElementById('locate-btn');
  btn.classList.add('locating');
  setStatus('Getting location…', true);
  navigator.geolocation.getCurrentPosition(
    (pos) => {
      btn.classList.remove('locating');
      setStatus('', false);
      const { latitude, longitude } = pos.coords;
      map.flyTo([latitude, longitude], 10, { duration: 1.5 });
      setTimeout(() => {
        map.invalidateSize();
        refreshRadarForRegion();
      }, 1600);
      fetchWeather(latitude, longitude, 'My Location');
    },
    (err) => {
      btn.classList.remove('locating');
      console.warn('Geolocation error:', err);
      const msg = err.code === 1
        ? 'Location denied — allow access in browser settings.'
        : 'Unable to get location. Try searching instead.';
      setStatus(msg, true);
      setTimeout(() => setStatus('', false), 5000);
    },
    { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
  );
};

// ── SEARCH ────────────────────────────────────────────────────────────────
const searchInput  = document.getElementById('search-input');
const searchResults = document.getElementById('search-results');
let searchTimer = null;

searchInput.addEventListener('input', () => {
  clearTimeout(searchTimer);
  const q = searchInput.value.trim();
  if (q.length < 2) { searchResults.classList.remove('show'); return; }
  searchTimer = setTimeout(() => doSearch(q), 350);
});

searchInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    clearTimeout(searchTimer);
    const q = searchInput.value.trim();
    if (q.length >= 2) doSearch(q);
  }
});

// Close search results when clicking outside
document.addEventListener('click', (e) => {
  if (!e.target.closest('#search-container')) searchResults.classList.remove('show');
});

async function doSearch(query) {
  try {
    const res = await fetch(
      `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(query)}&count=6&language=en&format=json`
    );
    const data = await res.json();
    if (!data.results || !data.results.length) {
      searchResults.innerHTML = '<div class="search-result-item"><span class="search-result-name">No results found</span></div>';
      searchResults.classList.add('show');
      return;
    }
    searchResults.innerHTML = '';
    data.results.forEach(r => {
      const item = document.createElement('div');
      item.className = 'search-result-item';
      const adminParts = [r.admin1, r.admin2, r.country].filter(Boolean).slice(0, 2);
      const sub = adminParts.join(', ') + (r.country ? ` · ${r.country}` : '');
      item.innerHTML = `<span class="search-result-name">${r.name}</span><div class="search-result-sub">${sub}</div>`;
      item.addEventListener('click', () => {
        searchResults.classList.remove('show');
        searchInput.value = r.name;
        map.flyTo([r.latitude, r.longitude], 10, { duration: 1.5 });
        // invalidateSize after flyTo completes to prevent blank map
        setTimeout(() => {
          map.invalidateSize();
          refreshRadarForRegion();
        }, 1600);
        fetchWeather(r.latitude, r.longitude, r.name);
      });
      searchResults.appendChild(item);
    });
    searchResults.classList.add('show');
  } catch(e) {
    console.warn('Search failed:', e);
  }
}

// ── WEATHER WIDGET ────────────────────────────────────────────────────────
let weatherUnit = localStorage.getItem('weather_unit') || 'C';
let lastWeatherData = null;
let lastWeatherLocation = null;

function setUnit(unit) {
  weatherUnit = unit;
  try { localStorage.setItem('weather_unit', unit); } catch(e) {}
  updateUnitButtons();
  if (lastWeatherData && lastWeatherLocation) {
    renderWeather(lastWeatherData, lastWeatherLocation);
  }
}
window.setUnit = setUnit;

function updateUnitButtons() {
  document.getElementById('ww-toggle-c').classList.toggle('active', weatherUnit === 'C');
  document.getElementById('ww-toggle-f').classList.toggle('active', weatherUnit === 'F');
  document.getElementById('ww-unit-label').textContent = weatherUnit === 'C' ? '°C' : '°F';
}

function toF(c) { return Math.round(c * 9 / 5 + 32); }
function displayTemp(c) { return weatherUnit === 'F' ? toF(c) : Math.round(c); }

function closeWeather() {
  document.getElementById('weather-widget').classList.remove('show');
}
window.closeWeather = closeWeather;

const WMO_CODES = {
  0: { icon: '☀️', desc: 'Clear' },
  1: { icon: '🌤️', desc: 'Mainly clear' },
  2: { icon: '⛅', desc: 'Partly cloudy' },
  3: { icon: '☁️', desc: 'Overcast' },
  45: { icon: '🌫️', desc: 'Foggy' },
  48: { icon: '🌫️', desc: 'Rime fog' },
  51: { icon: '🌦️', desc: 'Light drizzle' },
  53: { icon: '🌦️', desc: 'Drizzle' },
  55: { icon: '🌧️', desc: 'Heavy drizzle' },
  56: { icon: '🌨️', desc: 'Freezing drizzle' },
  57: { icon: '🌨️', desc: 'Heavy freezing drizzle' },
  61: { icon: '🌧️', desc: 'Light rain' },
  63: { icon: '🌧️', desc: 'Rain' },
  65: { icon: '🌧️', desc: 'Heavy rain' },
  66: { icon: '🌨️', desc: 'Freezing rain' },
  67: { icon: '🌨️', desc: 'Heavy freezing rain' },
  71: { icon: '🌨️', desc: 'Light snow' },
  73: { icon: '❄️', desc: 'Snow' },
  75: { icon: '❄️', desc: 'Heavy snow' },
  77: { icon: '🌨️', desc: 'Snow grains' },
  80: { icon: '🌦️', desc: 'Light showers' },
  81: { icon: '🌧️', desc: 'Showers' },
  82: { icon: '⛈️', desc: 'Heavy showers' },
  85: { icon: '🌨️', desc: 'Light snow showers' },
  86: { icon: '❄️', desc: 'Heavy snow showers' },
  95: { icon: '⛈️', desc: 'Thunderstorm' },
  96: { icon: '⛈️', desc: 'Thunderstorm w/ hail' },
  99: { icon: '⛈️', desc: 'Thunderstorm w/ heavy hail' },
};

function getWeatherIcon(code, isNight) {
  const info = WMO_CODES[code] || { icon: '🌡️', desc: 'Unknown' };
  if ((code === 0 || code === 1) && isNight) return { icon: '🌙', desc: info.desc };
  return info;
}

function dayName(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  const today = new Date();
  const tomorrow = new Date(today);
  tomorrow.setDate(tomorrow.getDate() + 1);
  if (d.toDateString() === today.toDateString()) return 'Today';
  if (d.toDateString() === tomorrow.toDateString()) return 'Tmrw';
  return d.toLocaleDateString('en', { weekday: 'short' }).slice(0, 3);
}

async function fetchWeather(lat, lon, locationName) {
  const widget = document.getElementById('weather-widget');
  widget.classList.add('show');

  try {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}` +
      `&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m,is_day` +
      `&daily=weather_code,temperature_2m_max,temperature_2m_min` +
      `&forecast_days=5&temperature_unit=celsius`;
    const res = await fetch(url);
    const data = await res.json();

    if (!data.current) return;
    lastWeatherData = data;
    lastWeatherLocation = locationName;
    renderWeather(data, locationName);
  } catch(e) {
    console.warn('Weather fetch failed:', e);
  }
}

function renderWeather(data, locationName) {
  document.getElementById('ww-loc-name').textContent = locationName;
  updateUnitButtons();

  const c = data.current;
  const isNight = c.is_day === 0;
  const weatherInfo = getWeatherIcon(c.weather_code, isNight);

  document.getElementById('ww-temp').textContent = displayTemp(c.temperature_2m);
  document.getElementById('ww-icon').textContent = weatherInfo.icon;
  document.getElementById('ww-feels').textContent = displayTemp(c.apparent_temperature);
  document.getElementById('ww-wind').textContent = Math.round(c.wind_speed_10m);
  document.getElementById('ww-humidity').textContent = c.relative_humidity_2m;

  // 5-day forecast
  const rows = document.getElementById('ww-forecast-rows');
  if (data.daily) {
    rows.innerHTML = '';
    for (let i = 0; i < data.daily.time.length && i < 5; i++) {
      const day = data.daily.time[i];
      const code = data.daily.weather_code[i];
      const high = displayTemp(data.daily.temperature_2m_max[i]);
      const low = displayTemp(data.daily.temperature_2m_min[i]);
      const info = getWeatherIcon(code, false);
      const row = document.createElement('div');
      row.className = 'ww-forecast-row';
      row.innerHTML = `
        <span class="ww-forecast-day">${dayName(day)}</span>
        <span class="ww-forecast-icon">${info.icon}</span>
        <span class="ww-forecast-temps"><span class="high">${high}°</span> <span class="low">${low}°</span></span>
      `;
      rows.appendChild(row);
    }
  }
}

// Only auto-start if beta was already acknowledged (returning user)
if(window._betaAlreadyAcknowledged){
  loadAlerts();
  setInterval(loadAlerts, 60000);
}

// Called by the "Got it" button
window.acknowledgeBeta = function() {
  if(document.getElementById('beta-no-show').checked){
    try{localStorage.setItem('beta_dismissed','1')}catch(e){}
  }
  document.getElementById('beta-overlay').style.display='none';
  loadAlerts();
  setInterval(loadAlerts, 60000);
};

// ── BUTTON WIRING ─────────────────────────────────────────────────────────
document.getElementById('locate-btn').addEventListener('click', locateMe);
document.getElementById('play-btn').addEventListener('click', togglePlay);
document.getElementById('panel-toggle').addEventListener('click', togglePanel);
document.getElementById('alert-pill').addEventListener('click', togglePanel);
document.getElementById('alert-pill').addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); togglePanel(); }
});

// Close weather widget button
document.querySelector('.ww-close-btn').addEventListener('click', closeWeather);

// Unit toggle buttons
document.getElementById('ww-toggle-c').addEventListener('click', () => setUnit('C'));
document.getElementById('ww-toggle-f').addEventListener('click', () => setUnit('F'));

// ── KEYBOARD NAVIGATION ───────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  // Space = play/pause (only when not focused on an input)
  if (e.key === ' ' && e.target.tagName !== 'INPUT') {
    e.preventDefault();
    togglePlay();
    return;
  }
  // Arrow keys = scrub timeline
  if ((e.key === 'ArrowLeft' || e.key === 'ArrowRight') && frames.length) {
    e.preventDefault();
    if (playing) stopPlay();
    const delta = e.key === 'ArrowRight' ? 1 : -1;
    showFrame(currentIdx + delta);
  }
  // Escape = close panel
  if (e.key === 'Escape') {
    const panel = document.getElementById('panel');
    if (panel.classList.contains('open')) togglePanel();
  }
});

// ── ORIENTATION CHANGE ────────────────────────────────────────────────────
const handleOrientationChange = () => {
  // Short delay lets the browser settle the new viewport dimensions
  setTimeout(() => {
    map.invalidateSize({ animate: false });
    if (frames.length) {
      if (activeRV && map.hasLayer(activeRV)) activeRV.redraw();
    }
  }, 300);
};

if (screen.orientation) {
  screen.orientation.addEventListener('change', handleOrientationChange);
} else {
  window.addEventListener('orientationchange', handleOrientationChange);
}

});  // end DOMContentLoaded
</script>
