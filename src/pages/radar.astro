/* WEATHER WIDGET */
#weather-widget {
  position:fixed; top:calc(var(--hdr) + 10px + var(--sat)); left:calc(12px + var(--sal)); z-index:1000;
  background:rgba(3,3,10,0.92); border:1px solid rgba(0,120,200,0.25);
  border-radius:12px; padding:12px 14px; min-width:180px; max-width:220px;
  -webkit-backdrop-filter:blur(16px); backdrop-filter:blur(16px);
  box-shadow:0 4px 20px rgba(0,0,0,0.4);
  display:none; /* shown after geolocation or search */
}
#weather-widget.show { display:block; }
.ww-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.ww-location-name { font-size:0.58rem; color:rgba(200,240,255,0.4); letter-spacing:0.06em; text-transform:uppercase; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:140px; }
.ww-close-btn {
  font-size:0.7rem; color:rgba(200,240,255,0.2); cursor:pointer; line-height:1; padding:2px 4px;
  background:none; border:none; touch-action:manipulation;
}
.ww-close-btn:hover { color:#c8f0ff; }
.ww-close-btn:focus-visible { outline:1px solid rgba(0,120,200,0.6); border-radius:2px; }
.ww-current { display:flex; align-items:center; gap:14px; margin-bottom:14px; }
.ww-temp { font-size:2.2rem; font-weight:700; color:#c8f0ff; line-height:1; }
.ww-temp-unit { font-size:0.7rem; color:rgba(200,240,255,0.4); vertical-align:super; }
.ww-unit-toggle {
  font-size:0.7rem; font-weight:700; color:rgba(200,240,255,0.25);
  cursor:pointer; padding:4px 10px; border-radius:6px; margin-left:6px;
  border:1px solid rgba(255,255,255,0.08); background:transparent;
  font-family:"JetBrains Mono",monospace; letter-spacing:0.06em;
  transition:all 0.15s;
}
.ww-unit-toggle:hover { color:rgba(200,240,255,0.6); border-color:rgba(255,255,255,0.15); }
.ww-unit-toggle.active { color:#40c8ff; border-color:rgba(0,120,200,0.5); background:rgba(0,120,200,0.15); }
.ww-icon { font-size:2.4rem; }
.ww-details { display:flex; gap:12px; margin-bottom:10px; }
.ww-detail { font-size:0.5rem; color:rgba(200,240,255,0.4); letter-spacing:0.04em; text-transform:uppercase; }
.ww-detail span { color:rgba(200,240,255,0.7); font-weight:600; }
.ww-forecast { border-top:1px solid rgba(255,255,255,0.06); padding-top:8px; }
.ww-forecast-title { font-size:0.48rem; color:rgba(200,240,255,0.25); letter-spacing:0.14em; text-transform:uppercase; margin-bottom:6px; }
.ww-forecast-row { display:flex; align-items:center; justify-content:space-between; padding:3px 0; }
.ww-forecast-day { font-size:0.52rem; color:rgba(200,240,255,0.4); width:36px; }
.ww-forecast-icon { font-size:0.7rem; width:20px; text-align:center; }
.ww-forecast-temps { font-size:0.52rem; color:rgba(200,240,255,0.5); }
.ww-forecast-temps .high { color:#c8f0ff; font-weight:600; }
.ww-forecast-temps .low { color:rgba(200,240,255,0.3); }

/* Hide broken/missing tile images silently */
.leaflet-tile .leaflet-tile-loaded { visibility: visible !important; }
.leaflet-control-zoom a {
  background:rgba(3,3,10,0.9) !important; color:rgba(200,240,255,0.7) !important;
  border-color:rgba(255,255,255,0.1) !important; font-family:"JetBrains Mono",monospace !important;
}
.leaflet-control-zoom a:hover { background:rgba(0,120,200,0.3) !important; color:#fff !important; }
.leaflet-control-attribution {
  background:rgba(3,3,10,0.7) !important; color:rgba(200,240,255,0.2) !important;
  font-family:"JetBrains Mono",monospace !important; font-size:9px !important;
}
.leaflet-control-attribution a { color:rgba(162,155,254,0.5) !important; }
.alert-tooltip {
  background:rgba(3,3,10,0.95) !important; border:1px solid rgba(255,71,87,0.3) !important;
  border-radius:6px !important; color:#c8f0ff !important;
  font-family:"JetBrains Mono",monospace !important; font-size:0.6rem !important;
  padding:7px 10px !important; box-shadow:0 4px 20px rgba(0,0,0,0.5) !important;
}

/* Panel backdrop — hidden globally, shown on mobile when panel is open */
#panel-backdrop {
  display:none; position:fixed; inset:0; z-index:899;
  background:rgba(0,0,0,0.5);
}

/* ── TABLET (641px – 1024px) ─────────────────────────────────────────────── */
@media (min-width: 641px) and (max-width: 1024px) {
  #panel { width:320px; }
  #panel.open ~ #panel-toggle { right:320px; }
  #search-container { width:min(340px, calc(100vw - 100px)); }
  #timeline { width:min(460px, calc(100vw - 60px)); }
  /* Move weather widget below the search/locate row to avoid overlap */
  #weather-widget { top:calc(var(--hdr) + 56px + var(--sat)); }
}

/* ── ULTRAWIDE (≥1600px) ─────────────────────────────────────────────────── */
@media (min-width: 1600px) {
  :root { --hdr: 58px; }
  #panel { width:400px; }
  #panel.open ~ #panel-toggle { right:400px; }
  #legend { padding:12px 28px; gap:20px; }
  .legend-label { font-size:0.72rem; }
  .legend-dot { width:12px; height:12px; }
  #timeline { width:min(640px, calc(100vw - 32px)); }
  #header { padding-left:28px; padding-right:28px; }
  .radar-logo-main { font-size:0.78rem; }
}

/* ── MOBILE ─────────────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  :root { --hdr: 48px; }

  /* Header — tighter, keep beta badge */
  #header { padding-left:12px; padding-right:12px; }
  .hdiv { display:none; }
  .radar-logo-sub { display:none; }
  #last-updated { display:none; }
  .radar-logo-main { font-size:0.78rem; }
  .radar-logo-icon { width:24px; height:24px; }

  /* Alert pill */
  .alert-pill {
    padding:6px 10px; font-size:0.58rem; cursor:pointer;
    -webkit-tap-highlight-color:transparent;
  }

  /* Locate button — top is now derived from --hdr via the base rule */
  #locate-btn { right:8px; width:32px; height:32px; }
  #locate-btn svg { width:16px; height:16px; }

  /* Search bar — leave room for locate button on the right */
  #search-container { left:12px; right:48px; width:auto; transform:none; }
  #search-input { padding:8px 12px 8px 32px; font-size:0.6rem; border-radius:8px; }
  #search-icon { width:14px; height:14px; left:9px; }
  #search-results { border-radius:8px; max-height:180px; }
  .search-result-item { padding:8px 12px; }
  .search-result-name { font-size:0.58rem; }
  .search-result-sub { font-size:0.44rem; }

  /* Weather widget — positioned above timeline, not over search */
  #weather-widget {
    top:auto; bottom:148px; left:8px; right:8px; min-width:auto; max-width:none;
    border-radius:8px; padding:10px 12px;
  }
  .ww-location-name { max-width:200px; font-size:0.52rem; }
  .ww-temp { font-size:1.8rem; }
  .ww-icon { font-size:2rem; }

  /* Panel — slides up from bottom, full width, safe-area bottom padding */
  #panel {
    top:auto; bottom:0; left:0; right:0; width:100%;
    height:65dvh; max-height:calc(100dvh - var(--hdr) - var(--sat));
    border-left:none; border-top:1px solid rgba(0,120,200,0.2);
    border-radius:16px 16px 0 0;
    transform:translateY(100%);
    transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
    box-shadow:0 -8px 40px rgba(0,0,0,0.5);
    padding-bottom: var(--sab);
  }
  #panel.open { transform:translateY(0); }
  #panel.open ~ #panel-backdrop { display:block; }

  /* Drag handle */
  .panel-header::before {
    content:''; display:block; position:absolute; top:8px; left:50%;
    transform:translateX(-50%);
    width:36px; height:4px; border-radius:2px;
    background:rgba(255,255,255,0.15);
  }
  .panel-header { position:relative; padding-top:20px; }

  /* Smaller tags on mobile */
  .alert-tag-chip { font-size:7.5px; padding:2px 5px; }

  /* Hide side toggle tab */
  #panel-toggle { display:none !important; }

  /* Timeline — full width, above bottom edge, no left:50% */
  #timeline {
    left:12px; right:12px; width:auto;
    transform:none;
    bottom:calc(12px + var(--sab));
    padding:10px 14px 12px;
    border-radius:12px;
  }
  .tl-row1 { margin-bottom:8px; gap:10px; }
  #play-btn { width:28px; height:28px; }
  #time-display { font-size:0.58rem; }
  .tick-label { font-size:0.42rem; }

  /* Legend — bottom left above timeline on mobile */
  #legend {
    bottom:calc(108px + var(--sab)); left:12px; right:auto;
    padding:7px 12px; gap:8px; border-radius:8px;
  }
  .legend-title { font-size:0.52rem; }
  .legend-items { gap:8px; }
  .legend-item { gap:4px; }
  .legend-dot { width:7px; height:7px; }
  .legend-label { font-size:0.52rem; }

  /* Zoom controls above timeline */
  .leaflet-control-zoom { margin-bottom:calc(110px + var(--sab)) !important; margin-right:12px !important; }

  /* Beta modal */
  #beta-modal { padding:24px 20px; border-radius:12px; }
  .beta-modal-title { font-size:0.85rem; }

  /* Weather widget hidden when panel is open (prevent z-index overlap) */
  #weather-widget.panel-hidden { display:none !important; }
}

/* ── VERY SMALL (≤380px) ─────────────────────────────────────────────────── */
@media (max-width: 380px) {
  #timeline { padding:8px 10px 10px; }
  #time-display { font-size:0.5rem; }
  .tick-label { font-size:0.38rem; }
  .legend-title { display:none; }
  .legend-items { gap:6px; }
}

/* Panel close button (visible on mobile bottom-sheet) */
.panel-close-btn {
  width:28px; height:28px; border-radius:6px; cursor:pointer;
  background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);
  display:none; align-items:center; justify-content:center;
  color:rgba(200,240,255,0.4); font-size:0.78rem; line-height:1;
  touch-action:manipulation; -webkit-tap-highlight-color:transparent;
  transition:all 0.15s; flex-shrink:0;
}
.panel-close-btn:hover { color:#c8f0ff; background:rgba(255,255,255,0.08); border-color:rgba(255,255,255,0.2); }
.panel-close-btn:focus-visible { outline:2px solid #40c8ff; outline-offset:1px; }
@media (max-width: 640px) {
  .panel-close-btn { display:flex; }
}

/* ── LANDSCAPE PHONE (short viewport in landscape) ───────────────────────── */
@media (max-height: 500px) and (orientation: landscape) {
  :root { --hdr: 48px; }
  /* Side-sliding panel (like desktop) instead of bottom sheet */
  #panel {
    top: calc(var(--hdr) + var(--sat));
    height: calc(100dvh - var(--hdr) - var(--sat));
    max-height: none; width: min(300px, 48vw);
    border-radius: 0; border-top: none; padding-bottom: 0;
    border-left: 1px solid rgba(0,120,200,0.2);
    transform: translateX(100%);
  }
  #panel.open { transform: translateX(0); }
  .panel-header::before { display: none; }
  .panel-header { padding-top: 14px; }
  #panel-toggle { display: flex !important; }
  /* Weather widget — compact, top-right */
  #weather-widget {
    bottom: auto;
    top: calc(var(--hdr) + 8px + var(--sat));
    left: auto;
    right: calc(8px + var(--sar));
    max-width: 170px; min-width: 150px;
  }
  /* Compact controls */
  #legend { bottom: calc(8px + var(--sab)); padding: 5px 10px; gap: 6px; }
  .legend-title { display: none; }
  #timeline { bottom: calc(8px + var(--sab)); padding: 8px 14px 10px; }
  .leaflet-control-zoom { margin-bottom: 60px !important; }
}

/* iOS performance: disable backdrop-filter blur on mobile to prevent GPU crash */
@media (max-width: 768px) {
  #header, #panel, #timeline, #legend, #radar-status, #beta-overlay, #beta-modal {
    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
  }
  #header    { background: rgba(3,3,10,0.97) !important; }
  #panel     { background: rgba(3,3,10,0.97) !important; }
  #timeline  { background: rgba(3,3,10,0.97) !important; }
  #legend    { background: rgba(3,3,10,0.95) !important; }
  #beta-overlay { background: rgba(3,3,10,0.95) !important; }
}
</style>
</head>
