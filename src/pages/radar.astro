  </div>
  <div id="scrubber-outer">
    <div id="scrubber-track">
      <div id="scrubber-fill"></div>
      <div id="scrubber-thumb"></div>
    </div>
    <div id="scrubber-ticks"></div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
window.addEventListener('DOMContentLoaded', function() {

// ── MAP SETUP ──────────────────────────────────────────────────────────────
const map = L.map('map', {
  center: [37, -95], zoom: 4,
  zoomControl: true,
  preferCanvas: true  // SVG → Canvas for alert polygons; much faster at scale
});

// CartoDB Dark Matter — free, no API key
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap contributors © CARTO',
  subdomains: 'abcd', maxZoom: 19, maxNativeZoom: 19
}).addTo(map);

// Force map to recalculate its size — fixes black map on mobile
setTimeout(() => map.invalidateSize(), 100);
// Use visualViewport on iOS to avoid resize firing on pinch zoom
if (window.visualViewport) {
  window.visualViewport.addEventListener('resize', () => map.invalidateSize());
} else {
  window.addEventListener('resize', () => map.invalidateSize());
}

// Custom pane for radar tiles so they are NOT affected by the base tile CSS filter
map.createPane('radarPane');
map.getPane('radarPane').style.zIndex = 300;
map.getPane('radarPane').classList.add('radar-pane');

// ── RADAR SOURCES ────────────────────────────────────────────────────────
//
// 1. RainViewer  — GLOBAL base, animated XYZ tiles, ~180 countries, zoom 8
// 2. IEM NEXRAD  — US/CONUS overlay, animated XYZ, zoom 10, high detail
// 3. MSC GeoMet  — Canada WMS overlay, free, no key
// 4. DWD         — Germany/Europe WMS overlay, free, no key
// 5. Buienradar  — Netherlands/Belgium, free
// 6. MET Norway  — Scandinavia, free
//
// RainViewer drives the master frame count (~12 past frames, 10-min steps).
// Regional WMS overlays are synced to the same timestamps.
// Only ONE layer type is active per region at a time to avoid duplicates.

const FADE_DURATION = 250;  // ms for smooth opacity crossfade between frames

// ── TILE ERROR SUPPRESSION (Bulletproof) ──────────────────────────────
function suppressTileErrors(layer) {
  // Override internal tile error handler — no console spam, no "zoom not supported"
  if (layer.createTile) {
    const origCreate = layer.createTile.bind(layer);
    layer.createTile = function(coords, done) {
      const tile = origCreate(coords, done);
      tile.onerror = null; // swallow all errors silently
      tile.style.opacity = '0';
      tile.onload = () => { tile.style.opacity = ''; };
      return tile;
    };
  }
  layer.on('tileerror', function(evt) {
    if (evt.tile) { evt.tile.style.display = 'none'; }
  });
  layer.on('add', function() {
    const el = layer.getContainer && layer.getContainer();
    if (el) el.style.transition = `opacity ${FADE_DURATION}ms ease-out`;
  });
  return layer;
}

// Override Leaflet's internal tile error handling globally
L.GridLayer.prototype._tileOnError = function() {};

const FRAME_INTERVAL = 500;  // ms between frame advances
const HOLD_INTERVAL  = 1500; // ms pause on last frame before looping

// IEM time slots matching approx 10-min intervals to align with RainViewer
const IEM_SLOTS = [
  { ts:'900913-m50m', minsAgo:50 }, { ts:'900913-m45m', minsAgo:45 },
  { ts:'900913-m40m', minsAgo:40 }, { ts:'900913-m35m', minsAgo:35 },
  { ts:'900913-m30m', minsAgo:30 }, { ts:'900913-m25m', minsAgo:25 },
  { ts:'900913-m20m', minsAgo:20 }, { ts:'900913-m15m', minsAgo:15 },
  { ts:'900913-m10m', minsAgo:10 }, { ts:'900913-m05m', minsAgo: 5 },
  { ts:'900913',      minsAgo: 0 },
];

// frames[i] = { minsAgo, time, rvPath, rvLayer, iemLayer }
let frames     = [];
let currentIdx = 0;
let playing    = false;
let playTimer  = null;
let seqId      = 0;
let activeRV   = null;
let activeIEM  = null;
let rvHost     = '';  // store RainViewer host for reloading

// ── REGIONAL WMS OVERLAYS ───────────────────────────────────────────────
let wmsCanada = null;
let wmsDWD    = null;
let wmsNorway = null;
let wmsINMIND = null;   // Netherlands (Buienradar)
let wmsUK     = null;   // UK Met Office
let wmsSpain  = null;   // AEMET Spain

function setStatus(msg, show) {
  const el = document.getElementById('radar-status');
  el.textContent = msg;
  el.classList.toggle('show', !!show);
}

function isoUTC(d) {
  return d.toISOString().replace(/\.\d{3}Z$/, 'Z');
}

function floorMins(d, n) {
  return new Date(Math.floor(d.getTime() / (n * 60000)) * (n * 60000));
}

// ── REGION DETECTION ────────────────────────────────────────────────────
function detectRegion(lat, lng) {
  // Alaska and Aleutians (west of -130° — not covered by contiguous US check)
  if (lat >= 51 && lat <= 72 && lng >= -180 && lng <= -130) return 'US';
  // Contiguous US + Hawaii
  if (lat >= 18 && lat <= 55 && lng >= -130 && lng <= -60) return 'US';
  if (lat >= 41 && lat <= 84 && lng >= -141 && lng <= -52) return 'CA';
  if (lat >= 45 && lat <= 55 && lng >= -11 && lng <= 2)   return 'UK';
  if (lat >= 47 && lat <= 55 && lng >= 5 && lng <= 15)    return 'DE';
  if (lat >= 36 && lat <= 44 && lng >= -9 && lng <= 4)    return 'ES';
  if (lat >= 50 && lat <= 54 && lng >= 3 && lng <= 8)     return 'NL';
  if (lat >= 57 && lat <= 71 && lng >= 4 && lng <= 31)    return 'NO';
  if (lat >= 35 && lat <= 72 && lng >= -11 && lng <= 40)  return 'EU';
  // Australia — full extent including Western Australia (lng ≥ 112)
  if (lat >= -44 && lat <= -10 && lng >= 112 && lng <= 180) return 'AU';
  if (lat >= -48 && lat <= -34 && lng >= 165 && lng <= 179) return 'NZ';
  if (lat >= 24 && lat <= 46 && lng >= 122 && lng <= 146) return 'JP';
  if (lat >= 6 && lat <= 36 && lng >= 68 && lng <= 97)    return 'IN';
  if (lat >= -56 && lat <= 13 && lng >= -82 && lng <= -34) return 'SA';
  return 'OTHER';
}

// Track which regional overlays are currently active
let activeRegionalLayers = [];

function clearRegionalLayers() {
  activeRegionalLayers.forEach(l => { try { map.removeLayer(l); } catch(e){} });
  activeRegionalLayers = [];
  wmsCanada = null; wmsDWD = null; wmsNorway = null;
  wmsINMIND = null; wmsUK = null; wmsSpain = null;
}

function buildRegionalOverlays(center) {
  clearRegionalLayers();
  const region = detectRegion(center.lat, center.lng);

  try {
    switch(region) {
      case 'CA':
        wmsCanada = suppressTileErrors(L.tileLayer.wms('https://geo.weather.gc.ca/geomet?', {
          layers: 'RADAR_1KM_RRAI', version: '1.3.0',
          format: 'image/png', transparent: true,
          opacity: 0.85, pane: 'radarPane', maxNativeZoom: 10, maxZoom: 19,
          crossOrigin: '', attribution: 'MSC/ECCC'
        }));
        break;
      case 'DE':
        wmsDWD = suppressTileErrors(L.tileLayer.wms('https://maps.dwd.de/geoserver/dwd/wms?', {
          layers: 'dwd:RX-Produkt', version: '1.3.0',
          format: 'image/png', transparent: true,
          opacity: 0.85, pane: 'radarPane', maxNativeZoom: 10, maxZoom: 19,
          crossOrigin: '', attribution: 'DWD'
        }));
        break;
      case 'NO':
        wmsNorway = suppressTileErrors(L.tileLayer.wms('https://shyrd.met.no/radar?', {
          layers: 'composite,se', version: '1.1.1',
          format: 'image/png', transparent: true,
          opacity: 0.8, pane: 'radarPane', maxNativeZoom: 10, maxZoom: 19,
          attribution: 'MET Norway'
        }));
        break;
      case 'NL':
        wmsINMIND = suppressTileErrors(L.tileLayer(
          'https://api.buienradar.nl/image/1.0/{z}/{x}/{y}.png',
          { opacity: 0.85, pane: 'radarPane', maxNativeZoom: 9, maxZoom: 19, attribution: 'Buienradar' }
        ));
        break;
      case 'EU':
        // Generic EU: use DWD as the base overlay
        wmsDWD = suppressTileErrors(L.tileLayer.wms('https://maps.dwd.de/geoserver/dwd/wms?', {
          layers: 'dwd:RX-Produkt', version: '1.3.0',
          format: 'image/png', transparent: true,
          opacity: 0.85, pane: 'radarPane', maxNativeZoom: 10, maxZoom: 19,
          crossOrigin: '', attribution: 'DWD'
        }));
        break;
      case 'UK':
        wmsUK = suppressTileErrors(L.tileLayer.wms('https://opendata-gw.metoffice.gov.uk/wms/layer/radar_composite?', {
          layers: 'composite_uk', version: '1.1.1',
          format: 'image/png', transparent: true,
          opacity: 0.85, pane: 'radarPane', maxNativeZoom: 9, maxZoom: 19,
          attribution: 'Met Office'
        }));
        break;
      case 'ES':
        wmsSpain = suppressTileErrors(L.tileLayer.wms('https://www.aemet.es/wms/mapas/precipitation?', {
          layers: 'radar', version: '1.3.0',
          format: 'image/png', transparent: true,
          opacity: 0.85, pane: 'radarPane', maxNativeZoom: 9, maxZoom: 19,
          attribution: 'AEMET'
        }));
        break;
    }
  } catch(e) { console.warn('Regional overlay failed:', e); }

  // Add whichever layers were created
  [wmsCanada, wmsDWD, wmsNorway, wmsINMIND, wmsUK, wmsSpain].forEach(l => {
    if (l) {
      try { l.addTo(map); activeRegionalLayers.push(l); } catch(e){}
    }
  });
}

function updateWMSTime(minsAgo) {
  const t = floorMins(new Date(Date.now() - minsAgo * 60000), 5);
  const ts = isoUTC(t);
  [wmsCanada, wmsDWD, wmsNorway, wmsUK, wmsSpain].forEach(wms => {
    if (wms) { try { wms.setParams({ TIME: ts }, false); } catch(e){} }
  });
}

async function loadRadar() {
  try {
    setStatus('Loading radar\u2026', true);

    let rv;
    try {
      const res = await fetch('https://api.rainviewer.com/public/weather-maps.json', {
        cache: 'no-store',
        mode: 'cors'
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      rv = await res.json();
    } catch(fetchErr) {
      console.warn('RainViewer fetch failed:', fetchErr);
      setStatus('Radar unavailable', true);
      return;
    }
    const rvPast = (rv.radar && rv.radar.past) || [];
    if (!rvPast.length) { setStatus('No radar data', true); return; }

    stopPlay();

    // Tear down old layers
    frames.forEach(f => {
      try { map.removeLayer(f.rvLayer);  } catch(e){}
      try { map.removeLayer(f.iemLayer); } catch(e){}
    });
    activeRV = null; activeIEM = null;

    const nowSec = Math.floor(Date.now() / 1000);
    const sz = 256;

    // Build frames with RainViewer global + IEM US overlay
    frames = IEM_SLOTS.map((slot, i) => {
      const frameTime = nowSec - slot.minsAgo * 60;
      const closest   = rvPast.reduce((b, r) =>
        Math.abs(r.time - frameTime) < Math.abs(b.time - frameTime) ? r : b
      );
      const rvPath = rv.host + closest.path + '/' + sz;
      return {
        minsAgo:  slot.minsAgo,
        time:     frameTime,
        rvPath:   rvPath,
        // RainViewer — global base, color map 1 = classic radar
        rvLayer:  suppressTileErrors(L.tileLayer(
          rvPath + '/{z}/{x}/{y}/1/1_1.png',
          { opacity: 0, pane: 'radarPane', maxNativeZoom: 8, maxZoom: 19 }
        )),
        // IEM NEXRAD — US only, returns transparent outside CONUS
        iemLayer: suppressTileErrors(L.tileLayer(
          `https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/nexrad-n0q-${slot.ts}/{z}/{x}/{y}.png`,
          { opacity: 0, pane: 'radarPane', maxNativeZoom: 10, maxZoom: 19 }
        ))
      };
    });

    rvHost = rv.host;

    // Build regional overlays based on current map center
    buildRegionalOverlays(map.getCenter());
    buildTicks();

    // Preload ALL frames
    frames.forEach(f => {
      f.rvLayer.addTo(map);
      f.iemLayer.addTo(map);
    });

    // Show latest frame then autoplay
    let shown = false;
    const go = () => {
      if (shown) return;
      shown = true;
      showFrame(frames.length - 1);
      setStatus('', false);
      startPlay();
    };

    const lastFrame = frames[frames.length - 1];
    lastFrame.rvLayer.once('load', go);
    setTimeout(go, 5000);

  } catch(e) {
    console.error('Radar load error:', e);
    setStatus('Radar unavailable', true);
  }
}

function showFrame(idx) {
  if (!frames.length) return;
  currentIdx = Math.max(0, Math.min(idx, frames.length - 1));
  const f = frames[currentIdx];
  const targetOpacity = getRadarOpacity();
  const prevRV = activeRV;
  const prevIEM = activeIEM;

  // Crossfade
  if (prevRV && prevRV !== f.rvLayer) prevRV.setOpacity(0);
  if (prevIEM && prevIEM !== f.iemLayer) prevIEM.setOpacity(0);
  f.rvLayer.setOpacity(targetOpacity);
  f.iemLayer.setOpacity(0.85);

  activeRV  = f.rvLayer;
  activeIEM = f.iemLayer;
  updateWMSTime(frames[currentIdx].minsAgo);
  updateUI();
}

// Radar opacity: clear and visible at all zooms
function getRadarOpacity() {
  const z = map.getZoom();
  if (z <= 3) return 0.35;
  if (z <= 5) return 0.55;
  if (z <= 7) return 0.7;
  return 0.85;
}

// Rebuild radar when search/locate moves the map to a new region
function refreshRadarForRegion() {
  buildRegionalOverlays(map.getCenter());
  // Update WMS time for regional overlays
  if (frames.length) updateWMSTime(frames[currentIdx].minsAgo);
}

function updateUI() {
  if (!frames.length) return;
  const f   = frames[currentIdx];
  const ago = f.minsAgo === 0 ? 'LIVE \u00b7 NOW' : `${f.minsAgo}m ago`;
  document.getElementById('time-display').innerHTML =
    `<span class="t-time">${fmtTime(f.time)}</span>` +
    `<span class="t-sep"> \u00b7 </span><span class="t-ago">${ago}</span>` +
    `<span class="t-sep"> \u00b7 </span><span class="t-pos">${currentIdx+1}/${frames.length}</span>`;
  const pct = frames.length > 1 ? (currentIdx / (frames.length - 1)) * 100 : 100;
  document.getElementById('scrubber-fill').style.width = pct + '%';
  document.getElementById('scrubber-thumb').style.left  = pct + '%';
}

function fmtTime(unixSec) {
  const t = new Date(unixSec * 1000);
  const h = t.getHours(), m = t.getMinutes();
  return `${((h % 12) || 12)}:${m.toString().padStart(2, '0')} ${h < 12 ? 'AM' : 'PM'}`;
}

function buildTicks() {
  if (!frames.length) return;
  const n = frames.length;
  const picks = [0, Math.floor(n * .25), Math.floor(n * .5), Math.floor(n * .75), n - 1];
  document.getElementById('scrubber-ticks').innerHTML =
    [...new Set(picks)].map(i => {
      const f = frames[i], isNow = f.minsAgo === 0;
      return `<span class="tick-label${isNow ? ' is-now' : ''}">${isNow ? 'NOW' : '-' + f.minsAgo + 'm'}</span>`;
    }).join('');
}

// ── PLAY / PAUSE ──────────────────────────────────────────────────────────
// seqId is incremented on every start/stop. Each scheduled timeout captures
// the seqId at the time it was scheduled — if seqId changed before it fires,
// it's stale and bails immediately. Guarantees zero ghost callbacks.

function setPlayIcon(on) {
  document.getElementById('play-icon').style.display  = on ? 'none' : '';
  document.getElementById('pause-icon').style.display = on ? ''     : 'none';
  document.getElementById('play-btn').setAttribute('aria-pressed', on ? 'true' : 'false');
  document.getElementById('play-btn').setAttribute('aria-label',   on ? 'Pause timeline animation' : 'Play timeline animation');
}

function _next(id, idx, delay) {
  clearTimeout(playTimer);
  playTimer = setTimeout(() => {
    if (id !== seqId) return;
    if (idx >= frames.length) {
      showFrame(frames.length - 1);
      _next(id, 0, HOLD_INTERVAL);
    } else {
      showFrame(idx);
      _next(id, idx + 1, FRAME_INTERVAL);
    }
  }, delay);
}

function startPlay() {
  if (playing || !frames.length) return;
  playing = true;
  seqId++;
  setPlayIcon(true);
  const next = currentIdx >= frames.length - 1 ? 0 : currentIdx + 1;
  if (next === 0) showFrame(0);
  _next(seqId, next, FRAME_INTERVAL);
}

function stopPlay() {
  playing = false;
  seqId++;
  clearTimeout(playTimer);
  playTimer = null;
  setPlayIcon(false);
}

function togglePlay() {
  if (playing) stopPlay();
  else         startPlay();
}
// Expose to global scope so the inline onclick="togglePlay()" can reach it
window.togglePlay = togglePlay;

loadRadar();
setInterval(loadRadar, 300000);
// ── SCRUBBER ──────────────────────────────────────────────────────────────
function scrubTo(clientX) {
  const rect = document.getElementById('scrubber-track').getBoundingClientRect();
  const pct  = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
  if (playing) stopPlay();
  if (frames.length) showFrame(Math.round(pct * (frames.length - 1)));
}

let dragging = false;
const track = document.getElementById('scrubber-track');
track.addEventListener('mousedown',  e => { dragging = true; scrubTo(e.clientX); });
track.addEventListener('touchstart', e => { dragging = true; scrubTo(e.touches[0].clientX); }, {passive:true});
window.addEventListener('mousemove',  e => { if (dragging) scrubTo(e.clientX); });
window.addEventListener('touchmove',  e => { if (dragging) scrubTo(e.touches[0].clientX); }, {passive:true});
window.addEventListener('mouseup',   () => dragging = false);
window.addEventListener('touchend',  () => dragging = false);

// ── GLOBAL ALERTS ─────────────────────────────────────────────────────────
let alertLayers = [];
let cachedAlerts = [];
const SEV = { Extreme:'#ff00cc', Severe:'#ff2d2d', Moderate:'#ffa500', Minor:'#ffd600', Unknown:'rgba(255,255,255,0.3)' };
const sevOrder = { Extreme:0, Severe:1, Moderate:2, Minor:3, Unknown:4 };
const sevClass = s => 'sev-' + (s||'unknown').toLowerCase();
const timeAgo = iso => {
  if (!iso) return '';
  const d = Math.round((Date.now() - new Date(iso)) / 60000);
  return d < 60 ? `${d}m ago` : d < 1440 ? `${Math.round(d/60)}h ago` : `${Math.round(d/1440)}d ago`;
};

// Map bounds → which region APIs to query
// We always fetch NWS (US). For Europe we use MeteoAlarm.
// For other regions we use national APIs where available.

// ── US — NWS CAP alerts (severe thunderstorm, tornado, flash flood, etc.) ─
async function fetchNWSAlerts() {
  try {
    const data = await (await fetch('https://api.weather.gov/alerts/active?status=actual&message_type=alert&limit=500')).json();
    return (data.features||[]).map(f => {
      const p = f.properties || {};
      const event = p.event || 'Alert';

      // NWS severity mapping based on event type
      let sev = p.severity || 'Unknown';
      const evt = event.toLowerCase();
      if (/tornado|extreme wind|flash flood|dust storm|typhoon|hurricane/.test(evt)) sev = 'Extreme';
      else if (/severe thunderstorm|flash flood watch|flood warning|winter storm|blizzard|ice storm|high wind|storm surge|special marine/.test(evt)) sev = 'Severe';
      else if (/flood watch|winter weather|freez.*advisory|wind advisory|heat advisory|dense fog|red flag|hard freeze|frost/.test(evt)) sev = 'Moderate';
      else sev = sev || 'Minor';

      // Determine icon/tag based on event type
      let tag = '';
      if (/tornado/.test(evt))           tag = 'TORNADO';
      else if (/severe thunderstorm/.test(evt)) tag = 'SEVERE TSTM';
      else if (/flash flood/.test(evt))   tag = 'FLASH FLOOD';
      else if (/flood/.test(evt))         tag = 'FLOOD';
      else if (/winter storm|blizzard|ice storm|snow/.test(evt)) tag = 'WINTER STORM';
      else if (/hurricane|tropical cyclone/.test(evt)) tag = 'HURRICANE';
      else if (/high wind|extreme wind/.test(evt))     tag = 'HIGH WIND';
      else if (/heat/.test(evt))          tag = 'HEAT';
      else if (/fire|red flag/.test(evt)) tag = 'FIRE';
      else if (/fog/.test(evt))           tag = 'FOG';
      else if (/air quality|smoke/.test(evt)) tag = 'AIR QUALITY';
      else if (/marine|special marine/.test(evt)) tag = 'MARINE';
      else if (/coastal flood|storm surge/.test(evt)) tag = 'COASTAL FLOOD';
      else if (/extreme cold|wind chill/.test(evt)) tag = 'EXTREME COLD';
      else if (/excessive heat/.test(evt)) tag = 'EXCESSIVE HEAT';

      return {
        severity: sev,
        event: event,
        tag,   // extra label for the card UI
        area:     p.areaDesc || '',
        sent:     p.sent,
        geometry: f.geometry,
        region:   'US',
        source:   'NWS',
        url:      f.id || p['@id'] || 'https://www.weather.gov/alerts',
        instruction: p.instruction || null,
        headline:    p.headline || null
      };
    });
  } catch(e) { return []; }
}

// ── CANADA — MSC GeoMet OGC API (free, no key, CORS-friendly) ─────────────
async function fetchCanadaAlerts() {
  try {
    const url = 'https://api.weather.gc.ca/collections/warnings/items?f=json&limit=500&lang=en';
    const data = await (await fetch(url)).json();
    return (data.features || []).map(f => {
      const p = f.properties || {};
      const evt = (p.alert_name || '').toLowerCase();
      let sev = 'Minor';
      if (/tornado|extreme|hurricane|tsunami/.test(evt))    sev = 'Extreme';
      else if (/warning|severe|blizzard|ice storm/.test(evt)) sev = 'Severe';
      else if (/watch|winter storm/.test(evt))                sev = 'Moderate';
      else if (/advisory|special/.test(evt))                  sev = 'Minor';

      let tag = '';
      if (/tornado/.test(evt))           tag = 'TORNADO';
      else if (/severe thunderstorm/.test(evt)) tag = 'SEVERE TSTM';
      else if (/flash flood|flood/.test(evt)) tag = 'FLOOD';
      else if (/winter storm|blizzard|snow/.test(evt)) tag = 'WINTER STORM';
      else if (/high wind|wind/.test(evt)) tag = 'HIGH WIND';
      else if (/heat|extreme temp/.test(evt)) tag = 'HEAT';
      else if (/fog|freezing fog/.test(evt)) tag = 'FOG';
      else if (/rainfall|rain/.test(evt))  tag = 'HEAVY RAIN';
      else if (/freezing rain/.test(evt))  tag = 'FREEZING RAIN';
      else if (/blowing snow/.test(evt))   tag = 'BLOWING SNOW';
      else if (/extreme cold/.test(evt))   tag = 'EXTREME COLD';
      else if (/frost/.test(evt))          tag = 'FROST';
      else if (/weather\/rainfall/.test(evt)) tag = 'HEAVY RAIN';

      return {
        severity: sev,
        event:    p.alert_name || p.type || 'Weather Alert',
        tag,
        area:     p.zone || p.location || 'Canada',
        sent:     p.effective || null,
        geometry: f.geometry,
        region:   'CA',
        source:   'ECCC',
        url:      p.url || 'https://weather.gc.ca/warnings/index_e.html',
        instruction: p.instruction || null,
        headline:    p.headline || null
      };
    });
  } catch(e) { return []; }
}

// ── AUSTRALIA — BOM public app API (no key required) ──────────────────────
// Source: api.weather.bom.gov.au — official Bureau of Meteorology backend
async function fetchAustraliaAlerts() {
  try {
    const data = await (await fetch(
      'https://api.weather.bom.gov.au/v1/warnings',
      { headers: { 'Accept': 'application/json' } }
    )).json();
    return (data.data || []).map(w => {
      // BOM warning_group_type: "flood_warning", "severe_thunderstorm_warning",
      // "tropical_cyclone_warning", "fire_weather_warning", "coastal_hazard_warning", etc.
      const wtype = (w.warning_group_type || '').toLowerCase();
      let sev = 'Minor';
      if (/tropical_cyclone|extreme/i.test(wtype))           sev = 'Extreme';
      else if (/severe_thunderstorm|major_flood|fire_weather/i.test(wtype)) sev = 'Severe';
      else if (/moderate_flood|coastal_hazard|strong_wind/i.test(wtype))    sev = 'Moderate';

      // Build a clean area string: prefer the full title location over bare state code
      // BOM title is e.g. "Flood Warning for the Daly River" — strip the warning type prefix
      const rawTitle = w.title || w.short_title || 'Weather Warning';
      // area: pull the "for..." part of the title if present, else fall back to state
      const forMatch = rawTitle.match(/\bfor\b\s+(.+)/i);
      const area = forMatch
        ? forMatch[1].trim()
        : (w.state ? w.state.toUpperCase() : 'Australia');

      // Event label: strip trailing location noise to keep it concise
      const event = rawTitle
        .replace(/\s+for\s+.+/i, '')   // "Flood Warning" not "Flood Warning for the Daly River"
        .trim();

      let tag = '';
      if (/tropical_cyclone/.test(wtype)) tag = 'CYCLONE';
      else if (/severe_thunderstorm/.test(wtype)) tag = 'SEVERE TSTM';
      else if (/flood/.test(wtype)) tag = 'FLOOD';
      else if (/fire_weather/.test(wtype)) tag = 'FIRE DANGER';
      else if (/coastal_hazard/.test(wtype)) tag = 'COASTAL HAZARD';
      else if (/strong_wind/.test(wtype)) tag = 'HIGH WIND';
      else if (/heat/.test(wtype)) tag = 'HEAT';
      else if (/frost/.test(wtype)) tag = 'FROST';
      else if (/marine_wind/.test(wtype)) tag = 'MARINE WIND';

      return {
        severity: sev,
        event,
        tag,
        area,
        sent:     w.issue_time || null,
        geometry: null,
        region:   'AU',
        source:   'BOM',
        url:      (function() {
          // Map BOM state to their state-specific warnings page
          const statePages = {
            'qld': 'https://www.bom.gov.au/qld/warnings/',
            'nsw': 'https://www.bom.gov.au/nsw/warnings/',
            'vic': 'https://www.bom.gov.au/vic/warnings/',
            'wa':  'https://www.bom.gov.au/wa/warnings/',
            'sa':  'https://www.bom.gov.au/sa/warnings/',
            'tas': 'https://www.bom.gov.au/tas/warnings/',
            'nt':  'https://www.bom.gov.au/nt/warnings/',
            'act': 'https://www.bom.gov.au/act/warnings/',
          };
          const st = (w.state || '').toLowerCase();
          return statePages[st] || 'https://www.bom.gov.au/warnings/';
        })(),
        instruction: null,
        headline: rawTitle
      };
    }).filter(a => a.event && !/cancel|terminated/i.test(a.event));
  } catch(e) { return []; }
}

// ── NEW ZEALAND — MetService public CAP Atom feed (no key) ─────────────────
async function fetchNZAlerts() {
  try {
    const r = await fetch('https://alerts.metservice.com/cap/rss');
    if (!r.ok) return [];
    const txt = await r.text();
    const doc = new DOMParser().parseFromString(txt, 'text/xml');
    return [...doc.querySelectorAll('item')].map(item => {
      const title = (item.querySelector('title') ? item.querySelector('title').textContent : null) || 'Weather Alert';
      const desc = (item.querySelector('description') && item.querySelector('description').textContent) || '';
      const areaText = desc.split(':')[0] || 'New Zealand';
      const nzLink = (item.querySelector('link') ? item.querySelector('link').textContent : null) || 'https://www.metservice.com/warnings/home';
      const evt = title.toLowerCase();
      let sev = 'Minor';
      if (/severe|heavy|gale|extreme|tornado|cyclone/.test(evt))   sev = 'Severe';
      if (/thunderstorm|tropical cyclone/.test(evt)) sev = 'Extreme';

      let tag = '';
      if (/tornado/.test(evt)) tag = 'TORNADO';
      else if (/severe thunderstorm/.test(evt)) tag = 'SEVERE TSTM';
      else if (/heavy rain|flood/.test(evt)) tag = 'FLOOD';
      else if (/gale|strong wind/.test(evt)) tag = 'HIGH WIND';
      else if (/cyclone/.test(evt)) tag = 'CYCLONE';
      else if (/snow|ice/.test(evt)) tag = 'WINTER STORM';
      else if (/heat/.test(evt)) tag = 'HEAT';
      else if (/frost/.test(evt)) tag = 'FROST';
      else if (/marine/.test(evt)) tag = 'MARINE';

      return { severity: sev, event: title, tag, area: areaText, sent: null, geometry: null, region: 'NZ', source: 'MetService', url: nzLink, instruction: null, headline: null };
    });
  } catch(e) { return []; }
}

// ── GDACS shared fetch — one request reused by SA, JP, and IN ─────────────
let _gdacsPromise = null;
async function getGDACS() {
  if (!_gdacsPromise) {
    _gdacsPromise = fetch('https://www.gdacs.org/gdacs/api/gdacsAlerts')
      .then(r => r.json())
      .catch(() => ({ alerts: [] }));
  }
  return _gdacsPromise;
}

// ── SOUTH AMERICA ──────────────────────────────────────────────────────────
async function fetchSouthAmericaAlerts() {
  try {
    const data = await getGDACS();
    return (data.alerts || [])
      .filter(a => {
        const saCountries = ['BR','AR','CL','CO','PE','VE','EC','BO','PY','UY','GY','SR','GF','FK'];
        return saCountries.some(c => (a.country || '').includes(c) || (a.location || '').includes('Brazil') || (a.location || '').includes('Argentina') || (a.location || '').includes('Colombia') || (a.location || '').includes('Chile') || (a.location || '').includes('Peru'));
      })
      .map(a => {
        const sev = a.alertlevel >= 3 ? 'Extreme' : a.alertlevel >= 2 ? 'Severe' : a.alertlevel >= 1 ? 'Moderate' : 'Minor';
        const evt = (a.eventtype || '').toLowerCase();
        let tag = '';
        if (/earthquake|tsunami/.test(evt)) tag = 'EARTHQUAKE';
        else if (/tornado/.test(evt)) tag = 'TORNADO';
        else if (/cyclone|typhoon|hurricane/.test(evt)) tag = 'CYCLONE';
        else if (/flood/.test(evt)) tag = 'FLOOD';
        else if (/volcano/.test(evt)) tag = 'VOLCANO';
        else if (/fire|wildfire/.test(evt)) tag = 'FIRE DANGER';
        else if (/drought/.test(evt)) tag = 'DROUGHT';
        else if (/landslide/.test(evt)) tag = 'LANDSLIDE';

        return {
          severity: sev,
          event:    a.eventtype || 'Weather Alert',
          tag,
          area:     a.location || 'South America',
          sent:     a.fromdate || null,
          geometry: null,
          region:   'SA',
          source:   'GDACS',
          url:      a.gdacsurl || 'https://www.gdacs.org/',
          instruction: null,
          headline: a.description || null
        };
      });
  } catch(e) { return []; }
}

