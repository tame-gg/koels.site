<div id="copyMsg" style="display:none;position:fixed;bottom:20px;left:50%;margin-left:-80px;width:160px;background:#001830;border:1px solid #40c8ff;padding:8px;text-align:center;font-family:'Courier New',monospace;font-size:11px;color:#00ffcc;z-index:9999">
