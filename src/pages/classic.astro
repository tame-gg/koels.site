<script>
// IE9 compatible JS — no arrow functions, no const/let, no template literals
var hitBase = 48291;

function randBetween(a, b) {
  return Math.floor(Math.random() * (b - a + 1)) + a;
}

// Fake hit counter
var hits = hitBase + randBetween(0, 999);
var hitsStr = String(hits);
while (hitsStr.length < 6) { hitsStr = '0' + hitsStr; }
document.getElementById('hitCounter').innerHTML = hitsStr;
document.getElementById('visitorNum').innerHTML = '#' + hits;

function copyIP() {
  if (window.clipboardData) {
    window.clipboardData.setData('Text', 'koels.online');
  } else if (navigator.clipboard) {
    navigator.clipboard.writeText('koels.online');
  }
  var msg = document.getElementById('copyMsg');
  msg.style.display = 'block';
  setTimeout(function() { msg.style.display = 'none'; }, 2000);
}

// MC status check
function updateMC() {
  var xhr = new XMLHttpRequest();
  xhr.open('GET', 'https://mcapi.us/server/status?ip=koels.online', true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    try {
      var d = JSON.parse(xhr.responseText);
      if (d && d.online) {
        document.getElementById('mcStatusVal').innerHTML = '<span style="color:#00ffcc">ONLINE</span>';
        document.getElementById('mcStatusVal').style.color = '#00ffcc';
        document.getElementById('mcNow').innerHTML = d.players.now;
        document.getElementById('mcMax').innerHTML = d.players.max;
        document.getElementById('sidebarStatus').innerHTML = '&#128994; ONLINE';
        document.getElementById('sidebarPlayers').innerHTML = d.players.now + ' / ' + d.players.max + ' online';
      } else {
        document.getElementById('mcStatusVal').innerHTML = '<span style="color:#ff4757">OFFLINE</span>';
        document.getElementById('mcNow').innerHTML = '0';
        document.getElementById('mcMax').innerHTML = '0';
        document.getElementById('sidebarStatus').innerHTML = '&#128308; OFFLINE';
        document.getElementById('sidebarPlayers').innerHTML = 'server is down';
      }
    } catch(e) {
      document.getElementById('mcStatusVal').innerHTML = '<span style="color:#ff4757">OFFLINE</span>';
      document.getElementById('sidebarStatus').innerHTML = '&#128308; OFFLINE';
      document.getElementById('sidebarPlayers').innerHTML = 'could not connect';
    }
  };
  xhr.send();
}
updateMC();
</script>
