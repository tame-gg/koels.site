---
// src/pages/speedtest.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>koels.site — Speedtest</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2303030a'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23a29bfe'/%3E%3Cstop offset='100%25' stop-color='%236c5ce7'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:       #03030a;
  --bg2:      #08080f;
  --surface:  #0f0f1a;
  --surface2: #141420;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text:     #f0eeff;
  --muted:    rgba(240,238,255,0.68);
  --dim:      rgba(240,238,255,0.4);
  --accent:   #6c5ce7;
  --accent2:  #a29bfe;
  --lime:     #00ff88;
  --white:    #ffffff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:17px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── CURTAIN ── */
#curtain {
  position:fixed; inset:0; background:var(--bg); z-index:9997;
  display:flex; align-items:center; justify-content:center;
  transition:opacity 0.8s var(--ease), visibility 0.8s;
}
#curtain.gone { opacity:0; visibility:hidden; pointer-events:none }
.curtain-logo {
  font-family:var(--mono); font-size:0.85rem; letter-spacing:0.25em;
  color:var(--dim); text-transform:uppercase;
  animation:curtain-pulse 1s ease infinite;
}
@keyframes curtain-pulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:60px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid var(--border);
  background:rgba(3,3,10,0.85);
  backdrop-filter:blur(24px) saturate(1.8);
  -webkit-backdrop-filter:blur(24px) saturate(1.8);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--white);
  display:flex; align-items:center; gap:10px;
}
.logo-pulse {
  width:6px; height:6px; border-radius:50%;
  background:var(--lime); box-shadow:0 0 10px var(--lime);
  animation:lg-pulse 2s ease infinite;
}
@keyframes lg-pulse { 0%,100%{box-shadow:0 0 6px var(--lime)} 50%{box-shadow:0 0 20px var(--lime),0 0 40px rgba(0,255,136,0.25)} }

.nav { display:flex; align-items:center; gap:32px }
.nav a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
.nav a:hover { color:var(--white) }

/* ── MAIN LAYOUT ── */
.test-page {
  min-height:100vh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:100px 20px 60px;
  position:relative;
}
.test-page::before {
  content:''; position:absolute; inset:0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 40%, black 0%, transparent 100%);
  -webkit-mask-image:radial-gradient(ellipse 90% 90% at 50% 40%, black 0%, transparent 100%);
  opacity:0.35; pointer-events:none; z-index:0;
}

.content-wrap {
  position:relative; z-index:2; width:100%; max-width:720px;
  display:flex; flex-direction:column; align-items:center;
}

/* ── PHASE INDICATOR ── */
.phase-bar {
  display:flex; align-items:center; gap:8px; margin-bottom:40px;
  animation:fade-up 0.6s var(--ease) both;
}
.phase-dot {
  width:8px; height:8px; border-radius:50%;
  background:var(--border2); transition:all 0.3s;
}
.phase-dot.active { background:var(--accent2); box-shadow:0 0 8px var(--accent2); }
.phase-dot.done   { background:var(--lime); box-shadow:0 0 6px var(--lime); }
.phase-label {
  font-family:var(--mono); font-size:0.58rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--dim); transition:color 0.3s;
}
.phase-label.active { color:var(--accent2); }
.phase-label.done   { color:var(--lime); }
.phase-sep { width:20px; height:1px; background:var(--border); }

/* ── GAUGE ── */
.gauge-wrap {
  position:relative; width:320px; height:320px; margin-bottom:24px;
}
.gauge-svg { width:100%; height:100%; }

/* Gauge rings */
.gauge-ring-bg {
  fill:none; stroke:rgba(255,255,255,0.05); stroke-width:6;
}
.gauge-ring-fill {
  fill:none; stroke:url(#gaugeGrad); stroke-width:6;
  stroke-linecap:round;
  transition:stroke-dashoffset 0.3s var(--ease);
  filter:url(#glow);
}

/* Gauge center text */
.gauge-phase {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.2em;
  fill:var(--dim); text-anchor:middle; text-transform:uppercase;
}
.gauge-speed {
  font-family:var(--sans); font-size:3.6rem; font-weight:900;
  fill:var(--white); text-anchor:middle; letter-spacing:-0.05em;
}
.gauge-unit {
  font-family:var(--mono); font-size:0.7rem; fill:var(--dim);
  text-anchor:middle; letter-spacing:0.08em; text-transform:uppercase;
}

/* Glow filter */
.gauge-glow {
  stdDeviation:4; flood-color:#a29bfe; flood-opacity:0.4;
}

/* ── START BUTTON ── */
#start-btn {
  width:72px; height:72px; border-radius:50%; border:none;
  background:linear-gradient(135deg, var(--accent2), var(--accent));
  color:var(--white); cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 0 30px rgba(108,92,231,0.4), 0 0 60px rgba(108,92,231,0.15);
  transition:transform 0.2s, box-shadow 0.2s;
  position:absolute; bottom:0; left:50%; transform:translateX(-50%);
}
#start-btn:hover { transform:translateX(-50%) scale(1.08); box-shadow:0 0 40px rgba(108,92,231,0.6), 0 0 80px rgba(108,92,231,0.2); }
#start-btn:active { transform:translateX(-50%) scale(0.95); }
#start-btn:disabled { opacity:0.3; cursor:default; transform:translateX(-50%); box-shadow:none; }
#start-btn svg { width:24px; height:24px; fill:var(--white); }

/* ── RESULTS ── */
.results-section {
  width:100%; max-width:720px; margin:0 auto;
  padding:0 20px 100px;
}
.result-metric {
  display:grid; grid-template-columns:repeat(3,1fr); gap:16px;
}
.rm-card {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  padding:28px 20px;
  text-align:center;
  position:relative; overflow:hidden;
  animation:fade-up 0.5s var(--ease) both;
}
.rm-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:2px;
}
.rm-card.ping::before { background:var(--accent2); }
.rm-card.dl::before  { background:linear-gradient(90deg, var(--accent), var(--lime)); }
.rm-card.ul::before  { background:linear-gradient(90deg, var(--lime), #00ccff); }
.rm-icon {
  font-size:1.2rem; margin-bottom:10px;
}
.rm-label {
  font-family:var(--mono); font-size:0.52rem; letter-spacing:0.16em;
  text-transform:uppercase; color:var(--dim); margin-bottom:12px;
}
.rm-value {
  font-family:var(--sans); font-size:2.6rem; font-weight:900;
  letter-spacing:-0.05em; line-height:1; margin-bottom:4px;
}
.rm-card.ping .rm-value { color:var(--accent2); }
.rm-card.dl  .rm-value { color:var(--lime); }
.rm-card.ul  .rm-value { color:#00ccff; }
.rm-unit {
  font-family:var(--mono); font-size:0.6rem; color:var(--dim);
  letter-spacing:0.06em; text-transform:uppercase;
}

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between; padding:22px 48px;
}
.foot-l, .foot-r { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.12em; color:var(--dim); text-transform:uppercase }
.foot-r { display:flex; gap:18px }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(22px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

@media(max-width:860px){
  header { padding:0 20px }
  .nav { display:none }
  .test-page { padding:100px 16px 40px; min-height:auto; }
  .gauge-wrap { width:260px; height:260px; }
  .gauge-speed { font-size:2.6rem; }
  .result-metric { grid-template-columns:1fr; }
  footer { flex-direction:column; gap:10px; text-align:center }
}
</style>
</head>
<body>

<div id="curtain"><div class="curtain-logo">koels.site</div></div>

<!-- HEADER -->
<header>
  <div class="logo"><div class="logo-pulse"></div>Koels.site</div>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/links">Links</a>
    <a href="/radar">Radar</a>
  </nav>
</header>

<!-- SPEEDTEST -->
<div class="test-page">
  <div class="content-wrap">

    <!-- Phase bar -->
    <div class="phase-bar" id="phase-bar">
      <div class="phase-dot" id="pd-ping"></div>
      <div class="phase-label" id="pl-ping">Ping</div>
      <div class="phase-sep"></div>
      <div class="phase-dot" id="pd-dl"></div>
      <div class="phase-label" id="pl-dl">Download</div>
      <div class="phase-sep"></div>
      <div class="phase-dot" id="pd-ul"></div>
      <div class="phase-label" id="pl-ul">Upload</div>
    </div>

    <!-- Gauge -->
    <div class="gauge-wrap">
      <svg class="gauge-svg" viewBox="0 0 320 320">
        <defs>
          <linearGradient id="gaugeGrad" x1="0%" y1="100%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#6c5ce7"/>
            <stop offset="50%" stop-color="#a29bfe"/>
            <stop offset="100%" stop-color="#00ff88"/>
          </linearGradient>
          <filter id="glow">
            <feGaussianBlur class="gauge-glow" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        <!-- Outer decorative ring -->
        <circle cx="160" cy="160" r="148" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>

        <!-- Background ring -->
        <circle class="gauge-ring-bg" cx="160" cy="160" r="130"/>

        <!-- Filled ring -->
        <circle class="gauge-ring-fill" id="gauge-fill" cx="160" cy="160" r="130"
                stroke-dasharray="816.81" stroke-dashoffset="816.81"
                transform="rotate(-90 160 160)"/>

        <!-- Center text -->
        <text class="gauge-phase" x="160" y="120" id="gauge-phase-label">Ready</text>
        <text class="gauge-speed" x="160" y="180" id="gauge-num">—</text>
        <text class="gauge-unit" x="160" y="205" id="gauge-unit-label">Mbps</text>
      </svg>

      <!-- Start button -->
      <button id="start-btn" onclick="runTest()">
        <svg viewBox="0 0 24 24"><polygon points="8,5 20,12 8,19"/></svg>
      </button>
    </div>

  </div>
</div>

<!-- RESULTS -->
<div class="results-section" id="results-section"></div>

<!-- FOOTER -->
<footer>
  <div class="foot-l">© 2026 Koels.site</div>
  <div class="foot-r">
    <a href="/">Home</a>
    <span>·</span>
    <a href="/links">Links</a>
    <span>·</span>
    <a href="/radar">Radar</a>
    <span>·</span>
    <a href="/ping">Ping</a>
  </div>
</footer>

<script is:inline>
/* Curtain */
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('curtain').classList.add('gone'),650))

/* ── ELEMENTS ── */
const gaugeFill   = document.getElementById('gauge-fill');
const gaugeNum    = document.getElementById('gauge-num');
const gaugePhase  = document.getElementById('gauge-phase-label');
const gaugeUnit   = document.getElementById('gauge-unit-label');
const startBtn    = document.getElementById('start-btn');
const resultsEl   = document.getElementById('results-section');
const ARC = 816.81;

/* Phase elements */
const phases = {
  ping: { dot: document.getElementById('pd-ping'), label: document.getElementById('pl-ping') },
  dl:   { dot: document.getElementById('pd-dl'),   label: document.getElementById('pl-dl') },
  ul:   { dot: document.getElementById('pd-ul'),   label: document.getElementById('pl-ul') },
};

let running = false;

function setPhase(key) {
  ['ping','dl','ul'].forEach(k => {
    phases[k].dot.classList.remove('active','done');
    phases[k].label.classList.remove('active','done');
  });
  if (key === 'ping')  { phases.ping.dot.classList.add('active');  phases.ping.label.classList.add('active'); }
  if (key === 'dl')    { phases.ping.dot.classList.add('done'); phases.dl.dot.classList.add('active'); phases.dl.label.classList.add('active'); }
  if (key === 'ul')    { phases.ping.dot.classList.add('done'); phases.dl.dot.classList.add('done'); phases.ul.dot.classList.add('active'); phases.ul.label.classList.add('active'); }
  if (key === 'done')  { phases.ping.dot.classList.add('done'); phases.dl.dot.classList.add('done'); phases.ul.dot.classList.add('done'); phases.ping.label.classList.add('done'); phases.dl.label.classList.add('done'); phases.ul.label.classList.add('done'); }
}

function setGauge(pct, value) {
  gaugeFill.style.strokeDashoffset = ARC - (ARC * Math.min(Math.max(pct,0),100) / 100);
  gaugeNum.textContent = typeof value === 'number' ? (value >= 10 ? Math.round(value) : value.toFixed(1)) : value;
}

/* ── PING ── */
async function measurePing(samples = 10) {
  const pings = [];
  for (let i = 0; i < samples; i++) {
    const start = performance.now();
    await fetch('https://speed.cloudflare.com/cdn-cgi/trace', {
      method: 'HEAD',
      mode: 'no-cors',
      cache: 'no-store'
    });
    pings.push(Math.round(performance.now() - start));
    /* Animate gauge during ping */
    setGauge((i / samples) * 100, pings[i] + ' ms');
    await new Promise(r => setTimeout(r, 100));
  }
  /* Remove outliers: sort and take middle 80% */
  pings.sort((a,b) => a - b);
  const trimmed = pings.slice(1, -1);
  const avg = Math.round(trimmed.reduce((a,b) => a+b, 0) / trimmed.length);
  return avg;
}

/* ── DOWNLOAD ── */
async function measureDownload() {
  const sizes = [1_000_000, 5_000_000, 10_000_000, 25_000_000];
  const speeds = [];

  for (const size of sizes) {
    const start = performance.now();
    await fetch(`https://speed.cloudflare.com/__down?bytes=${size}`, {
      cache: 'no-store',
      mode: 'no-cors'
    });
    const elapsed = (performance.now() - start) / 1000;
    const speed = (size * 8) / (elapsed * 1e6);
    speeds.push(speed);

    const totalSoFar = sizes.slice(0, sizes.indexOf(size) + 1).reduce((a,b)=>a+b,0);
    const pct = Math.min((totalSoFar / 41_000_000) * 100, 100);
    setGauge(pct, speed);
  }

  /* Use last (largest) as most accurate */
  const avgSpeed = speeds[speeds.length - 1];
  const peakSpeed = Math.max(...speeds);
  return { avgSpeed, peakSpeed, totalMB: 41, time: 0 };
}

/* ── UPLOAD ── */
async function measureUpload() {
  const sizes = [1_000_000, 2_000_000, 5_000_000, 10_000_000];
  const speeds = [];

  for (const size of sizes) {
    const data = new Uint8Array(size);
    const start = performance.now();
    await fetch('https://speed.cloudflare.com/__up', {
      method: 'POST',
      body: data,
      cache: 'no-store',
      mode: 'no-cors'
    });
    const elapsed = (performance.now() - start) / 1000;
    const speed = (size * 8) / (elapsed * 1e6);
    speeds.push(speed);

    const totalSoFar = sizes.slice(0, sizes.indexOf(size) + 1).reduce((a,b)=>a+b,0);
    const pct = Math.min((totalSoFar / 18_000_000) * 100, 100);
    setGauge(pct, speed);
  }

  const avgSpeed = speeds[speeds.length - 1];
  const peakSpeed = Math.max(...speeds);
  return { avgSpeed, peakSpeed, totalMB: 18, time: 0 };
}

/* ── MAIN ── */
async function runTest() {
  if (running) return;
  running = true;
  startBtn.disabled = true;
  startBtn.style.opacity = '0';
  resultsEl.innerHTML = '';

  try {
    /* 1. Ping */
    setPhase('ping');
    gaugePhase.textContent = 'Ping';
    gaugeUnit.textContent = 'ms';
    const ping = await measurePing();

    /* 2. Download */
    setPhase('dl');
    gaugePhase.textContent = 'Download';
    gaugeUnit.textContent = 'Mbps';
    setGauge(0, 0);
    const dl = await measureDownload();

    /* 3. Upload */
    setPhase('ul');
    gaugePhase.textContent = 'Upload';
    gaugeUnit.textContent = 'Mbps';
    setGauge(0, 0);
    const ul = await measureUpload();

    /* Done */
    setPhase('done');
    gaugePhase.textContent = 'Complete';
    gaugeUnit.textContent = 'Mbps';
    setGauge(100, dl.avgSpeed);

    /* Show results */
    resultsEl.innerHTML = `
      <div class="result-metric">
        <div class="rm-card ping" style="animation-delay:0s">
          <div class="rm-icon">📡</div>
          <div class="rm-label">Ping</div>
          <div class="rm-value">${ping}</div>
          <div class="rm-unit">ms</div>
        </div>
        <div class="rm-card dl" style="animation-delay:0.1s">
          <div class="rm-icon">⬇️</div>
          <div class="rm-label">Download</div>
          <div class="rm-value">${dl.avgSpeed.toFixed(1)}</div>
          <div class="rm-unit">Mbps · peak ${dl.peakSpeed.toFixed(1)}</div>
        </div>
        <div class="rm-card ul" style="animation-delay:0.2s">
          <div class="rm-icon">⬆️</div>
          <div class="rm-label">Upload</div>
          <div class="rm-value">${ul.avgSpeed.toFixed(1)}</div>
          <div class="rm-unit">Mbps · peak ${ul.peakSpeed.toFixed(1)}</div>
        </div>
      </div>
    `;

    startBtn.style.opacity = '1';
    startBtn.disabled = false;

  } catch (err) {
    resultsEl.innerHTML = `
      <div class="result-metric">
        <div class="rm-card ping" style="animation-delay:0s">
          <div class="rm-label">Error</div>
          <div class="rm-value" style="font-size:1.4rem;color:var(--red)">${err.message}</div>
          <div class="rm-unit">Cloudflare may be unreachable</div>
        </div>
      </div>
    `;
    startBtn.style.opacity = '1';
    startBtn.disabled = false;
    running = false;
  }
}
</script>
</body>
</html>
