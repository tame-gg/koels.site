        <a href="#privacy-policy">Privacy Policy</a>
        <a href="https://www.mozilla.org/en-US/firefox/" target="_blank" rel="noopener">Built on Firefox</a>
      </div>
      <span class="footer-copy">Not affiliated with or endorsed by Mozilla Corporation.</span>
    </footer>
  </div>

  <script>
    (function () {
      const ua = navigator.userAgent.toLowerCase();
      const pl = (navigator.platform ?? '').toLowerCase();
      let os = 'Unknown', icon = '⬇';
      if (/win/.test(pl) || /windows/.test(ua))        { os = 'Windows x64'; icon = '🪟'; }
      else if (/mac/.test(pl) || /mac os/.test(ua))    { os = 'macOS ARM';   icon = ''; }
      else if (/linux/.test(pl) || /linux/.test(ua))   { os = 'Linux x64';   icon = '🐧'; }
      document.getElementById('btn-label').textContent  = `Download for ${os}`;
      document.getElementById('btn-icon').textContent   = icon;
      document.getElementById('platform-hint').textContent = `detected: ${os} — builds in progress`;
    })();
  </script>

