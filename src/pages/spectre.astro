---
// Spectre Browser — landing page
// Built with Astro. Deploy to any static host.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Spectre Browser — Privacy Without Compromise</title>
  <meta name="description" content="Spectre is a privacy-first browser built on Firefox, with tracking protection, fingerprinting resistance, and no telemetry baked in." />

  <!-- Open Graph / Discord / Slack / iMessage embeds -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://koels.site/spectre" />
  <meta property="og:title"       content="Spectre Browser — Privacy Without Compromise" />
  <meta property="og:description" content="A Firefox fork with strict tracking protection, fingerprint resistance, and zero telemetry — on by default. Free and open source." />
  <meta property="og:image"       content="https://koels.site/og.png" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"   content="Spectre Browser" />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter / X card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Spectre Browser — Privacy Without Compromise" />
  <meta name="twitter:description" content="A Firefox fork with strict tracking protection, fingerprint resistance, and zero telemetry — on by default." />
  <meta name="twitter:image"       content="https://koels.site/og.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #03030a;
      --bg2:      #07070f;
      --surface:  #0e0e1c;
      --surface2: #131324;
      --border:   rgba(255,255,255,0.06);
      --border2:  rgba(255,255,255,0.11);
      --text:     #f0eeff;
      --muted:    rgba(240,238,255,0.6);
      --dim:      rgba(240,238,255,0.35);
      --accent:   #6c5ce7;
      --accent2:  #a29bfe;
      --lime:     #00ff88;
      --red:      #ff4757;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── Nav ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 60px;
      background: rgba(3,3,10,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: -0.02em;
      color: var(--text);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .nav-logo span { color: var(--accent2); }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.875rem;
      transition: color 0.15s;
    }

    .nav-links a:hover { color: var(--text); }

    /* ── Hero ── */
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 7rem 1.5rem 5rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 700px;
      background: radial-gradient(ellipse at center, rgba(108,92,231,0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.3rem 0.8rem;
      border-radius: 99px;
      border: 1px solid rgba(162,155,254,0.3);
      background: rgba(108,92,231,0.1);
      color: var(--accent2);
      font-size: 0.8rem;
      font-weight: 500;
      margin-bottom: 1.8rem;
      font-family: 'JetBrains Mono', monospace;
    }

    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      max-width: 800px;
      margin-bottom: 1.2rem;
    }

    .hero h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin-bottom: 2.5rem;
    }

    /* ── Download area ── */
    .download-primary {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .btn-download {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 2rem;
      border-radius: 10px;
      border: none;
      font-size: 1rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
      text-decoration: none;
      background: linear-gradient(135deg, var(--accent), #8b7cf7);
      color: #fff;
      box-shadow: 0 4px 24px rgba(108,92,231,0.35);
      position: relative;
    }

    .btn-download:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 32px rgba(108,92,231,0.5);
    }

    .btn-download:active { transform: translateY(0); }

    .btn-download.soon {
      opacity: 0.55;
      cursor: not-allowed;
      background: var(--surface2);
      box-shadow: none;
      border: 1px solid var(--border2);
      color: var(--muted);
    }

    .btn-download.soon::after {
      content: 'building…';
      position: absolute;
      top: -22px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.7rem;
      font-family: 'JetBrains Mono', monospace;
      color: var(--accent2);
      white-space: nowrap;
    }

    .platform-hint {
      font-size: 0.8rem;
      color: var(--dim);
      font-family: 'JetBrains Mono', monospace;
    }

    .other-platforms {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 0.5rem;
    }

    .btn-alt {
      padding: 0.5rem 1.1rem;
      border-radius: 8px;
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--muted);
      font-size: 0.875rem;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
      position: relative;
    }

    .btn-alt:hover { border-color: var(--accent2); color: var(--text); }

    /* ── Fork notice ── */
    .fork-notice {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      max-width: 640px;
      margin: 3.5rem auto 0;
      padding: 1.2rem 1.4rem;
      border-radius: 12px;
      background: var(--surface);
      border: 1px solid var(--border2);
      text-align: left;
    }

    .fork-notice .icon { font-size: 1.5rem; flex-shrink: 0; }

    .fork-notice p {
      font-size: 0.875rem;
      color: var(--muted);
      margin: 0;
    }

    .fork-notice strong { color: var(--text); }

    /* ── Features ── */
    .section {
      padding: 5rem 1.5rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent2);
      font-family: 'JetBrains Mono', monospace;
      margin-bottom: 0.75rem;
    }

    .section h2 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      margin-bottom: 3rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
    }

    .feature-card {
      padding: 1.5rem;
      border-radius: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      transition: border-color 0.2s, transform 0.2s;
    }

    .feature-card:hover {
      border-color: rgba(108,92,231,0.35);
      transform: translateY(-2px);
    }

    .feature-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(108,92,231,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }

    .feature-card h3 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .feature-card p {
      font-size: 0.875rem;
      color: var(--muted);
    }

    /* ── Privacy Policy ── */
    .policy-section {
      padding: 5rem 1.5rem;
      background: var(--bg2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .policy-inner {
      max-width: 720px;
      margin: 0 auto;
    }

    .policy-inner h2 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      margin-bottom: 0.5rem;
    }

    .policy-inner .updated {
      font-size: 0.8rem;
      color: var(--dim);
      font-family: 'JetBrains Mono', monospace;
      margin-bottom: 2.5rem;
      display: block;
    }

    .policy-block {
      margin-bottom: 2rem;
    }

    .policy-block h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--accent2);
      margin-bottom: 0.6rem;
    }

    .policy-block p, .policy-block ul {
      font-size: 0.9rem;
      color: var(--muted);
    }

    .policy-block ul {
      padding-left: 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    /* ── Footer ── */
    footer {
      padding: 3rem 1.5rem;
      text-align: center;
    }

    footer p {
      font-size: 0.8rem;
      color: var(--dim);
    }

    footer a {
      color: var(--accent2);
      text-decoration: none;
    }

    footer a:hover { text-decoration: underline; }

    .divider {
      height: 1px;
      background: var(--border);
      margin: 0;
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      nav { padding: 0 1rem; }
      .nav-links { display: none; }
      .hero { padding: 5rem 1rem 4rem; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="#" class="nav-logo">
      ◈ <span>Spectre</span>
    </a>
    <ul class="nav-links">
      <li><a href="#features">Features</a></li>
      <li><a href="#download">Download</a></li>
      <li><a href="#privacy-policy">Privacy</a></li>
      <li><a href="https://github.com/koelss/Spectre" target="_blank" rel="noopener">GitHub</a></li>
    </ul>
  </nav>

  <!-- ── Hero ── -->
  <section class="hero" id="download">
    <div class="badge">v0.1 — currently building</div>

    <h1>Browse the web<br />without being <em>watched</em>.</h1>

    <p>
      Spectre is a Firefox-based browser with tracking protection, fingerprint
      resistance, and zero telemetry — built in and on by default.
    </p>

    <!-- Primary download button — platform-detected -->
    <div class="download-primary">
      <button id="btn-primary" class="btn-download soon" onclick="return false;">
        <span id="btn-icon">⬇</span>
        <span id="btn-label">Download Spectre</span>
      </button>
      <span class="platform-hint" id="platform-hint">detecting your platform…</span>
    </div>

    <!-- Other platforms -->
    <div class="other-platforms">
      <button class="btn-alt soon" onclick="return false;">Windows x64</button>
      <button class="btn-alt soon" onclick="return false;">Linux x64</button>
      <button class="btn-alt soon" onclick="return false;">macOS ARM</button>
    </div>

    <!-- Firefox fork notice -->
    <div class="fork-notice">
      <span class="icon">🦊</span>
      <p>
        <strong>Spectre is a fork of Mozilla Firefox.</strong> It inherits full
        compatibility with Firefox extensions (AMO), Mozilla's rendering engine
        (Gecko), and the existing Firefox security model — then layers privacy
        defaults on top that Mozilla ships as opt-in. Spectre is not affiliated
        with or endorsed by Mozilla Corporation.
      </p>
    </div>
  </section>

  <!-- ── Features ── -->
  <section class="section" id="features">
    <p class="section-label">What's different</p>
    <h2>Privacy on by default.</h2>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🛡</div>
        <h3>Strict Tracking Protection</h3>
        <p>Blocks trackers, cryptominers, social tracking scripts, and fingerprinters out of the box — no settings toggle required.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎭</div>
        <h3>Fingerprint Resistance</h3>
        <p>Enables <code style="font-family:'JetBrains Mono',monospace;font-size:0.8em;color:var(--accent2)">resistFingerprinting</code> and first-party isolation so sites can't build a profile of your browser environment.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📡</div>
        <h3>No Telemetry</h3>
        <p>All Mozilla telemetry, crash reporting, and data collection is disabled at compile time — not just toggled off in prefs.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔒</div>
        <h3>HTTPS-Only Mode</h3>
        <p>Every connection is forced to HTTPS by default. Spectre warns you before falling back to an unencrypted connection.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🧩</div>
        <h3>Firefox Extension Support</h3>
        <p>Full compatibility with the Firefox Add-ons Marketplace (AMO). Install uBlock Origin, Bitwarden, or anything else you already use.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌐</div>
        <h3>DNS over HTTPS</h3>
        <p>Resolves DNS through Cloudflare's encrypted resolver by default, preventing your ISP from logging every site you visit.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🚫</div>
        <h3>No Pocket, No Sponsored Sites</h3>
        <p>Pocket integration, sponsored top sites, and all built-in advertising surfaces are removed from the build entirely.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔗</div>
        <h3>WebRTC IP Leak Prevention</h3>
        <p>WebRTC is restricted to proxy-only mode so your real IP address can't be leaked by video call or voice chat sites.</p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ── Privacy Policy ── -->
  <section class="policy-section" id="privacy-policy">
    <div class="policy-inner">
      <p class="section-label">Legal</p>
      <h2>Privacy Policy</h2>
      <span class="updated">Last updated: April 2026</span>

      <div class="policy-block">
        <h3>What Spectre collects</h3>
        <p>
          <strong style="color:var(--lime)">Nothing.</strong> Spectre Browser does not collect, transmit, or store any
          data about you or your browsing. Telemetry, crash reporting, and health
          reports are disabled at the build level — there is no opt-out because
          there is nothing to opt out of.
        </p>
      </div>

      <div class="policy-block">
        <h3>This website</h3>
        <p>The Spectre homepage (this page) does not use cookies, analytics, or
        tracking scripts. No third-party analytics provider has access to your
        visit. The only external request made is to Google Fonts to load the
        Inter and JetBrains Mono typefaces.</p>
      </div>

      <div class="policy-block">
        <h3>GitHub</h3>
        <p>Spectre's source code is hosted on GitHub. Downloading a release
        means connecting to GitHub's servers and CDN, which are subject to
        <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener" style="color:var(--accent2)">GitHub's privacy policy</a>. Spectre has no
        control over data GitHub collects during that request.</p>
      </div>

      <div class="policy-block">
        <h3>Firefox upstream</h3>
        <p>Spectre is a fork of Mozilla Firefox. While we disable all of
        Mozilla's data collection at build time, the underlying Gecko engine
        may still make network requests for legitimate browser functionality
        (e.g. Safe Browsing list updates, certificate revocation checks). These
        are not telemetry and are standard browser security infrastructure.</p>
      </div>

      <div class="policy-block">
        <h3>Updates</h3>
        <p>Spectre's auto-updater is disabled. You will never receive an
        automatic background update. New versions are announced on GitHub
        Releases, and you choose when and whether to upgrade.</p>
      </div>

      <div class="policy-block">
        <h3>Contact</h3>
        <p>Questions or concerns? Open an issue on
        <a href="https://github.com/koelss/Spectre/issues" target="_blank" rel="noopener" style="color:var(--accent2)">GitHub</a>.</p>
      </div>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer>
    <p style="margin-bottom:0.4rem">
      Spectre Browser is free and open source —
      <a href="https://github.com/koelss/Spectre" target="_blank" rel="noopener">view source on GitHub</a>
    </p>
    <p>
      Built on <a href="https://www.mozilla.org/en-US/firefox/" target="_blank" rel="noopener">Mozilla Firefox</a>.
      Not affiliated with or endorsed by Mozilla Corporation.
    </p>
  </footer>

  <script>
    // Detect platform and update the primary download button label
    (function () {
      const ua = navigator.userAgent.toLowerCase();
      const platform = navigator.platform?.toLowerCase() ?? '';

      let os = 'Unknown';
      let icon = '⬇';

      if (/win/.test(platform) || /windows/.test(ua)) {
        os = 'Windows x64';
        icon = '🪟';
      } else if (/mac/.test(platform) || /mac os/.test(ua)) {
        os = 'macOS ARM';
        icon = '🍎';
      } else if (/linux/.test(platform) || /linux/.test(ua)) {
        os = 'Linux x64';
        icon = '🐧';
      }

      document.getElementById('btn-label').textContent = `Download for ${os}`;
      document.getElementById('btn-icon').textContent = icon;
      document.getElementById('platform-hint').textContent =
        `Detected: ${os} — builds in progress`;
    })();
  </script>

</body>
</html>
