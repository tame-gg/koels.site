  <script>
    (function () {
      const meta = {
        win:   { label: 'Windows x64', icon: '🪟', ext: '.exe' },
        mac:   { label: 'macOS ARM',   icon: '',   ext: '.dmg' },
        linux: { label: 'Linux x64',   icon: '🐧', ext: '.AppImage' },
      }

      const ua = navigator.userAgent.toLowerCase()
      const pl = (navigator.platform ?? '').toLowerCase()
      let platform = 'linux'
      if (/win/.test(pl) || /windows/.test(ua))     platform = 'win'
      else if (/mac/.test(pl) || /mac os/.test(ua)) platform = 'mac'

      // Update button label immediately (before API responds)
      document.getElementById('btn-icon').textContent  = meta[platform].icon
      document.getElementById('btn-label').textContent = `Download for ${meta[platform].label}`

      // Highlight detected platform button
      document.querySelectorAll('.btn-platform[data-platform]').forEach(a => {
        if (a.dataset.platform === platform) a.classList.add('active')
      })

      // Fetch latest release — resolve actual asset URLs by extension
      fetch('https://api.github.com/repos/koelss/Spectre/releases/latest')
        .then(r => r.json())
        .then(data => {
          if (!data.assets) return

          // Build a map: platform → download URL (matched by file extension)
          const urls = {}
          for (const [p, { ext }] of Object.entries(meta)) {
            const asset = data.assets.find(a =>
              a.name.toLowerCase().endsWith(ext.toLowerCase()) &&
              // prefer installer over portable for windows
              (p !== 'win' || a.name.toLowerCase().includes('setup') || !a.name.toLowerCase().includes('portable'))
            )
            if (asset) urls[p] = asset.browser_download_url
          }

          // Wire up primary button
          if (urls[platform]) document.getElementById('btn-primary').href = urls[platform]

          // Wire up all platform buttons
          document.querySelectorAll('.btn-platform[data-platform]').forEach(a => {
            if (urls[a.dataset.platform]) a.href = urls[a.dataset.platform]
          })

          // Version badge + hint
          if (data.tag_name) {
            document.getElementById('version-badge').textContent = data.tag_name
            document.getElementById('platform-hint').textContent =
              `${data.tag_name} · ${meta[platform].label} detected`
          } else {
            document.getElementById('platform-hint').textContent = `${meta[platform].label} detected`
          }

          // Auto-start download
          if (urls[platform]) {
            const a = document.createElement('a')
            a.href = urls[platform]
            a.download = ''
            document.body.appendChild(a)
            a.click()
            document.body.removeChild(a)
          }
        })
        .catch(() => {
          document.getElementById('platform-hint').textContent = `${meta[platform].label} detected`
        })
    })()
  </script>

