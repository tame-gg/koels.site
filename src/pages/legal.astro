---
// src/pages/legal.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Legal — koels.site</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2303030a'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23a29bfe'/%3E%3Cstop offset='100%25' stop-color='%236c5ce7'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:       #03030a;
  --bg2:      #08080f;
  --surface:  #0f0f1a;
  --surface2: #141420;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text:     #f0eeff;
  --muted:    rgba(240,238,255,0.68);
  --dim:      rgba(240,238,255,0.4);
  --accent:   #6c5ce7;
  --accent2:  #a29bfe;
  --lime:     #00ff88;
  --red:      #ff4757;
  --white:    #ffffff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:17px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

#curtain {
  position:fixed; inset:0; background:var(--bg); z-index:9997;
  display:flex; align-items:center; justify-content:center;
  transition:opacity 0.8s var(--ease), visibility 0.8s;
}
#curtain.gone { opacity:0; visibility:hidden; pointer-events:none }
.curtain-logo {
  font-family:var(--mono); font-size:0.85rem; letter-spacing:0.25em;
  color:var(--dim); text-transform:uppercase;
  animation:curtain-pulse 1s ease infinite;
}
@keyframes curtain-pulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:60px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid var(--border);
  background:rgba(3,3,10,0.85);
  backdrop-filter:blur(24px) saturate(1.8);
  -webkit-backdrop-filter:blur(24px) saturate(1.8);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--white);
  display:flex; align-items:center; gap:10px;
}
.logo-pulse {
  width:6px; height:6px; border-radius:50%;
  background:var(--lime); box-shadow:0 0 10px var(--lime);
  animation:lg-pulse 2s ease infinite;
}
@keyframes lg-pulse { 0%,100%{box-shadow:0 0 6px var(--lime)} 50%{box-shadow:0 0 20px var(--lime),0 0 40px rgba(0,255,136,0.25)} }
.nav { display:flex; align-items:center; gap:32px }
.nav a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
.nav a:hover { color:var(--white) }

.page-wrap { max-width:860px; margin:0 auto; padding:120px 40px 80px }

.page-hero { margin-bottom:72px; position:relative }
.page-hero::before {
  content:''; position:absolute;
  top:-60px; left:-40px; right:-40px; bottom:0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 80% 100% at 20% 50%, black 0%, transparent 100%);
  -webkit-mask-image:radial-gradient(ellipse 80% 100% at 20% 50%, black 0%, transparent 100%);
  opacity:0.4; pointer-events:none; z-index:0;
}
.eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.72rem; font-weight:500;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--accent2);
  margin-bottom:24px; animation:fade-up 0.9s var(--ease) both;
}
.eyebrow-line { width:28px; height:1px; background:var(--accent) }
.page-title {
  font-family:var(--sans); font-size:clamp(2.6rem, 5vw, 4.5rem);
  font-weight:900; line-height:0.95; letter-spacing:-0.03em; color:var(--white);
  animation:fade-up 0.9s 0.07s var(--ease) both; position:relative; z-index:1;
}
.page-title .grad {
  background:linear-gradient(135deg, var(--accent2) 0%, #c084fc 50%, var(--accent2) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 4s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }
.page-meta {
  margin-top:20px; font-family:var(--mono); font-size:0.72rem;
  color:var(--dim); letter-spacing:0.1em; text-transform:uppercase;
  animation:fade-up 0.9s 0.14s var(--ease) both;
}

.tab-nav {
  display:flex; border:1px solid var(--border2);
  border-radius:6px; overflow:hidden; margin-bottom:56px;
  animation:fade-up 0.9s 0.2s var(--ease) both;
}
.tab-btn {
  flex:1; padding:13px 20px;
  font-family:var(--mono); font-size:0.7rem; font-weight:600;
  letter-spacing:0.14em; text-transform:uppercase;
  background:transparent; color:var(--muted);
  border:none; cursor:pointer; transition:0.25s var(--ease);
}
.tab-btn + .tab-btn { border-left:1px solid var(--border2) }
.tab-btn.active { background:var(--accent); color:var(--white) }
.tab-btn:not(.active):hover { background:rgba(255,255,255,0.04); color:var(--white) }

.panel { display:none }
.panel.active { display:block }

.doc-section { margin-bottom:44px; padding-bottom:44px; border-bottom:1px solid var(--border) }
.doc-section:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0 }
.section-header { display:flex; align-items:baseline; gap:16px; margin-bottom:16px }
.section-num { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.2em; color:var(--accent2); text-transform:uppercase; flex-shrink:0 }
.section-title { font-family:var(--sans); font-size:1rem; font-weight:700; color:var(--white); letter-spacing:-0.01em }
.doc-text { font-family:var(--mono); font-size:0.8rem; line-height:1.95; color:var(--muted); letter-spacing:0.03em }
.doc-text + .doc-text { margin-top:12px }

.data-table { width:100%; border-collapse:collapse; margin-top:20px; border:1px solid var(--border2); border-radius:6px; overflow:hidden }
.data-table th { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--dim); background:var(--surface2); padding:12px 16px; text-align:left; border-bottom:1px solid var(--border2) }
.data-table td { font-family:var(--mono); font-size:0.75rem; color:var(--muted); padding:12px 16px; border-bottom:1px solid var(--border); line-height:1.6 }
.data-table tr:last-child td { border-bottom:none }
.data-table tr:hover td { background:rgba(255,255,255,0.02) }
.badge { display:inline-flex; align-items:center; padding:2px 9px; border-radius:999px; font-size:0.62rem; letter-spacing:0.1em; font-weight:600; text-transform:uppercase }
.badge-green { background:rgba(0,255,136,0.1); color:var(--lime); border:1px solid rgba(0,255,136,0.2) }

.callout { display:flex; gap:14px; align-items:flex-start; padding:16px 18px; border-radius:6px; margin-top:16px }
.callout-promise { background:rgba(0,255,136,0.05); border:1px solid rgba(0,255,136,0.15) }
.callout-warn { background:rgba(108,92,231,0.06); border:1px solid rgba(108,92,231,0.2) }
.callout-icon { font-size:1rem; flex-shrink:0; margin-top:1px }
.callout-text { font-family:var(--mono); font-size:0.75rem; line-height:1.8; color:var(--muted); letter-spacing:0.03em }
.callout-promise .callout-text { color:rgba(0,255,136,0.85) }

footer { display:flex; align-items:center; justify-content:space-between; padding:22px 48px; border-top:1px solid var(--border); margin-top:56px }
.foot-l, .foot-r { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.12em; color:var(--dim); text-transform:uppercase }
.foot-r { display:flex; gap:18px }

@keyframes fade-up { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(22px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

@media(max-width:700px){
  .page-wrap { padding:100px 20px 60px }
  header { padding:0 20px }
  .nav { display:none }
  footer { flex-direction:column; gap:10px; text-align:center; padding:22px 20px }
  .data-table th, .data-table td { padding:10px 12px }
}
</style>
</head>
<body>

<div id="curtain"><div class="curtain-logo">koels.site</div></div>

<header>
  <a href="/" class="logo"><div class="logo-pulse"></div>Koels.site</a>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/links">Links</a>
  </nav>
</header>

<div class="page-wrap">

  <div class="page-hero">
    <div class="eyebrow"><span class="eyebrow-line"></span>Discord Bot</div>
    <h1 class="page-title"><span class="grad">Legal</span><br>Docs.</h1>
    <div class="page-meta">Last updated — April 2026 &nbsp;·&nbsp; Effective immediately</div>
  </div>

  <div class="tab-nav">
    <button class="tab-btn active" onclick="switchTab('tos', this)">Terms of Service</button>
    <button class="tab-btn" onclick="switchTab('privacy', this)">Privacy Policy</button>
  </div>

  <!-- TERMS OF SERVICE -->
  <div id="panel-tos" class="panel active">

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">01</span>
        <span class="section-title">Agreement</span>
      </div>
      <p class="doc-text">
        By using or interacting with this Discord bot, you agree to these terms. This bot is private and only operates within my personal Discord server — it is not publicly available. Even if added elsewhere, it will not function outside of its intended server.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">02</span>
        <span class="section-title">Eligibility</span>
      </div>
      <p class="doc-text">
        You must be at least 13 years old to use this bot, in line with Discord's own Terms of Service. Since this bot is private to my server, only members I've approved will ever interact with it.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">03</span>
        <span class="section-title">Acceptable Use</span>
      </div>
      <p class="doc-text">
        Use the bot for its intended purpose only — Minecraft verification. Don't try to abuse, exploit, or break it.
      </p>
      <div class="callout callout-warn">
        <span class="callout-icon">⚠</span>
        <span class="callout-text">Spoofing accounts, spamming commands, or trying to manipulate the verification system is not allowed and may result in a permanent ban.</span>
      </div>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">04</span>
        <span class="section-title">Availability</span>
      </div>
      <p class="doc-text">
        The bot is provided as-is with no uptime guarantees. It may go offline for maintenance or updates at any time. I reserve the right to modify or shut it down without prior notice.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">05</span>
        <span class="section-title">Termination</span>
      </div>
      <p class="doc-text">
        I can restrict or remove your access at any time if these terms are violated. Since this is a private bot, access is already limited to members of my server.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">06</span>
        <span class="section-title">Staff &amp; Admin Terms</span>
      </div>
      <p class="doc-text">
        Staff and admin roles are granted access to view player data as part of their responsibilities. By accepting a staff or admin role, you agree to the following:
      </p>
      <p class="doc-text" style="margin-top:14px; padding-left:16px; border-left:2px solid var(--border2);">
        · You will not use player data for any malicious, harmful, or unauthorized purpose.<br><br>
        · You will not sell, share, leak, or give out any player information to anyone outside of this server, under any circumstances.<br><br>
        · You will treat all data you have access to with care and respect the privacy of every player.<br><br>
        · If you are found to have violated any of the above, your staff permissions will be revoked immediately and you will be demoted.
      </p>
      <div class="callout callout-warn">
        <span class="callout-icon">⚠</span>
        <span class="callout-text">Selling or giving out player information as a staff member is an immediate demotion offense — no exceptions. Accepting a staff role means you've read and agreed to this.</span>
      </div>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">07</span>
        <span class="section-title">Contact</span>
      </div>
      <p class="doc-text">
        Questions? Reach me on Discord at <span style="color:var(--accent2)">@koels</span> or by email at <span style="color:var(--accent2)">kyle@koels.site</span>.
      </p>
    </div>

  </div>

  <!-- PRIVACY POLICY -->
  <div id="panel-privacy" class="panel">

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">01</span>
        <span class="section-title">The Short Version</span>
      </div>
      <p class="doc-text">
        I collect a small amount of data to make the bot work. None of it is sold, shared, or used for anything other than keeping the bot functional.
      </p>
      <div class="callout callout-promise">
        <span class="callout-icon">✦</span>
        <span class="callout-text">Your data will never be sold to anyone, ever. No ads, no third-party sharing, no bad intent. I'm just a person running a small bot for the community.</span>
      </div>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">02</span>
        <span class="section-title">What I Collect</span>
      </div>
      <p class="doc-text">The following is collected when you use the verification system:</p>
      <table class="data-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Why</th>
            <th>Sold?</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Minecraft Username</td>
            <td>Account verification &amp; linking</td>
            <td><span class="badge badge-green">Never</span></td>
          </tr>
          <tr>
            <td>Minecraft UUID</td>
            <td>Unique account identification</td>
            <td><span class="badge badge-green">Never</span></td>
          </tr>
          <tr>
            <td>Discord Username</td>
            <td>Linking Discord to MC account</td>
            <td><span class="badge badge-green">Never</span></td>
          </tr>
          <tr>
            <td>Discord User ID</td>
            <td>Unique user identification</td>
            <td><span class="badge badge-green">Never</span></td>
          </tr>
          <tr>
            <td>IP Address</td>
            <td>Abuse prevention &amp; security</td>
            <td><span class="badge badge-green">Never</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">03</span>
        <span class="section-title">How It's Stored</span>
      </div>
      <p class="doc-text">
        All data is stored locally on my personal computer — not in the cloud, not on any third-party server. The files that hold your data are fully encrypted, meaning even I cannot open them and read the contents directly. The raw files are completely unreadable without the encryption key, which never leaves the server.
      </p>
      <p class="doc-text">
        The only way your data can ever be viewed is through a private Discord command (<code style="color:var(--accent2);background:rgba(108,92,231,0.1);padding:1px 6px;border-radius:3px">/view</code>). Responses from this command are ephemeral — meaning only the staff member who ran the command can see the result. It is not visible to anyone else in the server, ever.
      </p>
      <p class="doc-text">
        Certain staff and admin members may be granted access to use <code style="color:var(--accent2);background:rgba(108,92,231,0.1);padding:1px 6px;border-radius:3px">/view</code> as part of their role. All staff with this access are bound by the Staff &amp; Admin Terms and must agree to them before the command works. Every use of <code style="color:var(--accent2);background:rgba(108,92,231,0.1);padding:1px 6px;border-radius:3px">/view</code> is privately logged so I can see who looked up what and when.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">04</span>
        <span class="section-title">Third Parties</span>
      </div>
      <p class="doc-text">
        The bot communicates with Discord (the platform it runs on) and Mojang's public API (to verify Minecraft accounts). No personal data is shared with either beyond what's strictly necessary. No other third parties are involved at all.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">05</span>
        <span class="section-title">Your Rights</span>
      </div>
      <p class="doc-text">
        You have the right to request that your data be deleted at any time. If you ask, I will run a command that permanently removes your verification record and all stored player data — this includes your IP address, join history, Discord account link, and Minecraft details. Just reach out on Discord at <span style="color:var(--accent2)">@koels</span> or email <span style="color:var(--accent2)">kyle@koels.site</span> and I'll take care of it promptly.
      </p>
      <p class="doc-text">
        Note: if you have an active ban on record, the ban entry (which contains your Minecraft username, UUID, and ban reason) will be retained.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">06</span>
        <span class="section-title">Policy Changes</span>
      </div>
      <p class="doc-text">
        This policy may be updated over time. Any changes will be reflected on this page. Continued use of the bot after changes means you accept the updated policy.
      </p>
    </div>

  </div>

</div>

<footer>
  <div class="foot-l">© 2026 Koels.site</div>
  <div class="foot-r">
    <a href="/">Home</a>
    <span>·</span>
    <a href="/links">Links</a>
  </div>
</footer>

<script is:inline>
window.addEventListener('load', () => setTimeout(() => document.getElementById('curtain').classList.add('gone'), 650))

const obs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible') }), { threshold: 0.08 })
document.querySelectorAll('.reveal').forEach(el => obs.observe(el))

function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'))
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
  document.getElementById('panel-' + id).classList.add('active')
  btn.classList.add('active')
  document.querySelectorAll('#panel-' + id + ' .reveal').forEach(el => {
    el.classList.remove('visible')
    setTimeout(() => el.classList.add('visible'), 60)
  })
}
</script>
</body>
</html>
