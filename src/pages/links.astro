  <!-- volume slider (expands on hover) -->
  <div id="vol-wrap">
    <input type="range" id="vol-slider" min="0" max="1" step="0.01" value="0.7" aria-label="Volume">
    <svg id="vol-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
    </svg>
  </div>
  <!-- play/pause -->
  <button id="music-fab" onclick="toggleMusic()" aria-label="Play/pause music">
    <svg id="fab-play"  viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    <svg id="fab-pause" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    <div class="fab-shine"></div>
  </button>
</div>

<script is:inline>
/* ── THEME ─────────────────────────────────── */
const FADE_DURATION = 1200; // ms for volume fade
let fadeInterval = null;
let userPaused = false; // true when the user explicitly paused

function fadeVolume(audio, targetVol, duration, onDone) {
  if (fadeInterval) clearInterval(fadeInterval);
  const startVol = audio.volume;
  const diff = targetVol - startVol;
  const steps = 30;
  const stepTime = duration / steps;
  let step = 0;
  fadeInterval = setInterval(function() {
    step++;
    audio.volume = Math.max(0, Math.min(1, startVol + diff * (step / steps)));
    if (step >= steps) {
      clearInterval(fadeInterval);
      fadeInterval = null;
      if (onDone) onDone();
    }
  }, stepTime);
}

function setTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  localStorage.setItem('koels-theme', t);
  document.getElementById('btn-dark').classList.toggle('active', t === 'dark');
  document.getElementById('btn-aero').classList.toggle('active', t === 'aero');

  const audio = document.getElementById('music-audio');
  const float = document.getElementById('music-float');

  if (t === 'aero') {
    float.classList.add('visible');
    const targetVol = parseFloat(document.getElementById('vol-slider').value);
    if (!userPaused && audio.paused) {
      audio.volume = 0;
      audio.play().then(() => {
        fadeVolume(audio, targetVol, FADE_DURATION);
        setFabState(true);
      }).catch(() => {});
    } else if (!audio.paused) {
      fadeVolume(audio, targetVol, FADE_DURATION);
    }
    // if userPaused, just show the float but don't resume
  } else {
    // fade out then pause
    fadeVolume(audio, 0, FADE_DURATION, () => {
      audio.pause();
      setFabState(false);
    });
    float.classList.remove('visible');
  }
}

// Apply before first paint
(function(){
  const s = localStorage.getItem('koels-theme') || 'dark';
  document.documentElement.setAttribute('data-theme', s);
})();

window.addEventListener('DOMContentLoaded', function(){
  const s = localStorage.getItem('koels-theme') || 'dark';
  document.getElementById('btn-dark').classList.toggle('active', s === 'dark');
  document.getElementById('btn-aero').classList.toggle('active', s === 'aero');

  const audio = document.getElementById('music-audio');
  const volSlider = document.getElementById('vol-slider');
  const float = document.getElementById('music-float');

  // Set initial volume
  audio.volume = parseFloat(volSlider.value);

  // Volume slider controls live volume
  volSlider.addEventListener('input', function() {
    if (!audio.paused) audio.volume = parseFloat(this.value);
  });

  // If starting in aero, autoplay
  if (s === 'aero') {
    float.classList.add('visible');
    audio.volume = 0;
    audio.play().then(() => {
      fadeVolume(audio, parseFloat(volSlider.value), FADE_DURATION);
      setFabState(true);
    }).catch(() => {
      // Autoplay blocked by browser — wait for first user interaction then play
      setFabState(false);
      function onFirstInteraction() {
        if (!userPaused && audio.paused) {
          audio.volume = 0;
          audio.play().then(() => {
            fadeVolume(audio, parseFloat(volSlider.value), FADE_DURATION);
            setFabState(true);
          }).catch(() => {});
        }
        document.removeEventListener('click', onFirstInteraction);
        document.removeEventListener('keydown', onFirstInteraction);
        document.removeEventListener('touchstart', onFirstInteraction);
      }
      document.addEventListener('click', onFirstInteraction);
      document.addEventListener('keydown', onFirstInteraction);
      document.addEventListener('touchstart', onFirstInteraction);
    });
  }
});

/* ── MUSIC ──────────────────────────────────── */
function setFabState(playing) {
  document.getElementById('fab-play').style.display  = playing ? 'none' : '';
  document.getElementById('fab-pause').style.display = playing ? '' : 'none';
}

function toggleMusic() {
  const audio = document.getElementById('music-audio');
  const volSlider = document.getElementById('vol-slider');
  if (audio.paused) {
    userPaused = false;
    audio.volume = 0;
    audio.play().then(() => {
      fadeVolume(audio, parseFloat(volSlider.value), 600);
      setFabState(true);
    }).catch(() => {});
  } else {
    userPaused = true;
    fadeVolume(audio, 0, 600, () => {
      audio.pause();
      setFabState(false);
    });
  }
}

/* ── DISCORD / LANYARD ───────────────────────── */
(function(){
  const ID='1135328814394785903';
  const els={
    dot:       document.getElementById('card-status-dot'),
    label:     document.getElementById('card-status-label'),
    avatarImg: document.getElementById('avatar-img'),
    avatarFb:  document.getElementById('avatar-fallback'),
    cAvatarImg:document.getElementById('card-avatar-img'),
    cAvatarFb: document.getElementById('card-avatar-fallback'),
    name:      document.getElementById('card-displayname'),
    user:      document.getElementById('card-username'),
    spRow:     document.getElementById('spotify-row'),
    spSong:    document.getElementById('spotify-song'),
    spArtist:  document.getElementById('spotify-artist'),
    spBar:     document.getElementById('spotify-bar'),
    spEl:      document.getElementById('spotify-elapsed'),
    spDur:     document.getElementById('spotify-duration'),
    gameRow:   document.getElementById('game-row'),
    gameName:  document.getElementById('game-name'),
    actRows:   document.getElementById('activity-rows'),
  };
  let prog=null;
  function fms(ms){ const s=Math.floor(ms/1000),m=Math.floor(s/60); return m+':'+(s%60).toString().padStart(2,'0'); }
  function startP(ts){
    if(prog)clearInterval(prog); const{start,end}=ts,tot=end-start; els.spDur.textContent=fms(tot);
    function tk(){ const e=Math.min(Date.now()-start,tot); els.spBar.style.width=((e/tot)*100)+'%'; els.spEl.textContent=fms(e); }
    tk(); prog=setInterval(tk,1000);
  }
  function stopP(){ if(prog){clearInterval(prog);prog=null;} els.spBar.style.width='0%'; els.spEl.textContent='0:00'; els.spDur.textContent='0:00'; }
  const S={online:{c:'#00ff88',l:'online'},idle:{c:'#ffa500',l:'idle'},dnd:{c:'#ff4757',l:'do not disturb'},offline:{c:'#747f8d',l:'offline'}};
  function setAv(url){ [els.avatarImg,els.cAvatarImg].forEach(i=>{i.src=url;i.style.display='block';}); els.avatarFb.style.display='none'; els.cAvatarFb.style.display='none'; }
  async function go(){
    try{
      const d=(await(await fetch(`https://api.lanyard.rest/v1/users/${ID}`)).json()).data;
      if(!d)return;
      const st=d.discord_status||'offline',{c,l}=S[st]||S.offline;
      els.dot.style.background=c; els.dot.style.boxShadow=st!=='offline'?`0 0 6px ${c}88`:'none';
      els.label.textContent=l; els.label.style.color=st!=='offline'?c:'';
      let any=false;
      if(d.listening_to_spotify&&d.spotify){
        const song=d.spotify.song, artist=d.spotify.artist;
        const dur=d.spotify.timestamps ? (d.spotify.timestamps.end - d.spotify.timestamps.start) : 0;
        // only fetch lyrics if song changed
        if(song !== currentSong || artist !== currentArtist){
          currentSong=song; currentArtist=artist;
          lyricsLines=[]; lyricsOpen=false;
          document.getElementById('lyrics-panel').style.display='none';
          document.getElementById('lyrics-btn').style.display='none';
          document.getElementById('lyrics-btn').textContent='Show Lyrics';
          document.getElementById('lyrics-lines').innerHTML='';
          fetchLyrics(song, artist, Math.round(dur/1000));
        }
        els.spSong.textContent=song;
        els.spArtist.textContent=artist;
        const spArt=document.getElementById('sp-art');
        const artUrl=d.spotify.album_art_url;
        if(artUrl){spArt.src=artUrl;spArt.style.display='block';}
        else{spArt.style.display='none';}
        els.spRow.style.display='block';
        if(d.spotify.timestamps){ startP(d.spotify.timestamps); spotifyStart = d.spotify.timestamps.start; }
        any=true;
      } else {
        els.spRow.style.display='none'; stopP();
        currentSong=''; currentArtist=''; lyricsLines=[]; lyricsOpen=false; spotifyStart=0; lastActiveIdx=-1;
        document.getElementById('lyrics-panel').style.display='none';
        document.getElementById('lyrics-btn').style.display='none';
        document.getElementById('lyrics-lines').innerHTML='';
      }
      const gm=d.activities&&d.activities.find(a=>a.type===0);
      if(gm){ els.gameName.textContent=gm.name; els.gameRow.style.display='block'; any=true; } else { els.gameRow.style.display='none'; }
      els.actRows.style.paddingBottom=any?'12px':'0';
      const u=d.discord_user;
      if(u.global_name||u.display_name)els.name.textContent=u.global_name||u.display_name;
      els.user.textContent='@'+u.username;
      if(u.avatar)setAv(`https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.${u.avatar.startsWith('a_')?'gif':'png'}?size=128`);
    }catch(e){}
  }
  go(); setInterval(go,3000);
})();

/* ── LYRICS ─────────────────────────────────── */
let lyricsLines    = [];
let lyricsOpen     = false;
let currentSong    = '';
let currentArtist  = '';
let lyricsInterval = null;
let spotifyStart   = 0;   // ms epoch when track started (from Lanyard timestamps.start)

async function fetchLyrics(song, artist, duration) {
  try {
    const url = `https://lrclib.net/api/get?track_name=${encodeURIComponent(song)}&artist_name=${encodeURIComponent(artist)}&duration=${duration}`;
    const res = await fetch(url);
    if (!res.ok) return;
    const data = await res.json();
    if (!data.syncedLyrics) return;
    // Parse LRC: [mm:ss.xx] text
    lyricsLines = data.syncedLyrics
      .split('\n')
      .map(line => {
        const m = line.match(/^\[(\d+):(\d+\.\d+)\](.*)/);
        if (!m) return null;
        const secs = parseInt(m[1]) * 60 + parseFloat(m[2]);
        return { t: secs, text: m[3].trim() };
      })
      .filter(l => l && l.text.length > 0);
    if (lyricsLines.length > 0) {
      document.getElementById('lyrics-btn').style.display = 'block';
      renderLyrics();
      startLyricsSync();
    }
  } catch(e) {}
}

function renderLyrics() {
  const container = document.getElementById('lyrics-lines');
  container.innerHTML = '';
  lyricsLines.forEach((line, i) => {
    const el = document.createElement('div');
    el.className = 'lyric-line';
    el.id = `lyric-${i}`;
    el.textContent = line.text;
    container.appendChild(el);
  });
}

function startLyricsSync() {
  if (lyricsInterval) clearInterval(lyricsInterval);
  lyricsInterval = setInterval(syncLyrics, 100); // 100ms for smooth feel
}

let lastActiveIdx = -1;

function syncLyrics() {
  if (!lyricsOpen || lyricsLines.length === 0 || !spotifyStart) return;

  // High-accuracy time: use real wall clock against Spotify's start timestamp
  const currentSec = (Date.now() - spotifyStart) / 1000;

  let activeIdx = -1;
  for (let i = lyricsLines.length - 1; i >= 0; i--) {
    if (currentSec >= lyricsLines[i].t) { activeIdx = i; break; }
  }

  if (activeIdx === lastActiveIdx) return; // nothing changed
  lastActiveIdx = activeIdx;

  lyricsLines.forEach((_, i) => {
    const el = document.getElementById(`lyric-${i}`);
    if (!el) return;
    el.classList.remove('active', 'near-prev', 'near-next');
    if (i === activeIdx)     el.classList.add('active');
    else if (i === activeIdx - 1) el.classList.add('near-prev');
    else if (i === activeIdx + 1) el.classList.add('near-next');
  });

  // Keep active line centered in scroll container
  if (activeIdx >= 0) {
    const activeEl = document.getElementById(`lyric-${activeIdx}`);
    const scroll   = document.getElementById('lyrics-scroll');
    if (activeEl && scroll) {
      const target = activeEl.offsetTop - (scroll.clientHeight / 2) + (activeEl.offsetHeight / 2);
      scroll.scrollTo({ top: target, behavior: 'smooth' });
    }
  }
}

function toggleLyrics() {
  lyricsOpen = !lyricsOpen;
  const panel = document.getElementById('lyrics-panel');
  const btn   = document.getElementById('lyrics-btn');
  panel.style.display = lyricsOpen ? 'block' : 'none';
  btn.textContent = lyricsOpen ? 'Hide Lyrics' : 'Show Lyrics';
  if (lyricsOpen) { lastActiveIdx = -1; syncLyrics(); }
}
</script>
</body>
</html>
