<meta property="og:type" content="website" />
<meta property="og:image" content="https://koels.site/og-links.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="koels — links" />
<meta name="twitter:description" content="youtube · spotify · tiktok · instagram · x · github" />
<meta name="twitter:image" content="https://koels.site/og-links.png" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<script is:inline>
  document.documentElement.setAttribute('data-theme', localStorage.getItem('koels-theme') || 'dark');
</script>
<style is:global>
/* =====================================================
   DARK THEME
   ===================================================== */
:root, :is(html, html[data-theme="dark"]) {
  --ease: cubic-bezier(0.16,1,0.3,1);
  --avatar-ring: conic-gradient(from 0deg,#6c5ce7,transparent 30%,transparent 70%,#a29bfe);
  --toggle-bg: #141420;
  --toggle-border: rgba(255,255,255,0.12);
  --toggle-inactive: rgba(240,238,255,0.35);
  --toggle-inactive-hover: rgba(240,238,255,0.7);
}
html[data-theme="aero"] {
  --ease: cubic-bezier(0.16,1,0.3,1);
  --avatar-ring: conic-gradient(from 0deg,#7dd3fc,#fff 30%,#bae6fd 70%,#38bdf8);
  --toggle-bg: rgba(255,255,255,0.6);
  --toggle-border: rgba(255,255,255,0.95);
  --toggle-inactive: #64a8c8;
  --toggle-inactive-hover: #1a5a8a;
}

/* =====================================================
   RESET
   ===================================================== */
*,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; font-size:17px; }

/* =====================================================
   BODY
   ===================================================== */
body {
  min-height:100vh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:40px 20px;
  font-family:"Inter",system-ui,sans-serif;
  background:#03030a;
  color:#f0eeff;
}

:is(html, html[data-theme="dark"]) body {
  font-family:"Inter",system-ui,sans-serif;
  background:#03030a; color:#f0eeff;
}
:is(html, html[data-theme="dark"]) body::before {
  content:''; position:fixed; inset:0;
  background-image:
    linear-gradient(rgba(108,92,231,0.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(108,92,231,0.04) 1px,transparent 1px);
  background-size:48px 48px; pointer-events:none; z-index:0;
}
:is(html, html[data-theme="dark"]) body::after {
  content:''; position:fixed; top:-20%; left:50%; transform:translateX(-50%);
  width:600px; height:400px;
  background:radial-gradient(ellipse,rgba(108,92,231,0.12) 0%,transparent 70%);
  pointer-events:none; z-index:0;
}

html[data-theme="aero"] body {
  font-family:"Nunito",system-ui,sans-serif;
  /* classic Frutiger Aero sky */
  background: linear-gradient(180deg,
    #dff2ff 0%, #b8e2fb 20%,
    #9dd6f8 45%, #b6e8fd 70%,
    #d8f4ff 100%
  );
  color:#0d4a80;
}
/* large soft light blooms */
html[data-theme="aero"] body::before {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:0;
  background:
    radial-gradient(ellipse 80% 55% at 10% 15%, rgba(255,255,255,0.6) 0%, transparent 55%),
    radial-gradient(ellipse 55% 65% at 90% 85%, rgba(160,220,255,0.35) 0%, transparent 55%),
    radial-gradient(ellipse 45% 40% at 65% 8%,  rgba(255,255,255,0.4) 0%, transparent 50%);
}
/* bubble orb glows */
html[data-theme="aero"] body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:0;
  background:
    radial-gradient(circle 100px at 7%  68%, rgba(255,255,255,0.5) 0%, rgba(180,225,255,0.1) 55%, transparent 70%),
    radial-gradient(circle  65px at 93% 22%, rgba(255,255,255,0.45) 0%, rgba(150,210,255,0.1) 55%, transparent 72%),
    radial-gradient(circle 120px at 52% 92%, rgba(200,240,255,0.3) 0%, transparent 65%),
    radial-gradient(circle  55px at 78% 52%, rgba(255,255,255,0.3) 0%, transparent 60%);
}

/* =====================================================
   LAYOUT
   ===================================================== */
.container {
  position:relative; z-index:1;
  width:100%; max-width:420px;
  display:flex; flex-direction:column; align-items:center;
}
:is(html, html[data-theme="dark"]) .container { gap:24px; }
html[data-theme="aero"] .container { gap:14px; }

/* =====================================================
   THEME TOGGLE
   ===================================================== */
.theme-toggle {
  position:fixed; top:14px; right:14px; z-index:200;
  display:flex; align-items:center;
  background:var(--toggle-bg);
  border:1px solid var(--toggle-border);
  border-radius:999px; padding:3px; gap:2px;
  backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
}
:is(html, html[data-theme="dark"]) .theme-toggle { box-shadow:0 2px 14px rgba(0,0,0,0.45); }
html[data-theme="aero"] .theme-toggle { box-shadow:0 4px 20px rgba(80,160,230,0.2), inset 0 1px 0 #fff; }

.theme-btn {
  display:flex; align-items:center; gap:5px;
  padding:5px 13px; border-radius:999px;
  font-size:0.58rem; letter-spacing:0.07em; text-transform:uppercase; font-weight:700;
  border:none; cursor:pointer; background:transparent;
  color:var(--toggle-inactive);
  transition:all 0.2s ease;
  font-family:inherit;
}
.theme-btn:hover { color:var(--toggle-inactive-hover); }
.theme-btn svg { width:10px; height:10px; fill:currentColor; flex-shrink:0; }
:is(html, html[data-theme="dark"]) .theme-btn.active { background:#6c5ce7; color:#fff; box-shadow:0 1px 8px rgba(108,92,231,0.5); }
html[data-theme="aero"] .theme-btn.active {
  background:linear-gradient(160deg,#4ab8f7 0%,#1a7fd4 100%);
  color:#fff;
  box-shadow:0 3px 12px rgba(30,100,210,0.35), inset 0 1px 0 rgba(255,255,255,0.5), inset 0 -1px 0 rgba(0,80,160,0.2);
}

/* =====================================================
   AVATAR — DARK
   ===================================================== */
:is(html, html[data-theme="dark"]) .avatar {
  width:80px; height:80px; border-radius:50%;
  background:#141420; border:1px solid rgba(255,255,255,0.12);
  display:flex; align-items:center; justify-content:center;
  position:relative; overflow:hidden;
}
:is(html, html[data-theme="dark"]) .avatar::before {
  content:''; position:absolute; inset:-1px; border-radius:50%;
  background:var(--avatar-ring); z-index:-1; animation:spin 6s linear infinite;
}
:is(html, html[data-theme="dark"]) .avatar-inner {
  width:76px; height:76px; border-radius:50%;
  background:#0f0f1a;
  display:flex; align-items:center; justify-content:center;
  font-family:"JetBrains Mono",monospace; font-size:1.2rem; font-weight:700; color:#a29bfe;
}

/* =====================================================
   AVATAR — AERO
   ===================================================== */
html[data-theme="aero"] .avatar {
  width:90px; height:90px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  position:relative; overflow:hidden;
  background:linear-gradient(145deg,#fff 0%,#b8e4f9 100%);
  border:2.5px solid rgba(255,255,255,0.92);
  box-shadow:0 6px 26px rgba(30,120,220,0.28), 0 2px 6px rgba(30,120,220,0.14), inset 0 2px 4px rgba(255,255,255,0.9), inset 0 -2px 6px rgba(100,180,240,0.3);
}
html[data-theme="aero"] .avatar::before {
  content:''; position:absolute; inset:-2px; border-radius:50%;
  background:var(--avatar-ring); z-index:-1; animation:spin 8s linear infinite;
}
html[data-theme="aero"] .avatar::after {
  content:''; position:absolute;
  top:5px; left:14px; right:14px; height:36%;
  border-radius:50%;
  background:linear-gradient(180deg,rgba(255,255,255,0.75) 0%,transparent 100%);
  pointer-events:none;
}
html[data-theme="aero"] .avatar-inner {
  width:84px; height:84px; border-radius:50%;
  background:linear-gradient(145deg,#e8f6ff,#cce8fa);
  display:flex; align-items:center; justify-content:center;
  font-family:"Nunito",sans-serif; font-size:1.3rem; font-weight:800; color:#1a6baa;
}

@keyframes spin { to { transform:rotate(360deg); } }

/* =====================================================
   PROFILE
   ===================================================== */
.profile { text-align:center; display:flex; flex-direction:column; }
:is(html, html[data-theme="dark"]) .profile { gap:6px; }
html[data-theme="aero"] .profile { gap:3px; }

:is(html, html[data-theme="dark"]) .name {
  font-family:"JetBrains Mono",monospace; font-size:1.1rem; font-weight:700;
  letter-spacing:0.05em; color:#fff;
}
html[data-theme="aero"] .name {
  font-family:"Nunito",sans-serif; font-size:1.35rem; font-weight:900;
  letter-spacing:-0.01em; color:#0d4a80;
  text-shadow:0 1px 3px rgba(255,255,255,0.8);
}
:is(html, html[data-theme="dark"]) .handle {
  font-family:"JetBrains Mono",monospace; font-size:0.72rem;
  color:rgba(240,238,255,0.4); letter-spacing:0.12em; text-transform:uppercase;
}
html[data-theme="aero"] .handle {
  font-family:"Nunito",sans-serif; font-size:0.75rem; font-weight:600;
  color:#4a90c0; letter-spacing:0.06em; text-transform:uppercase;
}

/* =====================================================
   DISCORD CARD — DARK
   ===================================================== */
:is(html, html[data-theme="dark"]) #discord-card {
  width:100%; border-radius:12px;
  border:1px solid rgba(255,255,255,0.07);
  background:#0f0f1a; overflow:hidden;
}
:is(html, html[data-theme="dark"]) .card-label {
  padding:14px 14px 12px;
  font-family:"JetBrains Mono",monospace; font-size:0.6rem;
  letter-spacing:0.14em; color:rgba(240,238,255,0.4); text-transform:uppercase;
}
:is(html, html[data-theme="dark"]) .card-body { padding:0 14px 14px; }
:is(html, html[data-theme="dark"]) .card-name-text {
  font-family:"JetBrains Mono",monospace; font-size:0.85rem; font-weight:700; color:#fff;
}
:is(html, html[data-theme="dark"]) .card-username-text {
  font-family:"JetBrains Mono",monospace; font-size:0.65rem;
  color:rgba(240,238,255,0.4); letter-spacing:0.05em; margin-bottom:6px;
}
:is(html, html[data-theme="dark"]) .card-badge {
  display:inline-flex; align-items:center; gap:5px;
  padding:3px 10px; border-radius:20px;
  border:1px solid rgba(255,255,255,0.1); background:#141420;
}
:is(html, html[data-theme="dark"]) .card-badge-label {
  font-family:"JetBrains Mono",monospace; font-size:0.58rem;
  letter-spacing:0.1em; text-transform:uppercase;
}
:is(html, html[data-theme="dark"]) #activity-rows { margin:0 14px; border-top:1px solid rgba(255,255,255,0.07); }
:is(html, html[data-theme="dark"]) #spotify-song { font-family:"JetBrains Mono",monospace; font-size:0.65rem; color:#fff; }
:is(html, html[data-theme="dark"]) #spotify-artist { font-family:"JetBrains Mono",monospace; font-size:0.6rem; color:rgba(240,238,255,0.4); }
:is(html, html[data-theme="dark"]) .time-txt { font-family:"JetBrains Mono",monospace; font-size:0.55rem; color:rgba(240,238,255,0.4); }
:is(html, html[data-theme="dark"]) #game-name { font-family:"JetBrains Mono",monospace; font-size:0.65rem; color:#fff; }
:is(html, html[data-theme="dark"]) .game-sub { font-family:"JetBrains Mono",monospace; font-size:0.6rem; color:rgba(240,238,255,0.4); }

/* =====================================================
   DISCORD CARD — AERO
   ===================================================== */
html[data-theme="aero"] #discord-card {
  width:100%; border-radius:22px;
  border:1.5px solid rgba(255,255,255,0.92);
  background:linear-gradient(155deg,rgba(255,255,255,0.84) 0%,rgba(215,240,255,0.72) 100%);
  overflow:hidden;
  backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
  box-shadow:0 8px 32px rgba(30,100,200,0.13), 0 2px 8px rgba(30,100,200,0.08), inset 0 1.5px 0 #fff, inset 0 -1px 0 rgba(100,180,240,0.15);
  position:relative;
}
html[data-theme="aero"] #discord-card::before {
  content:''; position:absolute;
  top:0; left:0; right:0; height:44%;
  background:linear-gradient(180deg,rgba(255,255,255,0.5) 0%,transparent 100%);
  border-radius:22px 22px 60% 60% / 22px 22px 28px 28px;
  pointer-events:none;
}
html[data-theme="aero"] .card-label {
  padding:14px 16px 10px;
  font-family:"Nunito",sans-serif; font-size:0.63rem; font-weight:700;
  letter-spacing:0.1em; color:#4a90c0; text-transform:uppercase;
}
html[data-theme="aero"] .card-body { padding:0 16px 14px; }
html[data-theme="aero"] .card-name-text {
  font-family:"Nunito",sans-serif; font-size:0.9rem; font-weight:800; color:#0d4a80;
}
html[data-theme="aero"] .card-username-text {
  font-family:"Nunito",sans-serif; font-size:0.68rem; font-weight:600;
  color:#5a9dc0; letter-spacing:0.04em; margin-bottom:6px;
}
html[data-theme="aero"] .card-badge {
  display:inline-flex; align-items:center; gap:5px;
  padding:3px 12px; border-radius:999px;
  border:1.5px solid rgba(255,255,255,0.9);
  background:linear-gradient(180deg,rgba(255,255,255,0.7) 0%,rgba(210,236,255,0.5) 100%);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.9);
}
html[data-theme="aero"] .card-badge-label {
  font-family:"Nunito",sans-serif; font-size:0.6rem; font-weight:700;
  letter-spacing:0.06em; text-transform:uppercase; color:#4a90c0;
}
html[data-theme="aero"] #activity-rows { margin:0 16px; border-top:1px solid rgba(100,180,240,0.2); }
html[data-theme="aero"] #spotify-song { font-family:"Nunito",sans-serif; font-size:0.68rem; font-weight:700; color:#0d4a80; }
html[data-theme="aero"] #spotify-artist { font-family:"Nunito",sans-serif; font-size:0.62rem; font-weight:600; color:#5a9dc0; }
html[data-theme="aero"] .time-txt { font-family:"Nunito",sans-serif; font-size:0.55rem; font-weight:600; color:#5a9dc0; }
html[data-theme="aero"] #game-name { font-family:"Nunito",sans-serif; font-size:0.68rem; font-weight:700; color:#0d4a80; }
html[data-theme="aero"] .game-sub { font-family:"Nunito",sans-serif; font-size:0.62rem; font-weight:600; color:#5a9dc0; }

/* =====================================================
   LINK BUTTONS — DARK
   ===================================================== */
.links { width:100%; display:flex; flex-direction:column; }
:is(html, html[data-theme="dark"]) .links { gap:10px; }
html[data-theme="aero"] .links { gap:9px; }

:is(html, html[data-theme="dark"]) .link-btn {
  display:flex; align-items:center; gap:14px;
  padding:14px 18px; border-radius:10px;
  border:1px solid rgba(255,255,255,0.07);
  background:#0f0f1a; color:rgba(240,238,255,0.68);
  font-family:"JetBrains Mono",monospace; font-size:0.78rem;
  letter-spacing:0.08em; text-transform:uppercase;
  text-decoration:none;
  transition:all 0.2s var(--ease);
  cursor:pointer; position:relative; overflow:hidden;
}
:is(html, html[data-theme="dark"]) .link-btn::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(90deg,transparent,rgba(108,92,231,0.06),transparent);
  transform:translateX(-100%); transition:transform 0.4s var(--ease);
}
:is(html, html[data-theme="dark"]) .link-btn:hover { border-color:rgba(255,255,255,0.12); color:#fff; background:#141420; transform:translateY(-1px); }
:is(html, html[data-theme="dark"]) .link-btn:hover::before { transform:translateX(100%); }
:is(html, html[data-theme="dark"]) .link-btn:active { transform:translateY(0); }
:is(html, html[data-theme="dark"]) .link-arrow { font-size:0.65rem; color:rgba(240,238,255,0.4); transition:transform 0.2s,color 0.2s; }
:is(html, html[data-theme="dark"]) .link-btn:hover .link-arrow { transform:translateX(2px); color:rgba(240,238,255,0.68); }

/* =====================================================
   LINK BUTTONS — AERO (glossy pill)
   ===================================================== */
html[data-theme="aero"] .link-btn {
  display:flex; align-items:center; gap:14px;
  padding:13px 20px; border-radius:999px;
  border:1.5px solid rgba(255,255,255,0.92);
  background:linear-gradient(180deg, rgba(255,255,255,0.88) 0%, rgba(210,236,255,0.74) 52%, rgba(182,222,252,0.65) 100%);
  color:#1a5a90;
  font-family:"Nunito",sans-serif; font-size:0.82rem; font-weight:700;
  letter-spacing:0.02em; text-transform:none;
  text-decoration:none;
  transition:all 0.18s var(--ease);
  cursor:pointer; position:relative; overflow:hidden;
  backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px);
  box-shadow:0 3px 10px rgba(30,100,200,0.12), 0 1px 3px rgba(30,100,200,0.1), inset 0 1.5px 0 #fff, inset 0 -1px 0 rgba(100,160,220,0.2);
}
/* top gloss shine */
html[data-theme="aero"] .link-btn::before {
  content:''; position:absolute;
  top:0; left:0; right:0; height:52%;
  background:linear-gradient(180deg,rgba(255,255,255,0.58) 0%,transparent 100%);
  border-radius:999px 999px 0 0; pointer-events:none;
}
/* hover shimmer sweep */
html[data-theme="aero"] .link-btn::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.38),transparent);
  transform:translateX(-100%); transition:transform 0.38s ease;
}
html[data-theme="aero"] .link-btn:hover {
  transform:translateY(-2px);
  background:linear-gradient(180deg,rgba(255,255,255,0.98) 0%,rgba(220,242,255,0.9) 52%,rgba(192,228,255,0.82) 100%);
  color:#0d3d6e;
  box-shadow:0 6px 22px rgba(30,100,200,0.2), 0 2px 6px rgba(30,100,200,0.14), inset 0 1.5px 0 #fff, inset 0 -1px 0 rgba(100,160,220,0.25);
}
html[data-theme="aero"] .link-btn:hover::after { transform:translateX(100%); }
html[data-theme="aero"] .link-btn:active { transform:translateY(0); }
html[data-theme="aero"] .link-arrow { font-size:0.72rem; color:#5ba8d8; transition:transform 0.18s,color 0.18s; }
html[data-theme="aero"] .link-btn:hover .link-arrow { transform:translateX(3px); color:#1a6baa; }

/* shared icon */
.link-icon { width:20px; height:20px; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
.link-icon svg { width:18px; height:18px; fill:currentColor; }
.link-label { flex:1; }

/* =====================================================
   CD SPIN (shared keyframe for spotify + float disc)
   ===================================================== */
@keyframes disc-spin { to { transform:rotate(360deg); } }

@keyframes fadeUp {
  from { opacity:0; transform:translateY(14px); }
  to   { opacity:1; transform:translateY(0); }
}

/* =====================================================
   FLOATING MUSIC CONTROLS (Aero only)
   ===================================================== */
#music-float {
  position:fixed; bottom:22px; right:22px; z-index:300;
  display:flex; align-items:center; gap:10px;
  opacity:0; pointer-events:none;
  transform:translateY(12px);
  transition:opacity 0.5s ease, transform 0.5s ease;
}
#music-float.visible {
  opacity:1; pointer-events:auto;
  transform:translateY(0);
}

/* ---- volume wrap ---- */
#vol-wrap {
  display:flex; align-items:center; gap:6px;
  background:linear-gradient(155deg,rgba(255,255,255,0.82) 0%,rgba(210,238,255,0.72) 100%);
  border:1.5px solid rgba(255,255,255,0.92);
  border-radius:999px;
  padding:6px 12px 6px 10px;
  backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
  box-shadow:0 4px 18px rgba(30,100,200,0.14), inset 0 1px 0 #fff;
  overflow:hidden;
  max-width:32px; /* collapsed: just shows icon */
  transition:max-width 0.35s cubic-bezier(0.16,1,0.3,1), padding 0.35s ease, opacity 0.35s ease;
}
#vol-wrap:hover, #vol-wrap:focus-within {
  max-width:160px;
  padding:6px 14px 6px 10px;
}
#vol-icon {
  width:16px; height:16px; flex-shrink:0; fill:#1a6baa;
}
#vol-slider {
  width:80px; flex-shrink:0;
  -webkit-appearance:none; appearance:none;
  height:4px; border-radius:999px;
  background:linear-gradient(90deg,#3aa8f0 0%,#c8e8fa 100%);
  outline:none; cursor:pointer;
  opacity:0; transition:opacity 0.25s ease 0.05s;
}
#vol-wrap:hover #vol-slider,
#vol-wrap:focus-within #vol-slider { opacity:1; }
#vol-slider::-webkit-slider-thumb {
  -webkit-appearance:none;
  width:12px; height:12px; border-radius:50%;
  background:linear-gradient(145deg,#6dcfff,#1a7fd4);
  box-shadow:0 1px 4px rgba(20,100,220,0.4), inset 0 1px 0 rgba(255,255,255,0.5);
  cursor:pointer;
}
#vol-slider::-moz-range-thumb {
  width:12px; height:12px; border-radius:50%; border:none;
  background:linear-gradient(145deg,#6dcfff,#1a7fd4);
  box-shadow:0 1px 4px rgba(20,100,220,0.4);
  cursor:pointer;
}

/* ---- fab play/pause button ---- */
#music-fab {
  width:48px; height:48px; border-radius:50%; flex-shrink:0;
  border:none; cursor:pointer;
  background:linear-gradient(160deg,#5cc8ff 0%,#1a85d4 60%,#0f6ab8 100%);
  display:flex; align-items:center; justify-content:center;
  box-shadow:
    0 6px 20px rgba(20,100,220,0.45),
    0 2px 6px rgba(20,100,220,0.3),
    inset 0 1.5px 0 rgba(255,255,255,0.55),
    inset 0 -1px 0 rgba(0,60,140,0.3);
  transition:transform 0.15s ease, box-shadow 0.15s ease;
  position:relative; overflow:hidden;
}
.fab-shine {
  position:absolute;
  top:3px; left:8px; right:8px; height:46%;
  background:linear-gradient(180deg,rgba(255,255,255,0.48) 0%,transparent 100%);
  border-radius:50%; pointer-events:none;
}
#music-fab:hover {
  transform:scale(1.1);
  box-shadow:0 8px 28px rgba(20,100,220,0.55), 0 3px 8px rgba(20,100,220,0.3), inset 0 1.5px 0 rgba(255,255,255,0.55), inset 0 -1px 0 rgba(0,60,140,0.3);
}
#music-fab:active { transform:scale(0.95); }
#music-fab svg { width:16px; height:16px; fill:#fff; position:relative; z-index:1; }

/* =====================================================
   FOOTER
   ===================================================== */
:is(html, html[data-theme="dark"]) .footer {
  font-family:"JetBrains Mono",monospace; font-size:0.6rem;
  letter-spacing:0.15em; color:rgba(240,238,255,0.4); text-transform:uppercase; opacity:0.5;
}
html[data-theme="aero"] .footer {
  font-family:"Nunito",sans-serif; font-size:0.65rem; font-weight:600;
  letter-spacing:0.04em; color:#5a9dc0; opacity:0.9;
}

/* =====================================================
   ENTRANCE ANIMATIONS
   ===================================================== */
.container > * { opacity:0; animation:fadeUp 0.5s var(--ease) forwards; }
.container > *:nth-child(1){animation-delay:0.05s}
.container > *:nth-child(2){animation-delay:0.12s}
.container > *:nth-child(3){animation-delay:0.2s}
.container > *:nth-child(4){animation-delay:0.28s}
.container > *:nth-child(5){animation-delay:0.36s}
.container > *:nth-child(6){animation-delay:0.44s}
.container > *:nth-child(7){animation-delay:0.52s}
/* =====================================================
   LYRICS — Apple Music style
   ===================================================== */
#lyrics-scroll { scrollbar-width:none; -ms-overflow-style:none; }
#lyrics-scroll::-webkit-scrollbar { display:none; }

/* The panel itself */
#lyrics-panel {
  border-radius:10px;
  overflow:hidden;
}
:is(html, html[data-theme="dark"]) #lyrics-panel {
  background:#0a0a16;
  border:1px solid rgba(255,255,255,0.06);
}
html[data-theme="aero"] #lyrics-panel {
  background:rgba(255,255,255,0.45);
  border:1.5px solid rgba(255,255,255,0.8);
  backdrop-filter:blur(12px);
}

/* Each lyric line */
.lyric-line {
  font-size:0.88rem;
  font-weight:700;
  line-height:1.35;
  padding:5px 14px;
  border-radius:6px;
  cursor:default;
  text-align:left;
  transition:
    color      0.45s cubic-bezier(0.16,1,0.3,1),
    opacity    0.45s cubic-bezier(0.16,1,0.3,1),
    transform  0.45s cubic-bezier(0.16,1,0.3,1),
    font-size  0.35s cubic-bezier(0.16,1,0.3,1);
  will-change: transform, opacity;
  transform-origin: left center;
}

/* Dark theme default — dim, slightly small */
:is(html, html[data-theme="dark"]) .lyric-line {
  color:rgba(240,238,255,0.18);
  transform:scale(0.93);
  opacity:0.6;
}
:is(html, html[data-theme="dark"]) .lyric-line.near-prev,
:is(html, html[data-theme="dark"]) .lyric-line.near-next {
  color:rgba(240,238,255,0.42);
  transform:scale(0.97);
  opacity:0.85;
}
:is(html, html[data-theme="dark"]) .lyric-line.active {
  color:#ffffff;
  font-size:1.02rem;
  transform:scale(1);
  opacity:1;
}

/* Aero theme */
html[data-theme="aero"] .lyric-line {
  color:rgba(13,74,128,0.22);
  transform:scale(0.93);
  opacity:0.6;
}
html[data-theme="aero"] .lyric-line.near-prev,
html[data-theme="aero"] .lyric-line.near-next {
  color:rgba(13,74,128,0.5);
  transform:scale(0.97);
  opacity:0.85;
}
html[data-theme="aero"] .lyric-line.active {
  color:#0d4a80;
  font-size:1.02rem;
  transform:scale(1);
  opacity:1;
}

/* Lyrics button */
#lyrics-btn {
  font-family:inherit;
}
:is(html, html[data-theme="dark"]) #lyrics-btn {
  border-color:rgba(255,255,255,0.08);
  background:rgba(255,255,255,0.03);
  color:rgba(240,238,255,0.4);
}
:is(html, html[data-theme="dark"]) #lyrics-btn:hover {
  background:rgba(255,255,255,0.07);
  color:rgba(240,238,255,0.75);
}
html[data-theme="aero"] #lyrics-btn {
  border-color:rgba(100,180,240,0.25);
  background:rgba(255,255,255,0.15);
  color:#4a90c0;
}
html[data-theme="aero"] #lyrics-btn:hover {
  background:rgba(255,255,255,0.35);
  color:#1a5a90;
}


.links .link-btn { opacity:0; animation:fadeUp 0.4s var(--ease) forwards; }
.links .link-btn:nth-child(1){animation-delay:0.22s}
.links .link-btn:nth-child(2){animation-delay:0.28s}
.links .link-btn:nth-child(3){animation-delay:0.34s}
.links .link-btn:nth-child(4){animation-delay:0.40s}
.links .link-btn:nth-child(5){animation-delay:0.46s}
.links .link-btn:nth-child(6){animation-delay:0.52s}
.links .link-btn:nth-child(7){animation-delay:0.58s}
</style>
</head>
