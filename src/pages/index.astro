<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Kyle — koels.site</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #020810;
  --text: #c8f0ff;
  --muted: rgba(200,240,255,0.5);
  --dim: rgba(200,240,255,0.28);
  --border: rgba(0,120,200,0.14);
  --border2: rgba(64,200,255,0.22);
  --accent: #40c8ff;
  --teal: #00ffcc;
  --sans: 'Inter', system-ui, sans-serif;
  --mono: 'JetBrains Mono', monospace;
  --ease: cubic-bezier(0.16,1,0.3,1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

/* ── BLOBS ── */
.blobs { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden }
.blob { position:absolute; border-radius:50%; filter:blur(120px) }
.b1 { width:700px;height:560px;background:radial-gradient(#0050c8,transparent 70%);opacity:.22;top:-150px;left:-150px;animation:bm1 35s ease-in-out infinite }
.b2 { width:600px;height:600px;background:radial-gradient(#003080,transparent 70%);opacity:.18;top:-100px;right:-150px;animation:bm2 45s ease-in-out infinite }
.b3 { width:550px;height:440px;background:radial-gradient(#00a8b0,transparent 70%);opacity:.16;bottom:5%;left:10%;animation:bm3 28s ease-in-out infinite }
.b4 { width:480px;height:480px;background:radial-gradient(#0070c0,transparent 70%);opacity:.14;bottom:0;right:5%;animation:bm4 50s ease-in-out infinite }
@keyframes bm1 { 0%,100%{transform:translate(0,0) scale(1)} 40%{transform:translate(60px,80px) scale(1.08)} 70%{transform:translate(20px,140px) scale(.94)} }
@keyframes bm2 { 0%,100%{transform:translate(0,0) scale(1)} 30%{transform:translate(-70px,100px) scale(1.1)} 65%{transform:translate(-30px,180px) scale(.9)} }
@keyframes bm3 { 0%,100%{transform:translate(0,0) scale(1)} 45%{transform:translate(60px,-70px) scale(1.1)} }
@keyframes bm4 { 0%,100%{transform:translate(0,0) scale(1)} 40%{transform:translate(-50px,-90px) scale(1.07)} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:100;
  height:58px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  background:rgba(2,8,16,0.7);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:#e8f8ff;
  display:flex; align-items:center; gap:9px;
}
.logo-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--teal); box-shadow:0 0 10px var(--teal);
  animation:dot-pulse 2s ease infinite;
}
@keyframes dot-pulse { 0%,100%{box-shadow:0 0 6px var(--teal)} 50%{box-shadow:0 0 20px var(--teal),0 0 40px rgba(0,255,204,0.2)} }
nav { display:flex; align-items:center; gap:28px }
nav a {
  font-family:var(--mono); font-size:0.7rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
nav a:hover { color:#e8f8ff }

/* ── HERO ── */
.hero {
  min-height:100vh;
  display:flex; flex-direction:column; justify-content:center;
  padding:120px 80px 80px;
  position:relative; z-index:1;
}
.hero-tag {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.68rem; letter-spacing:0.22em;
  text-transform:uppercase; color:var(--accent); margin-bottom:36px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.1s both;
}
.hero-tag-line { width:24px; height:1px; background:var(--accent) }

.hero h1 {
  font-size:clamp(3.5rem,8vw,8.5rem);
  font-weight:900; line-height:0.88; letter-spacing:-0.04em;
  color:#e8f8ff; max-width:900px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.18s both;
}
.hero h1 .grad {
  background:linear-gradient(135deg, var(--accent) 0%, var(--teal) 60%, var(--accent) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 5s linear infinite;
}
@keyframes shimmer { to{background-position:200% center} }
.hero h1 .ghost {
  -webkit-text-stroke:1.5px rgba(200,240,255,0.08);
  -webkit-text-fill-color:transparent;
}

.hero-sub {
  margin-top:32px;
  font-size:1.05rem; color:var(--muted); line-height:1.75;
  max-width:480px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.26s both;
}

.hero-actions {
  margin-top:44px; display:flex; gap:14px; flex-wrap:wrap;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.34s both;
}
.btn {
  display:inline-flex; align-items:center; gap:8px;
  padding:11px 24px; border-radius:6px;
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.12em; text-transform:uppercase;
  cursor:pointer; border:1px solid transparent; transition:0.2s var(--ease);
  position:relative; overflow:hidden;
}
.btn > * { position:relative; z-index:1 }
.btn::before { content:''; position:absolute; inset:0; transform:translateX(-101%); transition:transform 0.28s var(--ease) }
.btn:hover::before { transform:translateX(0) }
.btn-primary { background:var(--accent); color:#010810; border-color:var(--accent); box-shadow:0 0 28px rgba(64,200,255,0.25) }
.btn-primary::before { background:#2ab0e8 }
.btn-ghost { background:transparent; color:var(--muted); border-color:var(--border2) }
.btn-ghost::before { background:rgba(0,120,200,0.08) }
.btn-ghost:hover { color:#e8f8ff; border-color:rgba(64,200,255,0.3) }

/* ── SECTION COMMON ── */
section { position:relative; z-index:1 }
.section-header {
  display:flex; align-items:baseline; gap:16px; margin-bottom:48px;
}
.section-num {
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.2em;
  color:var(--dim); text-transform:uppercase;
}
.section-title {
  font-size:1.5rem; font-weight:800; letter-spacing:-0.02em; color:#e8f8ff;
}

/* ── PROJECTS ── */
.projects {
  padding:100px 80px;
  border-top:1px solid var(--border);
}
.projects-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(300px,1fr));
  gap:16px;
}
.project-card {
  background:rgba(2,10,24,0.55);
  border:1px solid var(--border);
  border-radius:14px;
  padding:28px;
  backdrop-filter:blur(16px);
  display:flex; flex-direction:column; gap:12px;
  transition:border-color 0.25s, transform 0.25s var(--ease), box-shadow 0.25s;
  position:relative; overflow:hidden;
}
.project-card::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(64,200,255,0.03), transparent 60%);
  opacity:0; transition:opacity 0.3s;
}
.project-card:hover { border-color:var(--border2); transform:translateY(-4px); box-shadow:0 16px 48px rgba(0,0,0,0.4); }
.project-card:hover::before { opacity:1 }

.project-top { display:flex; align-items:flex-start; justify-content:space-between; gap:12px }
.project-icon {
  width:40px; height:40px; border-radius:10px;
  background:rgba(64,200,255,0.08); border:1px solid rgba(64,200,255,0.12);
  display:flex; align-items:center; justify-content:center;
  font-size:1.1rem; flex-shrink:0;
}
.project-badge {
  font-family:var(--mono); font-size:0.58rem; letter-spacing:0.14em;
  text-transform:uppercase; padding:3px 9px; border-radius:999px;
  border:1px solid; font-weight:600;
}
.badge-live  { color:#00ffcc; border-color:rgba(0,255,204,0.3); background:rgba(0,255,204,0.06) }
.badge-beta  { color:var(--accent); border-color:rgba(64,200,255,0.3); background:rgba(64,200,255,0.06) }
.badge-wip   { color:rgba(200,240,255,0.45); border-color:rgba(200,240,255,0.12); background:rgba(200,240,255,0.04) }

.project-name {
  font-size:1.05rem; font-weight:700; letter-spacing:-0.01em; color:#e8f8ff;
}
.project-desc {
  font-size:0.875rem; color:var(--muted); line-height:1.65;
  flex:1;
}
.project-link {
  display:inline-flex; align-items:center; gap:6px;
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--accent);
  margin-top:4px; transition:gap 0.2s;
}
.project-link:hover { gap:10px }
.project-card.wip .project-link { color:var(--dim); pointer-events:none }

/* ── MC WIDGET ── */
.mc-section {
  padding:0 80px 100px;
}
.mc-widget {
  background:rgba(2,10,24,0.55);
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  backdrop-filter:blur(16px);
  max-width:600px;
}
.mc-stripe { height:2px; background:linear-gradient(90deg,var(--accent),var(--teal)) }
.mc-body { padding:28px 32px }
.mc-top {
  display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;
}
.mc-label {
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.18em;
  text-transform:uppercase; color:var(--dim);
}
.mc-live {
  display:flex; align-items:center; gap:6px;
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em;
  color:var(--accent); text-transform:uppercase;
}
.mc-live i { width:5px;height:5px;border-radius:50%;background:var(--accent);animation:blink 1.3s ease infinite }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.1} }
.mc-status-row { display:flex; align-items:center; gap:16px; margin-bottom:16px }
.mc-status-text {
  font-size:2.5rem; font-weight:900; letter-spacing:-0.04em; line-height:1;
  color:var(--dim); transition:color 0.5s;
}
.mc-status-text.online { color:var(--teal); text-shadow:0 0 40px rgba(0,255,204,0.25) }
.mc-status-text.offline { color:#ff4757 }
.mc-players { font-family:var(--mono); font-size:0.8rem; color:var(--muted) }
.mc-players strong { color:var(--text) }
.mc-bar-row {
  display:flex; justify-content:space-between;
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--dim); margin-bottom:8px;
}
.mc-track { height:2px; background:rgba(0,120,200,0.12); border-radius:99px; overflow:hidden; margin-bottom:20px }
.mc-fill { height:100%; width:0%; background:linear-gradient(90deg,var(--accent),var(--teal)); border-radius:99px; transition:width 1s var(--ease) }
.mc-ip {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--mono); font-size:0.75rem; font-weight:700;
  letter-spacing:0.08em; color:#e8f8ff;
  padding:10px 20px; border-radius:8px;
  background:rgba(64,200,255,0.07); border:1px solid rgba(64,200,255,0.15);
  cursor:pointer; transition:0.2s;
}
.mc-ip:hover { background:rgba(64,200,255,0.13); border-color:rgba(64,200,255,0.3) }

/* ── ABOUT + CONTACT ── */
.bottom-grid {
  display:grid; grid-template-columns:1fr 1fr;
  border-top:1px solid var(--border);
}
.bottom-col {
  padding:80px;
  border-right:1px solid var(--border);
}
.bottom-col:last-child { border-right:none }

.about-text {
  font-size:1.15rem; font-weight:500; color:var(--muted); line-height:1.8;
  margin-top:20px;
}
.about-text em {
  font-style:normal; color:#e8f8ff;
  background:linear-gradient(135deg,var(--accent),var(--teal));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}

.contact-rows { margin-top:20px; display:flex; flex-direction:column }
.crow {
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 0; border-bottom:1px solid var(--border);
  cursor:pointer; transition:0.2s; gap:12px;
}
.crow:first-child { border-top:1px solid var(--border) }
.crow:hover { padding-left:8px }
.c-type { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--dim); flex-shrink:0 }
.c-val { font-size:1rem; font-weight:600; color:var(--text) }
.c-arr { color:var(--accent); opacity:0; transition:0.2s; font-size:0.85rem }
.crow:hover .c-arr { opacity:1; transform:translate(3px,-2px) }

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 80px; border-top:1px solid var(--border);
  position:relative; z-index:1;
}
.foot-l { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim) }
.foot-links { display:flex; gap:20px }
.foot-links a { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--dim); transition:color 0.2s }
.foot-links a:hover { color:var(--accent) }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(20px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

/* toast */
.toast {
  position:fixed; bottom:32px; left:50%; transform:translateX(-50%) translateY(16px);
  background:rgba(2,12,28,0.9); backdrop-filter:blur(16px);
  border:1px solid var(--border2);
  color:var(--teal); font-family:var(--mono); font-size:0.65rem;
  letter-spacing:0.12em; text-transform:uppercase;
  padding:11px 22px; border-radius:6px;
  opacity:0; transition:opacity 0.3s, transform 0.3s;
  z-index:9999; pointer-events:none;
  box-shadow:0 8px 32px rgba(0,0,0,0.5);
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0) }

@media(max-width:900px) {
  header { padding:0 20px }
  nav { display:none }
  .hero { padding:100px 24px 64px }
  .projects { padding:72px 24px }
  .mc-section { padding:0 24px 72px }
  .bottom-grid { grid-template-columns:1fr }
  .bottom-col { padding:52px 24px; border-right:none; border-bottom:1px solid var(--border) }
  .bottom-col:last-child { border-bottom:none }
  footer { padding:20px 24px; flex-direction:column; gap:10px; text-align:center }
}
</style>
</head>
<body>

<div class="blobs" aria-hidden="true">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
  <div class="blob b4"></div>
</div>

<div class="toast" id="toast">Copied!</div>

<header>
  <div class="logo"><div class="logo-dot"></div>Koels.site</div>
  <nav>
    <a href="/links">Links</a>
    <a href="/radar">Radar</a>
    <a href="/vanta">Vanta</a>
  </nav>
</header>

<!-- ── HERO ── -->
<div class="hero">
  <div class="hero-tag"><span class="hero-tag-line"></span>Personal site</div>
  <h1>Hey, I'm <span class="grad">Kyle.</span><br><span class="ghost">Builder.</span></h1>
  <p class="hero-sub">
    20 years old. I build things — apps, tools, servers, whatever sounds interesting at the time. This is where it all lives.
  </p>
  <div class="hero-actions">
    <a href="/links" class="btn btn-primary"><span>Links ↗</span></a>
    <a href="/radar" class="btn btn-ghost"><span>Radar</span></a>
  </div>
</div>

<!-- ── PROJECTS ── -->
<section class="projects">
  <div class="section-header reveal">
    <span class="section-num">01 / Projects</span>
    <span class="section-title">Things I've built</span>
  </div>

  <div class="projects-grid">

    <a href="/vanta" class="project-card reveal">
      <div class="project-top">
        <div class="project-icon">🎯</div>
        <span class="project-badge badge-wip">WIP</span>
      </div>
      <div class="project-name">Vanta</div>
      <div class="project-desc">A Valorant tracker. Stats, match history, and more. Actively in development — no ETA yet.</div>
      <div class="project-link">View page →</div>
    </a>

    <a href="/radar" class="project-card reveal" style="transition-delay:.05s">
      <div class="project-top">
        <div class="project-icon">🌩️</div>
        <span class="project-badge badge-beta">Beta</span>
      </div>
      <div class="project-name">Radar</div>
      <div class="project-desc">Live global weather radar with animated playback, severe weather alerts, and location search.</div>
      <div class="project-link">Open radar →</div>
    </a>

    <a href="/modpack" class="project-card reveal" style="transition-delay:.1s">
      <div class="project-top">
        <div class="project-icon">⛏️</div>
        <span class="project-badge badge-live">Live</span>
      </div>
      <div class="project-name">Modpack</div>
      <div class="project-desc">A custom Minecraft modpack. Download and play with the same setup as the server.</div>
      <div class="project-link">View page →</div>
    </a>

    <a href="/calculator" class="project-card reveal" style="transition-delay:.15s">
      <div class="project-top">
        <div class="project-icon">🧮</div>
        <span class="project-badge badge-live">Live</span>
      </div>
      <div class="project-name">Calculator</div>
      <div class="project-desc">A calculator. With a paywall. You'll see.</div>
      <div class="project-link">Try it →</div>
    </a>

  </div>
</section>

<!-- ── MC SERVER ── -->
<section class="mc-section">
  <div class="section-header reveal">
    <span class="section-num">02 / Server</span>
    <span class="section-title">Minecraft server</span>
  </div>

  <div class="mc-widget reveal">
    <div class="mc-stripe"></div>
    <div class="mc-body">
      <div class="mc-top">
        <span class="mc-label">koels.online</span>
        <span class="mc-live"><i></i>Live</span>
      </div>
      <div class="mc-status-row">
        <div class="mc-status-text" id="mcStatus">Checking…</div>
      </div>
      <div class="mc-players"><strong id="mcNow">—</strong> / <strong id="mcMax">—</strong> players online</div>
      <div class="mc-bar-row" style="margin-top:16px"><span>Capacity</span><span id="mcPct">—</span></div>
      <div class="mc-track"><div class="mc-fill" id="mcFill"></div></div>
      <button class="mc-ip" onclick="copyIP()">
        <span>⛏</span> koels.online — click to copy
      </button>
    </div>
  </div>
</section>

<!-- ── ABOUT + CONTACT ── -->
<div class="bottom-grid">
  <div class="bottom-col reveal">
    <div class="section-header">
      <span class="section-num">03 / About</span>
      <span class="section-title">Me</span>
    </div>
    <p class="about-text">
      I'm Kyle, 20. I like building <em>computers</em>, messing around with tech, and hosting game servers for friends. Most of what you see on this site started as something I made just to see if I could.
    </p>
  </div>

  <div class="bottom-col reveal" style="transition-delay:.1s">
    <div class="section-header">
      <span class="section-num">04 / Contact</span>
      <span class="section-title">Get in touch</span>
    </div>
    <div class="contact-rows">
      <div class="crow" onclick="copyText('kylematthewglenn@gmail.com', 'Email copied!')">
        <span class="c-type">Email</span>
        <span class="c-val">kyle@koels.site</span>
        <span class="c-arr">↗</span>
      </div>
      <div class="crow" onclick="copyText('koels', 'Discord copied!')">
        <span class="c-type">Discord</span>
        <span class="c-val">@koels</span>
        <span class="c-arr">↗</span>
      </div>
      <div class="crow" onclick="window.open('/links')">
        <span class="c-type">All links</span>
        <span class="c-val">koels.site/links</span>
        <span class="c-arr">↗</span>
      </div>
    </div>
  </div>
</div>

<footer>
  <span class="foot-l">© 2026 koels.site</span>
  <div class="foot-links">
    <a href="/links">Links</a>
    <a href="/radar">Radar</a>
    <a href="/vanta">Vanta</a>
    <a href="/legal">Legal</a>
  </div>
</footer>

<script is:inline>
// reveal on scroll
const obs = new IntersectionObserver(
  es => es.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible') }),
  { threshold: 0.08 }
);
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

// toast
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function copyIP() {
  navigator.clipboard.writeText('koels.online').then(() => showToast('koels.online copied!'));
}

function copyText(text, msg) {
  navigator.clipboard.writeText(text).then(() => showToast(msg));
}

// MC server status
async function updateMC() {
  try {
    const d = await (await fetch('https://mcapi.us/server/status?ip=koels.online')).json();
    const s = document.getElementById('mcStatus');
    if (!d || !d.online) {
      s.textContent = 'Offline'; s.className = 'mc-status-text offline';
      document.getElementById('mcNow').textContent = '0';
      document.getElementById('mcMax').textContent = '0';
      document.getElementById('mcFill').style.width = '0%';
      document.getElementById('mcPct').textContent = '0%';
      return;
    }
    const now = d.players.now, max = d.players.max;
    const pct = max > 0 ? Math.round(now / max * 100) : 0;
    s.textContent = 'Online'; s.className = 'mc-status-text online';
    document.getElementById('mcNow').textContent = now;
    document.getElementById('mcMax').textContent = max;
    document.getElementById('mcFill').style.width = pct + '%';
    document.getElementById('mcPct').textContent = pct + '%';
  } catch(e) {
    document.getElementById('mcStatus').textContent = 'Offline';
    document.getElementById('mcStatus').className = 'mc-status-text offline';
  }
}
updateMC();
setInterval(updateMC, 180000);
</script>
</body>
</html>
