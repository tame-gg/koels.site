<noscript><style>.reveal{opacity:1;transform:none}</style></noscript>
<style>
@view-transition { navigation: auto; }

:root {
  --bg: #020810;
  --text: #c8f0ff;
  --muted: rgba(200,240,255,0.5);
  --dim: rgba(200,240,255,0.28);
  --border: rgba(0,120,200,0.14);
  --border2: rgba(64,200,255,0.22);
  --accent: #40c8ff;
  --teal: #00ffcc;
  --sans: 'Inter', system-ui, sans-serif;
  --mono: 'JetBrains Mono', monospace;
  --ease: cubic-bezier(0.16,1,0.3,1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

/* ── CURSOR GLOW ── */
.cursor-glow {
  position:fixed; pointer-events:none; z-index:2;
  width:700px; height:700px; border-radius:50%;
  background:radial-gradient(circle, rgba(64,200,255,0.055) 0%, transparent 65%);
  transform:translate(-50%,-50%);
  top:-350px; left:-350px;
  transition:opacity 0.4s;
  opacity:0;
}
body:has(.cursor-glow) { }

/* ── NOISE ── */
body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── BLOBS ── */
.blobs { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden }
.blob { position:absolute; border-radius:50%; filter:blur(120px) }
.b1 { width:700px;height:560px;background:radial-gradient(#0050c8,transparent 70%);opacity:.22;top:-150px;left:-150px;animation:bm1 35s ease-in-out infinite }
.b2 { width:600px;height:600px;background:radial-gradient(#003080,transparent 70%);opacity:.18;top:-100px;right:-150px;animation:bm2 45s ease-in-out infinite }
.b3 { width:550px;height:440px;background:radial-gradient(#00a8b0,transparent 70%);opacity:.16;bottom:5%;left:10%;animation:bm3 28s ease-in-out infinite }
.b4 { width:480px;height:480px;background:radial-gradient(#0070c0,transparent 70%);opacity:.14;bottom:0;right:5%;animation:bm4 50s ease-in-out infinite }
@keyframes bm1 { 0%,100%{transform:translate(0,0) scale(1)} 40%{transform:translate(60px,80px) scale(1.08)} 70%{transform:translate(20px,140px) scale(.94)} }
@keyframes bm2 { 0%,100%{transform:translate(0,0) scale(1)} 30%{transform:translate(-70px,100px) scale(1.1)} 65%{transform:translate(-30px,180px) scale(.9)} }
@keyframes bm3 { 0%,100%{transform:translate(0,0) scale(1)} 45%{transform:translate(60px,-70px) scale(1.1)} }
@keyframes bm4 { 0%,100%{transform:translate(0,0) scale(1)} 40%{transform:translate(-50px,-90px) scale(1.07)} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:100;
  height:58px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  background:rgba(2,8,16,0.7);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:#e8f8ff;
  display:flex; align-items:center; gap:9px;
}
.logo-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--teal); box-shadow:0 0 10px var(--teal);
  animation:dot-pulse 2s ease infinite;
}
@keyframes dot-pulse { 0%,100%{box-shadow:0 0 6px var(--teal)} 50%{box-shadow:0 0 20px var(--teal),0 0 40px rgba(0,255,204,0.2)} }
nav { display:flex; align-items:center; gap:18px }
nav a {
  font-family:var(--mono); font-size:0.68rem; letter-spacing:0.06em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
nav a:hover { color:#e8f8ff }

/* ── HAMBURGER ── */
.hamburger {
  display:none; flex-direction:column; gap:5px; cursor:pointer;
  padding:4px; background:none; border:none;
}
.hamburger span {
  display:block; width:20px; height:1.5px;
  background:var(--muted); border-radius:99px;
  transition:transform 0.25s var(--ease), opacity 0.2s;
}
.hamburger.open span:nth-child(1) { transform:translateY(6.5px) rotate(45deg); background:#e8f8ff }
.hamburger.open span:nth-child(2) { opacity:0 }
.hamburger.open span:nth-child(3) { transform:translateY(-6.5px) rotate(-45deg); background:#e8f8ff }

/* ── MOBILE MENU ── */
#mobile-menu {
  display:none; position:fixed; top:58px; left:0; right:0; z-index:99;
  background:rgba(2,8,16,0.97); border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
  flex-direction:column; padding:8px 0;
}
#mobile-menu.open { display:flex }
#mobile-menu a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--muted);
  padding:14px 24px; transition:color 0.2s, background 0.2s;
}
#mobile-menu a:hover { color:#e8f8ff; background:rgba(64,200,255,0.04) }

/* ── HERO ── */
.hero {
  min-height:100vh;
  display:flex; flex-direction:column; justify-content:center;
  padding:120px 80px 80px;
  position:relative; z-index:1;
}
.hero-tag {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.68rem; letter-spacing:0.22em;
  text-transform:uppercase; color:var(--accent); margin-bottom:36px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.1s both;
}
.hero-tag-line { width:24px; height:1px; background:var(--accent) }

.hero h1 {
  font-size:clamp(3.5rem,8vw,8.5rem);
  font-weight:900; line-height:0.9; letter-spacing:-0.04em;
  color:#e8f8ff; max-width:900px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.18s both;
}
.hero h1 .grad {
  background:linear-gradient(135deg, var(--accent) 0%, var(--teal) 60%, var(--accent) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 5s linear infinite;
}
.hero h1 .line2 {
  display:block;
  font-size:0.52em; font-weight:900; letter-spacing:-0.04em;
  color:var(--muted); margin-top:18px;
  -webkit-text-fill-color:unset;
}
@keyframes shimmer { to{background-position:200% center} }

.hero-sub {
  margin-top:32px;
  font-size:1.05rem; color:var(--muted); line-height:1.75;
  max-width:480px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.26s both;
}

.hero-actions {
  margin-top:44px; display:flex; gap:14px; flex-wrap:wrap;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.34s both;
}
.btn {
  display:inline-flex; align-items:center; gap:8px;
  padding:11px 24px; border-radius:6px;
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.12em; text-transform:uppercase;
  cursor:pointer; border:1px solid transparent; transition:0.2s var(--ease);
  position:relative; overflow:hidden;
}
.btn > * { position:relative; z-index:1 }
.btn::before { content:''; position:absolute; inset:0; transform:translateX(-101%); transition:transform 0.28s var(--ease) }
.btn:hover::before { transform:translateX(0) }
.btn-primary { background:var(--accent); color:#010810; border-color:var(--accent); box-shadow:0 0 28px rgba(64,200,255,0.25) }
.btn-primary::before { background:#2ab0e8 }
.btn-ghost { background:transparent; color:var(--muted); border-color:var(--border2) }
.btn-ghost::before { background:rgba(0,120,200,0.08) }
.btn-ghost:hover { color:#e8f8ff; border-color:rgba(64,200,255,0.3) }

/* ── SCROLL HINT ── */
.scroll-hint {
  position:absolute; bottom:40px; left:80px;
  display:flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.6rem; letter-spacing:0.18em;
  text-transform:uppercase; color:var(--dim);
  opacity:0; animation:fade-up 1s var(--ease) 0.9s both;
}
.scroll-line {
  width:40px; height:1px; background:var(--border2);
  position:relative; overflow:hidden;
}
.scroll-line::after {
  content:''; position:absolute; top:0; left:-100%; width:100%; height:100%;
  background:var(--accent); animation:scan 2.2s ease-in-out 1.5s infinite;
}
@keyframes scan { 0%{left:-100%} 100%{left:100%} }

/* ── SECTION COMMON ── */
section { position:relative; z-index:1 }
.section-header {
  display:flex; align-items:baseline; gap:16px; margin-bottom:48px;
}
.section-num {
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.2em;
  color:var(--dim); text-transform:uppercase;
}
.section-title {
  font-size:1.5rem; font-weight:800; letter-spacing:-0.02em; color:#e8f8ff;
}

/* ── PROJECTS ── */
.projects {
  padding:100px 80px;
  border-top:1px solid var(--border);
}
.projects-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(300px,1fr));
  gap:16px;
}
.project-card {
  background:rgba(2,10,24,0.55);
  border:1px solid var(--border);
  border-radius:14px;
  padding:28px;
  backdrop-filter:blur(16px);
  display:flex; flex-direction:column; gap:12px;
  transition:border-color 0.25s, transform 0.25s var(--ease), box-shadow 0.25s;
  position:relative; overflow:hidden;
}
.project-card::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(64,200,255,0.04), transparent 60%);
  opacity:0; transition:opacity 0.3s; pointer-events:none;
}
.project-card:hover { border-color:var(--border2); transform:translateY(-4px); box-shadow:0 16px 48px rgba(0,0,0,0.45) }
.project-card:hover::after { opacity:1 }

/* top accent line on hover */
.project-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity:0; transition:opacity 0.3s;
}
.project-card:hover::before { opacity:1 }

.project-top { display:flex; align-items:flex-start; justify-content:space-between; gap:12px }
.project-icon {
  width:40px; height:40px; border-radius:10px;
  background:rgba(64,200,255,0.07); border:1px solid rgba(64,200,255,0.12);
  display:flex; align-items:center; justify-content:center;
  font-size:1.1rem; flex-shrink:0;
  transition:background 0.2s, border-color 0.2s;
}
.project-card:hover .project-icon { background:rgba(64,200,255,0.12); border-color:rgba(64,200,255,0.22) }
.project-badge {
  font-family:var(--mono); font-size:0.58rem; letter-spacing:0.14em;
  text-transform:uppercase; padding:3px 9px; border-radius:999px;
  border:1px solid; font-weight:600;
}
.badge-live  { color:#00ffcc; border-color:rgba(0,255,204,0.3); background:rgba(0,255,204,0.06) }
.badge-beta  { color:var(--accent); border-color:rgba(64,200,255,0.3); background:rgba(64,200,255,0.06) }
.badge-wip   { color:rgba(200,240,255,0.4); border-color:rgba(200,240,255,0.1); background:rgba(200,240,255,0.03) }

.project-name {
  font-size:1.05rem; font-weight:700; letter-spacing:-0.01em; color:#e8f8ff;
}
.project-desc {
  font-size:0.875rem; color:var(--muted); line-height:1.65;
  flex:1;
}
.project-link {
  display:inline-flex; align-items:center; gap:6px;
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--accent);
  margin-top:4px; transition:gap 0.2s;
}
.project-link:hover { gap:10px }
.project-card.wip .project-link { color:var(--dim); pointer-events:none }

/* ── COMMUNITY ── */
.mc-section { padding:0 80px 100px }
.widget-row {
  display:flex; gap:16px; align-items:flex-start;
}
.mc-widget, .dc-widget {
  background:rgba(2,10,24,0.55);
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  backdrop-filter:blur(16px);
  transition:border-color 0.25s;
}
.mc-widget { flex:1 }
.mc-widget:hover { border-color:var(--border2) }
.mc-stripe { height:2px; background:linear-gradient(90deg,var(--accent),var(--teal)) }
.mc-body { padding:28px 32px }
.mc-top {
  display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;
}
.mc-label {
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.18em;
  text-transform:uppercase; color:var(--dim);
}
.mc-live {
  display:flex; align-items:center; gap:6px;
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em;
  color:var(--accent); text-transform:uppercase;
}
.mc-live i { width:5px;height:5px;border-radius:50%;background:var(--accent);animation:blink 1.3s ease infinite }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.15} }
.mc-status-row { display:flex; align-items:baseline; gap:14px; margin-bottom:16px }
.mc-status-text {
  font-size:2.5rem; font-weight:900; letter-spacing:-0.04em; line-height:1;
  color:var(--dim); transition:color 0.5s;
}
.mc-status-text.online { color:var(--teal); text-shadow:0 0 40px rgba(0,255,204,0.2) }
.mc-status-text.offline { color:#ff4757 }
.mc-players { font-family:var(--mono); font-size:0.8rem; color:var(--muted) }
.mc-players strong { color:var(--text) }
.mc-bar-row {
  display:flex; justify-content:space-between;
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--dim); margin:16px 0 8px;
}
.mc-track { height:2px; background:rgba(0,120,200,0.12); border-radius:99px; overflow:hidden; margin-bottom:20px }
.mc-fill { height:100%; width:0%; background:linear-gradient(90deg,var(--accent),var(--teal)); border-radius:99px; transition:width 1s var(--ease) }
.mc-ip {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--mono); font-size:0.75rem; font-weight:700;
  letter-spacing:0.08em; color:#e8f8ff;
  padding:10px 20px; border-radius:8px;
  background:rgba(64,200,255,0.07); border:1px solid rgba(64,200,255,0.15);
  cursor:pointer; transition:0.2s;
}
.mc-ip:hover { background:rgba(64,200,255,0.13); border-color:rgba(64,200,255,0.3) }

/* discord card */
.dc-widget { flex-shrink:0; width:320px }
.dc-widget:hover { border-color:rgba(88,101,242,0.4) }
.dc-stripe { height:2px; background:linear-gradient(90deg,#5865f2,#7289da) }
.dc-body { padding:28px 32px }
.dc-head { display:flex; align-items:center; gap:12px; margin-bottom:24px }
.dc-logo {
  width:38px; height:38px; border-radius:10px; flex-shrink:0;
  background:#5865f2; display:flex; align-items:center; justify-content:center;
}
.dc-name { font-size:1rem; font-weight:700; color:#e8f8ff }
.dc-tag { font-family:var(--mono); font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim); margin-top:2px }
.dc-stats { display:flex; flex-direction:column; gap:14px; margin-bottom:24px }
.dc-stat { display:flex; align-items:center; justify-content:space-between }
.dc-stat-label { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--dim) }
.dc-stat-val { font-size:1.4rem; font-weight:900; letter-spacing:-0.03em; color:#e8f8ff }
.dc-stat-val.green { color:#57f287; text-shadow:0 0 24px rgba(87,242,135,0.2) }
.dc-members-preview { display:flex; align-items:center; gap:10px; margin-bottom:24px }
.dc-av-stack { display:flex; flex-direction:row; align-items:center }
.dc-av-sm {
  width:28px; height:28px; border-radius:50%;
  border:2px solid rgba(2,8,16,1);
  background:rgba(88,101,242,0.3);
  overflow:hidden; flex-shrink:0;
  margin-left:-7px;
}
.dc-av-sm:first-child { margin-left:0 }
.dc-av-sm img { width:28px; height:28px; object-fit:cover; display:block }
.dc-av-sm span { display:flex; align-items:center; justify-content:center; width:28px; height:28px; font-size:0.6rem; color:rgba(200,240,255,0.6) }
.dc-av-more {
  font-family:var(--mono); font-size:0.62rem; font-weight:600;
  color:rgba(200,240,255,0.45); letter-spacing:0.04em; flex-shrink:0;
}
.dc-join {
  display:flex; align-items:center; justify-content:center; gap:8px;
  width:100%; padding:11px 0; border-radius:8px; text-decoration:none;
  font-family:var(--mono); font-size:0.7rem; font-weight:700; letter-spacing:0.1em;
  text-transform:uppercase; color:#e8f8ff;
  background:rgba(88,101,242,0.14); border:1px solid rgba(88,101,242,0.3);
  transition:0.2s;
}
.dc-join:hover { background:rgba(88,101,242,0.26); border-color:rgba(88,101,242,0.55) }

/* ── ABOUT + CONTACT ── */
.bottom-grid {
  display:grid; grid-template-columns:1fr 1fr;
  border-top:1px solid var(--border);
}
.bottom-col {
  padding:80px;
  border-right:1px solid var(--border);
}
.bottom-col:last-child { border-right:none }

.about-text {
  font-size:1.1rem; font-weight:400; color:var(--muted); line-height:1.85;
  margin-top:20px;
}
.about-text em {
  font-style:normal; color:#e8f8ff;
  background:linear-gradient(135deg,var(--accent),var(--teal));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}

.contact-rows { margin-top:20px; display:flex; flex-direction:column }
.crow {
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 0; border-bottom:1px solid var(--border);
  cursor:pointer; transition:padding 0.2s, background 0.2s; gap:12px;
}
.crow:first-child { border-top:1px solid var(--border) }
.crow:hover { padding-left:6px }
.c-type { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--dim); flex-shrink:0 }
.c-val { font-size:1rem; font-weight:600; color:var(--text) }
.c-arr { color:var(--accent); opacity:0; transition:opacity 0.2s, transform 0.2s; font-size:0.85rem }
.crow:hover .c-arr { opacity:1; transform:translate(3px,-2px) }

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 80px; border-top:1px solid var(--border);
  position:relative; z-index:1;
}
.foot-l { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim) }
.foot-links { display:flex; gap:20px }
.foot-links a { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--dim); transition:color 0.2s }
.foot-links a:hover { color:var(--accent) }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(20px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

.toast {
  position:fixed; bottom:32px; left:50%; transform:translateX(-50%) translateY(16px);
  background:rgba(2,12,28,0.9); backdrop-filter:blur(16px);
  border:1px solid var(--border2);
  color:var(--teal); font-family:var(--mono); font-size:0.65rem;
  letter-spacing:0.12em; text-transform:uppercase;
  padding:11px 22px; border-radius:6px;
  opacity:0; transition:opacity 0.3s, transform 0.3s;
  z-index:9999; pointer-events:none;
  box-shadow:0 8px 32px rgba(0,0,0,0.5);
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0) }

@media(max-width:900px) {
  header { padding:0 20px }
  nav { display:none }
  .hamburger { display:flex }

  /* hero — no forced full-height on mobile */
  .hero {
    min-height:unset;
    padding:90px 24px 48px;
  }
  .hero h1 { font-size:clamp(2.8rem,12vw,5rem) }
