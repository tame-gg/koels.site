<script is:inline>
// cursor spotlight with rAF throttle
(function() {
  const glow = document.getElementById('cursorGlow');
  if (!glow) return;
  let glowVisible = false, rafId = null;
  document.addEventListener('mousemove', e => {
    if (rafId) return;
    rafId = requestAnimationFrame(() => {
      glow.style.left = e.clientX + 'px';
      glow.style.top  = e.clientY + 'px';
      if (!glowVisible) { glow.style.opacity = '1'; glowVisible = true; }
      rafId = null;
    });
  });
  document.addEventListener('mouseleave', () => { glow.style.opacity = '0'; glowVisible = false; });
})();

// hamburger via addEventListener (no inline onclick)
document.getElementById('hamburger').addEventListener('click', toggleMenu);
function toggleMenu() {
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  const open = btn.classList.toggle('open');
  menu.classList.toggle('open', open);
  btn.setAttribute('aria-expanded', open);
}

// keyboard activation for .crow interactive rows
document.querySelectorAll('.crow').forEach(el => {
  el.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); el.click(); }
  });
});

const obs = new IntersectionObserver(
  es => es.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
  { threshold: 0.08 }
);
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function copyIP() {
  navigator.clipboard.writeText('koels.online').then(() => showToast('koels.online copied!'));
}

function copyText(text, msg) {
  navigator.clipboard.writeText(text).then(() => showToast(msg));
}

async function updateMC() {
  try {
    const d = await (await fetch('https://api.mcsrvstat.us/3/koels.online')).json();
    const s = document.getElementById('mcStatus');
    if (!d || !d.online) {
      s.textContent = 'Offline'; s.className = 'mc-status-text offline';
      document.getElementById('mcNow').textContent = '0';
      document.getElementById('mcMax').textContent = '0';
      document.getElementById('mcFill').style.width = '0%';
      document.getElementById('mcPct').textContent = '0%';
      return;
    }
    const now = d.players.online, max = d.players.max;
    const pct = max > 0 ? Math.round(now / max * 100) : 0;
    s.textContent = 'Online'; s.className = 'mc-status-text online';
    document.getElementById('mcNow').textContent = now;
    document.getElementById('mcMax').textContent = max;
    document.getElementById('mcFill').style.width = pct + '%';
    document.getElementById('mcPct').textContent = pct + '%';
  } catch(e) {
    document.getElementById('mcStatus').textContent = 'Offline';
    document.getElementById('mcStatus').className = 'mc-status-text offline';
  }
}
updateMC();
setInterval(() => { if (!document.hidden) updateMC(); }, 180000);

async function updateDiscord() {
  try {
    const d = await (await fetch('https://discord.com/api/guilds/1494858459785465896/widget.json')).json();
    if (!d.name) return;
    document.getElementById('dcName').textContent = d.name;
    document.getElementById('dcOnline').textContent = d.presence_count ?? '—';
    if (d.instant_invite) document.getElementById('dcJoin').href = d.instant_invite;
    const avContainer = document.getElementById('dcAvatars');
    avContainer.innerHTML = '';
    avContainer.style.cssText = 'display:flex;flex-direction:row;align-items:center;gap:8px;margin-bottom:24px;';
    const members = (d.members || []).slice(0, 7);
    const stack = document.createElement('div');
    stack.style.cssText = 'display:flex;flex-direction:row;align-items:center;flex-wrap:nowrap;';
    members.forEach((m, i) => {
      const el = document.createElement('div');
      el.style.cssText = 'width:28px;height:28px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid rgba(2,8,16,1);background:rgba(88,101,242,0.3);' + (i > 0 ? 'margin-left:-8px;' : '');
      if (m.avatar_url) {
        const img = document.createElement('img');
        img.src = m.avatar_url; img.alt = '';
        img.style.cssText = 'width:28px;height:28px;object-fit:cover;display:block;border-radius:50%;';
        el.appendChild(img);
      } else {
        el.style.cssText += 'display:flex;align-items:center;justify-content:center;font-size:0.6rem;color:rgba(200,240,255,0.6);font-family:monospace;';
        el.textContent = (m.username||'?')[0].toUpperCase();
      }
      stack.appendChild(el);
    });
    avContainer.appendChild(stack);
    const extra = (d.presence_count || 0) - members.length;
    if (extra > 0) {
      const more = document.createElement('span');
      more.style.cssText = 'font-family:monospace;font-size:0.65rem;font-weight:600;color:rgba(200,240,255,0.45);flex-shrink:0;';
      more.textContent = '+' + extra;
      avContainer.appendChild(more);
    }
  } catch(e) {}
}
updateDiscord();
setInterval(updateDiscord, 60000);

</script>
