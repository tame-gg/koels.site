<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>404 — koels.site</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box }

html, body {
  height: 100%;
  font-family: 'Inter', system-ui, sans-serif;
  background: #020810;
  color: #c8f0ff;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

/* ── canvas particles ── */
canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  opacity: 0.4;
}

/* ── blobs ── */
.blobs {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}
.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
}
.b1 { width:550px;height:450px;background:radial-gradient(#0050c8,transparent 70%);opacity:.25;top:-80px;left:-100px;animation:bm1 28s ease-in-out infinite }
.b2 { width:450px;height:450px;background:radial-gradient(#00a8b0,transparent 70%);opacity:.2;bottom:-80px;right:-80px;animation:bm2 35s ease-in-out infinite }
.b3 { width:350px;height:350px;background:radial-gradient(#003080,transparent 70%);opacity:.15;top:50%;left:50%;transform:translate(-50%,-50%);animation:bm3 22s ease-in-out infinite }
@keyframes bm1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(50px,70px) scale(1.07)} }
@keyframes bm2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-50px,-50px) scale(1.05)} }
@keyframes bm3 { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.12)} }

/* ── content ── */
.wrap {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  text-align: center;
  padding: 2rem;
  gap: 0;
}

/* ── glitch 404 ── */
.glitch-wrap {
  position: relative;
  margin-bottom: 1.5rem;
}

.glitch {
  font-family: 'JetBrains Mono', monospace;
  font-size: clamp(7rem, 22vw, 14rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.05em;
  color: #40c8ff;
  position: relative;
  display: inline-block;
  animation: glitch-main 4s infinite;
}

.glitch::before,
.glitch::after {
  content: '404';
  position: absolute;
  inset: 0;
  background: transparent;
}
.glitch::before {
  color: #ff4e7a;
  animation: glitch-r 4s infinite;
  clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
}
.glitch::after {
  color: #00ffcc;
  animation: glitch-l 4s infinite;
  clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%);
}

@keyframes glitch-main {
  0%,89%,91%,100% { transform: translate(0) skewX(0) }
  90% { transform: translate(-3px, 1px) skewX(-2deg) }
}
@keyframes glitch-r {
  0%,88%,90%,100% { transform: translate(0); opacity: 0 }
  89% { transform: translate(4px, -2px); opacity: 1 }
}
@keyframes glitch-l {
  0%,87%,91%,100% { transform: translate(0); opacity: 0 }
  88%,90% { transform: translate(-4px, 2px); opacity: 1 }
}

/* ── scanlines ── */
.glitch::before {
  text-shadow: 2px 0 #ff4e7a;
}
.glitch::after {
  text-shadow: -2px 0 #00ffcc;
}

/* ── subtitle ── */
.sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(200,240,255,0.35);
  margin-bottom: 1.25rem;
}

/* ── message ── */
.msg {
  font-size: 1.05rem;
  font-weight: 500;
  color: rgba(200,240,255,0.55);
  margin-bottom: 2.5rem;
  max-width: 340px;
  line-height: 1.6;
}
.msg span {
  color: #40c8ff;
}

/* ── back button ── */
.back {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.6rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: #020810;
  background: linear-gradient(135deg, #40c8ff, #00ffcc);
  text-decoration: none;
  transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
  box-shadow: 0 0 24px rgba(64,200,255,0.25);
}
.back:hover {
  opacity: 0.9;
  transform: translateY(-2px);
  box-shadow: 0 0 36px rgba(64,200,255,0.4);
}
.back:active { transform: translateY(0); }

/* ── random floating chars ── */
.chars {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}
.char {
  position: absolute;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: rgba(64,200,255,0.12);
  animation: fall linear infinite;
  user-select: none;
}
@keyframes fall {
  from { transform: translateY(-20px); opacity: 0 }
  10%  { opacity: 1 }
  90%  { opacity: 1 }
  to   { transform: translateY(100vh); opacity: 0 }
}
</style>
</head>
<body>
  <canvas id="c"></canvas>

  <div class="blobs">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
  </div>

  <div class="chars" id="chars"></div>

  <div class="wrap">
    <div class="glitch-wrap">
      <div class="glitch">404</div>
    </div>
    <div class="sub">page not found</div>
    <p class="msg">
      You wandered somewhere that <span>doesn't exist.</span><br>
      No map for this one.
    </p>
    <a href="/" class="back">← take me home</a>
  </div>

  <script>
    // ── Floating random chars ──
    const pool = '01アイウエオカキクケコ∆∑∞≠≈{}[]<>/\\|';
    const container = document.getElementById('chars');
    for (let i = 0; i < 30; i++) {
      const el = document.createElement('span');
      el.className = 'char';
      el.textContent = pool[Math.floor(Math.random() * pool.length)];
      el.style.left = Math.random() * 100 + 'vw';
      el.style.animationDuration = (8 + Math.random() * 16) + 's';
      el.style.animationDelay = (-Math.random() * 20) + 's';
      el.style.fontSize = (0.6 + Math.random() * 0.6) + 'rem';
      container.appendChild(el);
    }

    // ── Particle canvas ──
    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    let W, H, particles;

    function resize() {
      W = canvas.width  = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }

    function init() {
      resize();
      particles = Array.from({ length: 60 }, () => ({
        x: Math.random() * W,
        y: Math.random() * H,
        r: 0.5 + Math.random() * 1.5,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        a: 0.2 + Math.random() * 0.5,
      }));
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = W;
        if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H;
        if (p.y > H) p.y = 0;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(64,200,255,${p.a})`;
        ctx.fill();
      }

      // draw faint connection lines
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(64,200,255,${0.06 * (1 - dist/120)})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    window.addEventListener('resize', () => { resize(); });
    init();
    draw();
  </script>
</body>
</html>
