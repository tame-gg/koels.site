<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>404 — koels.site</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }

html, body {
  height: 100%;
  font-family: 'Inter', system-ui, sans-serif;
  background: #020810;
  color: #c8f0ff;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

/* blobs */
.blobs { position:fixed;inset:0;pointer-events:none;z-index:0 }
.blob  { position:absolute;border-radius:50%;filter:blur(110px) }
.b1 { width:550px;height:450px;background:radial-gradient(#0050c8,transparent 70%);opacity:.22;top:-80px;left:-100px;animation:bm1 28s ease-in-out infinite }
.b2 { width:450px;height:450px;background:radial-gradient(#00a8b0,transparent 70%);opacity:.18;bottom:-80px;right:-80px;animation:bm2 35s ease-in-out infinite }
.b3 { width:320px;height:320px;background:radial-gradient(#003080,transparent 70%);opacity:.12;top:50%;left:50%;transform:translate(-50%,-50%);animation:bm3 22s ease-in-out infinite }
@keyframes bm1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(50px,70px) scale(1.07)} }
@keyframes bm2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-50px,-50px) scale(1.05)} }
@keyframes bm3 { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.12)} }

/* layout */
.page {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 2rem;
}

/* terminal window */
.terminal {
  width: 100%;
  max-width: 560px;
  background: rgba(4,14,28,0.85);
  border: 1px solid rgba(64,200,255,0.12);
  border-radius: 0.875rem;
  overflow: hidden;
  backdrop-filter: blur(20px);
  box-shadow:
    0 40px 80px rgba(0,0,0,0.55),
    0 0 0 1px rgba(64,200,255,0.05),
    0 0 60px rgba(0,80,200,0.08);
}

/* title bar */
.title-bar {
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  padding: 0.7rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.dot { width:11px;height:11px;border-radius:50% }
.dot-r { background:#ff5f56 }
.dot-y { background:#ffbd2e }
.dot-g { background:#27c93f }
.title-bar-label {
  margin-left: auto;
  margin-right: auto;
  transform: translateX(-18px);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem;
  color: rgba(200,240,255,0.25);
  letter-spacing: 0.05em;
}

/* terminal body */
.term-body {
  padding: 1.5rem 1.75rem 1.75rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.82rem;
  line-height: 1.7;
}

.line { display: flex; gap: 0.5rem; opacity: 0; white-space: pre-wrap; word-break: break-all }
.line.show { opacity: 1 }

.prompt { color: rgba(64,200,255,0.5); user-select: none; flex-shrink: 0 }
.cmd    { color: #c8f0ff }
.out    { color: rgba(200,240,255,0.4); padding-left: 1.1rem }
.err    { color: #ff4e7a; padding-left: 1.1rem }
.warn   { color: #f59e0b; padding-left: 1.1rem }
.dim    { color: rgba(200,240,255,0.18); padding-left: 1.1rem; font-size:0.72rem }
.highlight { color: #40c8ff }
.success { color: #00ffcc; padding-left: 1.1rem }

/* cursor */
.cursor-line { display: flex; gap: 0.5rem; margin-top: 0.25rem }
.cursor {
  display: inline-block;
  width: 8px; height: 1em;
  background: #40c8ff;
  vertical-align: middle;
  animation: blink 1.1s step-end infinite;
  opacity: 0;
  margin-top: 1px;
}
.cursor.show { opacity: 1 }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

/* home button */
.home-wrap {
  padding: 0 1.75rem 1.5rem;
  opacity: 0;
  transition: opacity 0.4s;
}
.home-wrap.show { opacity: 1 }
.home-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1.25rem;
  border-radius: 0.45rem;
  border: 1px solid rgba(64,200,255,0.2);
  background: rgba(64,200,255,0.06);
  color: #40c8ff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem;
  font-weight: 500;
  text-decoration: none;
  transition: background 0.2s, border-color 0.2s, transform 0.15s;
}
.home-btn:hover {
  background: rgba(64,200,255,0.12);
  border-color: rgba(64,200,255,0.35);
  transform: translateY(-1px);
}
.home-btn:active { transform: translateY(0) }
</style>
</head>
<body>

<div class="blobs">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
</div>

<div class="page">
  <div class="terminal">
    <div class="title-bar">
      <div class="dot dot-r"></div>
      <div class="dot dot-y"></div>
      <div class="dot dot-g"></div>
      <span class="title-bar-label">bash — koels.site</span>
    </div>

    <div class="term-body" id="term">
      <!-- lines injected by JS -->
    </div>

    <div class="home-wrap" id="home-wrap">
      <a href="/" class="home-btn">
        <span>$</span> cd ~
      </a>
    </div>
  </div>
</div>

<script>
  const term = document.getElementById('term');
  const homeWrap = document.getElementById('home-wrap');

  const path = window.location.pathname;

  const lines = [
    { type: 'prompt', text: `navigate ${path}` },
    { type: 'out',    text: 'Resolving route…', delay: 320 },
    { type: 'err',    text: `Error: ENOENT — no such route: '${path}'`, delay: 280 },
    { type: 'dim',    text: '  at Router.resolve (core/router.js:404:1)', delay: 80 },
    { type: 'dim',    text: '  at Navigator.push (core/nav.js:22:14)', delay: 60 },
    { type: 'dim',    text: '  at handleRequest (server.js:89:5)', delay: 60 },
    { type: 'blank',  delay: 220 },
    { type: 'warn',   text: 'Exit code 404. Page does not exist.', delay: 160 },
    { type: 'blank',  delay: 280 },
    { type: 'prompt', text: 'ls pages/', delay: 120 },
    { type: 'out',    text: 'index    links    vanta    spectre    extension    calculator', delay: 400 },
    { type: 'blank',  delay: 200 },
    { type: 'success',text: `Tip: '${path}' is not listed. Try going home.`, delay: 160 },
  ];

  let i = 0;

  function addLine(cfg) {
    const div = document.createElement('div');

    if (cfg.type === 'blank') {
      div.style.height = '0.5em';
      div.className = 'line show';
      term.appendChild(div);
      return;
    }

    if (cfg.type === 'prompt') {
      div.className = 'line show';
      div.innerHTML = `<span class="prompt">~/koels.site</span><span class="prompt" style="color:#00ffcc"> ❯</span><span class="cmd"> ${cfg.text}</span>`;
    } else {
      div.className = `line ${cfg.type} show`;
      div.textContent = cfg.text;
    }

    term.appendChild(div);
  }

  function next() {
    if (i >= lines.length) {
      // show cursor then home button
      const cursorLine = document.createElement('div');
      cursorLine.className = 'cursor-line';
      cursorLine.innerHTML = '<span class="prompt">~/koels.site</span><span class="prompt" style="color:#00ffcc"> ❯</span>&nbsp;<span class="cursor show"></span>';
      term.appendChild(cursorLine);
      setTimeout(() => homeWrap.classList.add('show'), 400);
      return;
    }

    const cfg = lines[i++];
    setTimeout(() => {
      addLine(cfg);
      next();
    }, cfg.delay ?? 200);
  }

  // small initial pause then start
  setTimeout(next, 350);
</script>
</body>
</html>
