<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>404 — koels.site</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box }

html, body {
  height: 100%;
  font-family: 'Inter', system-ui, sans-serif;
  background: #020810;
  color: #c8f0ff;
  -webkit-font-smoothing: antialiased;
}

body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  overflow: hidden;
  position: relative;
}

/* blobs */
.bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.22;
}
.blob1 {
  width: 600px; height: 500px;
  background: radial-gradient(ellipse, #0050c8, transparent 70%);
  top: -100px; left: -150px;
  animation: b1 30s ease-in-out infinite;
}
.blob2 {
  width: 500px; height: 500px;
  background: radial-gradient(ellipse, #00a8b0, transparent 70%);
  bottom: -100px; right: -100px;
  animation: b2 38s ease-in-out infinite;
}
@keyframes b1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(60px,80px)} }
@keyframes b2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-60px,-60px)} }

/* content */
.content {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 2rem;
}

.code {
  font-family: 'JetBrains Mono', monospace;
  font-size: clamp(5rem, 18vw, 10rem);
  font-weight: 900;
  line-height: 1;
  background: linear-gradient(135deg, #40c8ff, #00ffcc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.04em;
  margin-bottom: 1rem;
}

.msg {
  font-size: 1.1rem;
  font-weight: 500;
  color: rgba(200, 240, 255, 0.5);
  margin-bottom: 2.5rem;
  letter-spacing: 0.01em;
}

.back {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.65rem 1.4rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: #020810;
  background: linear-gradient(135deg, #40c8ff, #00ffcc);
  text-decoration: none;
  transition: opacity 0.2s, transform 0.2s;
}
.back:hover { opacity: 0.85; transform: translateY(-1px); }
</style>
</head>
<body>
  <div class="bg">
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
  </div>

  <div class="content">
    <div class="code">404</div>
    <p class="msg">This page doesn't exist.</p>
    <a href="/" class="back">
      ← Back home
    </a>
  </div>
</body>
</html>
