---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/></svg>`,
    title: 'Live Match Overview',
    desc:  'See your current match scoreboard, K/D, ACS, and agent breakdown without alt-tabbing. Updates in real time.',
    tag:   'Real-time',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
    title: 'Rank & RR Tracking',
    desc:  'Watch your RR climb or fall across every session. Track your peak rank, streaks, and daily net RR at a glance.',
    tag:   'Progress',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    title: 'Match History',
    desc:  'Scroll through your last 100 matches with map, score, agent, RR delta, MVP badge, and outcome at a glance.',
    tag:   'History',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="9" height="9" rx="1"/><rect x="13" y="2" width="9" height="9" rx="1"/><rect x="2" y="13" width="9" height="9" rx="1"/><rect x="13" y="13" width="9" height="9" rx="1"/></svg>`,
    title: 'Player Stats',
    desc:  'K/D ratio, headshot percentage, win rate, damage per round, first bloods — all in one clean, sortable dashboard.',
    tag:   'Analytics',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Agent Performance',
    desc:  'Break down your stats per agent, per map, and per role. See where you excel and where to improve.',
    tag:   'Breakdown',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: 'Lightweight & Fast',
    desc:  'Built on Tauri. Under 60 MB installed, &lt; 0.5% CPU when idle, and launches in under 2 seconds. Your PC stays yours.',
    tag:   'Performance',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Privacy Focused',
    desc:  'No ads, no analytics, no account required. Your data never leaves your machine — Vanta runs entirely offline.',
    tag:   'Privacy',
  },
];
---

<section id="features" class="relative py-32 px-6 overflow-hidden">
  <!-- subtle bg texture -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-x-0 top-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.07),transparent)"></div>
    <div class="absolute inset-x-0 bottom-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.07),transparent)"></div>
  </div>

  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-20" data-reveal>
      <span class="section-label mb-4 inline-flex">Features</span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-4 leading-tight">
        Everything you need.<br/>
        <span class="text-gradient-red">Nothing you don't.</span>
      </h2>
      <p class="max-w-md mx-auto text-base leading-relaxed" style="color:rgba(240,240,245,0.4)">
        Purpose-built for competitive players who want real data,
        not a bloated overlay suite.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((f, i) => (
        <div
          class="group relative rounded-xl p-6 transition-all duration-300 hover:border-white/14 cursor-default"
          style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07)"
          data-reveal
          data-reveal-d={String(Math.min(i + 1, 7))}
        >
          <!-- Top glow on hover -->
          <div class="absolute inset-x-0 top-0 h-px rounded-t-xl transition-opacity duration-300 opacity-0 group-hover:opacity-100"
               style="background:linear-gradient(90deg,transparent,rgba(255,70,85,0.4),transparent)"></div>

          <!-- Icon -->
          <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                 style="background:rgba(255,70,85,0.1);color:#ff6070">
              <Fragment set:html={f.icon} />
            </div>
            <span class="font-mono text-[0.58rem] tracking-widest uppercase px-2 py-0.5 rounded-full"
                  style="background:rgba(255,255,255,0.05);color:rgba(240,240,245,0.3);border:1px solid rgba(255,255,255,0.07)">
              {f.tag}
            </span>
          </div>

          <!-- Text -->
          <h3 class="font-semibold text-white text-base mb-2 tracking-tight">{f.title}</h3>
          <p class="text-sm leading-relaxed" style="color:rgba(240,240,245,0.42)" set:html={f.desc}></p>
        </div>
      ))}

      <!-- Placeholder card (coming soon) -->
      <div
        class="rounded-xl p-6 flex items-center justify-center col-span-1 md:col-span-1 lg:col-span-1"
        style="background:rgba(255,255,255,0.015);border:1px dashed rgba(255,255,255,0.07)"
        data-reveal
        data-reveal-d="7"
      >
        <div class="text-center">
          <div class="w-10 h-10 rounded-lg mx-auto mb-3 flex items-center justify-center"
               style="background:rgba(255,255,255,0.04)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                 style="color:rgba(255,255,255,0.2)">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <p class="text-sm font-medium" style="color:rgba(255,255,255,0.2)">More coming soon</p>
          <p class="text-xs mt-1" style="color:rgba(255,255,255,0.12)">Follow on GitHub for updates</p>
        </div>
      </div>
    </div>
  </div>
</section>
