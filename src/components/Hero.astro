---
---
<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-6 py-28"
>
  <!-- ── Background ── -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Animated glow orbs -->
    <div class="absolute top-[20%] left-[15%] w-[560px] h-[420px] rounded-full animate-blob"
         style="background:radial-gradient(circle,rgba(255,70,85,0.18),transparent 70%);filter:blur(110px)"></div>
    <div class="absolute bottom-[15%] right-[10%] w-[480px] h-[380px] rounded-full animate-blob-alt"
         style="background:radial-gradient(circle,rgba(255,100,100,0.1),transparent 70%);filter:blur(100px)"></div>
    <div class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[700px] h-[300px] rounded-full animate-blob-slow"
         style="background:radial-gradient(circle,rgba(120,40,80,0.08),transparent 70%);filter:blur(130px)"></div>
    <!-- Dot grid -->
    <div class="absolute inset-0 dot-grid opacity-[0.18]"></div>
    <!-- Radial vignette -->
    <div class="absolute inset-0"
         style="background:radial-gradient(ellipse 85% 70% at 50% 50%,transparent 0%,#08080e 75%)"></div>
  </div>

  <!-- ── Nav bar ── -->
  <header class="absolute top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-5">
    <div class="flex items-center gap-2.5">
      <!-- Logo mark -->
      <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 8 L16 24 L27 8" stroke="#ff4655" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="font-bold text-white tracking-tight text-base">Vanta</span>
    </div>
    <nav class="hidden md:flex items-center gap-8">
      <a href="#features"     class="text-sm text-white/45 hover:text-white/80 transition-colors">Features</a>
      <a href="#preview"      class="text-sm text-white/45 hover:text-white/80 transition-colors">Preview</a>
      <a href="#performance"  class="text-sm text-white/45 hover:text-white/80 transition-colors">Performance</a>
      <a href="#download"
         class="flex items-center gap-2 px-4 py-2 rounded-md text-sm font-semibold transition-all duration-200"
         style="background:#ff4655;color:#fff;box-shadow:0 0 20px rgba(255,70,85,0.3)">
        Notify Me
      </a>
    </nav>
  </header>

  <!-- ── Hero Content ── -->
  <div class="relative z-10 text-center max-w-4xl mx-auto">

    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full text-xs font-mono tracking-widest uppercase mb-10"
      style="background:rgba(255,70,85,0.07);border:1px solid rgba(255,70,85,0.2);color:rgba(255,100,110,0.85)"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-vanta-red animate-pulse-dot"></span>
      In Development — Coming Soon
    </div>

    <!-- Title -->
    <h1 class="font-black tracking-tighter leading-[0.88] mb-8">
      <span class="block text-[clamp(5.5rem,15vw,10.5rem)] text-white">Vanta</span>
      <span
        class="block text-[clamp(1.1rem,3vw,2rem)] font-medium tracking-tight mt-3 leading-snug"
        style="color:rgba(240,240,245,0.38)"
      >
        Competitive Valorant insights<br class="hidden sm:block"/>
        without the clutter.
      </span>
    </h1>

    <!-- Description -->
    <p class="text-base md:text-lg font-light leading-relaxed mb-12 max-w-[480px] mx-auto"
       style="color:rgba(240,240,245,0.35)">
      Track rank progression, review match history, and analyze your stats — all in a
      fast, private desktop app that gets out of your way.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-14">
      <a
        href="#download"
        class="group flex items-center gap-3 px-7 py-3.5 rounded-lg font-semibold text-sm transition-all duration-200 hover:brightness-110 active:scale-[0.98]"
        style="background:#ff4655;color:#fff;box-shadow:0 0 36px rgba(255,70,85,0.32)"
      >
        <!-- bell icon -->
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        Notify Me at Launch
      </a>
      <a
        href="#features"
        class="flex items-center gap-2 px-7 py-3.5 rounded-lg font-medium text-sm transition-all duration-200 hover:bg-white/10"
        style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(240,240,245,0.6)"
      >
        View Features
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-mono text-[0.65rem] tracking-widest uppercase"
         style="color:rgba(240,240,245,0.22)">
      <span class="flex items-center gap-1.5">
        <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor" style="color:rgba(255,70,85,0.5)">
          <path d="M12 1l3.22 6.52 7.18 1.04-5.2 5.06 1.23 7.16L12 17.77l-6.43 3.37 1.23-7.16L1.6 8.56l7.18-1.04z"/>
        </svg>
        Free Forever
      </span>
      <span style="color:rgba(255,255,255,0.1)">·</span>
      <span class="flex items-center gap-1.5">
        <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor" style="color:rgba(255,70,85,0.5)">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
        </svg>
        No Telemetry
      </span>
      <span style="color:rgba(255,255,255,0.1)">·</span>
      <span>No Ads</span>
      <span style="color:rgba(255,255,255,0.1)">·</span>
      <span>Windows 10 / 11</span>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
       style="color:rgba(255,255,255,0.15)" aria-hidden="true">
    <span class="font-mono text-[0.55rem] tracking-[0.2em] uppercase">Scroll</span>
    <div class="w-px h-10" style="background:linear-gradient(to bottom,rgba(255,255,255,0.18),transparent)"></div>
  </div>
</section>
