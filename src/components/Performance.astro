---
const stats = [
  {
    value: '< 60',
    unit:  'MB',
    label: 'Installed size',
    sub:   'Most apps ship 300 MB+',
    icon:  `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
    bar:   18, // % of some "max"
  },
  {
    value: '< 0.5',
    unit:  '%',
    label: 'CPU when idle',
    sub:   'Optimized Rust backend',
    icon:  `<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
    bar:   4,
  },
  {
    value: '< 2',
    unit:  's',
    label: 'Cold launch time',
    sub:   'Ready before your queue pops',
    icon:  `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
    bar:   12,
  },
  {
    value: '~40',
    unit:  'MB',
    label: 'RAM footprint',
    sub:   'Leaves headroom for your game',
    icon:  `<line x1="22" y1="12" x2="2" y2="12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>`,
    bar:   8,
  },
];
---

<section id="performance" class="relative py-32 px-6 overflow-hidden">

  <!-- Subtle divider glow top -->
  <div class="absolute inset-x-0 top-0 h-px pointer-events-none"
       style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.06),transparent)" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

      <!-- Left: text + stat cards -->
      <div>
        <div data-reveal>
          <span class="section-label mb-4 inline-flex">Performance</span>
          <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-4 leading-tight">
            Built on Tauri.<br/>
            <span class="text-gradient-red">Not Electron.</span>
          </h2>
          <p class="text-base leading-relaxed mb-10" style="color:rgba(240,240,245,0.4)">
            Most overlays are glorified web browsers running in the background.
            Vanta uses a native Rust core so your game gets the resources it deserves.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {stats.map((s, i) => (
            <div
              class="group relative rounded-xl p-5 transition-all duration-300"
              style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07)"
              data-reveal
              data-reveal-d={String(i + 1)}
            >
              <!-- top glow on hover -->
              <div class="absolute inset-x-0 top-0 h-px rounded-t-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                   style="background:linear-gradient(90deg,transparent,rgba(255,70,85,0.35),transparent)"></div>

              <!-- Icon -->
              <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-3"
                   style="background:rgba(255,70,85,0.08);color:#ff6070">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={s.icon} />
                </svg>
              </div>

              <!-- Number -->
              <div class="flex items-end gap-0.5 mb-0.5">
                <span class="text-2xl font-black text-white tracking-tighter leading-none">{s.value}</span>
                <span class="text-sm font-bold mb-0.5 leading-none" style="color:#ff6070">{s.unit}</span>
              </div>
              <div class="text-xs font-semibold text-white mb-1">{s.label}</div>
              <div class="text-[0.62rem] mb-3" style="color:rgba(240,240,245,0.3)">{s.sub}</div>

              <!-- Mini bar -->
              <div class="h-1 w-full rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06)">
                <div class="h-full rounded-full" style={`width:${s.bar}%;background:linear-gradient(90deg,#ff4655,#ff8a8a)`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: comparison table -->
      <div data-reveal data-reveal-d="2">
        <div class="rounded-2xl overflow-hidden" style="border:1px solid rgba(255,255,255,0.07)">
          <!-- Table header -->
          <div class="grid grid-cols-3 text-center text-[0.6rem] font-mono tracking-widest uppercase py-3 px-4"
               style="background:rgba(255,255,255,0.04);border-bottom:1px solid rgba(255,255,255,0.06);color:rgba(240,240,245,0.3)">
            <span class="text-left">Metric</span>
            <span style="color:#ff6070">Vanta</span>
            <span>Typical overlay</span>
          </div>

          {[
            { metric: 'CPU idle',      vanta: '< 0.5%',  other: '2–8%'    },
            { metric: 'RAM',           vanta: '~40 MB',  other: '150–400 MB' },
            { metric: 'Install size',  vanta: '< 60 MB', other: '200–500 MB' },
            { metric: 'Launch time',   vanta: '< 2 s',   other: '5–15 s'  },
            { metric: 'Ads',           vanta: 'None',    other: 'Often'   },
            { metric: 'Telemetry',     vanta: 'None',    other: 'Always'  },
            { metric: 'Account req.',  vanta: 'No',      other: 'Yes'     },
            { metric: 'Offline',       vanta: 'Yes',     other: 'Rarely'  },
          ].map((row, i) => (
            <div
              class="grid grid-cols-3 text-center text-xs py-3 px-4"
              style={`border-bottom:1px solid rgba(255,255,255,0.04);background:${i % 2 === 0 ? 'transparent' : 'rgba(255,255,255,0.01)'}`}
            >
              <span class="text-left font-medium" style="color:rgba(240,240,245,0.5)">{row.metric}</span>
              <span class="font-semibold" style="color:#34c759">{row.vanta}</span>
              <span style="color:rgba(240,240,245,0.28)">{row.other}</span>
            </div>
          ))}

          <!-- Footer note -->
          <div class="py-3 px-4 text-center text-[0.58rem] font-mono" style="color:rgba(240,240,245,0.2);background:rgba(255,255,255,0.02)">
            Estimates based on testing on Windows 10 / 11 during idle gameplay sessions.
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
