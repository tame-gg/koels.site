---
const year = new Date().getFullYear();
---

<footer class="relative border-t px-6 py-12" style="border-color:rgba(255,255,255,0.06);background:#06060f">

  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8">

      <!-- Brand -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <div class="flex items-center gap-2.5">
          <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 8 L16 24 L27 8" stroke="#ff4655" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-bold text-white tracking-tight text-sm">Vanta</span>
        </div>
        <p class="text-[0.65rem] font-mono text-center md:text-left max-w-[200px]" style="color:rgba(240,240,245,0.25)">
          Competitive Valorant insights.<br/>Free. Private. Fast.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-2">
        <a href="#features"
           class="text-xs font-mono transition-colors hover:text-white/60"
           style="color:rgba(240,240,245,0.3)">
          Features
        </a>
        <a href="#preview"
           class="text-xs font-mono transition-colors hover:text-white/60"
           style="color:rgba(240,240,245,0.3)">
          Preview
        </a>
        <a href="#performance"
           class="text-xs font-mono transition-colors hover:text-white/60"
           style="color:rgba(240,240,245,0.3)">
          Performance
        </a>
        <a href="#download"
           class="text-xs font-mono transition-colors hover:text-white/60"
           style="color:rgba(240,240,245,0.3)">
          Download
        </a>
        <a href="https://github.com/koelss/vanta/blob/main/PRIVACY.md"
           class="text-xs font-mono transition-colors hover:text-white/60"
           style="color:rgba(240,240,245,0.3)"
           target="_blank"
           rel="noopener noreferrer">
          Privacy Policy
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 border-t" style="border-color:rgba(255,255,255,0.05)">
      <p class="text-[0.6rem] font-mono" style="color:rgba(240,240,245,0.2)">
        © {year} Vanta. All rights reserved.
      </p>
      <p class="text-[0.6rem] font-mono text-center" style="color:rgba(240,240,245,0.15)">
        Not affiliated with Riot Games, Inc. VALORANT™ is a trademark of Riot Games.
      </p>
    </div>
  </div>
</footer>
