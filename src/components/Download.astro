---
---

<section id="download" class="relative py-32 px-6 overflow-hidden">

  <!-- Glow bg -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full"
         style="background:radial-gradient(ellipse,rgba(255,70,85,0.09),transparent 65%);filter:blur(60px)"></div>
    <div class="absolute inset-x-0 top-0 h-px"
         style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.06),transparent)"></div>
  </div>

  <div class="max-w-3xl mx-auto text-center">

    <!-- Label -->
    <div data-reveal>
      <span class="section-label mb-4 inline-flex justify-center">Coming Soon</span>

      <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-4 leading-tight">
        Still being built.<br/>
        <span class="text-gradient-red">Worth the wait.</span>
      </h2>

      <p class="text-base leading-relaxed mb-10 max-w-md mx-auto" style="color:rgba(240,240,245,0.4)">
        Vanta is currently in development. It'll be available here when it's ready — free, forever.
      </p>
    </div>

    <!-- WIP card -->
    <div
      class="relative rounded-2xl p-8 mb-8"
      style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08)"
      data-reveal
      data-reveal-d="1"
    >
      <!-- Top red glow line -->
      <div class="absolute inset-x-0 top-0 h-px rounded-t-2xl"
           style="background:linear-gradient(90deg,transparent,rgba(255,70,85,0.4),transparent)"></div>

      <!-- Progress indicator -->
      <div class="flex flex-col items-center gap-5">
        <div class="w-14 h-14 rounded-xl flex items-center justify-center"
             style="background:rgba(255,70,85,0.1);border:1px solid rgba(255,70,85,0.2)">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ff6070" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>

        <div>
          <div class="text-white font-bold text-base mb-1">Vanta for Windows</div>
          <div class="text-xs font-mono" style="color:rgba(240,240,245,0.3)">Windows 10 / 11 · x64 · Free</div>
        </div>

        <p class="text-sm max-w-xs text-center" style="color:rgba(240,240,245,0.35)">
          Actively in development. No ETA yet.
        </p>
      </div>
    </div>

    <!-- Riot disclaimer -->
    <p class="mt-12 text-[0.6rem] font-mono leading-relaxed mx-auto max-w-lg" style="color:rgba(240,240,245,0.18)">
      Vanta is an independent project and is not affiliated with, endorsed by, or sponsored by Riot Games.
      VALORANT and all related marks are trademarks of Riot Games, Inc.
    </p>
  </div>
</section>
